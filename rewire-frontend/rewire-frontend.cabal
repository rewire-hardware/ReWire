license:        BSD3
license-file:   LICENSE
build-type:     Simple
extra-source-files:
    README.md

source-repository head
  type: git
  location: https://github.com/rewire-hardware/ReWire
  subdir: rewire-frontend

library
  exposed-modules:
      ReWire.Builtins
      ReWire.Crust.KindCheck
      ReWire.Crust.PrimBasis
      ReWire.Crust.Purify
      ReWire.Crust.Syntax
