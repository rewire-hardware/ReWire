license:        BSD3
license-file:   LICENSE
build-type:     Simple
extra-source-files:
    README.md
    vhdl/rw_helpers.vhdl

source-repository head
  type: git
  location: https://github.com/rewire-hardware/ReWire
  subdir: rewire-core

library
  exposed-modules:
      ReWire.Annotation
      ReWire.BitVector
      ReWire.Config
      ReWire.Cryptol.Syntax
      ReWire.Error
      ReWire.Fix
      ReWire.Flags
      ReWire.Hyle.Check
