source-repository head
  type: git
  location: https://github.com/rewire-hardware/ReWire

library
  exposed-modules:
      Driver
      RWC
      RWE
  other-modules:
      Paths_rewire
  hs-source-dirs:
      src
  default-extensions:
      LambdaCase
      TupleSections
      ViewPatterns
  ghc-options: -Wall -Werror -Wunused-packages -fno-warn-name-shadowing -funbox-strict-fields -O2 -optc-O3 -j8 +RTS -A64m -RTS
  build-depends:
      base ==4.20.*
    , filepath ==1.5.*
    , lens ==5.3.*
    , rewire-base
    , rewire-embedder
    , rewire-frontend
    , text ==2.1.*
  default-language: Haskell2010

executable rwc
  main-is: Main.hs
  other-modules:
      Paths_rewire
  hs-source-dirs:
      apps/rwc
  default-extensions:
      LambdaCase
      TupleSections
      ViewPatterns
  ghc-options: -Wall -Werror -Wunused-packages -fno-warn-name-shadowing -funbox-strict-fields -O2 -optc-O3 -j8 +RTS -A64m -RTS
  build-depends:
      base ==4.20.*
    , rewire
  default-language: Haskell2010

executable rwe
  main-is: Main.hs
  other-modules:
      Paths_rewire
  hs-source-dirs:
      apps/rwe
  default-extensions:
      LambdaCase
      TupleSections
      ViewPatterns
  ghc-options: -Wall -Werror -Wunused-packages -fno-warn-name-shadowing -funbox-strict-fields -O2 -optc-O3 -j8 +RTS -A64m -RTS
  build-depends:
      base ==4.20.*
    , rewire
  default-language: Haskell2010

test-suite rwc-test
