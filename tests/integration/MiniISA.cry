// Per-cycle step: outputs # next register values.
rw_step : [88] -> [10] -> [106]
rw_step st i = (take`{8} s5) # ((take`{8} (drop`{8} s5)) # ((take`{1} (drop`{16} s5)) # ((take`{1} (drop`{17} s5)) # ((take`{7} (drop`{18} s5)) # (drop`{25} s5)))))
  where
    s0 : [7]
    s0 = take`{7} st
    s1 : [81]
    s1 = drop`{7} st
    s2 : [8]
    s2 = take`{8} i
    s3 : [1]
    s3 = take`{1} (drop`{8} i)
    s4 : [1]
    s4 = drop`{9} i
    s5 : [106]
    s5 = rw__Pure_dispatch (s0 # s1) (s2 # (s3 # s4))

// Device: top_level
// Inputs, MSB-first: __in0 : [8], __in1 : [1], __in2 : [1]
// Outputs, MSB-first: __out0 : [8], __out1 : [8], __out2 : [1], __out3 : [1]
rw_device : {n} (fin n) => [n][10] -> [n][18]
rw_device ins = outs
  where
    rs : [n][106]
    rs = [rw_step st i | st <- sts | i <- ins]
    sts : [1 + n][88]
    sts = [0x6000000000000000000000] # [drop`{18} r | r <- rs]
    outs : [n][18]
    outs = [take`{18} r | r <- rs]