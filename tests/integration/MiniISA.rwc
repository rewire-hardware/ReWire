--| partially applied from 'Main.shlCW8'
Main.shlCW8$sFalse_Bool : ([8]) -> [9]
Main.shlCW8$sFalse_Bool v =
      Main.msbW8 v # or (shl v 8'h1) 8'h0

--| partially applied from 'Main.shrCW8'
Main.shrCW8$sFalse_Bool : ([8]) -> [9]
Main.shrCW8$sFalse_Bool v =
      Main.lsbW8 v # or (lshr v 8'h1) 8'h0

--| partially applied from 'Main.minusCW8'
Main.minusCW8$sMain_oneW8_False_Bool : ([8]) -> [9]
