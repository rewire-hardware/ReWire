device top_level
      input __in0 : [8]
      input __in1 : [1]
      input __in2 : [1]
      output __out0 : [8]
      output __out1 : [8]
      output __out2 : [1]
      output __out3 : [1]
      register __resumption_tag : [7] init 7'h30
      register __st0 : [81] init 81'h0
      tag i2 = 0
      tag i4 = 1
      tag i6 = 2
      tag i7 = 3
      tag i8 = 4
      let $res = main.$dispatch (__resumption_tag # __st0) (__in0 # __in1 # __in2)
      __out0 := $res[98 +: 8]
      __out1 := $res[90 +: 8]
      __out2 := $res[89 +: 1]
      __out3 := $res[88 +: 1]
      next __resumption_tag := $res[81 +: 7]
      next __st0 := $res[0 +: 81]