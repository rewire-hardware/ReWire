Main.minusCW8 : ([8], [8], [1]) -> [9]
Main.minusCW8 a b cin =
      let s = sub (sub (zext 9 a) (zext 9 b)) (zext 9 cin) in
      s[8 +: 1] # trunc 8 s

Main.plusCW8 : ([8], [8], [1]) -> [9]
Main.plusCW8 a b cin =
      let s = add (add (zext 9 a) (zext 9 b)) (zext 9 cin) in
      s[8 +: 1] # trunc 8 s

Main.lsbW8 : ([8]) -> [1]
Main.lsbW8 v =
      v[0 +: 1]

Main.shrCW8 : ([8], [1]) -> [9]
Main.shrCW8 v cin =
      Main.lsbW8 v # or (lshr v 8'h1) (shl (zext 8 cin) 8'h7)

Main.msbW8 : ([8]) -> [1]
Main.msbW8 v =
      v[7 +: 1]

Main.shlCW8 : ([8], [1]) -> [9]
Main.shlCW8 v cin =
      Main.msbW8 v # or (shl v 8'h1) (zext 8 cin)

--| partially applied from 'Main.plusCW8'
Main.plusCW8$sMain_oneW8_False_Bool : ([8]) -> [9]
Main.plusCW8$sMain_oneW8_False_Bool a =
      let s = add (add (zext 9 a) 9'h1) 9'h0 in
      s[8 +: 1] # trunc 8 s

--| partially applied from 'Main.minusCW8'
Main.minusCW8$sFalse_Bool : ([8], [8]) -> [9]
Main.minusCW8$sFalse_Bool a b =
