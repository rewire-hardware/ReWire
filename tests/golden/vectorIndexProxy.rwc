$Pure.dispatch : ([1056]) -> [64]
$Pure.dispatch i =
      Main.loop i

Main.compute : ([1024], [32]) -> [64]
Main.compute v w =
      $LL.Main.compute w v[960 +: 64] # $LL.Main.compute w v[896 +: 64] # $LL.Main.compute w v[832 +: 64] # $LL.Main.compute w v[768 +: 64] # $LL.Main.compute w v[704 +: 64] # $LL.Main.compute w v[640 +: 64] # $LL.Main.compute w v[576 +: 64] # $LL.Main.compute w v[512 +: 64]

$LL.Main.compute : ([32], [64]) -> [8]
$LL.Main.compute w v' =
      add w[0 +: 8] v'[32 +: 8]

Main.loop : ([1056]) -> [64]
Main.loop ds =
      let v = ds[32 +: 1024] in
      let w = ds[0 +: 32] in
      $LL.Main.loop (Main.compute v w)

$LL.Main.loop : ([64]) -> [64]
$LL.Main.loop rabind =
      rabind

device top_level
      input __in0 : [1024]
      input __in1 : [32]
      output __out0 : [64]
      let $in = __in0 # __in1
      let $res = $Pure.dispatch $in
      __out0 := $res