  where
    s0 : [512]
    s0 = i
    s1 : [256]
    s1 = rw_main__dispatch s0

// Device: top_level
// Inputs, MSB-first: __in0 : [512]
// Outputs, MSB-first: __out0 : [256]
rw_device : {n} (fin n) => [n][512] -> [n][256]
rw_device ins = [rw_step i | i <- ins]