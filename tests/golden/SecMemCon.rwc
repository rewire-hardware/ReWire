--| state dispatch for process main: 0=$x4 1=$x6 2=$x10 3=_unused22 4=$x
main.$dispatch : ([208], [46]) -> [241]
main.$dispatch disc i =
      if eq disc[205 +: 3] 3'h0 then main.$x4 i disc[0 +: 205]
            else if eq disc[205 +: 3] 3'h1 then main.$x6 i disc[0 +: 205] else if eq disc[205 +: 3] 3'h2 then main.$x10 i disc[0 +: 205] else if eq disc[205 +: 3] 3'h3 then main._unused22 i disc[0 +: 205] else main.$x i disc[0 +: 205]

