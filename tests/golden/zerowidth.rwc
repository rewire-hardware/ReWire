$Pure.dispatch : ([8]) -> [16]
$Pure.dispatch disc =
      $LL.Main.loop7 disc

$LL.Main.loop7 : ([8]) -> [16]
$LL.Main.loop7 sto0 =
      Main.loop sto0

$LL.Main.loop6 : ([8], [8]) -> [16]
$LL.Main.loop6 x sto0 =
      x # sto0

$LL.Main.loop5 : ([8], [8]) -> [16]
$LL.Main.loop5 $x sto0 =
      $LL.Main.loop4 $x sto0

Main.loop : ([8]) -> [16]
Main.loop sto0 =
      $LL.Main.loop sto0

$LL.Main.loop4 : ([8], [8]) -> [16]
$LL.Main.loop4 x sto0 =
      $LL.Main.loop3 x sto0

$LL.Main.loop3 : ([8], [8]) -> [16]
$LL.Main.loop3 $x sto0 =
      $LL.Main.loop6 $x sto0

$LL.Main.loop2 : ([8], [8]) -> [16]
$LL.Main.loop2 x sto0 =
      $LL.Main.loop5 x (add x 8'h1)

$LL.Main.loop1 : ([8], [8]) -> [16]
$LL.Main.loop1 $x1 sto0 =
      $LL.Main.loop2 $x1 sto0

$LL.Main.loop : ([8]) -> [16]
$LL.Main.loop sto0 =
      $LL.Main.loop1 sto0 sto0

device top_level
      output __out0 : [8]
      register __st0 : [8] init 8'h1
      let $res = $Pure.dispatch __st0
      __out0 := $res[8 +: 8]
      next __st0 := $res[0 +: 8]