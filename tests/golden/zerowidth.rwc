--| state dispatch for process main: 0=_unused3
main.$dispatch : ([8]) -> [16]
main.$dispatch disc =
      main._unused3 disc

--| block '$L._unused3' of process main (state 0)
main._unused3 : ([8]) -> [16]
main._unused3 s0 =
      main.loop s0

--| block '$L._unused2' of process main
main._unused2 : ([8], [8]) -> [16]
main._unused2 x s0 =
      x # s0

--| block '$L._unused' of process main
main._unused : ([8], [8]) -> [16]
main._unused x s0 =
      main._unused2 x s0

--| block '$L.x' of process main
main.x : ([8], [8]) -> [16]
main.x x s0 =
      let s01 = add x 8'h1 in
      main._unused x s01

--| block '$L.z' of process main
main.z : ([8]) -> [16]
main.z s0 =
      main.x s0 s0

--| block '$L.Main.loop' of process main
main.loop : ([8]) -> [16]
main.loop s0 =
      main.z s0

device top_level
      output __out0 : [8]
      register __st0 : [8] init 8'h1
      tag _unused3 = 0
      let $res = main.$dispatch __st0
      __out0 := $res[8 +: 8]
      next __st0 := $res[0 +: 8]