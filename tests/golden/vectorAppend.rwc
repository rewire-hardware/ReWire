$Pure.dispatch : ([128]) -> [64]
$Pure.dispatch i =
      Main.loop1 i

Main.compute : ([128]) -> [64]
Main.compute $x =
      $LL.Main.compute $x

$LL.Main.loop1 : ([128]) -> [64]
$LL.Main.loop1 $2 =
      $LL.Main.loop (Main.compute $2)

Main.loop1 : ([128]) -> [64]
Main.loop1 $x =
      $LL.Main.loop1 $x

$LL.Main.loop : ([64]) -> [64]
$LL.Main.loop rabind =
      rabind

$LL.Main.compute : ([128]) -> [64]
$LL.Main.compute $3 =
      $3[96 +: 8] # $3[104 +: 8] # $3[112 +: 8] # $3[120 +: 8] # 8'h0 # $3[0 +: 24]

device top_level
      input __in0 : [64]
      input __in1 : [64]
      output __out0 : [64]
      let $in = __in0 # __in1
      let $res = $Pure.dispatch $in
      __out0 := $res