$Pure.dispatch : ([128]) -> [64]
$Pure.dispatch i =
      $L.$x4 i

Main.compute : ([128]) -> [64]
Main.compute ds =
      ds[96 +: 8] # ds[104 +: 8] # ds[112 +: 8] # ds[120 +: 8] # 8'h0 # ds[0 +: 24]

$L.Main.loop3 : ([128]) -> [64]
$L.Main.loop3 i =
      $L.$x5 (Main.compute i)

$L.$x5 : ([64]) -> [64]
$L.$x5 $x =
      $x

$L.$x4 : ([128]) -> [64]
$L.$x4 $x =
      $L.Main.loop3 $x

device top_level
      input __in0 : [64]
      input __in1 : [64]
      output __out0 : [64]
      let $in = __in0 # __in1
      let $res = $Pure.dispatch $in
      __out0 := $res