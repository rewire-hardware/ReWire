$Pure.dispatch : ([128]) -> [64]
$Pure.dispatch i =
      Main.loop i

$LL.Main.loop1 : ([64]) -> [64]
$LL.Main.loop1 rabind =
      rabind

Main.compute : ([128]) -> [64]
Main.compute ds =
      ds[96 +: 8] # ds[104 +: 8] # ds[112 +: 8] # ds[120 +: 8] # 8'h0 # ds[0 +: 24]

Main.loop : ([128]) -> [64]
Main.loop i =
      $LL.Main.loop1 (Main.compute i)

device top_level
      input __in0 : [64]
      input __in1 : [64]
      output __out0 : [64]
      let $in = __in0 # __in1
      let $res = $Pure.dispatch $in
      __out0 := $res