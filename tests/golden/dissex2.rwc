--| state dispatch for process main: 0=i
main.$dispatch : ([16], [1]) -> [24]
main.$dispatch disc i =
      main.i i disc[8 +: 8] disc[0 +: 8]

--| block '$L._unused' of process main
main._unused : ([8], [8], [8], [8]) -> [24]
main._unused r0 r1 s0 s1 =
      let $a = Main.plus r0 r1 in
      main.sig s0 $a

--| block '$L.r1' of process main
main.r1 : ([8], [8], [8], [8]) -> [24]
main.r1 r0 r1 s0 s1 =
      main._unused r0 r1 r1 s1

--| block '$L.r02' of process main
main.r02 : ([8], [8], [8]) -> [24]
main.r02 r0 s0 s1 =
      main.r1 r0 s1 s0 s1

--| block '$L.Main.incr' of process main
main.incr : ([8], [8]) -> [24]
main.incr s0 s1 =
      main.r02 s0 s0 s1

--| block '$L.i' of process main (state 0)
main.i : ([1], [8], [8]) -> [24]
main.i i s0 s1 =
      if not i then main.sig s0 s1
            else main.incr s0 s1

--| block '$L.r0' of process main
main.r0 : ([8], [8], [8]) -> [24]
main.r0 r0 s0 s1 =
      r0 # s0 # s1

--| block '$L.Main.sig' of process main
main.sig : ([8], [8]) -> [24]
main.sig s0 s1 =
      main.r0 s0 s0 s1

Main.plus : ([8], [8]) -> [8]
Main.plus $eta0 $eta1 =
      add $eta0 $eta1

device top_level
      input __in0 : [1]
      output __out0 : [8]
      register __st0 : [8] init 8'h0
      register __st1 : [8] init 8'h1
      tag i = 0
      let $res = main.$dispatch (__st0 # __st1) __in0
      __out0 := $res[16 +: 8]
      next __st0 := $res[8 +: 8]
      next __st1 := $res[0 +: 8]