extern andW32
      input p0 : [32]
      input p1 : [32]
      output p2 : [32]
      model Main.andModel

extern notW32
      input p0 : [32]
      output p1 : [32]
      model Main.notModel

extern plusW32
      input p0 : [32]
      input p1 : [32]
      output p2 : [32]
      model Main.plusModel

extern xorW32
      input p0 : [32]
      input p1 : [32]
      output p2 : [32]
      model Main.xorModel

$Pure.dispatch : ([32]) -> [32]
$Pure.dispatch i =
      ReWire.Monad.iter i

$LL.Main.f1 : ([32]) -> [32]
$LL.Main.f1 $10 =
      Main.plusW32 (Main.andW321 $10) (Main.xorW32 (Main.notW321 $10))

Main.xorModel : ([32], [32]) -> [32]
Main.xorModel $4 $5 =
      $LL.Main.xorModel ($4 # $5)

Main.notW321 : ([32]) -> [32]
Main.notW321 $x =
      notW32 $x

Main.plusW32 : ([32], [32]) -> [32]
Main.plusW32 $x $x1 =
      plusW32 $x $x1

Main.xorW32 : ([32]) -> [32]
Main.xorW32 sp =
      xorW32 sp 32'h12345678

Main.plusModel : ([32], [32]) -> [32]
Main.plusModel $0 $1 =
      $LL.Main.plusModel ($0 # $1)

Main.andW321 : ([32]) -> [32]
Main.andW321 sp =
      andW32 sp 32'hf0f0f0f0

Main.andModel : ([32], [32]) -> [32]
Main.andModel $2 $3 =
      $LL.Main.andModel ($2 # $3)

$LL.Main.andModel : ([64]) -> [32]
$LL.Main.andModel $8 =
      let a = $8[32 +: 32] in
      let b = $8[0 +: 32] in
      and a b

$LL.Main.xorModel : ([64]) -> [32]
$LL.Main.xorModel $9 =
      let a = $9[32 +: 32] in
      let b = $9[0 +: 32] in
      xor a b

Main.f : ([32]) -> [32]
Main.f $x =
      $LL.Main.f1 $x

$LL.Main.plusModel : ([64]) -> [32]
$LL.Main.plusModel $7 =
      let a = $7[32 +: 32] in
      let b = $7[0 +: 32] in
      add a b

Main.notModel : ([32]) -> [32]
Main.notModel $x =
      not $x

ReWire.Monad.iter : ([32]) -> [32]
ReWire.Monad.iter $1 =
      Main.f $1

device top_level
      input __in0 : [32]
      output __out0 : [32]
      let $res = $Pure.dispatch __in0
      __out0 := $res