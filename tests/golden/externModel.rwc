extern andW32
      input p0 : [32]
      input p1 : [32]
      output p2 : [32]
      model Main.andModel

extern notW32
      input p0 : [32]
      output p1 : [32]
      model Main.notModel

extern plusW32
      input p0 : [32]
      input p1 : [32]
      output p2 : [32]
      model Main.plusModel

extern xorW32
      input p0 : [32]
      input p1 : [32]
      output p2 : [32]
      model Main.xorModel

$Pure.dispatch : ([32]) -> [32]
$Pure.dispatch i =
      $LL.Pure.dispatch i

$LL.Main.xorModel1 : ([32], [32]) -> [32]
$LL.Main.xorModel1 $x $x1 =
      xor $x $x1

Main.xorModel : ([32], [32]) -> [32]
Main.xorModel $4 $5 =
      $LL.Main.xorModel ($4 # $5)

Main.notW32 : ([32]) -> [32]
Main.notW32 $x =
      notW32 $x

Main.plusW32 : ([32], [32]) -> [32]
Main.plusW32 $x $x1 =
      plusW32 $x $x1

$LL.Main.f2 : ([32]) -> [32]
$LL.Main.f2 $x =
      $LL.Main.f $x

ReWire.Monad.iter : ([32]) -> [32]
ReWire.Monad.iter $1 =
      Main.f1 $1

Main.plusModel : ([32], [32]) -> [32]
Main.plusModel $0 $1 =
      $LL.Main.plusModel1 ($0 # $1)

$LL.Main.f : ([32]) -> [32]
$LL.Main.f x =
      Main.plusW32 (Main.andW32 x) (Main.xorW32 (Main.notW32 x))

$LL.Main.andModel1 : ([32], [32]) -> [32]
$LL.Main.andModel1 $x $x1 =
      and $x $x1

$LL.Pure.dispatch : ([32]) -> [32]
$LL.Pure.dispatch i =
      ReWire.Monad.iter i

Main.andModel : ([32], [32]) -> [32]
Main.andModel $2 $3 =
      $LL.Main.andModel ($2 # $3)

$LL.Main.andModel : ([64]) -> [32]
$LL.Main.andModel $8 =
      $LL.Main.andModel1 $8[32 +: 32] $8[0 +: 32]

$LL.Main.plusModel1 : ([64]) -> [32]
$LL.Main.plusModel1 $7 =
      $LL.Main.plusModel $7[32 +: 32] $7[0 +: 32]

$LL.Main.xorModel : ([64]) -> [32]
$LL.Main.xorModel $9 =
      $LL.Main.xorModel1 $9[32 +: 32] $9[0 +: 32]

Main.f1 : ([32]) -> [32]
Main.f1 $x =
      $LL.Main.f2 $x

Main.andW32 : ([32]) -> [32]
Main.andW32 sp =
      andW32 sp 32'hf0f0f0f0

$LL.Main.plusModel : ([32], [32]) -> [32]
$LL.Main.plusModel $x $x1 =
      add $x $x1

Main.notModel : ([32]) -> [32]
Main.notModel $x =
      not $x

Main.xorW32 : ([32]) -> [32]
Main.xorW32 sp =
      xorW32 sp 32'h12345678

device top_level
      input __in0 : [32]
      output __out0 : [32]
      let $res = $Pure.dispatch __in0
      __out0 := $res