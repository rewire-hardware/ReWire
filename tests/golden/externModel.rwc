extern andW32
      input p0 : [32]
      input p1 : [32]
      output p2 : [32]
      model Main.andModel

extern notW32
      input p0 : [32]
      output p1 : [32]
      model Main.notModel

extern plusW32
      input p0 : [32]
      input p1 : [32]
      output p2 : [32]
      model Main.plusModel

extern xorW32
      input p0 : [32]
      input p1 : [32]
      output p2 : [32]
      model Main.xorModel

$Pure.dispatch : ([32]) -> [32]
$Pure.dispatch i =
      ReWire.Monad.iter$1$s2 i

Main.xorModel : ([32], [32]) -> [32]
Main.xorModel $x $x1 =
      xor $x $x1

Main.notW32 : ([32]) -> [32]
Main.notW32 $x =
      notW32 $x

Main.plusW32 : ([32], [32]) -> [32]
Main.plusW32 $x $x1 =
      plusW32 $x $x1

Main.plusModel : ([32], [32]) -> [32]
Main.plusModel $x $x1 =
      add $x $x1

ReWire.Monad.iter$1$s2 : ([32]) -> [32]
ReWire.Monad.iter$1$s2 i =
      Main.f i

Main.andModel : ([32], [32]) -> [32]
Main.andModel $x $x1 =
      and $x $x1

Main.xorW32 : ([32], [32]) -> [32]
Main.xorW32 $x $x1 =
      xorW32 $x $x1

Main.f : ([32]) -> [32]
Main.f x =
      Main.plusW32 (Main.andW32 x 32'hf0f0f0f0) (Main.xorW32 (Main.notW32 x) 32'h12345678)

Main.andW32 : ([32], [32]) -> [32]
Main.andW32 $x $x1 =
      andW32 $x $x1

Main.notModel : ([32]) -> [32]
Main.notModel $x =
      not $x

device top_level
      input __in0 : [32]
      output __out0 : [32]
      let $res = $Pure.dispatch __in0
      __out0 := $res