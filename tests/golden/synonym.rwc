$Pure.dispatch : ([16], [1]) -> [24]
$Pure.dispatch disc i =
      let s = disc[8 +: 8] in
      let s1 = disc[0 +: 8] in
      $L.i6 i s s1

$L.Main.sig4 : ([8], [8]) -> [24]
$L.Main.sig4 s0 $x =
      $L.r05 s0 s0 $x

$LL.L.r19 : ([8], [8], [8], [8]) -> [24]
$LL.L.r19 r1 r0 s1 s' =
      $L._unused10 r0 r1 s' s1

$L.r08 : ([8], [8], [8]) -> [24]
$L.r08 r0 s0 s1 =
      $L.r19 r0 s1 s0 s1

$L.Main.incr7 : ([8], [8]) -> [24]
$L.Main.incr7 s0 $x =
      $L.r08 s0 s0 $x

$L._unused10 : ([8], [8], [8], [8]) -> [24]
$L._unused10 r0 r1 s0 s1 =
      $L.Main.sig4 s0 (add r0 r1)

$L.r05 : ([8], [8], [8]) -> [24]
$L.r05 r0 s0 s1 =
      r0 # s0 # s1

$L.i6 : ([1], [8], [8]) -> [24]
$L.i6 i s0 s1 =
      if eq i 1'h0 then $L.Main.sig4 s0 s1
            else $L.Main.incr7 s0 s1

$L.r19 : ([8], [8], [8], [8]) -> [24]
$L.r19 r0 r1 s0 s1 =
      $LL.L.r19 r1 r0 s1 r1

device top_level
      input __in0 : [1]
      output __out0 : [8]
      register __st0 : [8] init 8'h0
      register __st1 : [8] init 8'h1
      let $res = $Pure.dispatch (__st0 # __st1) __in0
      __out0 := $res[16 +: 8]
      next __st0 := $res[8 +: 8]
      next __st1 := $res[0 +: 8]