// Generated by rwc from device: top_level.
// rw_device maps a sequence of per-cycle inputs to per-cycle outputs.

module top_level where

// Helpers implementing ReWire Hyle primitive semantics.
rw'resize : {m, n} (fin m, fin n) => [n] -> [m]
rw'resize x = drop`{n} ((zero : [m]) # x)

rw'repl : {n, w} (fin n, fin w) => [w] -> [n * w]
rw'repl x = join (repeat`{n} x)

rw'parity : {n} (fin n) => [n] -> Bit
rw'parity x = foldr (^) False x

rw'sext : {m, n} (fin m, fin n, n >= 1) => [n] -> [m]
rw'sext x = if x @ 0 then ~ (rw'resize (~ x)) else rw'resize x

// $Pure.dispatch
rw__Pure_dispatch : [8] -> [16]
rw__Pure_dispatch x0 = rw__LL_Main_loop2 x0

// $LL.Main.loop7
rw__LL_Main_loop7 : [8] -> [8] -> [16]
rw__LL_Main_loop7 x0 x1 = rw__LL_Main_loop5 x0 x1

// $LL.Main.loop6
rw__LL_Main_loop6 : [8] -> [8] -> [16]
rw__LL_Main_loop6 x0 x1 = rw__LL_Main_loop7 x0 x1

// $LL.Main.loop5
rw__LL_Main_loop5 : [8] -> [8] -> [16]
rw__LL_Main_loop5 x0 x1 = rw__LL_Main_loop4 x0 x1

// $LL.Main.loop4
rw__LL_Main_loop4 : [8] -> [8] -> [16]
rw__LL_Main_loop4 x0 x1 = x0 # x1

// Main.loop
rw_Main_loop : [8] -> [16]
rw_Main_loop x0 = rw__LL_Main_loop1 x0

// $LL.Main.loop3
rw__LL_Main_loop3 : [8] -> [8] -> [16]
rw__LL_Main_loop3 x0 x1 = rw__LL_Main_loop x0 x1

// $LL.Main.loop2
rw__LL_Main_loop2 : [8] -> [16]
rw__LL_Main_loop2 x0 = rw_Main_loop x0

// $LL.Main.loop1
rw__LL_Main_loop1 : [8] -> [16]
rw__LL_Main_loop1 x0 = rw__LL_Main_loop3 x0 x0

// $LL.Main.loop
rw__LL_Main_loop : [8] -> [8] -> [16]
rw__LL_Main_loop x0 x1 = rw__LL_Main_loop6 x0 (x0 + 0x01)

// Per-cycle step: outputs # next register values.
rw_step : [8] -> [16]
rw_step st = (take`{8} s1) # (drop`{8} s1)
  where
    s0 : [8]
    s0 = st
    s1 : [16]
    s1 = rw__Pure_dispatch s0

// Device: top_level
// Inputs, MSB-first: (none)
// Outputs, MSB-first: __out0 : [8]
rw_device : {n} (fin n) => [n][0] -> [n][8]
rw_device ins = outs
  where
    rs : [n][16]
    rs = [rw_step st | st <- sts | _ <- ins]
    sts : [1 + n][8]
    sts = [0x01] # [drop`{8} r | r <- rs]
    outs : [n][8]
    outs = [take`{8} r | r <- rs]