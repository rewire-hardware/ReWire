// Generated by rwc from device: top_level.
// rw_device maps a sequence of per-cycle inputs to per-cycle outputs.

module top_level where

// Helpers implementing ReWire Hyle primitive semantics.
rw'resize : {m, n} (fin m, fin n) => [n] -> [m]
rw'resize x = drop`{n} ((zero : [m]) # x)

rw'repl : {n, w} (fin n, fin w) => [w] -> [n * w]
rw'repl x = join (repeat`{n} x)

rw'parity : {n} (fin n) => [n] -> Bit
rw'parity x = foldr (^) False x

rw'sext : {m, n} (fin m, fin n, n >= 1) => [n] -> [m]
rw'sext x = if x @ 0 then ~ (rw'resize (~ x)) else rw'resize x

// main.$dispatch
rw_main__dispatch : [8] -> [16]
rw_main__dispatch x0 = rw_main__unused3 x0

// main._unused3
rw_main__unused3 : [8] -> [16]
rw_main__unused3 x0 = rw_main_loop x0

// main._unused2
rw_main__unused2 : [8] -> [8] -> [16]
rw_main__unused2 x0 x1 = x0 # x1

// main._unused
rw_main__unused : [8] -> [8] -> [16]
rw_main__unused x0 x1 = rw_main__unused2 x0 x1

// main.x
rw_main_x : [8] -> [8] -> [16]
rw_main_x x0 x1 = rw_main__unused x0 s0
  where
    s0 : [8]
    s0 = x0 + 0x01

// main.z
rw_main_z : [8] -> [16]
rw_main_z x0 = rw_main_x x0 x0

// main.loop
rw_main_loop : [8] -> [16]
rw_main_loop x0 = rw_main_z x0

// Per-cycle step: outputs # next register values.
rw_step : [8] -> [16]
rw_step st = (take`{8} s1) # (drop`{8} s1)
  where
    s0 : [8]
    s0 = st
    s1 : [16]
    s1 = rw_main__dispatch s0

// Device: top_level
// Inputs, MSB-first: (none)
// Outputs, MSB-first: __out0 : [8]
rw_device : {n} (fin n) => [n][0] -> [n][8]
rw_device ins = outs
  where
    rs : [n][16]
    rs = [rw_step st | st <- sts | _ <- ins]
    sts : [1 + n][8]
    sts = [0x01] # [drop`{8} r | r <- rs]
    outs : [n][8]
    outs = [take`{8} r | r <- rs]