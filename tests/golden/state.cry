// Generated by rwc from device: top_level.
// rw_device maps a sequence of per-cycle inputs to per-cycle outputs.

module top_level where

// Helpers implementing ReWire Hyle primitive semantics.
rw'resize : {m, n} (fin m, fin n) => [n] -> [m]
rw'resize x = drop`{n} ((zero : [m]) # x)

rw'repl : {n, w} (fin n, fin w) => [w] -> [n * w]
rw'repl x = join (repeat`{n} x)

rw'parity : {n} (fin n) => [n] -> Bit
rw'parity x = foldr (^) False x

rw'sext : {m, n} (fin m, fin n, n >= 1) => [n] -> [m]
rw'sext x = if x @ 0 then ~ (rw'resize (~ x)) else rw'resize x

// $Pure.dispatch
rw__Pure_dispatch : [1] -> [1] -> [3]
rw__Pure_dispatch x0 x1 = rw_Main_loop x1 x0

// $LL.Main.stateAction3
rw__LL_Main_stateAction3 : [1] -> [1] -> [1] -> [2]
rw__LL_Main_stateAction3 x0 x1 x2 = rw__LL_Main_stateAction2 x0 x1 x2

// $LL.Main.stateAction2
rw__LL_Main_stateAction2 : [1] -> [1] -> [1] -> [2]
rw__LL_Main_stateAction2 x0 x1 x2 = rw__LL_Main_stateAction1 x1 s0
  where
    s0 : [1]
    s0 = x0 ^ x1

// $LL.Main.loop
rw__LL_Main_loop : [1] -> [1] -> [3]
rw__LL_Main_loop x0 x1 = 0b1 # (x0 # x1)

// $LL.Main.stateAction1
rw__LL_Main_stateAction1 : [1] -> [1] -> [2]
rw__LL_Main_stateAction1 x0 x1 = rw__LL_Main_stateAction x0 x1

// Main.loop
rw_Main_loop : [1] -> [1] -> [3]
rw_Main_loop x0 x1 = rw__LL_Main_loop s4 s5
  where
    s0 : [2]
    s0 = rw_Main_stateAction x0 x1
    s1 : [1]
    s1 = take`{1} s0
    s2 : [1]
    s2 = drop`{1} s0
    s3 : [3]
    s3 = 0b0 # (s1 # s2)
    s4 : [1]
    s4 = take`{1} (drop`{1} s3)
    s5 : [1]
    s5 = drop`{2} s3

// $LL.Main.stateAction
rw__LL_Main_stateAction : [1] -> [1] -> [2]
rw__LL_Main_stateAction x0 x1 = x0 # x1

// Main.stateAction
rw_Main_stateAction : [1] -> [1] -> [2]
rw_Main_stateAction x0 x1 = rw__LL_Main_stateAction3 x0 x1 x1

// Per-cycle step: outputs # next register values.
rw_step : [1] -> [1] -> [2]
rw_step st i = (take`{1} (drop`{1} s2)) # (drop`{2} s2)
  where
    s0 : [1]
    s0 = st
    s1 : [1]
    s1 = i
    s2 : [3]
    s2 = rw__Pure_dispatch s0 s1

// Device: top_level
// Inputs, MSB-first: __in0 : [1]
// Outputs, MSB-first: __out0 : [1]
rw_device : {n} (fin n) => [n][1] -> [n][1]
rw_device ins = outs
  where
    rs : [n][2]
    rs = [rw_step st i | st <- sts | i <- ins]
    sts : [1 + n][1]
    sts = [0b0] # [drop`{1} r | r <- rs]
    outs : [n][1]
    outs = [take`{1} r | r <- rs]