$Pure.dispatch : ([2], [1]) -> [3]
$Pure.dispatch disc i =
      $L.$x5 i disc

$L.Main.repl4 : ([1], [2]) -> [3]
$L.Main.repl4 ds s0 =
      1'h0 # s0

$L.$x5 : ([1], [2]) -> [3]
$L.$x5 $x $x1 =
      $L.Main.repl4 $x $x1

device top_level
      input __in0 : [1]
      output __out0 : [1]
      register __st0 : [1] init 1'h0
      register __st1 : [1] init 1'h0
      let $res = $Pure.dispatch (__st0 # __st1) __in0
      __out0 := $res[2 +: 1]
      next __st0 := $res[1 +: 1]
      next __st1 := $res[0 +: 1]