--| state dispatch for process main: 0=$x2
main.$dispatch : ([2], [1]) -> [3]
main.$dispatch disc i =
      main.$x2 i disc

--| block '$L.$x2' of process main (state 0)
main.$x2 : ([1], [2]) -> [3]
main.$x2 $x s0 =
      main.repl $x s0

--| block '$L.Main.repl' of process main
main.repl : ([1], [2]) -> [3]
main.repl $ds s0 =
      1'h0 # s0

device top_level
      input __in0 : [1]
      output __out0 : [1]
      register __st0 : [1] init 1'h0
      register __st1 : [1] init 1'h0
      tag $x2 = 0
      let $res = main.$dispatch (__st0 # __st1) __in0
      __out0 := $res[2 +: 1]
      next __st0 := $res[1 +: 1]
      next __st1 := $res[0 +: 1]