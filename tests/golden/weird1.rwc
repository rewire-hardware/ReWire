main.$dispatch : ([2], [1]) -> [3]
main.$dispatch disc i =
      main.$L.$x5$239 i disc

main.$L.$x5$239 : ([1], [2]) -> [3]
main.$L.$x5$239 $x s0 =
      main.$L.Main.repl4$237 $x s0

main.$L.Main.repl4$237 : ([1], [2]) -> [3]
main.$L.Main.repl4$237 ds s0 =
      1'h0 # s0

device top_level
      input __in0 : [1]
      output __out0 : [1]
      register __st0 : [1] init 1'h0
      register __st1 : [1] init 1'h0
      let $res = main.$dispatch (__st0 # __st1) __in0
      __out0 := $res[2 +: 1]
      next __st0 := $res[1 +: 1]
      next __st1 := $res[0 +: 1]