$Pure.dispatch : ([2]) -> [1]
$Pure.dispatch i =
      Main.startp i

Main.startp : ([2]) -> [1]
Main.startp i =
      Main.proc i

$LL.Main.proc : ([2]) -> [1]
$LL.Main.proc wild =
      if eq wild 2'h0 then 1'h0
            else if eq wild 2'h1 then 1'h0 else if eq wild 2'h2 then 1'h0 else 1'h1

Main.proc : ([2]) -> [1]
Main.proc $x =
      $LL.Main.proc $x

device top_level
      input __in0 : [2]
      output __out0 : [1]
      let $res = $Pure.dispatch __in0
      __out0 := $res