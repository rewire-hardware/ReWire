$Pure.dispatch : ([2]) -> [1]
$Pure.dispatch i =
      $L.$x5 i

$LL.L.Main.startp$s12 : ([1]) -> [1]
$LL.L.Main.startp$s12 $a =
      $a

$LL.Main.proc : ([2]) -> [1]
$LL.Main.proc wild =
      if eq wild 2'h0 then 1'h0
            else if eq wild 2'h1 then 1'h0 else if eq wild 2'h2 then 1'h0 else 1'h1

$L.$x5 : ([2]) -> [1]
$L.$x5 $x =
      $L.Main.startp4 $x

$L.Main.startp4 : ([2]) -> [1]
$L.Main.startp4 i =
      $LL.L.Main.startp$s12 (Main.proc i)

Main.proc : ([2]) -> [1]
Main.proc $x =
      $LL.Main.proc $x

device top_level
      input __in0 : [2]
      output __out0 : [1]
      let $res = $Pure.dispatch __in0
      __out0 := $res