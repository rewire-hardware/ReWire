$Pure.dispatch : ([2]) -> [1]
$Pure.dispatch i =
      Main.startp1 i

$LL.Main.proc3 : ([2], [2]) -> [1]
$LL.Main.proc3 i $7 =
      if eq $7 2'h0 then 1'h0
            else $LL.Main.proc1 i i

Main.startp1 : ([2]) -> [1]
Main.startp1 $x =
      $LL.Main.startp $x

$LL.Main.proc2 : ([2]) -> [1]
$LL.Main.proc2 $5 =
      if eq $5 2'h2 then 1'h0
            else 1'h1

$LL.Main.proc1 : ([2], [2]) -> [1]
$LL.Main.proc1 i $6 =
      if eq $6 2'h1 then 1'h0
            else $LL.Main.proc2 i

$LL.Main.proc : ([2]) -> [1]
$LL.Main.proc $8 =
      $LL.Main.proc3 $8 $8

$LL.Main.startp : ([2]) -> [1]
$LL.Main.startp $9 =
      Main.proc $9

Main.proc : ([2]) -> [1]
Main.proc $x =
      $LL.Main.proc $x

device top_level
      input __in0 : [2]
      output __out0 : [1]
      let $res = $Pure.dispatch __in0
      __out0 := $res