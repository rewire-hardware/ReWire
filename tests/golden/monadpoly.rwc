$Pure.dispatch : ([1], [1]) -> [3]
$Pure.dispatch disc i =
      $LL.Main.dev i disc

Main.whenB$1$s1 : ([1], [1]) -> [1]
Main.whenB$1$s1 $x sigma0 =
      $LL.Main.whenB$1$s1 $x sigma0

$LL.Main.dev7 : ([1], [1]) -> [3]
$LL.Main.dev7 s sto0 =
      let $t1 = (let $t0 = $LL.Main.dev2 s sto0 in
      2'h0 # $t0) in
      let s0 = $t1[0 +: 1] in
      $LL.Main.dev4 s s0

Main.dev : ([1]) -> [3]
Main.dev sto0 =
      $LL.Main.dev5 sto0 sto0

$LL.Main.dev6 : ([1], [1]) -> [3]
$LL.Main.dev6 $x sto0 =
      $LL.Main.dev7 $x sto0

$LL.Main.dev5 : ([1], [1]) -> [3]
$LL.Main.dev5 s sto0 =
      let $t1 = (let $t0 = Main.whenB$1$s1 s sto0 in
      2'h0 # $t0) in
      let s0 = $t1[0 +: 1] in
      $LL.Main.dev6 s s0

$LL.Main.dev4 : ([1], [1]) -> [3]
$LL.Main.dev4 $x sto0 =
      $LL.Main.dev1 $x sto0

Main.thenB$1$s1 : ([1]) -> [1]
Main.thenB$1$s1 sigma0 =
      1'h1

$LL.Main.dev3 : ([1]) -> [3]
$LL.Main.dev3 sto0 =
      Main.dev sto0

$LL.Main.dev2 : ([1], [1]) -> [1]
$LL.Main.dev2 wild sigma0 =
      if eq wild 1'h0 then 1'h1
            else sigma0

$LL.Main.dev1 : ([1], [1]) -> [3]
$LL.Main.dev1 s sto0 =
      1'h1 # s # sto0

$LL.Main.dev : ([1], [1]) -> [3]
$LL.Main.dev b sto0 =
      if eq b 1'h0 then $LL.Main.dev3 sto0
            else let $t1 = (let $t0 = Main.thenB$1$s1 sto0 in
            2'h0 # $t0) in
            let s0 = $t1[0 +: 1] in
            $LL.Main.dev3 s0

$LL.Main.whenB$1$s1 : ([1], [1]) -> [1]
$LL.Main.whenB$1$s1 wild sigma0 =
      if eq wild 1'h0 then sigma0
            else 1'h0

device top_level
      input __in0 : [1]
      output __out0 : [1]
      register __st0 : [1] init 1'h1
      let $res = $Pure.dispatch __st0 __in0
      __out0 := $res[1 +: 1]
      next __st0 := $res[0 +: 1]