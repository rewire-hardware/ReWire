$Pure.dispatch : ([1], [1]) -> [2]
$Pure.dispatch disc i =
      $L.b5 i disc

$L.Main.whenB$2$s17 : ([1], [1]) -> [2]
$L.Main.whenB$2$s17 b s0 =
      if eq b 1'h0 then $L.Main.dev1 s0
            else $L._unused9 s0

$L.b5 : ([1], [1]) -> [2]
$L.b5 $x $x1 =
      $L.Main.whenB$2$s17 $x $x1

$L.Main.dev1 : ([1]) -> [2]
$L.Main.dev1 s0 =
      $L.Main.whenB$1$s111 s0 s0 s0

$L._unused3 : ([1], [1]) -> [2]
$L._unused3 s s0 =
      if eq s 1'h0 then $L.arm10 s s0
            else $L._unused4 s s0

$L.Main.whenB$1$s111 : ([1], [1], [1]) -> [2]
$L.Main.whenB$1$s111 s b s0 =
      if eq b 1'h0 then $L._unused3 s s0
            else $L.arm12 s s0

$L._unused9 : ([1]) -> [2]
$L._unused9 s0 =
      2'h2

$L.arm12 : ([1], [1]) -> [2]
$L.arm12 s s0 =
      $L._unused3 s 1'h0

$L.arm10 : ([1], [1]) -> [2]
$L.arm10 s s0 =
      $L._unused4 s 1'h1

$L._unused4 : ([1], [1]) -> [2]
$L._unused4 s s0 =
      s # s0

device top_level
      input __in0 : [1]
      output __out0 : [1]
      register __st0 : [1] init 1'h1
      let $res = $Pure.dispatch __st0 __in0
      __out0 := $res[1 +: 1]
      next __st0 := $res[0 +: 1]