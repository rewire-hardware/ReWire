$Pure.dispatch : ([1], [1]) -> [3]
$Pure.dispatch disc i =
      $LL.Main.dev3 i disc

$LL.Main.dev6 : ([1]) -> [3]
$LL.Main.dev6 sto0 =
      Main.dev sto0

Main.whenB : ([1], [1]) -> [1]
Main.whenB sp sigma0 =
      if eq sp 1'h0 then sigma0
            else 1'h0

$LL.Main.thenB : ([1]) -> [1]
$LL.Main.thenB sigma0 =
      1'h1

$LL.Main.dev5 : ([1], [1]) -> [3]
$LL.Main.dev5 $x sto0 =
      $LL.Main.dev $x sto0

Main.dev : ([1]) -> [3]
Main.dev sto0 =
      $LL.Main.dev1 sto0 sto0

$LL.Main.dev4 : ([1], [1]) -> [3]
$LL.Main.dev4 s sto0 =
      1'h1 # s # sto0

$LL.Main.dev3 : ([1], [1]) -> [3]
$LL.Main.dev3 b sto0 =
      if eq b 1'h0 then $LL.Main.dev6 sto0
            else let $t1 = (let $t0 = $LL.Main.thenB sto0 in
            2'h0 # $t0) in
            let s0 = $t1[0 +: 1] in
            $LL.Main.dev6 s0

$LL.Main.dev2 : ([1], [1]) -> [3]
$LL.Main.dev2 $x sto0 =
      $LL.Main.dev4 $x sto0

$LL.Main.dev1 : ([1], [1]) -> [3]
$LL.Main.dev1 s sto0 =
      let $t1 = (let $t0 = Main.whenB s sto0 in
      2'h0 # $t0) in
      let s0 = $t1[0 +: 1] in
      $LL.Main.dev5 s s0

$LL.Main.dev : ([1], [1]) -> [3]
$LL.Main.dev s sto0 =
      let $t1 = (let $t0 = (if eq s 1'h0 then 1'h1
            else sto0) in
      2'h0 # $t0) in
      let s0 = $t1[0 +: 1] in
      $LL.Main.dev2 s s0

device top_level
      input __in0 : [1]
      output __out0 : [1]
      register __st0 : [1] init 1'h1
      let $res = $Pure.dispatch __st0 __in0
      __out0 := $res[1 +: 1]
      next __st0 := $res[0 +: 1]