$LL.Main.swapix33 f32 m l s b2 ds j =
      $LL.Main.swapix37 f32 j m l s b2 (let b1 = ds[4 +: 1] in
      b1)

Main.explode5 : ([5]) -> [5]
Main.explode5 w5 =
      trunc 1 (lshr w5 128'h4) # trunc 1 (lshr w5 128'h3) # trunc 1 (lshr w5 128'h2) # trunc 1 (lshr w5 128'h1) # trunc 1 (lshr w5 128'h0)

$LL.Main.swapix32 : ([5], [1024], [5], [1]) -> [32]
$LL.Main.swapix32 f32 s ds m =
      $LL.Main.swapix34 f32 m s ds (let l = ds[1 +: 1] in
      l)

$LL.Main.xorix : ([1], [1], [1024], [5], [1], [1], [1]) -> [32]
$LL.Main.xorix k m s i1 j l wild =
      if eq wild 1'h0 then trunc 32 (lshr s (mul (sub (sub 128'h20 (zext 128 i1)) 128'h1) 128'h20))
            else xor (trunc 32 (lshr s (mul (sub (sub 128'h20 (zext 128 (1'h0 # j # k # l # m))) 128'h1) 128'h20))) (trunc 32 (lshr s (mul (sub (sub 128'h20 (zext 128 i1)) 128'h1) 128'h20)))

Main.addix : ([1024], [5]) -> [32]
Main.addix s f32 =
      $LL.Main.addix (Main.accesses s f32)

$L.x6 : ([1024], [1024]) -> [2048]
$L.x6 x s0 =
      x # s0

$LL.Main.swapix31 : ([5], [1], [1], [1], [1], [1024], [1], [1]) -> [32]
$LL.Main.swapix31 f32 j b1 m l s b2 wild =
      if eq wild 1'h0 then $LL.Main.swapix36 f32 j m l s ($LL.Main.swapix111 b2 ($LL.Main.swapix19 b1))
            else trunc 32 (lshr s (mul (sub (sub 128'h20 (zext 128 (1'h0 # j # 1'h1 # l # m))) 128'h1) 128'h20))

$LL.Main.swapix1 : ([1], [1], [5], [1024], [5], [1]) -> [32]
$LL.Main.swapix1 m l ds s f32 k =
      $LL.Main.swapix13 m l k ds s f32 (let b2 = ds[3 +: 1] in
      b2)

