// Per-cycle step: outputs # next register values.
rw_step : [128] -> [128]
rw_step i = (take`{64} s3) # (drop`{64} s3)
  where
    s0 : [64]
    s0 = take`{64} i
    s1 : [64]
    s1 = drop`{64} i
    s2 : [128]
    s2 = s0 # s1
    s3 : [128]
    s3 = rw__Pure_dispatch s2

// Device: top_level
// Inputs, MSB-first: __in0 : [64], __in1 : [64]
// Outputs, MSB-first: __out0 : [64], __out1 : [64]
rw_device : {n} (fin n) => [n][128] -> [n][128]
rw_device ins = [rw_step i | i <- ins]