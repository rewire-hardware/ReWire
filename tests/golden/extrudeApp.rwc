main.$dispatch : ([16], [8]) -> [24]
main.$dispatch disc i =
      main.$L.i4$262 disc[8 +: 8] i disc[0 +: 8]

main.$L.i4$262 : ([8], [8], [8]) -> [24]
main.$L.i4$262 k i s0 =
      main.$L.Main.dev2$260 k i

main.$L.s3$261 : ([8], [8], [8]) -> [24]
