$Pure.dispatch : ([16], [8]) -> [24]
$Pure.dispatch disc i =
      let store0 = disc[8 +: 8] in
      let s0 = disc[0 +: 8] in
      $LL.Main.dev store0 i s0

$LL.Main.dev5 : ([8], [8]) -> [24]
$LL.Main.dev5 $x sto0 =
      $LL.Main.dev2 $x sto0

Main.dev : ([8], [8]) -> [24]
Main.dev k sto0 =
      $LL.Main.dev3 k sto0 sto0

$LL.Main.dev4 : ([8], [8], [8]) -> [24]
$LL.Main.dev4 k i sto0 =
      $LL.Main.dev5 k i

$LL.Main.dev3 : ([8], [8], [8]) -> [24]
$LL.Main.dev3 $x $x1 sto0 =
      $LL.Main.dev1 $x $x1 sto0

$LL.Main.dev2 : ([8], [8]) -> [24]
$LL.Main.dev2 k sto0 =
      Main.dev k sto0

$LL.Main.dev1 : ([8], [8], [8]) -> [24]
$LL.Main.dev1 k s sto0 =
      add s k # k # sto0

$LL.Main.dev : ([8], [8], [8]) -> [24]
$LL.Main.dev $x $x1 sto0 =
      $LL.Main.dev4 $x $x1 sto0

device top_level
      input __in0 : [8]
      output __out0 : [8]
      register __resumption_tag : [8] init 8'h3
      register __st0 : [8] init 8'h0
      let $res = $Pure.dispatch (__resumption_tag # __st0) __in0
      __out0 := $res[16 +: 8]
      next __resumption_tag := $res[8 +: 8]
      next __st0 := $res[0 +: 8]