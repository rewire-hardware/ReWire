// Generated by rwc from device: top_level.
// rw_device maps a sequence of per-cycle inputs to per-cycle outputs.

module top_level where

// Helpers implementing ReWire Hyle primitive semantics.
rw'resize : {m, n} (fin m, fin n) => [n] -> [m]
rw'resize x = drop`{n} ((zero : [m]) # x)

rw'repl : {n, w} (fin n, fin w) => [w] -> [n * w]
rw'repl x = join (repeat`{n} x)

rw'parity : {n} (fin n) => [n] -> Bit
rw'parity x = foldr (^) False x

rw'sext : {m, n} (fin m, fin n, n >= 1) => [n] -> [m]
rw'sext x = if x @ 0 then ~ (rw'resize (~ x)) else rw'resize x

// $Pure.dispatch
rw__Pure_dispatch : [3] -> [1] -> [4]
rw__Pure_dispatch x0 x1 = if (take`{1} x0) == 0b0 then (rw__L__unused5 s0 x1 s1) else (rw__L__unused2 x1 s2)
  where
    s0 : [1]
    s0 = take`{1} (drop`{1} x0)
    s1 : [1]
    s1 = drop`{2} x0
    s2 : [1]
    s2 = drop`{2} x0

// $L._unused5
rw__L__unused5 : [1] -> [1] -> [1] -> [4]
rw__L__unused5 x0 x1 x2 = rw__L_Main_convtest4 x0 x0

// $L._unused2
rw__L__unused2 : [1] -> [1] -> [4]
rw__L__unused2 x0 x1 = 0x0

// $L.Main.convtest4
rw__L_Main_convtest4 : [1] -> [1] -> [4]
rw__L_Main_convtest4 x0 x1 = x0 # (0b0 # (x0 # x1))

// Per-cycle step: outputs # next register values.
rw_step : [3] -> [1] -> [4]
rw_step st i = (take`{1} s3) # ((take`{2} (drop`{1} s3)) # (drop`{3} s3))
  where
    s0 : [2]
    s0 = take`{2} st
    s1 : [1]
    s1 = drop`{2} st
    s2 : [1]
    s2 = i
    s3 : [4]
    s3 = rw__Pure_dispatch (s0 # s1) s2

// Device: top_level
// Inputs, MSB-first: __in0 : [1]
// Outputs, MSB-first: __out0 : [1]
rw_device : {n} (fin n) => [n][1] -> [n][1]
rw_device ins = outs
  where
    rs : [n][4]
    rs = [rw_step st i | st <- sts | i <- ins]
    sts : [1 + n][3]
    sts = [0b100] # [drop`{1} r | r <- rs]
    outs : [n][1]
    outs = [take`{1} r | r <- rs]