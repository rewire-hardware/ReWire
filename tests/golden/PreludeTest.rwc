$Pure.dispatch : ([2], [1]) -> [3]
$Pure.dispatch disc i =
      if eq disc[1 +: 1] 1'h1 then $LL.Main.loop$s1 i
            else let store0 = disc[0 +: 1] in
            $LL.Main.loop1 store0 i

$LL.Main.loop3 : ([1]) -> [1]
$LL.Main.loop3 s =
      if eq s 1'h1 then 1'h1
            else 1'h0

$LL.Main.loop1 : ([1], [1]) -> [3]
$LL.Main.loop1 $x $x1 =
      $LL.Main.loop $x $x1

$LL.Main.loop$s1 : ([1]) -> [3]
$LL.Main.loop$s1 b =
      3'h0

Main.loop : ([1]) -> [3]
Main.loop a =
      Main.zookus (Main.zookus a) # 1'h0 # a

Main.zookus : ([1]) -> [1]
Main.zookus x =
      x

$LL.Main.loop : ([1], [1]) -> [3]
$LL.Main.loop a b =
      Main.loop ($LL.Main.loop3 a)

device top_level
      input __in0 : [1]
      output __out0 : [1]
      register __resumption_tag : [2] init 2'h2
      let $res = $Pure.dispatch __resumption_tag __in0
      __out0 := $res[2 +: 1]
      next __resumption_tag := $res[0 +: 2]