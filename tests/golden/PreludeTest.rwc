--| state dispatch for process main: 0=b2 1=b
main.$dispatch : ([2], [1]) -> [3]
main.$dispatch disc i =
      if not disc[1 +: 1] then main.b2 disc[0 +: 1] i
            else main.b i

--| block '$L.b2' of process main (state 0)
main.b2 : ([1], [1]) -> [3]
main.b2 a b =
      main.loop a

--| block '$L.Main.loop' of process main
main.loop : ([1]) -> [3]
main.loop a =
      let $a = Main.zookus a in
      let $a1 = Main.zookus $a in
      $a1 # 1'h0 # a

--| block '$L.b' of process main (state 1)
main.b : ([1]) -> [3]
main.b b =
      3'h0

Main.zookus : ([1]) -> [1]
Main.zookus x =
      x

device top_level
      input __in0 : [1]
      output __out0 : [1]
      register __resumption_tag : [2] init 2'h2
      tag b2 = 0
      tag b = 1
      let $res = main.$dispatch __resumption_tag __in0
      __out0 := $res[2 +: 1]
      next __resumption_tag := $res[0 +: 2]