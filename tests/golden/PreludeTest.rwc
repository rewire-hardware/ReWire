$Pure.dispatch : ([1], [1]) -> [2]
$Pure.dispatch disc i =
      $LL.Main.loop2 disc i

"$LL.ReWire.Prelude.&&1" : ([1], [1], [2]) -> [1]
"$LL.ReWire.Prelude.&&1" $11 $10 $52 =
      if eq $52[1 +: 1] 1'h1 then (let b = $52[0 +: 1] in
            b)
            else "$LL.ReWire.Prelude.&&" ($10 # $11)

$LL.Main.loop2 : ([1], [1]) -> [2]
$LL.Main.loop2 $x $x1 =
      $LL.Main.loop $x $x1

$LL.Main.zookus1 : ([2]) -> [1]
$LL.Main.zookus1 $61 =
      let x = $61[1 +: 1] in
      x

$LL.Main.loop1 : ([1]) -> [2]
$LL.Main.loop1 $2 =
      Main.zookus (Main.zookus $2) # $2

$LL.Main.loop : ([1], [1]) -> [2]
$LL.Main.loop a b =
      Main.loop1 ("ReWire.Prelude.&&" a 1'h1)

Main.loop1 : ([1]) -> [2]
Main.loop1 $x =
      $LL.Main.loop1 $x

$LL.Main.zookus : ([1]) -> [1]
$LL.Main.zookus $3 =
      $LL.Main.zookus1 ($3 # $3)

"ReWire.Prelude.&&" : ([1], [1]) -> [1]
"ReWire.Prelude.&&" $10 $11 =
      "$LL.ReWire.Prelude.&&1" $11 $10 ($10 # $11)

Main.zookus : ([1]) -> [1]
Main.zookus $x =
      $LL.Main.zookus $x

"$LL.ReWire.Prelude.&&" : ([2]) -> [1]
"$LL.ReWire.Prelude.&&" $51 =
      1'h0

device top_level
      input __in0 : [1]
      output __out0 : [1]
      register __resumption_tag : [1] init 1'h0
      let $res = $Pure.dispatch __resumption_tag __in0
      __out0 := $res[1 +: 1]
      next __resumption_tag := $res[0 +: 1]