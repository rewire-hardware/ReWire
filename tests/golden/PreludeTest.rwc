$Pure.dispatch : ([2], [1]) -> [3]
$Pure.dispatch disc i =
      if eq disc[1 +: 1] 1'h1 then (let store0 = disc[0 +: 1] in
            $LL.Main.loop1 store0 i)
            else $LL.Main.loop2 i

$LL.Main.loop6 : ([1], [1]) -> [1]
$LL.Main.loop6 $x $x1 =
      $LL.Main.y1 $x $x1

$LL.Main.loop5 : ([1], [1]) -> [3]
$LL.Main.loop5 a b =
      Main.loop ($LL.Main.loop6 a 1'h1)

$LL.Main.y1 : ([1], [1]) -> [1]
$LL.Main.y1 x y =
      if eq x 1'h1 then y
            else 1'h0

$LL.Main.loop2 : ([1]) -> [3]
$LL.Main.loop2 $x =
      $LL.Main.loop5 1'h0 $x

Main.loop : ([1]) -> [3]
Main.loop a =
      Main.zookus (Main.zookus a) # 1'h1 # a

$LL.Main.zookus : ([2]) -> [1]
$LL.Main.zookus p =
      let x = p[1 +: 1] in
      x

$LL.Main.loop1 : ([1], [1]) -> [3]
$LL.Main.loop1 $x $x1 =
      $LL.Main.loop5 $x $x1

Main.zookus : ([1]) -> [1]
Main.zookus x =
      $LL.Main.zookus (x # x)

device top_level
      input __in0 : [1]
      output __out0 : [1]
      register __resumption_tag : [2] init 2'h0
      let $res = $Pure.dispatch __resumption_tag __in0
      __out0 := $res[2 +: 1]
      next __resumption_tag := $res[0 +: 2]