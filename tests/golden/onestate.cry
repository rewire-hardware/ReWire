// Generated by rwc from device: top_level.
// rw_device maps a sequence of per-cycle inputs to per-cycle outputs.

module top_level where

// Helpers implementing ReWire Hyle primitive semantics.
rw'resize : {m, n} (fin m, fin n) => [n] -> [m]
rw'resize x = drop`{n} ((zero : [m]) # x)

rw'repl : {n, w} (fin n, fin w) => [w] -> [n * w]
rw'repl x = join (repeat`{n} x)

rw'parity : {n} (fin n) => [n] -> Bit
rw'parity x = foldr (^) False x

rw'sext : {m, n} (fin m, fin n, n >= 1) => [n] -> [m]
rw'sext x = if x @ 0 then ~ (rw'resize (~ x)) else rw'resize x

// $Pure.dispatch
rw__Pure_dispatch : [8] -> [1] -> [17]
rw__Pure_dispatch x0 x1 = rw__LL_Main_incr x1 x0

// $LL.Main.grunt
rw__LL_Main_grunt : [8] -> [8] -> [8]
rw__LL_Main_grunt x0 x1 = x0

// $LL.Main.incr2
rw__LL_Main_incr2 : [8] -> [8] -> [17]
rw__LL_Main_incr2 x0 x1 = 0b1 # (x0 # x1)

// Main.incr
rw_Main_incr : [8] -> [17]
rw_Main_incr x0 = rw__LL_Main_incr1 s2
  where
    s0 : [8]
    s0 = rw_Main_grunt x0
    s1 : [17]
    s1 = 0b000000000 # s0
    s2 : [8]
    s2 = drop`{9} s1

// $LL.Main.incr1
rw__LL_Main_incr1 : [8] -> [17]
rw__LL_Main_incr1 x0 = rw__LL_Main_incr2 x0 x0

// $LL.Main.incr
rw__LL_Main_incr : [1] -> [8] -> [17]
rw__LL_Main_incr x0 x1 = rw_Main_incr x1

// Main.grunt
rw_Main_grunt : [8] -> [8]
rw_Main_grunt x0 = rw__LL_Main_grunt x0 x0

// Per-cycle step: outputs # next register values.
rw_step : [8] -> [1] -> [16]
rw_step st i = (take`{8} (drop`{1} s2)) # (drop`{9} s2)
  where
    s0 : [8]
    s0 = st
    s1 : [1]
    s1 = i
    s2 : [17]
    s2 = rw__Pure_dispatch s0 s1

// Device: top_level
// Inputs, MSB-first: __in0 : [1]
// Outputs, MSB-first: __out0 : [8]
rw_device : {n} (fin n) => [n][1] -> [n][8]
rw_device ins = outs
  where
    rs : [n][16]
    rs = [rw_step st i | st <- sts | i <- ins]
    sts : [1 + n][8]
    sts = [0x00] # [drop`{8} r | r <- rs]
    outs : [n][8]
    outs = [take`{8} r | r <- rs]