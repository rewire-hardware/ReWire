$Pure.dispatch : ([8]) -> [16]
$Pure.dispatch i =
      Main.loop1 i

Main.loop1 : ([8]) -> [16]
Main.loop1 $x =
      $LL.Main.loop1 $x

$LL.Main.loop1 : ([8]) -> [16]
$LL.Main.loop1 $1 =
      $LL.Main.loop (xor (zext 16 $1) 16'h1)

$LL.Main.loop : ([16]) -> [16]
$LL.Main.loop rabind =
      rabind

device top_level
      input __in0 : [8]
      output __out0 : [16]
      let $res = $Pure.dispatch __in0
      __out0 := $res