$Pure.dispatch : ([8]) -> [16]
$Pure.dispatch i =
      Main.loop i

Main.loop : ([8]) -> [16]
Main.loop i =
      $LL.Main.loop1 (xor (zext 16 i) 16'h1)

$LL.Main.loop1 : ([16]) -> [16]
$LL.Main.loop1 rabind =
      rabind

device top_level
      input __in0 : [8]
      output __out0 : [16]
      let $res = $Pure.dispatch __in0
      __out0 := $res