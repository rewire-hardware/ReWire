$Pure.dispatch : ([8]) -> [16]
$Pure.dispatch i =
      $L.$x4 i

$L.$x5 : ([16]) -> [16]
$L.$x5 $x =
      $x

$L.$x4 : ([8]) -> [16]
$L.$x4 $x =
      $L.$x5 (xor (zext 16 $x) 16'h1)

device top_level
      input __in0 : [8]
      output __out0 : [16]
      let $res = $Pure.dispatch __in0
      __out0 := $res