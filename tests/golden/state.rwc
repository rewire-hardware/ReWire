$Pure.dispatch : ([1], [1]) -> [2]
$Pure.dispatch disc i =
      $L.$x4 i disc

$L.s7 : ([1], [1], [1]) -> [2]
$L.s7 i s s0 =
      $L.$x5 s (let $t1 = xor i s in
      $t1)

$L.$x5 : ([1], [1]) -> [2]
$L.$x5 $x s0 =
      $x # s0

$L.Main.stateAction6 : ([1], [1]) -> [2]
$L.Main.stateAction6 i s0 =
      $L.s7 i s0 s0

$L.$x4 : ([1], [1]) -> [2]
$L.$x4 $x $x1 =
      $L.Main.stateAction6 $x $x1

device top_level
      input __in0 : [1]
      output __out0 : [1]
      register __st0 : [1] init 1'h0
      let $res = $Pure.dispatch __st0 __in0
      __out0 := $res[1 +: 1]
      next __st0 := $res[0 +: 1]