// Generated by rwc from device: top_level.
// rw_device maps a sequence of per-cycle inputs to per-cycle outputs.

module top_level where

// Helpers implementing ReWire Hyle primitive semantics.
rw'resize : {m, n} (fin m, fin n) => [n] -> [m]
rw'resize x = drop`{n} ((zero : [m]) # x)

rw'repl : {n, w} (fin n, fin w) => [w] -> [n * w]
rw'repl x = join (repeat`{n} x)

rw'parity : {n} (fin n) => [n] -> Bit
rw'parity x = foldr (^) False x

rw'sext : {m, n} (fin m, fin n, n >= 1) => [n] -> [m]
rw'sext x = if x @ 0 then ~ (rw'resize (~ x)) else rw'resize x

// main.$dispatch
rw_main__dispatch : [2] -> [1] -> [3]
rw_main__dispatch x0 x1 = if ~ ((take`{1} x0) @ 0) then (rw_main_b2 (drop`{1} x0) x1) else (rw_main_b x1)

// main.b2
rw_main_b2 : [1] -> [1] -> [3]
rw_main_b2 x0 x1 = rw_main_loop x0

// main.loop
rw_main_loop : [1] -> [3]
rw_main_loop x0 = s1 # (0b0 # x0)
  where
    s0 : [1]
    s0 = rw_Main_zookus x0
    s1 : [1]
    s1 = rw_Main_zookus s0

// main.b
rw_main_b : [1] -> [3]
rw_main_b x0 = 0b000

// Main.zookus
rw_Main_zookus : [1] -> [1]
rw_Main_zookus x0 = x0

// Per-cycle step: outputs # next register values.
rw_step : [2] -> [1] -> [3]
rw_step st i = (take`{1} s2) # (drop`{1} s2)
  where
    s0 : [2]
    s0 = st
    s1 : [1]
    s1 = i
    s2 : [3]
    s2 = rw_main__dispatch s0 s1

// Device: top_level
// Inputs, MSB-first: __in0 : [1]
// Outputs, MSB-first: __out0 : [1]
rw_device : {n} (fin n) => [n][1] -> [n][1]
rw_device ins = outs
  where
    rs : [n][3]
    rs = [rw_step st i | st <- sts | i <- ins]
    sts : [1 + n][2]
    sts = [0b10] # [drop`{1} r | r <- rs]
    outs : [n][1]
    outs = [take`{1} r | r <- rs]