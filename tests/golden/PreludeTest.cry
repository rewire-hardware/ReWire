// Generated by rwc from device: top_level.
// rw_device maps a sequence of per-cycle inputs to per-cycle outputs.

module top_level where

// Helpers implementing ReWire Hyle primitive semantics.
rw'resize : {m, n} (fin m, fin n) => [n] -> [m]
rw'resize x = drop`{n} ((zero : [m]) # x)

rw'repl : {n, w} (fin n, fin w) => [w] -> [n * w]
rw'repl x = join (repeat`{n} x)

rw'parity : {n} (fin n) => [n] -> Bit
rw'parity x = foldr (^) False x

rw'sext : {m, n} (fin m, fin n, n >= 1) => [n] -> [m]
rw'sext x = if x @ 0 then ~ (rw'resize (~ x)) else rw'resize x

// $Pure.dispatch
rw__Pure_dispatch : [2] -> [1] -> [3]
rw__Pure_dispatch x0 x1 = if (take`{1} x0) == 0b1 then (rw__LL_Main_loop_s1 x1) else (rw__LL_Main_loop1 s0 x1)
  where
    s0 : [1]
    s0 = drop`{1} x0

// $LL.Main.loop3
rw__LL_Main_loop3 : [1] -> [1]
rw__LL_Main_loop3 x0 = if x0 == 0b1 then 0b1 else 0b0

// $LL.Main.loop1
rw__LL_Main_loop1 : [1] -> [1] -> [3]
rw__LL_Main_loop1 x0 x1 = rw__LL_Main_loop x0 x1

// $LL.Main.loop$s1
rw__LL_Main_loop_s1 : [1] -> [3]
rw__LL_Main_loop_s1 x0 = 0b000

// Main.loop
rw_Main_loop : [1] -> [3]
rw_Main_loop x0 = (rw_Main_zookus (rw_Main_zookus x0)) # (0b0 # x0)

// Main.zookus
rw_Main_zookus : [1] -> [1]
rw_Main_zookus x0 = x0

// $LL.Main.loop
rw__LL_Main_loop : [1] -> [1] -> [3]
rw__LL_Main_loop x0 x1 = rw_Main_loop (rw__LL_Main_loop3 x0)

// Per-cycle step: outputs # next register values.
rw_step : [2] -> [1] -> [3]
rw_step st i = (take`{1} s2) # (drop`{1} s2)
  where
    s0 : [2]
    s0 = st
    s1 : [1]
    s1 = i
    s2 : [3]
    s2 = rw__Pure_dispatch s0 s1

// Device: top_level
// Inputs, MSB-first: __in0 : [1]
// Outputs, MSB-first: __out0 : [1]
rw_device : {n} (fin n) => [n][1] -> [n][1]
rw_device ins = outs
  where
    rs : [n][3]
    rs = [rw_step st i | st <- sts | i <- ins]
    sts : [1 + n][2]
    sts = [0b10] # [drop`{1} r | r <- rs]
    outs : [n][1]
    outs = [take`{1} r | r <- rs]