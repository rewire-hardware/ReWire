$Pure.dispatch : ([3], [1]) -> [4]
$Pure.dispatch disc i =
      if eq disc[1 +: 2] 2'h1 then (let store0 = disc[0 +: 1] in
            $LL.Main.go2 store0 i)
            else if eq disc[1 +: 2] 2'h2 then $LL.Main.go1 i else $LL.Main.go3 i

$LL.Main.go6 : ([1], [1]) -> [1]
$LL.Main.go6 y s =
      if eq s 1'h1 then y
            else 1'h0

$LL.Main.go5 : ([1], [1]) -> [4]
$LL.Main.go5 $x $x1 =
      $LL.Main.go $x $x1

$LL.Main.go4 : ([1], [1]) -> [1]
$LL.Main.go4 x wild =
      if eq wild 1'h0 then $LL.Main.go6 x x
            else x

$LL.Main.go3 : ([1]) -> [4]
$LL.Main.go3 x =
      if eq x 1'h0 then x # 2'h1 # x
            else 3'h1 # x

$LL.Main.go2 : ([1], [1]) -> [4]
$LL.Main.go2 $x $x1 =
      $LL.Main.go5 $x $x1

$LL.Main.go1 : ([1]) -> [4]
$LL.Main.go1 z =
      4'h0

$LL.Main.go : ([1], [1]) -> [4]
$LL.Main.go x y =
      $LL.Main.go6 y ($LL.Main.go4 x y) # 3'h4

device top_level
      input __in0 : [1]
      output __out0 : [1]
      register __resumption_tag : [3] init 3'h0
      let $res = $Pure.dispatch __resumption_tag __in0
      __out0 := $res[3 +: 1]
      next __resumption_tag := $res[0 +: 3]