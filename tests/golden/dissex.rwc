main.$dispatch : ([16], [1]) -> [24]
main.$dispatch disc i =
      main.$L.i3$252 i disc[8 +: 8] disc[0 +: 8]

main.$L._unused7$256 : ([8], [8], [8], [8]) -> [24]
main.$L._unused7$256 r0 r1 s0 s1 =
      let $a = Main.plusW8 r0 r1 in
      main.$L.Main.sig1$250 s0 $a

main.$L.r16$255 : ([8], [8], [8], [8]) -> [24]
main.$L.r16$255 r0 r1 s0 s1 =
      main.$L._unused7$256 r0 r1 r1 s1

main.$L.r05$254 : ([8], [8], [8]) -> [24]
main.$L.r05$254 r0 s0 s1 =
      main.$L.r16$255 r0 s1 s0 s1

main.$L.Main.incr4$253 : ([8], [8]) -> [24]
main.$L.Main.incr4$253 s0 s1 =
      main.$L.r05$254 s0 s0 s1

main.$L.i3$252 : ([1], [8], [8]) -> [24]
main.$L.i3$252 i s0 s1 =
      if eq i 1'h0 then main.$L.Main.sig1$250 s0 s1
            else main.$L.Main.incr4$253 s0 s1

main.$L.r02$251 : ([8], [8], [8]) -> [24]
main.$L.r02$251 r0 s0 s1 =
      r0 # s0 # s1

main.$L.Main.sig1$250 : ([8], [8]) -> [24]
main.$L.Main.sig1$250 s0 s1 =
      main.$L.r02$251 s0 s0 s1

Main.plusW8 : ([8], [8]) -> [8]
Main.plusW8 $eta0 $eta1 =
      add $eta0 $eta1

device top_level
      input __in0 : [1]
      output __out0 : [8]
      register __st0 : [8] init 8'h0
      register __st1 : [8] init 8'h1
      let $res = main.$dispatch (__st0 # __st1) __in0
      __out0 := $res[16 +: 8]
      next __st0 := $res[8 +: 8]
      next __st1 := $res[0 +: 8]