$Pure.dispatch : ([16], [1]) -> [24]
$Pure.dispatch disc i =
      let s = disc[8 +: 8] in
      let s1 = disc[0 +: 8] in
      $L.i8 i s s1

$L.i8 : ([1], [8], [8]) -> [24]
$L.i8 i s0 s1 =
      if eq i 1'h0 then $L.Main.incr9 s0 s1
            else $L.Main.sig6 s0 s1

$L.Main.incr9 : ([8], [8]) -> [24]
$L.Main.incr9 s0 $x =
      $L.r010 s0 s0 $x

$L.r07 : ([8], [8], [8]) -> [24]
$L.r07 r0 s0 s1 =
      r0 # s0 # s1

$L.Main.sig6 : ([8], [8]) -> [24]
$L.Main.sig6 s0 $x =
      $L.r07 s0 s0 $x

$L._unused12 : ([8], [8], [8], [8]) -> [24]
$L._unused12 r0 r1 s0 s1 =
      $L.Main.sig6 s0 (add r0 r1)

$L.r010 : ([8], [8], [8]) -> [24]
$L.r010 r0 s0 s1 =
      $L.r111 r0 s1 s0 s1

$L.r111 : ([8], [8], [8], [8]) -> [24]
$L.r111 r0 r1 s0 s1 =
      $LL.L.r111 r0 s1 r1 r1

$LL.L.r111 : ([8], [8], [8], [8]) -> [24]
$LL.L.r111 r0 s1 r1 s' =
      $L._unused12 r0 r1 s' s1

device top_level
      input __in0 : [1]
      output __out0 : [8]
      register __st0 : [8] init 8'h0
      register __st1 : [8] init 8'h1
      let $res = $Pure.dispatch (__st0 # __st1) __in0
      __out0 := $res[16 +: 8]
      next __st0 := $res[8 +: 8]
      next __st1 := $res[0 +: 8]