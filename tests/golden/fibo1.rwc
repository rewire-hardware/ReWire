$Pure.dispatch : ([16], [1]) -> [24]
$Pure.dispatch disc i =
      let s0 = disc[8 +: 8] in
      let s1 = disc[0 +: 8] in
      $LL.Main.sig i s0 s1

$LL.Main.sig1 : ([8], [8], [8]) -> [24]
$LL.Main.sig1 r0 sto0 sto1 =
      r0 # sto0 # sto1

$LL.Main.incr4 : ([8], [8], [8], [8]) -> [24]
$LL.Main.incr4 r0 r1 sto0 sto1 =
      $LL.Main.incr3 r0 r1 r1 sto1

Main.incr : ([8], [8]) -> [24]
Main.incr sto0 sto1 =
      $LL.Main.incr1 sto0 sto0 sto1

$LL.Main.incr3 : ([8], [8], [8], [8]) -> [24]
$LL.Main.incr3 $x $x1 sto0 sto1 =
      $LL.Main.incr2 $x $x1 sto0 sto1

$LL.Main.incr2 : ([8], [8], [8], [8]) -> [24]
$LL.Main.incr2 r0 r1 sto0 sto1 =
      $LL.Main.begin sto0 (add r0 r1)

Main.sig : ([8], [8]) -> [24]
Main.sig sto0 sto1 =
      $LL.Main.sig1 sto0 sto0 sto1

$LL.Main.begin : ([8], [8]) -> [24]
$LL.Main.begin sto0 sto1 =
      Main.sig sto0 sto1

$LL.Main.sig : ([1], [8], [8]) -> [24]
$LL.Main.sig wild sto0 sto1 =
      if eq wild 1'h0 then Main.incr sto0 sto1
            else Main.sig sto0 sto1

$LL.Main.incr1 : ([8], [8], [8]) -> [24]
$LL.Main.incr1 r0 sto0 sto1 =
      $LL.Main.incr r0 sto1 sto0 sto1

$LL.Main.incr : ([8], [8], [8], [8]) -> [24]
$LL.Main.incr $x $x1 sto0 sto1 =
      $LL.Main.incr4 $x $x1 sto0 sto1

device top_level
      input __in0 : [1]
      output __out0 : [8]
      register __st0 : [8] init 8'h0
      register __st1 : [8] init 8'h1
      let $res = $Pure.dispatch (__st0 # __st1) __in0
      __out0 := $res[16 +: 8]
      next __st0 := $res[8 +: 8]
      next __st1 := $res[0 +: 8]