            else $LL.OD19.ProgramCounter.incPC210 $0 $0

$LL.Main.putReg : ([32], [39]) -> [39]
$LL.Main.putReg $x sigma0 =
      $LL.Main.putReg6 $x sigma0

$LL.Main.repl3 : ([32], [32], [39]) -> [81]
$LL.Main.repl3 w32 v $x =
      $LL.Main.repl53 w32 v $x

$LL.Main.repl2 : ([32], [7], [39]) -> [81]
$LL.Main.repl2 w32 $39 sto0 =
      if eq $39 7'h6 then $LL.Main.repl82 sto0 w32
            else $LL.Main.repl69 ($LL.Main.repl110 (Main.nextPC sto0))

$LL.Main.nextPC : ([32], [7], [39]) -> [39]
$LL.Main.nextPC $x $x1 sigma0 =
      $LL.Main.nextPC7 $x $x1 sigma0

device top_level
      input __in0 : [1]
      input __in1 : [32]
      output __out0 : [1]
      output __out1 : [1]
      register __st0 : [32] init 32'h0
      register __st1 : [7] init 7'h0
      let $res = $Pure.dispatch (__st0 # __st1) (__in0 # __in1)
      __out0 := $res[40 +: 1]
      __out1 := $res[39 +: 1]
      next __st0 := $res[7 +: 32]
      next __st1 := $res[0 +: 7]