      if eq $146 7'h6b then 7'h6c
            else $LL.OD19.ProgramCounter.incPC83 $0 $0

$LL.OD19.ProgramCounter.incPC14 : ([7], [7]) -> [7]
$LL.OD19.ProgramCounter.incPC14 $0 $200 =
      if eq $200 7'h35 then 7'h36
            else $LL.OD19.ProgramCounter.incPC18 $0 $0

$LL.Main.repl4 : ([32], [81]) -> [81]
$LL.Main.repl4 w32 disc =
      $LL.Main.repl63 w32 disc[39 +: 32] disc[0 +: 39]

$LL.OD19.ProgramCounter.incPC11 : ([7], [7]) -> [7]
$LL.OD19.ProgramCounter.incPC11 $0 $188 =
      if eq $188 7'h41 then 7'h42
            else $LL.OD19.ProgramCounter.incPC154 $0 $0

$LL.OD19.ProgramCounter.incPC9 : ([7], [7]) -> [7]
$LL.OD19.ProgramCounter.incPC9 $0 $250 =
