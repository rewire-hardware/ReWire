--| state dispatch for process main: 0=_unused2
main.$dispatch : ([8], [1]) -> [16]
main.$dispatch disc i =
      main._unused2 i disc

--| block '$L._unused2' of process main (state 0)
main._unused2 : ([1], [8]) -> [16]
main._unused2 _unused s0 =
      main.incr s0

--| block '$L._unused' of process main
main._unused : ([8], [8]) -> [16]
main._unused r0 s0 =
      r0 # s0

--| block '$L.r0' of process main
main.r0 : ([8], [8]) -> [16]
main.r0 r0 s0 =
      main._unused r0 r0

--| block '$L.Main.incr' of process main
main.incr : ([8]) -> [16]
main.incr s0 =
      main.r0 s0 s0

device top_level
      input __in0 : [1]
      output __out0 : [8]
      register __st0 : [8] init 8'h0
      tag _unused2 = 0
      let $res = main.$dispatch __st0 __in0
      __out0 := $res[8 +: 8]
      next __st0 := $res[0 +: 8]