$Pure.dispatch : ([8], [1]) -> [16]
$Pure.dispatch disc i =
      $LL.Main.incr2 i disc

$LL.Main.incr3 : ([8], [8]) -> [16]
$LL.Main.incr3 r0 sto0 =
      r0 # sto0

Main.incr : ([8]) -> [16]
Main.incr sto0 =
      $LL.Main.incr1 sto0 sto0

$LL.Main.incr2 : ([1], [8]) -> [16]
$LL.Main.incr2 $4 sto0 =
      Main.incr sto0

$LL.Main.incr1 : ([8], [8]) -> [16]
$LL.Main.incr1 r0 sto0 =
      $LL.Main.incr r0 r0

$LL.Main.incr : ([8], [8]) -> [16]
$LL.Main.incr $x sto0 =
      $LL.Main.incr3 $x sto0

device top_level
      input __in0 : [1]
      output __out0 : [8]
      register __st0 : [8] init 8'h0
      let $res = $Pure.dispatch __st0 __in0
      __out0 := $res[8 +: 8]
      next __st0 := $res[0 +: 8]