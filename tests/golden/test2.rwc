$Pure.dispatch : ([8], [1]) -> [16]
$Pure.dispatch disc i =
      $L._unused4 i disc

$L._unused3 : ([8], [8]) -> [16]
$L._unused3 r0 s0 =
      r0 # s0

$L.r02 : ([8], [8]) -> [16]
$L.r02 r0 s0 =
      $L._unused3 r0 r0

$L.Main.incr1 : ([8]) -> [16]
$L.Main.incr1 s0 =
      $L.r02 s0 s0

$L._unused4 : ([1], [8]) -> [16]
$L._unused4 _unused $x =
      $L.Main.incr1 $x

device top_level
      input __in0 : [1]
      output __out0 : [8]
      register __st0 : [8] init 8'h0
      let $res = $Pure.dispatch __st0 __in0
      __out0 := $res[8 +: 8]
      next __st0 := $res[0 +: 8]