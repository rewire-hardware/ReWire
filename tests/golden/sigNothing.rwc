$Pure.dispatch : ([8], [8]) -> [17]
$Pure.dispatch disc i =
      $LL.Pure.dispatch i disc

Main.start' : ([8]) -> [17]
Main.start' sto0 =
      9'h0 # sto0

$LL.Main.start'1 : ([8], [8]) -> [17]
$LL.Main.start'1 $x sto0 =
      $LL.Main.start' $x sto0

$LL.Main.start' : ([8], [8]) -> [17]
$LL.Main.start' $1 sto0 =
      Main.start' sto0

$LL.Pure.dispatch : ([8], [8]) -> [17]
$LL.Pure.dispatch i $x =
      $LL.Main.start'1 i $x

device top_level
      input __in0 : [8]
      output __out0 : [1]
      output __out1 : [8]
      register __st0 : [8] init 8'h0
      let $res = $Pure.dispatch __st0 __in0
      __out0 := $res[16 +: 1]
      __out1 := $res[8 +: 8]
      next __st0 := $res[0 +: 8]