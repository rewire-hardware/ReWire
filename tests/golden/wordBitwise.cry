// Main.compute
rw_Main_compute : [24] -> [8]
rw_Main_compute x0 = ((s0 && s1) ^ s2) || (~ (((~ s0) && (~ s1)) ^ s2))
  where
    s0 : [8]
    s0 = take`{8} x0
    s1 : [8]
    s1 = take`{8} (drop`{8} x0)
    s2 : [8]
    s2 = drop`{16} x0

// Per-cycle step: outputs # next register values.
rw_step : [24] -> [8]
rw_step i = s4
  where
    s0 : [8]
    s0 = take`{8} i
    s1 : [8]
    s1 = take`{8} (drop`{8} i)
    s2 : [8]
    s2 = drop`{16} i
    s3 : [24]
    s3 = s0 # (s1 # s2)
    s4 : [8]
    s4 = rw_main__dispatch s3

// Device: top_level
// Inputs, MSB-first: __in0 : [8], __in1 : [8], __in2 : [8]
// Outputs, MSB-first: __out0 : [8]
rw_device : {n} (fin n) => [n][24] -> [n][8]
rw_device ins = [rw_step i | i <- ins]