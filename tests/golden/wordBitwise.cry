// Helpers implementing ReWire Hyle primitive semantics.
rw'resize : {m, n} (fin m, fin n) => [n] -> [m]
rw'resize x = drop`{n} ((zero : [m]) # x)

rw'repl : {n, w} (fin n, fin w) => [w] -> [n * w]
rw'repl x = join (repeat`{n} x)

rw'parity : {n} (fin n) => [n] -> Bit
rw'parity x = foldr (^) False x

rw'sext : {m, n} (fin m, fin n, n >= 1) => [n] -> [m]
rw'sext x = if x @ 0 then ~ (rw'resize (~ x)) else rw'resize x

// $Pure.dispatch
rw__Pure_dispatch : [24] -> [9]
rw__Pure_dispatch x0 = rw__LL_Pure_dispatch x0

// $LL.Main.compute3
rw__LL_Main_compute3 : [8] -> [8] -> [8] -> [8]
rw__LL_Main_compute3 x0 x1 x2 = rw__LL_Main_compute x1 x0 x2

// $LL.Main.loop3
rw__LL_Main_loop3 : [24] -> [9]
rw__LL_Main_loop3 x0 = rw__LL_Main_loop2 (0b0 # (rw_Main_compute x0))

// Main.compute
rw_Main_compute : [24] -> [8]
rw_Main_compute x0 = rw__LL_Main_compute2 x0

// $LL.Main.compute2
rw__LL_Main_compute2 : [24] -> [8]
rw__LL_Main_compute2 x0 = rw__LL_Main_compute1 (take`{8} x0) (take`{8} (drop`{8} x0)) (drop`{16} x0)

// $LL.Main.compute1
rw__LL_Main_compute1 : [8] -> [8] -> [8] -> [8]
rw__LL_Main_compute1 x0 x1 x2 = rw__LL_Main_compute3 x0 x1 x2

// $LL.Main.compute
rw__LL_Main_compute : [8] -> [8] -> [8] -> [8]
rw__LL_Main_compute x0 x1 x2 = ((x1 && x0) ^ x2) || (~ (((~ x1) && (~ x0)) ^ x2))

// $LL.Main.loop2
rw__LL_Main_loop2 : [9] -> [9]
rw__LL_Main_loop2 x0 = rw__LL_Main_loop (drop`{1} x0)

// Main.loop1
rw_Main_loop1 : [24] -> [9]
rw_Main_loop1 x0 = rw__LL_Main_loop1 x0

// $LL.Main.loop1
rw__LL_Main_loop1 : [24] -> [9]
rw__LL_Main_loop1 x0 = rw__LL_Main_loop3 x0

// $LL.Main.loop
rw__LL_Main_loop : [8] -> [9]
rw__LL_Main_loop x0 = 0b1 # x0

// $LL.Pure.dispatch
rw__LL_Pure_dispatch : [24] -> [9]
rw__LL_Pure_dispatch x0 = rw_Main_loop1 x0

// Per-cycle step: outputs # next register values.
rw_step : [24] -> [8]
rw_step i = drop`{1} s4
  where
    s0 : [8]
    s0 = take`{8} i
    s1 : [8]
    s1 = take`{8} (drop`{8} i)
    s2 : [8]
    s2 = drop`{16} i
    s3 : [24]
    s3 = s0 # (s1 # s2)
    s4 : [9]
    s4 = rw__Pure_dispatch s3

// Device: top_level
// Inputs, MSB-first: __in0 : [8], __in1 : [8], __in2 : [8]
// Outputs, MSB-first: __out0 : [8]
rw_device : {n} (fin n) => [n][24] -> [n][8]
rw_device ins = [rw_step i | i <- ins]