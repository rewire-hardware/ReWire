// Generated by rwc from device: top_level.
// rw_device maps a sequence of per-cycle inputs to per-cycle outputs.

module top_level where

// Helpers implementing ReWire Hyle primitive semantics.
rw'resize : {m, n} (fin m, fin n) => [n] -> [m]
rw'resize x = drop`{n} ((zero : [m]) # x)

rw'repl : {n, w} (fin n, fin w) => [w] -> [n * w]
rw'repl x = join (repeat`{n} x)

rw'parity : {n} (fin n) => [n] -> Bit
rw'parity x = foldr (^) False x

rw'sext : {m, n} (fin m, fin n, n >= 1) => [n] -> [m]
rw'sext x = if x @ 0 then ~ (rw'resize (~ x)) else rw'resize x

// $Pure.dispatch
rw__Pure_dispatch : [16] -> [8]
rw__Pure_dispatch x0 = rw_Main_loop x0

// Main.compute
rw_Main_compute : [16] -> [8]
rw_Main_compute x0 = rw__LL_Main_compute x0 (rw__LL_Main_compute1 x0 (take`{1} x0))

// $LL.Main.loop
rw__LL_Main_loop : [8] -> [8]
rw__LL_Main_loop x0 = x0

// Main.loop
rw_Main_loop : [16] -> [8]
rw_Main_loop x0 = rw__LL_Main_loop (rw_Main_compute x0)

// $LL.Main.compute1
rw__LL_Main_compute1 : [16] -> [1] -> [1]
rw__LL_Main_compute1 x0 x1 = if x1 == 0b1 then (take`{1} (drop`{7} x0)) else 0b0

// $LL.Main.compute
rw__LL_Main_compute : [16] -> [1] -> [8]
rw__LL_Main_compute x0 x1 = if x1 == 0b0 then (take`{8} x0) else (drop`{8} x0)

// Per-cycle step: outputs # next register values.
rw_step : [16] -> [8]
rw_step i = s1
  where
    s0 : [16]
    s0 = i
    s1 : [8]
    s1 = rw__Pure_dispatch s0

// Device: top_level
// Inputs, MSB-first: __in0 : [16]
// Outputs, MSB-first: __out0 : [8]
rw_device : {n} (fin n) => [n][16] -> [n][8]
rw_device ins = [rw_step i | i <- ins]