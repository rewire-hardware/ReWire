// $LL.ReWire.Prelude.&&1
rw__LL_ReWire_Prelude___1 : [2] -> [1]
rw__LL_ReWire_Prelude___1 x0 = 0b0

// $LL.ReWire.Prelude.&&
rw__LL_ReWire_Prelude___ : [1] -> [1] -> [2] -> [1]
