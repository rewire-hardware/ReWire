// cry$tspw$7
rw_cry_tspw_7 : [8] -> [8]
rw_cry_tspw_7 x0 = (take`{1} x0) # ((take`{1} (drop`{4} x0)) # ((take`{1} (drop`{1} x0)) # ((take`{1} (drop`{5} x0)) # ((take`{1} (drop`{2} x0)) # ((take`{1} (drop`{6} x0)) # ((take`{1} (drop`{3} x0)) # (drop`{7} x0)))))))

// Per-cycle step: outputs # next register values.
rw_step : [16] -> [8]
rw_step i = s3
  where
    s0 : [8]
    s0 = take`{8} i
    s1 : [8]
    s1 = drop`{8} i
    s2 : [16]
    s2 = s0 # s1
    s3 : [8]
    s3 = rw_main__dispatch s2

// Device: top_level
// Inputs, MSB-first: __in0 : [8], __in1 : [8]
// Outputs, MSB-first: __out0 : [8]
rw_device : {n} (fin n) => [n][16] -> [n][8]
rw_device ins = [rw_step i | i <- ins]