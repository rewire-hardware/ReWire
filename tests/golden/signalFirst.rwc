device top_level
      input __in0 : [8]
      output __out0 : [8]
      register __resumption_tag : [9] init 9'h100
      register __st0 : [8] init 8'h0
      let $res = $Pure.dispatch (__resumption_tag # __st0) __in0
      __out0 := $res[17 +: 8]
      next __resumption_tag := $res[8 +: 9]
      next __st0 := $res[0 +: 8]