$Pure.dispatch : ([17], [8]) -> [26]
$Pure.dispatch disc i =
      if eq disc[16 +: 1] 1'h1 then $LL.Pure.dispatch2 i disc[0 +: 8]
            else $LL.Pure.dispatch1 i disc[8 +: 8] disc[0 +: 8]

$LL.Main.dev21 : ([8], [8]) -> [26]
$LL.Main.dev21 $x sto0 =
      $LL.Main.dev12 $x sto0

$LL.Pure.dispatch2 : ([8], [8]) -> [26]
