$Pure.dispatch : ([1], [1]) -> [3]
$Pure.dispatch disc i =
      $LL.Main.go i disc

$LL.Main.go4 : ([1]) -> [3]
$LL.Main.go4 sto0 =
      2'h2 # sto0

$LL.Main.go3 : ([1], [1]) -> [1]
$LL.Main.go3 rf sigma0 =
      let $t0 = $LL.Main.go1 rf in
      if eq $t0 1'h1 then sigma0
            else $LL.Main.go2 ($LL.Main.go1 rf) sigma0

$LL.Main.go2 : ([1], [1]) -> [1]
$LL.Main.go2 $7 sigma0 =
      sigma0

$LL.Main.go1 : ([1]) -> [1]
$LL.Main.go1 $46 =
      $46

Main.go : ([1]) -> [3]
Main.go sto0 =
      let $t1 = (let $t0 = $LL.Main.go3 sto0 sto0 in
      2'h0 # $t0) in
      let s0 = $t1[0 +: 1] in
      $LL.Main.go4 s0

$LL.Main.go : ([1], [1]) -> [3]
$LL.Main.go x sto0 =
      Main.go sto0

device top_level
      input __in0 : [1]
      output __out0 : [1]
      register __st0 : [1] init 1'h1
      let $res = $Pure.dispatch __st0 __in0
      __out0 := $res[1 +: 1]
      next __st0 := $res[0 +: 1]