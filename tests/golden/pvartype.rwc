$Pure.dispatch : ([1], [1]) -> [2]
$Pure.dispatch disc i =
      $L.x3 i disc

$L.Main.go1 : ([1]) -> [2]
$L.Main.go1 s0 =
      $L.rf4 s0 s0

$L._unused2 : ([1]) -> [2]
$L._unused2 s0 =
      1'h0 # s0

$L.x3 : ([1], [1]) -> [2]
$L.x3 x $x =
      $L.Main.go1 $x

$L.rf4 : ([1], [1]) -> [2]
$L.rf4 rf s0 =
      if eq rf 1'h0 then $L._unused2 s0
            else $L._unused2 s0

device top_level
      input __in0 : [1]
      output __out0 : [1]
      register __st0 : [1] init 1'h1
      let $res = $Pure.dispatch __st0 __in0
      __out0 := $res[1 +: 1]
      next __st0 := $res[0 +: 1]