Main.multiplyFun : ([256]) -> [128]
Main.multiplyFun ds =
      let a = ds[128 +: 128] in
      let b = ds[0 +: 128] in
      Main.multiply a b

device top_level
      input __in0 : [128]
      input __in1 : [128]
      output __out0 : [128]
      let $in = __in0 # __in1
      let $res = main.$dispatch $in
      __out0 := $res