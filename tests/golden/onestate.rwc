$Pure.dispatch : ([8], [1]) -> [17]
$Pure.dispatch disc i =
      $LL.Main.incr1 i disc

Main.incr : ([8]) -> [17]
Main.incr sto0 =
      let $t1 = (let $t0 = Main.grunt sto0 in
      9'h0 # $t0) in
      let s0 = $t1[0 +: 8] in
      $LL.Main.incr s0

$LL.Main.incr2 : ([8], [8]) -> [17]
$LL.Main.incr2 x sto0 =
      1'h1 # x # sto0

$LL.Main.incr1 : ([1], [8]) -> [17]
$LL.Main.incr1 _unused sto0 =
      Main.incr sto0

$LL.Main.incr : ([8]) -> [17]
$LL.Main.incr sto0 =
      $LL.Main.incr2 sto0 sto0

$LL.Main.grunt : ([8], [8]) -> [8]
$LL.Main.grunt $x sigma0 =
      $x

Main.grunt : ([8]) -> [8]
Main.grunt sigma0 =
      $LL.Main.grunt sigma0 sigma0

device top_level
      input __in0 : [1]
      output __out0 : [8]
      register __st0 : [8] init 8'h0
      let $res = $Pure.dispatch __st0 __in0
      __out0 := $res[8 +: 8]
      next __st0 := $res[0 +: 8]