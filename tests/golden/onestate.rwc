$Pure.dispatch : ([8], [1]) -> [16]
$Pure.dispatch disc i =
      $L._unused4 i disc

$L.Main.grunt5 : ([8]) -> [16]
$L.Main.grunt5 s0 =
      $L.$x6 s0 s0

$L._unused2 : ([8]) -> [16]
$L._unused2 s0 =
      $L.x3 s0 s0

$L._unused4 : ([1], [8]) -> [16]
$L._unused4 _unused $x =
      $L.Main.grunt5 $x

$L.x3 : ([8], [8]) -> [16]
$L.x3 x s0 =
      x # s0

$L.$x6 : ([8], [8]) -> [16]
$L.$x6 $x s0 =
      $L._unused2 $x

device top_level
      input __in0 : [1]
      output __out0 : [8]
      register __st0 : [8] init 8'h0
      let $res = $Pure.dispatch __st0 __in0
      __out0 := $res[8 +: 8]
      next __st0 := $res[0 +: 8]