// Generated by rwc from device: top_level.
// rw_device maps a sequence of per-cycle inputs to per-cycle outputs.

module top_level where

// Helpers implementing ReWire Hyle primitive semantics.
rw'resize : {m, n} (fin m, fin n) => [n] -> [m]
rw'resize x = drop`{n} ((zero : [m]) # x)

rw'repl : {n, w} (fin n, fin w) => [w] -> [n * w]
rw'repl x = join (repeat`{n} x)

rw'parity : {n} (fin n) => [n] -> Bit
rw'parity x = foldr (^) False x

rw'sext : {m, n} (fin m, fin n, n >= 1) => [n] -> [m]
rw'sext x = if x @ 0 then ~ (rw'resize (~ x)) else rw'resize x

// $Pure.dispatch
rw__Pure_dispatch : [1] -> [1] -> [3]
rw__Pure_dispatch x0 x1 = rw_Main_go x1 x0

// $LL.Main.notb1
rw__LL_Main_notb1 : [1] -> [1] -> [1]
rw__LL_Main_notb1 x0 x1 = if x1 == 0b0 then 0b1 else (rw__LL_Main_notb x0)

// $LL.Main.go7
rw__LL_Main_go7 : [1] -> [1] -> [3]
rw__LL_Main_go7 x0 x1 = 0b1 # (x0 # x1)

// $LL.Main.go6
rw__LL_Main_go6 : [1] -> [1] -> [2]
rw__LL_Main_go6 x0 x1 = rw__LL_Main_go2 (rw_Main_notb x0)

// $LL.Main.go5
rw__LL_Main_go5 : [1] -> [1] -> [3]
rw__LL_Main_go5 x0 x1 = if x0 == 0b1 then (rw__LL_Main_go4 s4 s5) else (rw__LL_Main_go x0 x1)
  where
    s0 : [2]
    s0 = rw__LL_Main_go6 x1 x1
    s1 : [1]
    s1 = take`{1} s0
    s2 : [1]
    s2 = drop`{1} s0
    s3 : [3]
    s3 = 0b0 # (s1 # s2)
    s4 : [1]
    s4 = take`{1} (drop`{1} s3)
    s5 : [1]
    s5 = drop`{2} s3

// $LL.Main.notb
rw__LL_Main_notb : [1] -> [1]
rw__LL_Main_notb x0 = 0b0

// Main.notb
rw_Main_notb : [1] -> [1]
rw_Main_notb x0 = rw__LL_Main_notb1 x0 x0

// $LL.Main.go4
rw__LL_Main_go4 : [1] -> [1] -> [3]
rw__LL_Main_go4 x0 x1 = rw__LL_Main_go7 x0 x0

// $LL.Main.go2
rw__LL_Main_go2 : [1] -> [2]
rw__LL_Main_go2 x0 = x0 # x0

// $LL.Main.go
rw__LL_Main_go : [1] -> [1] -> [3]
rw__LL_Main_go x0 x1 = rw__LL_Main_go4 x1 x1

// Main.go
rw_Main_go : [1] -> [1] -> [3]
rw_Main_go x0 x1 = rw__LL_Main_go5 x0 x1

// Per-cycle step: outputs # next register values.
rw_step : [1] -> [1] -> [2]
rw_step st i = (take`{1} (drop`{1} s2)) # (drop`{2} s2)
  where
    s0 : [1]
    s0 = st
    s1 : [1]
    s1 = i
    s2 : [3]
    s2 = rw__Pure_dispatch s0 s1

// Device: top_level
// Inputs, MSB-first: __in0 : [1]
// Outputs, MSB-first: __out0 : [1]
rw_device : {n} (fin n) => [n][1] -> [n][1]
rw_device ins = outs
  where
    rs : [n][2]
    rs = [rw_step st i | st <- sts | i <- ins]
    sts : [1 + n][1]
    sts = [0b0] # [drop`{1} r | r <- rs]
    outs : [n][1]
    outs = [take`{1} r | r <- rs]