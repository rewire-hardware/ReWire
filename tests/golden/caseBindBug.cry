// Generated by rwc from device: top_level.
// rw_device maps a sequence of per-cycle inputs to per-cycle outputs.

module top_level where

// Helpers implementing ReWire Hyle primitive semantics.
rw'resize : {m, n} (fin m, fin n) => [n] -> [m]
rw'resize x = drop`{n} ((zero : [m]) # x)

rw'repl : {n, w} (fin n, fin w) => [w] -> [n * w]
rw'repl x = join (repeat`{n} x)

rw'parity : {n} (fin n) => [n] -> Bit
rw'parity x = foldr (^) False x

rw'sext : {m, n} (fin m, fin n, n >= 1) => [n] -> [m]
rw'sext x = if x @ 0 then ~ (rw'resize (~ x)) else rw'resize x

// main.$dispatch
rw_main__dispatch : [1] -> [1] -> [2]
rw_main__dispatch x0 x1 = rw_main__x2 x1 x0

// main.$x2
rw_main__x2 : [1] -> [1] -> [2]
rw_main__x2 x0 x1 = rw_main_go x0 x1

// main._unused
rw_main__unused : [1] -> [1] -> [2]
rw_main__unused x0 x1 = x0 # x1

// main.emit
rw_main_emit : [1] -> [1] -> [2]
rw_main_emit x0 x1 = rw_main__unused x0 x0

// main.arm
rw_main_arm : [1] -> [2]
rw_main_arm x0 = rw_main_emit x0 x0

// main.x
rw_main_x : [1] -> [1] -> [2]
rw_main_x x0 x1 = rw_main_arm s0
  where
    s0 : [1]
    s0 = rw_Main_notb x0

// main.arm2
rw_main_arm2 : [1] -> [2]
rw_main_arm2 x0 = rw_main_x x0 x0

// main.go
rw_main_go : [1] -> [1] -> [2]
rw_main_go x0 x1 = if ~ (x0 @ 0) then (rw_main_arm x1) else (rw_main_arm2 x1)

// Main.notb
rw_Main_notb : [1] -> [1]
rw_Main_notb x0 = ~ x0

// Per-cycle step: outputs # next register values.
rw_step : [1] -> [1] -> [2]
rw_step st i = (take`{1} s2) # (drop`{1} s2)
  where
    s0 : [1]
    s0 = st
    s1 : [1]
    s1 = i
    s2 : [2]
    s2 = rw_main__dispatch s0 s1

// Device: top_level
// Inputs, MSB-first: __in0 : [1]
// Outputs, MSB-first: __out0 : [1]
rw_device : {n} (fin n) => [n][1] -> [n][1]
rw_device ins = outs
  where
    rs : [n][2]
    rs = [rw_step st i | st <- sts | i <- ins]
    sts : [1 + n][1]
    sts = [0b0] # [drop`{1} r | r <- rs]
    outs : [n][1]
    outs = [take`{1} r | r <- rs]