$Pure.dispatch : ([7]) -> [7]
$Pure.dispatch i =
      $LL.Pure.dispatch i

Main.dev : ([7]) -> [7]
Main.dev $x =
      $LL.Main.dev2 $x

$LL.Main.dev2 : ([7]) -> [7]
$LL.Main.dev2 $x =
      $LL.Main.dev1 $x

$LL.Main.dev1 : ([7]) -> [7]
$LL.Main.dev1 a =
      a

$LL.Pure.dispatch : ([7]) -> [7]
$LL.Pure.dispatch i =
      $LL.Main.dev i

$LL.Main.dev : ([7]) -> [7]
$LL.Main.dev a' =
      Main.dev (umod (add a' 7'h1) 7'h64)

device top_level
      input __in0 : [7]
      output __out0 : [7]
      let $res = $Pure.dispatch __in0
      __out0 := $res