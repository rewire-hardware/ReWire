$Pure.dispatch : ([7]) -> [7]
$Pure.dispatch i =
      $L.a'4 i

$L.Main.dev3 : ([7]) -> [7]
$L.Main.dev3 a =
      a

$L.a'4 : ([7]) -> [7]
$L.a'4 a' =
      $L.Main.dev3 (umod (add a' 7'h1) 7'h64)

device top_level
      input __in0 : [7]
      output __out0 : [7]
      let $res = $Pure.dispatch __in0
      __out0 := $res