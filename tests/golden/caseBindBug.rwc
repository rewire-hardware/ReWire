main.$dispatch : ([1], [1]) -> [2]
main.$dispatch disc i =
      main.$L.$x4$270 i disc

main.$L.$x4$270 : ([1], [1]) -> [2]
main.$L.$x4$270 $x s0 =
      main.$L.Main.go3$268 $x s0

main.$L._unused7$274 : ([1], [1]) -> [2]
main.$L._unused7$274 x s0 =
      x # s0

main.$L.Main.emit6$273 : ([1], [1]) -> [2]
main.$L.Main.emit6$273 x s0 =
      main.$L._unused7$274 x x

main.$L.arm8$276 : ([1]) -> [2]
main.$L.arm8$276 s0 =
      main.$L.Main.emit6$273 s0 s0

main.$L.x14$285 : ([1], [1]) -> [2]
main.$L.x14$285 x s0 =
      let $a = Main.notb x in
      main.$L.arm8$276 $a

main.$L.arm15$287 : ([1]) -> [2]
main.$L.arm15$287 s0 =
      main.$L.x14$285 s0 s0

main.$L.Main.go3$268 : ([1], [1]) -> [2]
main.$L.Main.go3$268 ds s0 =
      if eq ds 1'h0 then main.$L.arm8$276 s0
            else main.$L.arm15$287 s0

Main.notb : ([1]) -> [1]
Main.notb ds =
      if eq ds 1'h0 then 1'h1
            else 1'h0

device top_level
      input __in0 : [1]
      output __out0 : [1]
      register __st0 : [1] init 1'h0
      let $res = main.$dispatch __st0 __in0
      __out0 := $res[1 +: 1]
      next __st0 := $res[0 +: 1]