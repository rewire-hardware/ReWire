$Pure.dispatch : ([1], [1]) -> [2]
$Pure.dispatch disc i =
      $L.$x4 i disc

$L.x14 : ([1], [1]) -> [2]
$L.x14 x s0 =
      $L.arm8 (Main.notb x)

$LL.Main.notb : ([1]) -> [1]
$LL.Main.notb wild =
      if eq wild 1'h0 then 1'h1
            else 1'h0

$L.arm8 : ([1]) -> [2]
$L.arm8 s0 =
      $L.Main.emit6 s0 s0

$L.Main.go3 : ([1], [1]) -> [2]
$L.Main.go3 ds s0 =
      if eq ds 1'h0 then $L.arm8 s0
            else $L.arm15 s0

$L.Main.emit6 : ([1], [1]) -> [2]
$L.Main.emit6 x s0 =
      $L._unused7 x x

Main.notb : ([1]) -> [1]
Main.notb $x =
      $LL.Main.notb $x

$L.arm15 : ([1]) -> [2]
$L.arm15 s0 =
      $L.x14 s0 s0

$L._unused7 : ([1], [1]) -> [2]
$L._unused7 x s0 =
      x # s0

$L.$x4 : ([1], [1]) -> [2]
$L.$x4 $x $x1 =
      $L.Main.go3 $x $x1

device top_level
      input __in0 : [1]
      output __out0 : [1]
      register __st0 : [1] init 1'h0
      let $res = $Pure.dispatch __st0 __in0
      __out0 := $res[1 +: 1]
      next __st0 := $res[0 +: 1]