main.$L.Main.go3$266 : ([1], [1]) -> [2]
main.$L.Main.go3$266 ds s0 =
      if eq ds 1'h0 then main.$L.arm8$274 s0
            else main.$L.arm15$285 s0

Main.notb : ([1]) -> [1]
Main.notb ds =
      if eq ds 1'h0 then 1'h1
            else 1'h0

device top_level
      input __in0 : [1]
      output __out0 : [1]
      register __st0 : [1] init 1'h0
