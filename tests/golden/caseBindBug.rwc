--| state dispatch for process main: 0=$x2
main.$dispatch : ([1], [1]) -> [2]
main.$dispatch disc i =
      main.$x2 i disc

--| block '$L.$x2' of process main (state 0)
main.$x2 : ([1], [1]) -> [2]
main.$x2 $x s0 =
      main.go $x s0

--| block '$L._unused' of process main
main._unused : ([1], [1]) -> [2]
main._unused x s0 =
      x # s0

--| block '$L.Main.emit' of process main
main.emit : ([1], [1]) -> [2]
main.emit x s0 =
      main._unused x x

--| block '$L.arm' of process main
--| also: main._unused3
main.arm : ([1]) -> [2]
main.arm s0 =
      main.emit s0 s0

--| block '$L.x' of process main
main.x : ([1], [1]) -> [2]
main.x x s0 =
      let $a = Main.notb x in
      main.arm $a

--| block '$L.arm2' of process main
main.arm2 : ([1]) -> [2]
main.arm2 s0 =
      main.x s0 s0

--| block '$L.Main.go' of process main
main.go : ([1], [1]) -> [2]
main.go $ds s0 =
      if not $ds then main.arm s0
            else main.arm2 s0

Main.notb : ([1]) -> [1]
Main.notb $ds =
      not $ds

device top_level
      input __in0 : [1]
      output __out0 : [1]
      register __st0 : [1] init 1'h0
      tag $x2 = 0
      let $res = main.$dispatch __st0 __in0
      __out0 := $res[1 +: 1]
      next __st0 := $res[0 +: 1]