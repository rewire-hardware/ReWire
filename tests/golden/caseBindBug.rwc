main.$dispatch : ([1], [1]) -> [2]
main.$dispatch disc i =
      main.$L.$x4$268 i disc

main.$L.$x4$268 : ([1], [1]) -> [2]
main.$L.$x4$268 $x s0 =
      main.$L.Main.go3$266 $x s0

main.$L._unused7$272 : ([1], [1]) -> [2]
main.$L._unused7$272 x s0 =
