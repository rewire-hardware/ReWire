$Pure.dispatch : ([1], [1]) -> [3]
$Pure.dispatch disc i =
      Main.go i disc

$LL.Main.go5 : ([1], [1]) -> [3]
$LL.Main.go5 wild sto0 =
      if eq wild 1'h0 then $LL.Main.go1 sto0 sto0
            else let $t1 = (let $t0 = $LL.Main.go3 sto0 sto0 in
            let v = $t0[1 +: 1] in
            let s0 = $t0[0 +: 1] in
            1'h0 # v # s0) in
            let v = $t1[1 +: 1] in
            let s0 = $t1[0 +: 1] in
            $LL.Main.go1 v s0

$LL.Main.go4 : ([1], [1]) -> [1]
$LL.Main.go4 x sigma0 =
      Main.notb x

$LL.Main.go3 : ([1], [1]) -> [2]
$LL.Main.go3 rabind sigma0 =
      let $t0 = $LL.Main.go4 rabind sigma0 in
      $LL.Main.go $t0

$LL.Main.notb : ([1]) -> [1]
$LL.Main.notb wild =
      if eq wild 1'h0 then 1'h1
            else 1'h0

$LL.Main.go2 : ([1], [1]) -> [3]
$LL.Main.go2 rabind sto0 =
      1'h1 # rabind # sto0

$LL.Main.go1 : ([1], [1]) -> [3]
$LL.Main.go1 rabind sto0 =
      $LL.Main.go2 rabind rabind

Main.notb : ([1]) -> [1]
Main.notb $x =
      $LL.Main.notb $x

$LL.Main.go : ([1]) -> [2]
$LL.Main.go sigma0 =
      sigma0 # sigma0

Main.go : ([1], [1]) -> [3]
Main.go ds sto0 =
      $LL.Main.go5 ds sto0

device top_level
      input __in0 : [1]
      output __out0 : [1]
      register __st0 : [1] init 1'h0
      let $res = $Pure.dispatch __st0 __in0
      __out0 := $res[1 +: 1]
      next __st0 := $res[0 +: 1]