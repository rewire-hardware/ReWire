// Generated by rwc from device: top_level.
// rw_device maps a sequence of per-cycle inputs to per-cycle outputs.

module top_level where

// Helpers implementing ReWire Hyle primitive semantics.
rw'resize : {m, n} (fin m, fin n) => [n] -> [m]
rw'resize x = drop`{n} ((zero : [m]) # x)

rw'repl : {n, w} (fin n, fin w) => [w] -> [n * w]
rw'repl x = join (repeat`{n} x)

rw'parity : {n} (fin n) => [n] -> Bit
rw'parity x = foldr (^) False x

rw'sext : {m, n} (fin m, fin n, n >= 1) => [n] -> [m]
rw'sext x = if x @ 0 then ~ (rw'resize (~ x)) else rw'resize x

// $Pure.dispatch
rw__Pure_dispatch : [17] -> [1] -> [25]
rw__Pure_dispatch x0 x1 = if (take`{1} x0) == 0b1 then (rw__LL_Main_loop1 s0 s1 x1) else (rw__LL_Main_loop_s11 s2 x1)
  where
    s0 : [8]
    s0 = take`{8} (drop`{1} x0)
    s1 : [8]
    s1 = drop`{9} x0
    s2 : [8]
    s2 = drop`{9} x0

// $LL.Main.loop$s11
rw__LL_Main_loop_s11 : [8] -> [1] -> [25]
rw__LL_Main_loop_s11 x0 x1 = rw__LL_Main_loop_s1 x0 x1

// $LL.Main.loop1
rw__LL_Main_loop1 : [8] -> [8] -> [1] -> [25]
rw__LL_Main_loop1 x0 x1 x2 = rw__LL_Main_loop x1 x0 x2

// Main.loop
rw_Main_loop : [8] -> [8] -> [25]
rw_Main_loop x0 x1 = x0 # (0b1 # (x1 # x0))

// $LL.Main.loop
rw__LL_Main_loop : [8] -> [8] -> [1] -> [25]
rw__LL_Main_loop x0 x1 x2 = if x2 == 0b0 then (rw_Main_loop x1 (x0 + x1)) else (rw_Main_loop x0 x1)

// $LL.Main.loop$s1
rw__LL_Main_loop_s1 : [8] -> [1] -> [25]
rw__LL_Main_loop_s1 x0 x1 = if x1 == 0b0 then (rw_Main_loop x0 (0x00 + x0)) else (rw_Main_loop 0x00 x0)

// Per-cycle step: outputs # next register values.
rw_step : [17] -> [1] -> [25]
rw_step st i = (take`{8} s2) # (drop`{8} s2)
  where
    s0 : [17]
    s0 = st
    s1 : [1]
    s1 = i
    s2 : [25]
    s2 = rw__Pure_dispatch s0 s1

// Device: top_level
// Inputs, MSB-first: __in0 : [1]
// Outputs, MSB-first: __out0 : [8]
rw_device : {n} (fin n) => [n][1] -> [n][8]
rw_device ins = outs
  where
    rs : [n][25]
    rs = [rw_step st i | st <- sts | i <- ins]
    sts : [1 + n][17]
    sts = [0b00000000000000001] # [drop`{8} r | r <- rs]
    outs : [n][8]
    outs = [take`{8} r | r <- rs]