// Generated by rwc from device: top_level.
// rw_device maps a sequence of per-cycle inputs to per-cycle outputs.

module top_level where

// Helpers implementing ReWire Hyle primitive semantics.
rw'resize : {m, n} (fin m, fin n) => [n] -> [m]
rw'resize x = drop`{n} ((zero : [m]) # x)

rw'repl : {n, w} (fin n, fin w) => [w] -> [n * w]
rw'repl x = join (repeat`{n} x)

rw'parity : {n} (fin n) => [n] -> Bit
rw'parity x = foldr (^) False x

rw'sext : {m, n} (fin m, fin n, n >= 1) => [n] -> [m]
rw'sext x = if x @ 0 then ~ (rw'resize (~ x)) else rw'resize x

// main.$dispatch
rw_main__dispatch : [17] -> [1] -> [25]
rw_main__dispatch x0 x1 = if ~ ((take`{1} x0) @ 0) then (rw_main_b2 (take`{8} (drop`{1} x0)) (drop`{9} x0) x1) else (rw_main_b (drop`{9} x0) x1)

// main.b2
rw_main_b2 : [8] -> [8] -> [1] -> [25]
rw_main_b2 x0 x1 x2 = if ~ (x2 @ 0) then (rw_main_loop x1 (x0 + x1)) else (rw_main_loop x0 x1)

// main.loop
rw_main_loop : [8] -> [8] -> [25]
rw_main_loop x0 x1 = x0 # (0b0 # (x0 # x1))

// main.b
rw_main_b : [8] -> [1] -> [25]
rw_main_b x0 x1 = if ~ (x1 @ 0) then (rw_main_loop x0 (0x00 + x0)) else (rw_main_loop 0x00 x0)

// Per-cycle step: outputs # next register values.
rw_step : [17] -> [1] -> [25]
rw_step st i = (take`{8} s2) # (drop`{8} s2)
  where
    s0 : [17]
    s0 = st
    s1 : [1]
    s1 = i
    s2 : [25]
    s2 = rw_main__dispatch s0 s1

// Device: top_level
// Inputs, MSB-first: __in0 : [1]
// Outputs, MSB-first: __out0 : [8]
rw_device : {n} (fin n) => [n][1] -> [n][8]
rw_device ins = outs
  where
    rs : [n][25]
    rs = [rw_step st i | st <- sts | i <- ins]
    sts : [1 + n][17]
    sts = [0b10000000000000001] # [drop`{8} r | r <- rs]
    outs : [n][8]
    outs = [take`{8} r | r <- rs]