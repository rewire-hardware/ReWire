$Pure.dispatch : ([28], [4]) -> [44]
$Pure.dispatch disc i =
      let s0 = disc[24 +: 4] in
      let s1 = disc[16 +: 8] in
      let s2 = disc[0 +: 16] in
      Main.loop1 i s0 s1 s2

$LL.Main.loop12 : ([16], [4], [4], [8], [16]) -> [44]
$LL.Main.loop12 c a sto0 sto1 sto2 =
      add (zext 16 a) c # sto0 # sto1 # sto2

$LL.Main.loop11 : ([4], [16], [8], [4], [8], [16]) -> [44]
$LL.Main.loop11 a c b sto0 sto1 sto2 =
      $LL.Main.loop10 b c a sto0 sto1 sto2

$LL.Main.loop10 : ([8], [16], [4], [4], [8], [16]) -> [44]
$LL.Main.loop10 b c a sto0 sto1 sto2 =
      $LL.Main.loop1 c a sto0 sto1 (add (zext 16 b) c)

$LL.Main.loop9 : ([8], [16], [4], [4], [8], [16]) -> [44]
$LL.Main.loop9 b c a sto0 sto1 sto2 =
      $LL.Main.loop11 a c b sto0 (add (zext 8 a) b) sto2

$LL.Main.loop8 : ([16], [8], [4], [4], [8], [16]) -> [44]
$LL.Main.loop8 c b $x sto0 sto1 sto2 =
      $LL.Main.loop9 b c $x sto0 sto1 sto2

$LL.Main.loop7 : ([4], [4], [4], [8], [16]) -> [44]
$LL.Main.loop7 $x $x1 sto0 sto1 sto2 =
      $LL.Main.loop3 $x $x1 sto0 sto1 sto2

$LL.Main.loop6 : ([8], [4], [4], [16], [4], [8], [16]) -> [44]
$LL.Main.loop6 b i a c sto0 sto1 sto2 =
      $LL.Main.loop8 c b a i sto1 sto2

Main.loop1 : ([4], [4], [8], [16]) -> [44]
Main.loop1 $x sto0 sto1 sto2 =
      $LL.Main.loop4 $x sto0 sto1 sto2

$LL.Main.loop5 : ([4], [4], [8], [4], [8], [16]) -> [44]
$LL.Main.loop5 i a b sto0 sto1 sto2 =
      $LL.Main.loop a b i sto2 sto0 sto1 sto2

$LL.Main.loop4 : ([4], [4], [8], [16]) -> [44]
$LL.Main.loop4 $10 sto0 sto1 sto2 =
      $LL.Main.loop7 $10 sto0 sto0 sto1 sto2

$LL.Main.loop3 : ([4], [4], [4], [8], [16]) -> [44]
$LL.Main.loop3 i a sto0 sto1 sto2 =
      $LL.Main.loop2 a i sto1 sto0 sto1 sto2

$LL.Main.loop2 : ([4], [4], [8], [4], [8], [16]) -> [44]
$LL.Main.loop2 a i $x sto0 sto1 sto2 =
      $LL.Main.loop5 i a $x sto0 sto1 sto2

$LL.Main.loop1 : ([16], [4], [4], [8], [16]) -> [44]
$LL.Main.loop1 $x $x1 sto0 sto1 sto2 =
      $LL.Main.loop12 $x $x1 sto0 sto1 sto2

$LL.Main.loop : ([4], [8], [4], [16], [4], [8], [16]) -> [44]
$LL.Main.loop a b i $x sto0 sto1 sto2 =
      $LL.Main.loop6 b i a $x sto0 sto1 sto2

device top_level
      input __in0 : [4]
      output __out0 : [16]
      register __st0 : [4] init 4'h0
      register __st1 : [8] init 8'h3
      register __st2 : [16] init 16'h5
      let $res = $Pure.dispatch (__st0 # __st1 # __st2) __in0
      __out0 := $res[28 +: 16]
      next __st0 := $res[24 +: 4]
      next __st1 := $res[16 +: 8]
      next __st2 := $res[0 +: 16]