$Pure.dispatch : ([28], [4]) -> [44]
$Pure.dispatch disc i =
      let s0 = disc[24 +: 4] in
      let s1 = disc[16 +: 8] in
      let s2 = disc[0 +: 16] in
      Main.loop i s0 s1 s2

$LL.Main.loop11 : ([4], [16], [8], [4], [8], [16]) -> [44]
$LL.Main.loop11 a c b sto0 sto1 sto2 =
      $LL.Main.loop6 b c a sto0 (add (zext 8 a) b) sto2

$LL.Main.loop10 : ([4], [16], [4], [8], [16]) -> [44]
$LL.Main.loop10 a c sto0 sto1 sto2 =
      add (zext 16 a) c # sto0 # sto1 # sto2

$LL.Main.loop9 : ([4], [4], [8], [4], [8], [16]) -> [44]
$LL.Main.loop9 i a b sto0 sto1 sto2 =
      $LL.Main.loop1 i b a sto2 sto0 sto1 sto2

$LL.Main.loop8 : ([4], [16], [8], [4], [8], [16]) -> [44]
$LL.Main.loop8 a c b sto0 sto1 sto2 =
      $LL.Main.loop2 a c sto0 sto1 (add (zext 16 b) c)

Main.loop : ([4], [4], [8], [16]) -> [44]
Main.loop i sto0 sto1 sto2 =
      $LL.Main.loop5 i sto0 sto0 sto1 sto2

$LL.Main.loop7 : ([4], [4], [8], [4], [8], [16]) -> [44]
$LL.Main.loop7 $x $x1 $x2 sto0 sto1 sto2 =
      $LL.Main.loop9 $x $x1 $x2 sto0 sto1 sto2

$LL.Main.loop6 : ([8], [16], [4], [4], [8], [16]) -> [44]
$LL.Main.loop6 b c a sto0 sto1 sto2 =
      $LL.Main.loop8 a c b sto0 sto1 sto2

$LL.Main.loop5 : ([4], [4], [4], [8], [16]) -> [44]
$LL.Main.loop5 $x $x1 sto0 sto1 sto2 =
      $LL.Main.loop3 $x $x1 sto0 sto1 sto2

$LL.Main.loop4 : ([4], [4], [8], [16], [4], [8], [16]) -> [44]
$LL.Main.loop4 i a b c sto0 sto1 sto2 =
      $LL.Main.loop a c b i sto1 sto2

$LL.Main.loop3 : ([4], [4], [4], [8], [16]) -> [44]
$LL.Main.loop3 i a sto0 sto1 sto2 =
      $LL.Main.loop7 i a sto1 sto0 sto1 sto2

$LL.Main.loop2 : ([4], [16], [4], [8], [16]) -> [44]
$LL.Main.loop2 $x $x1 sto0 sto1 sto2 =
      $LL.Main.loop10 $x $x1 sto0 sto1 sto2

$LL.Main.loop1 : ([4], [8], [4], [16], [4], [8], [16]) -> [44]
$LL.Main.loop1 i b a $x sto0 sto1 sto2 =
      $LL.Main.loop4 i a b $x sto0 sto1 sto2

$LL.Main.loop : ([4], [16], [8], [4], [8], [16]) -> [44]
$LL.Main.loop $x $x1 $x2 sto0 sto1 sto2 =
      $LL.Main.loop11 $x $x1 $x2 sto0 sto1 sto2

device top_level
      input __in0 : [4]
      output __out0 : [16]
      register __st0 : [4] init 4'h0
      register __st1 : [8] init 8'h3
      register __st2 : [16] init 16'h5
      let $res = $Pure.dispatch (__st0 # __st1 # __st2) __in0
      __out0 := $res[28 +: 16]
      next __st0 := $res[24 +: 4]
      next __st1 := $res[16 +: 8]
      next __st2 := $res[0 +: 16]