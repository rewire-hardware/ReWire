$Pure.dispatch : ([28], [4]) -> [44]
$Pure.dispatch disc i =
      let s = disc[24 +: 4] in
      let s1 = disc[16 +: 8] in
      let s2 = disc[0 +: 16] in
      $L.$x16 i s s1 s2

$L.c12 : ([4], [4], [8], [16], [4], [8], [16]) -> [44]
$L.c12 i a b c s0 s1 s2 =
      $LL.L.c12 a c b s1 s2 i

$L.Main.loop9 : ([4], [4], [8], [16]) -> [44]
$L.Main.loop9 i s0 $x $x1 =
      $L.a10 i s0 s0 $x $x1

$L._unused13 : ([4], [8], [16], [4], [8], [16]) -> [44]
$L._unused13 a b c s0 s1 s2 =
      $LL.L._unused13 c a s0 b s2 (add (zext 8 a) b)

$L.$x16 : ([4], [4], [8], [16]) -> [44]
$L.$x16 $x $x1 $x2 $x3 =
      $L.Main.loop9 $x $x1 $x2 $x3

$LL.L._unused13 : ([16], [4], [4], [8], [16], [8]) -> [44]
$LL.L._unused13 c a s0 b s2 s' =
      $L._unused14 a b c s0 s' s2

$LL.L.c12 : ([4], [16], [8], [8], [16], [4]) -> [44]
$LL.L.c12 a c b s1 s2 s' =
      $L._unused13 a b c s' s1 s2

$L._unused15 : ([4], [16], [4], [8], [16]) -> [44]
$L._unused15 a c s0 s1 s2 =
      add (zext 16 a) c # s0 # s1 # s2

$L.b11 : ([4], [4], [8], [4], [8], [16]) -> [44]
$L.b11 i a b s0 s1 s2 =
      $L.c12 i a b s2 s0 s1 s2

$L._unused14 : ([4], [8], [16], [4], [8], [16]) -> [44]
$L._unused14 a b c s0 s1 s2 =
      $L._unused15 a c s0 s1 (add (zext 16 b) c)

$L.a10 : ([4], [4], [4], [8], [16]) -> [44]
$L.a10 i a s0 s1 $x =
      $L.b11 i a s1 s0 s1 $x

device top_level
      input __in0 : [4]
      output __out0 : [16]
      register __st0 : [4] init 4'h0
      register __st1 : [8] init 8'h3
      register __st2 : [16] init 16'h5
      let $res = $Pure.dispatch (__st0 # __st1 # __st2) __in0
      __out0 := $res[28 +: 16]
      next __st0 := $res[24 +: 4]
      next __st1 := $res[16 +: 8]
      next __st2 := $res[0 +: 16]