--| state dispatch for process main: 0=i 1=i3 2=i4 3=i5 4=i8
main.$dispatch : ([73], [17]) -> [88]
main.$dispatch disc i =
      if eq disc[70 +: 3] 3'h0 then main.i i disc[0 +: 70]
            else if eq disc[70 +: 3] 3'h1 then main.i3 i disc[0 +: 70] else if eq disc[70 +: 3] 3'h2 then main.i4 i disc[0 +: 70] else if eq disc[70 +: 3] 3'h3 then main.i5 i disc[0 +: 70] else main.i8 i disc[0 +: 70]

--| block '$L.s2' of process main
main.s2 : ([17], [70], [70]) -> [88]
main.s2 i s s0 =
      let $a = (let r0 = s[62 +: 8] in
      let r1 = s[54 +: 8] in
      let r2 = s[46 +: 8] in
      let r3 = s[38 +: 8] in
      let pc = s[32 +: 6] in
      let outputs = s[0 +: 15] in
      let $a = r0 # r1 # r2 # r3 # pc # i # outputs in
      $a) in
      main.getIns2 $a

