// Generated by rwc from device: top_level.
// rw_device maps a sequence of per-cycle inputs to per-cycle outputs.

module top_level where

// Helpers implementing ReWire Hyle primitive semantics.
rw'resize : {m, n} (fin m, fin n) => [n] -> [m]
rw'resize x = drop`{n} ((zero : [m]) # x)

rw'repl : {n, w} (fin n, fin w) => [w] -> [n * w]
rw'repl x = join (repeat`{n} x)

rw'parity : {n} (fin n) => [n] -> Bit
rw'parity x = foldr (^) False x

rw'sext : {m, n} (fin m, fin n, n >= 1) => [n] -> [m]
rw'sext x = if x @ 0 then ~ (rw'resize (~ x)) else rw'resize x

// $Pure.dispatch
rw__Pure_dispatch : [16] -> [24]
rw__Pure_dispatch x0 = rw__LL_Main_go3 s0 s1
  where
    s0 : [8]
    s0 = take`{8} x0
    s1 : [8]
    s1 = drop`{8} x0

// $LL.Main.go3
rw__LL_Main_go3 : [8] -> [8] -> [24]
rw__LL_Main_go3 x0 x1 = rw__LL_Main_go2 x0 x1

// $LL.Main.go2
rw__LL_Main_go2 : [8] -> [8] -> [24]
rw__LL_Main_go2 x0 x1 = rw__LL_Main_go1 (x0 + 0x01)

// $LL.Main.go1
rw__LL_Main_go1 : [8] -> [24]
rw__LL_Main_go1 x0 = rw_Main_go x0

// $LL.Main.go
rw__LL_Main_go : [8] -> [8] -> [24]
rw__LL_Main_go x0 x1 = x0 # (x0 # x1)

// Main.go
rw_Main_go : [8] -> [24]
rw_Main_go x0 = rw__LL_Main_go x0 x0

// Per-cycle step: outputs # next register values.
rw_step : [16] -> [24]
rw_step st = (take`{8} s3) # ((take`{8} (drop`{8} s3)) # (drop`{16} s3))
  where
    s0 : [8]
    s0 = take`{8} st
    s1 : [8]
    s1 = drop`{8} st
    s2 : [16]
    s2 = s0 # s1
    s3 : [24]
    s3 = rw__Pure_dispatch s2

// Device: top_level
// Inputs, MSB-first: (none)
// Outputs, MSB-first: __out0 : [8]
rw_device : {n} (fin n) => [n][0] -> [n][8]
rw_device ins = outs
  where
    rs : [n][24]
    rs = [rw_step st | st <- sts | _ <- ins]
    sts : [1 + n][16]
    sts = [0x0000] # [drop`{8} r | r <- rs]
    outs : [n][8]
    outs = [take`{8} r | r <- rs]