$Pure.dispatch : ([1]) -> [1]
$Pure.dispatch i =
      $L.$x3 i

$L.$x3 : ([1]) -> [1]
$L.$x3 $x =
      $L.Main.loop2 $x

$L.Main.loop2 : ([1]) -> [1]
$L.Main.loop2 i =
      $L.$x4 ($LL.L.Main.loop2 i)

$LL.L.Main.loop2 : ([1]) -> [1]
$LL.L.Main.loop2 s =
      if eq s 1'h1 then 1'h0
            else 1'h1

$L.$x4 : ([1]) -> [1]
$L.$x4 $x =
      $x

device top_level
      input __in0 : [1]
      output __out0 : [1]
      let $res = $Pure.dispatch __in0
      __out0 := $res