$Pure.dispatch : ([1]) -> [1]
$Pure.dispatch i =
      Main.loop i

$LL.Main.loop1 : ([1]) -> [1]
$LL.Main.loop1 rabind =
      rabind

Main.loop : ([1]) -> [1]
Main.loop i =
      $LL.Main.loop1 ($LL.Main.loop i)

$LL.Main.loop : ([1]) -> [1]
$LL.Main.loop s =
      if eq s 1'h1 then 1'h0
            else 1'h1

device top_level
      input __in0 : [1]
      output __out0 : [1]
      let $res = $Pure.dispatch __in0
      __out0 := $res