--| state dispatch for process main: 0=$x
main.$dispatch : ([1]) -> [1]
main.$dispatch i =
      main.$x i

--| block '$L.$x' of process main (state 0)
main.$x : ([1]) -> [1]
main.$x $x =
      main.loop $x

--| block '$L.$x2' of process main
main.$x2 : ([1]) -> [1]
main.$x2 $x =
      $x

--| block '$L.Main.loop' of process main
main.loop : ([1]) -> [1]
main.loop i =
      let $a = not i in
      main.$x2 $a

device top_level
      input __in0 : [1]
      output __out0 : [1]
      tag $x = 0
      let $res = main.$dispatch __in0
      __out0 := $res