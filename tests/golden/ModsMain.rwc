--| state dispatch for process main: 0=_unused2
main.$dispatch : ([1]) -> [1]
main.$dispatch i =
      main._unused2 i

--| block '$L._unused2' of process main (state 0)
main._unused2 : ([1]) -> [1]
main._unused2 _unused =
      1'h0

device top_level
      input __in0 : [1]
      output __out0 : [1]
      tag _unused2 = 0
      let $res = main.$dispatch __in0
      __out0 := $res