// Per-cycle step: outputs # next register values.
rw_step : [74] -> [17] -> [89]
rw_step st i = (take`{15} (drop`{1} s3)) # ((take`{4} (drop`{16} s3)) # (drop`{20} s3))
  where
    s0 : [4]
