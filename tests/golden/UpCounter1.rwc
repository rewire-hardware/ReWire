$Pure.dispatch : ([16]) -> [24]
$Pure.dispatch disc =
      let store0 = disc[8 +: 8] in
      let s0 = disc[0 +: 8] in
      $LL.Main.go3 store0 s0

$LL.Main.go3 : ([8], [8]) -> [24]
$LL.Main.go3 $x sto0 =
      $LL.Main.go $x sto0

$LL.Main.go2 : ([8], [8]) -> [24]
$LL.Main.go2 n sto0 =
      n # n # sto0

$LL.Main.go1 : ([8]) -> [24]
$LL.Main.go1 sto0 =
      Main.go sto0

$LL.Main.go : ([8], [8]) -> [24]
$LL.Main.go n sto0 =
      $LL.Main.go1 (add n 8'h1)

Main.go : ([8]) -> [24]
Main.go sto0 =
      $LL.Main.go2 sto0 sto0

device top_level
      output __out0 : [8]
      register __resumption_tag : [8] init 8'h0
      register __st0 : [8] init 8'h0
      let $in = __resumption_tag # __st0
      let $res = $Pure.dispatch $in
      __out0 := $res[16 +: 8]
      next __resumption_tag := $res[8 +: 8]
      next __st0 := $res[0 +: 8]