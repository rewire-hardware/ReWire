--| state dispatch for process main: 0=$x2
main.$dispatch : ([1]) -> [1]
main.$dispatch i =
      main.$x2 i

--| block '$L.$x2' of process main (state 0)
main.$x2 : ([1]) -> [1]
main.$x2 $x =
      main.iter$Bool$Bool$sMain_f $x

--| block '$L.ReWire.Monad.iter$Bool$Bool$sMain_f' of process main
main.iter$Bool$Bool$sMain_f : ([1]) -> [1]
main.iter$Bool$Bool$sMain_f i =
      let $a = Main.f i in
      $a

Main.f : ([1]) -> [1]
Main.f b =
      not b

device top_level
      input __in0 : [1]
      output __out0 : [1]
      tag $x2 = 0
      let $res = main.$dispatch __in0
      __out0 := $res