$Pure.dispatch : ([1]) -> [1]
$Pure.dispatch i =
      ReWire.Monad.iter i

ReWire.Monad.iter : ([1]) -> [1]
ReWire.Monad.iter i =
      Main.f1 i

Main.f1 : ([1]) -> [1]
Main.f1 b =
      if eq b 1'h1 then 1'h0
            else 1'h1

device top_level
      input __in0 : [1]
      output __out0 : [1]
      let $res = $Pure.dispatch __in0
      __out0 := $res