$Pure.dispatch : ([1]) -> [1]
$Pure.dispatch i =
      $L.$x4 i

$L.ReWire.Monad.iter$1$s23 : ([1]) -> [1]
$L.ReWire.Monad.iter$1$s23 i =
      $LL.L.ReWire.Monad.iter$1$s23 (Main.f i)

Main.f : ([1]) -> [1]
Main.f $x =
      $LL.Main.f $x

$LL.Main.f : ([1]) -> [1]
$LL.Main.f s =
      if eq s 1'h1 then 1'h0
            else 1'h1

$LL.L.ReWire.Monad.iter$1$s23 : ([1]) -> [1]
$LL.L.ReWire.Monad.iter$1$s23 $a =
      $a

$L.$x4 : ([1]) -> [1]
$L.$x4 $x =
      $L.ReWire.Monad.iter$1$s23 $x

device top_level
      input __in0 : [1]
      output __out0 : [1]
      let $res = $Pure.dispatch __in0
      __out0 := $res