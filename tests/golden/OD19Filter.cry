// Per-cycle step: outputs # next register values.
rw_step : [39] -> [33] -> [41]
rw_step st i = (take`{1} s4) # ((take`{1} (drop`{1} s4)) # ((take`{7} (drop`{2} s4)) # (drop`{9} s4)))
  where
    s0 : [7]
    s0 = take`{7} st
    s1 : [32]
    s1 = drop`{7} st
    s2 : [1]
    s2 = take`{1} i
    s3 : [32]
    s3 = drop`{1} i
    s4 : [41]
    s4 = rw_main__dispatch (s0 # s1) (s2 # s3)

// Device: top_level
// Inputs, MSB-first: __in0 : [1], __in1 : [32]
// Outputs, MSB-first: __out0 : [1], __out1 : [1]
rw_device : {n} (fin n) => [n][33] -> [n][2]
rw_device ins = outs
  where
    rs : [n][41]
    rs = [rw_step st i | st <- sts | i <- ins]
    sts : [1 + n][39]
    sts = [0b000000000000000000000000000000000000000] # [drop`{2} r | r <- rs]
    outs : [n][2]
    outs = [take`{2} r | r <- rs]