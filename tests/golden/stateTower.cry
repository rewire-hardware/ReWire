// Generated by rwc from device: top_level.
// rw_device maps a sequence of per-cycle inputs to per-cycle outputs.

module top_level where

// Helpers implementing ReWire Hyle primitive semantics.
rw'resize : {m, n} (fin m, fin n) => [n] -> [m]
rw'resize x = drop`{n} ((zero : [m]) # x)

rw'repl : {n, w} (fin n, fin w) => [w] -> [n * w]
rw'repl x = join (repeat`{n} x)

rw'parity : {n} (fin n) => [n] -> Bit
rw'parity x = foldr (^) False x

rw'sext : {m, n} (fin m, fin n, n >= 1) => [n] -> [m]
rw'sext x = if x @ 0 then ~ (rw'resize (~ x)) else rw'resize x

// main.$dispatch
rw_main__dispatch : [2] -> [1] -> [3]
rw_main__dispatch x0 x1 = rw_main__x2 x1 (take`{1} x0) (drop`{1} x0)

// main.$x2
rw_main__x2 : [1] -> [1] -> [1] -> [3]
rw_main__x2 x0 x1 x2 = rw_main_sig x0 x1 x2

// main.r02
rw_main_r02 : [1] -> [1] -> [1] -> [3]
rw_main_r02 x0 x1 x2 = x0 # (x1 # x2)

// main._unused
rw_main__unused : [1] -> [1] -> [3]
rw_main__unused x0 x1 = rw_main_r02 x0 x0 x1

// main._unused2
rw_main__unused2 : [1] -> [1] -> [1] -> [1] -> [3]
rw_main__unused2 x0 x1 x2 x3 = rw_main__unused x2 s1
  where
    s0 : [1]
    s0 = x0 ^ x1
    s1 : [1]
    s1 = s0

// main.r1
rw_main_r1 : [1] -> [1] -> [1] -> [1] -> [3]
rw_main_r1 x0 x1 x2 x3 = rw_main__unused2 x0 x1 x1 x3

// main.r03
rw_main_r03 : [1] -> [1] -> [1] -> [3]
rw_main_r03 x0 x1 x2 = rw_main_r1 x0 x2 x1 x2

// main.incr
rw_main_incr : [1] -> [1] -> [3]
rw_main_incr x0 x1 = rw_main_r03 x0 x0 x1

// main.sig
rw_main_sig : [1] -> [1] -> [1] -> [3]
rw_main_sig x0 x1 x2 = if ~ (s0 @ 0) then (rw_main__unused x1 x2) else (rw_main_incr x1 x2)
  where
    s0 : [1]
    s0 = ~ x0

// Per-cycle step: outputs # next register values.
rw_step : [2] -> [1] -> [3]
rw_step st i = (take`{1} s3) # ((take`{1} (drop`{1} s3)) # (drop`{2} s3))
  where
    s0 : [1]
    s0 = take`{1} st
    s1 : [1]
    s1 = drop`{1} st
    s2 : [1]
    s2 = i
    s3 : [3]
    s3 = rw_main__dispatch (s0 # s1) s2

// Device: top_level
// Inputs, MSB-first: __in0 : [1]
// Outputs, MSB-first: __out0 : [1]
rw_device : {n} (fin n) => [n][1] -> [n][1]
rw_device ins = outs
  where
    rs : [n][3]
    rs = [rw_step st i | st <- sts | i <- ins]
    sts : [1 + n][2]
    sts = [0b11] # [drop`{1} r | r <- rs]
    outs : [n][1]
    outs = [take`{1} r | r <- rs]