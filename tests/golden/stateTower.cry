// Generated by rwc from device: top_level.
// rw_device maps a sequence of per-cycle inputs to per-cycle outputs.

module top_level where

// Helpers implementing ReWire Hyle primitive semantics.
rw'resize : {m, n} (fin m, fin n) => [n] -> [m]
rw'resize x = drop`{n} ((zero : [m]) # x)

rw'repl : {n, w} (fin n, fin w) => [w] -> [n * w]
rw'repl x = join (repeat`{n} x)

rw'parity : {n} (fin n) => [n] -> Bit
rw'parity x = foldr (^) False x

rw'sext : {m, n} (fin m, fin n, n >= 1) => [n] -> [m]
rw'sext x = if x @ 0 then ~ (rw'resize (~ x)) else rw'resize x

// $Pure.dispatch
rw__Pure_dispatch : [2] -> [1] -> [3]
rw__Pure_dispatch x0 x1 = rw_Main_sig x1 s0 s1
  where
    s0 : [1]
    s0 = take`{1} x0
    s1 : [1]
    s1 = drop`{1} x0

// $LL.Main.sig5
rw__LL_Main_sig5 : [1] -> [1] -> [1] -> [3]
rw__LL_Main_sig5 x0 x1 x2 = rw__LL_Main_sig1 x0 x2 x1 x2

// $LL.Main.incr1
rw__LL_Main_incr1 : [1] -> [1] -> [1]
rw__LL_Main_incr1 x0 x1 = s0
  where
    s0 : [1]
    s0 = x0 ^ x1

// $LL.Main.sig4
rw__LL_Main_sig4 : [1] -> [1] -> [3]
rw__LL_Main_sig4 x0 x1 = rw__LL_Main_sig3 x0 x0 x1

// Main.sig
rw_Main_sig : [1] -> [1] -> [1] -> [3]
rw_Main_sig x0 x1 x2 = if s0 == 0b0 then (rw__LL_Main_sig4 x1 x2) else (rw__LL_Main_sig5 x1 x1 x2)
  where
    s0 : [1]
    s0 = rw__LL_Main_sig2 x0

// $LL.Main.sig3
rw__LL_Main_sig3 : [1] -> [1] -> [1] -> [3]
rw__LL_Main_sig3 x0 x1 x2 = x0 # (x1 # x2)

// $LL.Main.sig2
rw__LL_Main_sig2 : [1] -> [1]
rw__LL_Main_sig2 x0 = if x0 == 0b1 then 0b0 else 0b1

// $LL.Main.incr
rw__LL_Main_incr : [1] -> [1] -> [1]
rw__LL_Main_incr x0 x1 = rw__LL_Main_incr1 x0 x1

// $LL.Main.sig1
rw__LL_Main_sig1 : [1] -> [1] -> [1] -> [1] -> [3]
rw__LL_Main_sig1 x0 x1 x2 x3 = rw__LL_Main_sig x0 x1 x1 x3

// $LL.Main.sig
rw__LL_Main_sig : [1] -> [1] -> [1] -> [1] -> [3]
rw__LL_Main_sig x0 x1 x2 x3 = rw__LL_Main_sig4 x2 (rw__LL_Main_incr x0 x1)

// Per-cycle step: outputs # next register values.
rw_step : [2] -> [1] -> [3]
rw_step st i = (take`{1} s3) # ((take`{1} (drop`{1} s3)) # (drop`{2} s3))
  where
    s0 : [1]
    s0 = take`{1} st
    s1 : [1]
    s1 = drop`{1} st
    s2 : [1]
    s2 = i
    s3 : [3]
    s3 = rw__Pure_dispatch (s0 # s1) s2

// Device: top_level
// Inputs, MSB-first: __in0 : [1]
// Outputs, MSB-first: __out0 : [1]
rw_device : {n} (fin n) => [n][1] -> [n][1]
rw_device ins = outs
  where
    rs : [n][3]
    rs = [rw_step st i | st <- sts | i <- ins]
    sts : [1 + n][2]
    sts = [0b11] # [drop`{1} r | r <- rs]
    outs : [n][1]
    outs = [take`{1} r | r <- rs]