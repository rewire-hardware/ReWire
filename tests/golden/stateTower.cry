// Generated by rwc from device: top_level.
// rw_device maps a sequence of per-cycle inputs to per-cycle outputs.

module top_level where

// Helpers implementing ReWire Hyle primitive semantics.
rw'resize : {m, n} (fin m, fin n) => [n] -> [m]
rw'resize x = drop`{n} ((zero : [m]) # x)

rw'repl : {n, w} (fin n, fin w) => [w] -> [n * w]
rw'repl x = join (repeat`{n} x)

rw'parity : {n} (fin n) => [n] -> Bit
rw'parity x = foldr (^) False x

rw'sext : {m, n} (fin m, fin n, n >= 1) => [n] -> [m]
rw'sext x = if x @ 0 then ~ (rw'resize (~ x)) else rw'resize x

// $Pure.dispatch
rw__Pure_dispatch : [2] -> [1] -> [3]
rw__Pure_dispatch x0 x1 = rw__L__x6 x1 s0 s1
  where
    s0 : [1]
    s0 = take`{1} x0
    s1 : [1]
    s1 = drop`{1} x0

// $L.Main.sig4
rw__L_Main_sig4 : [1] -> [1] -> [1] -> [3]
rw__L_Main_sig4 x0 x1 x2 = rw__LL_L_Main_sig41 x2 x1 (rw__LL_L_Main_sig4 x0)

// $LL.L.r110
rw__LL_L_r110 : [1] -> [1] -> [1] -> [1] -> [3]
rw__LL_L_r110 x0 x1 x2 x3 = rw__L__unused11 x2 x1 x3 x0

// $L._unused11
rw__L__unused11 : [1] -> [1] -> [1] -> [1] -> [3]
rw__L__unused11 x0 x1 x2 x3 = rw__L__unused7 x2 s0
  where
    s0 : [1]
    s0 = x0 ^ x1

// $L.r09
rw__L_r09 : [1] -> [1] -> [1] -> [3]
rw__L_r09 x0 x1 x2 = rw__L_r110 x0 x2 x1 x2

// $L.r110
rw__L_r110 : [1] -> [1] -> [1] -> [1] -> [3]
rw__L_r110 x0 x1 x2 x3 = rw__LL_L_r110 x3 x1 x0 x1

// $LL.L.Main.sig41
rw__LL_L_Main_sig41 : [1] -> [1] -> [1] -> [3]
rw__LL_L_Main_sig41 x0 x1 x2 = if x2 == 0b0 then (rw__L__unused7 x1 x0) else (rw__L_Main_incr8 x1 x0)

// $L.$x6
rw__L__x6 : [1] -> [1] -> [1] -> [3]
rw__L__x6 x0 x1 x2 = rw__L_Main_sig4 x0 x1 x2

// $L.Main.incr8
rw__L_Main_incr8 : [1] -> [1] -> [3]
rw__L_Main_incr8 x0 x1 = rw__L_r09 x0 x0 x1

// $L.r05
rw__L_r05 : [1] -> [1] -> [1] -> [3]
rw__L_r05 x0 x1 x2 = x0 # (x1 # x2)

// $LL.L.Main.sig4
rw__LL_L_Main_sig4 : [1] -> [1]
rw__LL_L_Main_sig4 x0 = if x0 == 0b1 then 0b0 else 0b1

// $L._unused7
rw__L__unused7 : [1] -> [1] -> [3]
rw__L__unused7 x0 x1 = rw__L_r05 x0 x0 x1

// Per-cycle step: outputs # next register values.
rw_step : [2] -> [1] -> [3]
rw_step st i = (take`{1} s3) # ((take`{1} (drop`{1} s3)) # (drop`{2} s3))
  where
    s0 : [1]
    s0 = take`{1} st
    s1 : [1]
    s1 = drop`{1} st
    s2 : [1]
    s2 = i
    s3 : [3]
    s3 = rw__Pure_dispatch (s0 # s1) s2

// Device: top_level
// Inputs, MSB-first: __in0 : [1]
// Outputs, MSB-first: __out0 : [1]
rw_device : {n} (fin n) => [n][1] -> [n][1]
rw_device ins = outs
  where
    rs : [n][3]
    rs = [rw_step st i | st <- sts | i <- ins]
    sts : [1 + n][2]
    sts = [0b11] # [drop`{1} r | r <- rs]
    outs : [n][1]
    outs = [take`{1} r | r <- rs]