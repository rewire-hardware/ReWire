// main.iter$W8$W6$sMain_compute
rw_main_iter_W8_W6_sMain_compute : [8] -> [6]
rw_main_iter_W8_W6_sMain_compute x0 = s0
  where
    s0 : [6]
    s0 = rw_Main_compute x0

// Main.compute
rw_Main_compute : [8] -> [6]
rw_Main_compute x0 = [x0 == (~ zero)] # ((~ [x0 == (~ zero)]) # ([x0 != zero] # ((~ [x0 != zero]) # ([rw'parity x0] # (~ [rw'parity x0])))))

// Per-cycle step: outputs # next register values.
rw_step : [8] -> [6]
rw_step i = s1
  where
    s0 : [8]
    s0 = i
    s1 : [6]
    s1 = rw_main__dispatch s0

// Device: top_level
// Inputs, MSB-first: __in0 : [8]
// Outputs, MSB-first: __out0 : [6]
rw_device : {n} (fin n) => [n][8] -> [n][6]
rw_device ins = [rw_step i | i <- ins]