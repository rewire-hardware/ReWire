$Pure.dispatch : ([8]) -> [6]
$Pure.dispatch i =
      ReWire.Monad.iter1 i

Main.compute1 : ([8]) -> [6]
Main.compute1 w =
      redand w # not (redand w) # redor w # not (redor w) # redxor w # not (redxor w)

ReWire.Monad.iter1 : ([8]) -> [6]
ReWire.Monad.iter1 i =
      Main.compute1 i

device top_level
      input __in0 : [8]
      output __out0 : [6]
      let $res = $Pure.dispatch __in0
      __out0 := $res