$Pure.dispatch : ([8]) -> [6]
$Pure.dispatch i =
      ReWire.Monad.iter$1$s2 i

Main.compute : ([8]) -> [6]
Main.compute w =
      redand w # not (redand w) # redor w # not (redor w) # redxor w # not (redxor w)

ReWire.Monad.iter$1$s2 : ([8]) -> [6]
ReWire.Monad.iter$1$s2 i =
      Main.compute i

device top_level
      input __in0 : [8]
      output __out0 : [6]
      let $res = $Pure.dispatch __in0
      __out0 := $res