$Pure.dispatch : ([8]) -> [6]
$Pure.dispatch i =
      ReWire.Monad.iter i

Main.compute1 : ([8]) -> [6]
Main.compute1 $x =
      $LL.Main.compute1 $x

$LL.Main.compute1 : ([8]) -> [6]
$LL.Main.compute1 $1 =
      redand $1 # not (redand $1) # redor $1 # not (redor $1) # redxor $1 # not (redxor $1)

ReWire.Monad.iter : ([8]) -> [6]
ReWire.Monad.iter $1 =
      Main.compute1 $1

device top_level
      input __in0 : [8]
      output __out0 : [6]
      let $res = $Pure.dispatch __in0
      __out0 := $res