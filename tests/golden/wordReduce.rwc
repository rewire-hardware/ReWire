$Pure.dispatch : ([8]) -> [6]
$Pure.dispatch i =
      $LL.Pure.dispatch i

$LL.Main.compute3 : ([8]) -> [6]
$LL.Main.compute3 $x =
      $LL.Main.compute2 $x

Main.compute1 : ([8]) -> [6]
Main.compute1 $x =
      $LL.Main.compute3 $x

$LL.Main.compute2 : ([8]) -> [6]
$LL.Main.compute2 w =
      redand w # not (redand w) # redor w # not (redor w) # redxor w # not (redxor w)

ReWire.Monad.iter1 : ([8]) -> [6]
ReWire.Monad.iter1 $1 =
      Main.compute1 $1

$LL.Pure.dispatch : ([8]) -> [6]
$LL.Pure.dispatch i =
      ReWire.Monad.iter1 i

device top_level
      input __in0 : [8]
      output __out0 : [6]
      let $res = $Pure.dispatch __in0
      __out0 := $res