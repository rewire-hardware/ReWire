--| state dispatch for process main: 0=_unused3 1=_unused
main.$dispatch : ([3], [1]) -> [4]
main.$dispatch disc i =
      if not disc[2 +: 1] then main._unused3 disc[1 +: 1] i disc[0 +: 1]
            else main._unused i disc[0 +: 1]

--| block '$L._unused3' of process main (state 0)
main._unused3 : ([1], [1], [1]) -> [4]
main._unused3 b _unused s0 =
      main.convtest b b

--| block '$L.Main.convtest' of process main
main.convtest : ([1], [1]) -> [4]
main.convtest b s0 =
      b # 1'h0 # b # s0

--| block '$L._unused' of process main (state 1)
main._unused : ([1], [1]) -> [4]
main._unused _unused s0 =
      4'h0

device top_level
      input __in0 : [1]
      output __out0 : [1]
      register __resumption_tag : [2] init 2'h2
      register __st0 : [1] init 1'h0
      tag _unused3 = 0
      tag _unused = 1
      let $res = main.$dispatch (__resumption_tag # __st0) __in0
      __out0 := $res[3 +: 1]
      next __resumption_tag := $res[1 +: 2]
      next __st0 := $res[0 +: 1]