$Pure.dispatch : ([2], [1]) -> [3]
$Pure.dispatch disc i =
      let store0 = disc[1 +: 1] in
      let s0 = disc[0 +: 1] in
      $LL.Main.convtest1 store0 i s0

$LL.Main.convtest4 : ([1], [1], [1]) -> [3]
$LL.Main.convtest4 b $6 sto0 =
      $LL.Main.convtest3 b b

$LL.Main.convtest3 : ([1], [1]) -> [3]
$LL.Main.convtest3 $x sto0 =
      $LL.Main.convtest2 $x sto0

$LL.Main.convtest2 : ([1], [1]) -> [3]
$LL.Main.convtest2 b sto0 =
      Main.convtest b sto0

$LL.Main.convtest1 : ([1], [1], [1]) -> [3]
$LL.Main.convtest1 $x $x1 sto0 =
      $LL.Main.convtest4 $x $x1 sto0

$LL.Main.convtest : ([1], [1]) -> [3]
$LL.Main.convtest $7 sto0 =
      $7 # $7 # sto0

Main.convtest : ([1], [1]) -> [3]
Main.convtest $x sto0 =
      $LL.Main.convtest $x sto0

device top_level
      input __in0 : [1]
      output __out0 : [1]
      register __resumption_tag : [1] init 1'h0
      register __st0 : [1] init 1'h0
      let $res = $Pure.dispatch (__resumption_tag # __st0) __in0
      __out0 := $res[2 +: 1]
      next __resumption_tag := $res[1 +: 1]
      next __st0 := $res[0 +: 1]