main.$dispatch : ([8], [1]) -> [16]
main.$dispatch disc i =
      main.$L.b2$271 i disc

main.$L.n4$273 : ([8], [8]) -> [16]
main.$L.n4$273 n s0 =
      let $a = Main.incW8 n in
      main.$L.Main.go1$270 $a

main.$L.arm5$275 : ([8]) -> [16]
main.$L.arm5$275 s0 =
      main.$L.n4$273 s0 s0

main.$L.n6$276 : ([8], [8]) -> [16]
main.$L.n6$276 n s0 =
      let $a = Main.rolW8 n in
      main.$L.Main.go1$270 $a

main.$L.arm7$278 : ([8]) -> [16]
main.$L.arm7$278 s0 =
      main.$L.n6$276 s0 s0

main.$L.b2$271 : ([1], [8]) -> [16]
main.$L.b2$271 b s0 =
      if eq b 1'h0 then main.$L.arm5$275 s0
            else main.$L.arm7$278 s0

main.$L.$x8$280 : ([8], [8]) -> [16]
main.$L.$x8$280 $x s0 =
      $x # s0

main.$L.Main.go1$270 : ([8]) -> [16]
main.$L.Main.go1$270 s0 =
      main.$L.$x8$280 s0 s0

Main.incW8 : ([8]) -> [8]
Main.incW8 n =
      add n 8'h1

Main.msbitW8 : ([8]) -> [8]
Main.msbitW8 n =
      zext 8 n[7 +: 1]

Main.rolW8 : ([8]) -> [8]
Main.rolW8 n =
      or (shl n 8'h1) (Main.msbitW8 n)

device top_level
      input __in0 : [1]
      output __out0 : [8]
      register __st0 : [8] init 8'h0
      let $res = main.$dispatch __st0 __in0
      __out0 := $res[8 +: 8]
      next __st0 := $res[0 +: 8]