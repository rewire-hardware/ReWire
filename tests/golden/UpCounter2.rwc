$Pure.dispatch : ([8], [1]) -> [16]
$Pure.dispatch disc i =
      $L.b2 i disc

$L.$x8 : ([8], [8]) -> [16]
$L.$x8 $x s0 =
      $x # s0

$L.b2 : ([1], [8]) -> [16]
$L.b2 b s0 =
      if eq b 1'h0 then $L.arm5 s0
            else $L.arm7 s0

$L.Main.go1 : ([8]) -> [16]
$L.Main.go1 s0 =
      $L.$x8 s0 s0

$L.n6 : ([8], [8]) -> [16]
$L.n6 n s0 =
      $L.Main.go1 (Main.rolW8 n)

Main.rolW8 : ([8]) -> [8]
Main.rolW8 n =
      or (shl n 8'h1) (Main.msbitW8 n)

Main.incW8 : ([8]) -> [8]
Main.incW8 n =
      add n 8'h1

$L.arm5 : ([8]) -> [16]
$L.arm5 s0 =
      $L.n4 s0 s0

$L.arm7 : ([8]) -> [16]
$L.arm7 s0 =
      $L.n6 s0 s0

$L.n4 : ([8], [8]) -> [16]
$L.n4 n s0 =
      $L.Main.go1 (Main.incW8 n)

Main.msbitW8 : ([8]) -> [8]
Main.msbitW8 n =
      zext 8 n[7 +: 1]

device top_level
      input __in0 : [1]
      output __out0 : [8]
      register __st0 : [8] init 8'h0
      let $res = $Pure.dispatch __st0 __in0
      __out0 := $res[8 +: 8]
      next __st0 := $res[0 +: 8]