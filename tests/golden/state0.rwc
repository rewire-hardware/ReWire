            else if eq disc[3 +: 3] 3'h1 then main.$L._unused5$240 disc[0 +: 3] i else if eq disc[3 +: 3] 3'h2 then main.$L._unused6$241 disc[0 +: 3] i else if eq disc[3 +: 3] 3'h3 then main.$L._unused7$242 i else main.$L._unused8$243 i

main.$L.$x4$239 : ([3]) -> [10]
main.$L.$x4$239 $x =
