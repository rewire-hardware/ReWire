$Pure.dispatch : ([6], [3]) -> [10]
$Pure.dispatch disc i =
      if eq disc[3 +: 3] 3'h0 then $L.$x4 i
            else if eq disc[3 +: 3] 3'h1 then (let e = disc[0 +: 3] in
            $L._unused5 e i) else if eq disc[3 +: 3] 3'h2 then (let e = disc[0 +: 3] in
            $L._unused6 e i) else if eq disc[3 +: 3] 3'h3 then $L._unused7 i else $L._unused8 i

$LL.L._unused5 : ([4]) -> [10]
$LL.L._unused5 $a =
      $a # 6'h0

$L._unused5 : ([3], [3]) -> [10]
$L._unused5 i _unused =
      $LL.L._unused5 (1'h1 # i)

$L._unused6 : ([3], [3]) -> [10]
$L._unused6 i _unused =
      7'h1 # i

$L._unused8 : ([3]) -> [10]
$L._unused8 _unused =
      10'h18

$L.Main.dev3 : ([3]) -> [10]
$L.Main.dev3 i =
      7'h2 # i

$L._unused7 : ([3]) -> [10]
$L._unused7 _unused =
      10'h200

$L.$x4 : ([3]) -> [10]
$L.$x4 $x =
      $L.Main.dev3 $x

device top_level
      input __in0 : [3]
      output __out0 : [1]
      output __out1 : [3]
      register __resumption_tag : [6] init 6'h20
      let $res = $Pure.dispatch __resumption_tag __in0
      __out0 := $res[9 +: 1]
      __out1 := $res[6 +: 3]
      next __resumption_tag := $res[0 +: 6]