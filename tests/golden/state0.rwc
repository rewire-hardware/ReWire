$Pure.dispatch : ([6], [3]) -> [10]
$Pure.dispatch disc i =
      if eq disc[3 +: 3] 3'h1 then Main.dev1 i
            else if eq disc[3 +: 3] 3'h2 then (let store0 = disc[0 +: 3] in
            $LL.Main.dev2 store0 i) else if eq disc[3 +: 3] 3'h3 then $LL.Main.dev1 i else if eq disc[3 +: 3] 3'h4 then (let store0 = disc[0 +: 3] in
            $LL.Main.dev store0 i) else $LL.Main.dev3 i

$LL.Main.dev3 : ([3]) -> [10]
$LL.Main.dev3 rabind =
      10'h208

Main.dev1 : ([3]) -> [10]
Main.dev1 i =
      7'h4 # i

$LL.Main.dev2 : ([3], [3]) -> [10]
$LL.Main.dev2 i rabind =
      1'h1 # i # 6'h8

$LL.Main.dev1 : ([3]) -> [10]
$LL.Main.dev1 rabind =
      10'h0

$LL.Main.dev : ([3], [3]) -> [10]
$LL.Main.dev i rabind =
      7'h2 # i

device top_level
      input __in0 : [3]
      output __out0 : [1]
      output __out1 : [3]
      register __resumption_tag : [6] init 6'h18
      let $res = $Pure.dispatch __resumption_tag __in0
      __out0 := $res[9 +: 1]
      __out1 := $res[6 +: 3]
      next __resumption_tag := $res[0 +: 6]