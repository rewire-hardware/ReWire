$Pure.dispatch : ([5], [3]) -> [9]
$Pure.dispatch disc i =
      if eq disc[3 +: 2] 2'h1 then (let store0 = disc[0 +: 3] in
            $LL.Main.dev1 store0 i)
            else if eq disc[3 +: 2] 2'h2 then (let store0 = disc[0 +: 3] in
            $LL.Main.dev store0 i) else Main.dev1 i

$LL.Main.dev2 : ([3]) -> [9]
$LL.Main.dev2 $1 =
      6'h2 # $1

Main.dev1 : ([3]) -> [9]
Main.dev1 $x =
      $LL.Main.dev2 $x

$LL.Main.dev1 : ([3], [3]) -> [9]
$LL.Main.dev1 $1 $65 =
      1'h1 # $1 # 5'h0

$LL.Main.dev : ([3], [3]) -> [9]
$LL.Main.dev $1 $65 =
      6'h1 # $1

device top_level
      input __in0 : [3]
      output __out0 : [1]
      output __out1 : [3]
      register __resumption_tag : [5] init 5'h10
      let $res = $Pure.dispatch __resumption_tag __in0
      __out0 := $res[8 +: 1]
      __out1 := $res[5 +: 3]
      next __resumption_tag := $res[0 +: 5]