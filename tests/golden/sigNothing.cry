// rw_device maps a sequence of per-cycle inputs to per-cycle outputs.

module top_level where

// Helpers implementing ReWire Hyle primitive semantics.
rw'resize : {m, n} (fin m, fin n) => [n] -> [m]
rw'resize x = drop`{n} ((zero : [m]) # x)

rw'repl : {n, w} (fin n, fin w) => [w] -> [n * w]
rw'repl x = join (repeat`{n} x)

rw'parity : {n} (fin n) => [n] -> Bit
rw'parity x = foldr (^) False x

rw'sext : {m, n} (fin m, fin n, n >= 1) => [n] -> [m]
rw'sext x = if x @ 0 then ~ (rw'resize (~ x)) else rw'resize x

// main.$dispatch
rw_main__dispatch : [8] -> [8] -> [17]
rw_main__dispatch x0 x1 = rw_main__L_ds2_228 x1 x0

// main.$L.ds2$228
rw_main__L_ds2_228 : [8] -> [8] -> [17]
rw_main__L_ds2_228 x0 x1 = rw_main__L_Main_start_1_227 x1

// main.$L.Main.start'1$227
rw_main__L_Main_start_1_227 : [8] -> [17]
rw_main__L_Main_start_1_227 x0 = 0b000000000 # x0

// Per-cycle step: outputs # next register values.
rw_step : [8] -> [8] -> [17]
rw_step st i = (take`{1} s2) # ((take`{8} (drop`{1} s2)) # (drop`{9} s2))
  where
    s0 : [8]
    s0 = st
    s1 : [8]
    s1 = i
    s2 : [17]
    s2 = rw_main__dispatch s0 s1

// Device: top_level
// Inputs, MSB-first: __in0 : [8]
// Outputs, MSB-first: __out0 : [1], __out1 : [8]
rw_device : {n} (fin n) => [n][8] -> [n][9]
rw_device ins = outs
  where
    rs : [n][17]
    rs = [rw_step st i | st <- sts | i <- ins]
    sts : [1 + n][8]
    sts = [0x00] # [drop`{9} r | r <- rs]
    outs : [n][9]
    outs = [take`{9} r | r <- rs]