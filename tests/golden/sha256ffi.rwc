--| block '$L.ReWire.Monad.iter$W512$W256$sMain_sha256Block' of process main
main.iter$W512$W256$sMain_sha256Block : ([512]) -> [256]
main.iter$W512$W256$sMain_sha256Block i =
      let $a = Main.sha256Block i in
      $a

