main.$dispatch : ([8], [1]) -> [16]
main.$dispatch disc i =
      main.$L.b2$238 i disc

main.$L.b2$238 : ([1], [8]) -> [16]
main.$L.b2$238 b s0 =
      if eq b 1'h0 then main.$L.Main.tick3$239 s0
            else main.$L.Main.tick3$239 s0

main.$L.$x4$241 : ([8], [8]) -> [16]
main.$L.$x4$241 $x s0 =
      $x # s0

main.$L.Main.tick3$239 : ([8]) -> [16]
main.$L.Main.tick3$239 s0 =
      main.$L.$x4$241 s0 s0

device top_level
      input __in0 : [1]
      output __out0 : [8]
      register __st0 : [8] init 8'h0
