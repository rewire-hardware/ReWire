$Pure.dispatch : ([8], [1]) -> [16]
$Pure.dispatch disc i =
      $LL.Main.go i disc

$LL.Main.go1 : ([8], [8]) -> [16]
$LL.Main.go1 rabind sto0 =
      rabind # sto0

$LL.Main.go : ([1], [8]) -> [16]
$LL.Main.go wild sto0 =
      if eq wild 1'h0 then Main.go sto0
            else Main.go sto0

Main.go : ([8]) -> [16]
Main.go sto0 =
      $LL.Main.go1 sto0 sto0

device top_level
      input __in0 : [1]
      output __out0 : [8]
      register __st0 : [8] init 8'h0
      let $res = $Pure.dispatch __st0 __in0
      __out0 := $res[8 +: 8]
      next __st0 := $res[0 +: 8]