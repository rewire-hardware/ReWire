$Pure.dispatch : ([8], [1]) -> [16]
$Pure.dispatch disc i =
      $LL.Main.go3 i disc

$LL.Main.go3 : ([1], [8]) -> [16]
$LL.Main.go3 b sto0 =
      $LL.Main.go b b sto0

$LL.Main.go2 : ([8], [8]) -> [16]
$LL.Main.go2 rabind sto0 =
      rabind # sto0

$LL.Main.go1 : ([1], [8]) -> [16]
$LL.Main.go1 $1 sto0 =
      Main.go sto0

Main.go : ([8]) -> [16]
Main.go sto0 =
      $LL.Main.go2 sto0 sto0

$LL.Main.go : ([1], [1], [8]) -> [16]
$LL.Main.go b $2 sto0 =
      if eq $2 1'h1 then Main.go sto0
            else $LL.Main.go1 b sto0

device top_level
      input __in0 : [1]
      output __out0 : [8]
      register __st0 : [8] init 8'h0
      let $res = $Pure.dispatch __st0 __in0
      __out0 := $res[8 +: 8]
      next __st0 := $res[0 +: 8]