$Pure.dispatch : ([8], [1]) -> [16]
$Pure.dispatch disc i =
      $L.b2 i disc

$L.b2 : ([1], [8]) -> [16]
$L.b2 b s0 =
      if eq b 1'h0 then $L.Main.tick3 s0
            else $L.Main.tick3 s0

$L.Main.tick3 : ([8]) -> [16]
$L.Main.tick3 s0 =
      $L.$x4 s0 s0

$L.$x4 : ([8], [8]) -> [16]
$L.$x4 $x s0 =
      $x # s0

device top_level
      input __in0 : [1]
      output __out0 : [8]
      register __st0 : [8] init 8'h0
      let $res = $Pure.dispatch __st0 __in0
      __out0 := $res[8 +: 8]
      next __st0 := $res[0 +: 8]