$Pure.dispatch : ([10], [8]) -> [18]
$Pure.dispatch disc i =
      if eq disc[8 +: 2] 2'h1 then (let s0 = disc[0 +: 8] in
            $LL.Main.loop1 i s0)
            else if eq disc[8 +: 2] 2'h2 then (let s0 = disc[0 +: 8] in
            $LL.Main.reset i s0) else let s0 = disc[0 +: 8] in
            $LL.Main.loop1 i s0

$LL.Main.loop5 : ([8]) -> [18]
$LL.Main.loop5 sto0 =
      Main.loop sto0

$LL.Main.loop4 : ([8]) -> [1]
$LL.Main.loop4 $36 =
      ReWire.Prelude.not (let $t0 = trunc 1 $36 in
      $t0)

$LL.Main.loop3 : ([8], [8]) -> [18]
$LL.Main.loop3 i sto0 =
      let $t1 = $LL.Main.loop4 i in
      if eq $t1 1'h1 then 10'h9 # sto0
            else 10'h8 # sto0

$LL.ReWire.Prelude.not1 : ([1], [1]) -> [1]
$LL.ReWire.Prelude.not1 $14 $56 =
      if eq $56 1'h1 then 1'h0
            else $LL.ReWire.Prelude.not $14

ReWire.Prelude.not : ([1]) -> [1]
ReWire.Prelude.not $14 =
      $LL.ReWire.Prelude.not1 $14 $14

Main.loop : ([8]) -> [18]
Main.loop sto0 =
      $LL.Main.loop3 sto0 sto0

$LL.Main.loop1 : ([8], [8]) -> [18]
$LL.Main.loop1 rabind sto0 =
      $LL.Main.loop5 sto0

$LL.ReWire.Prelude.not : ([1]) -> [1]
$LL.ReWire.Prelude.not $55 =
      1'h1

$LL.Main.reset : ([8], [8]) -> [18]
$LL.Main.reset rabind sto0 =
      $LL.Main.loop5 rabind

device top_level
      input __in0 : [8]
      output __out0 : [8]
      register __resumption_tag : [2] init 2'h2
      register __st0 : [8] init 8'h0
      let $res = $Pure.dispatch (__resumption_tag # __st0) __in0
      __out0 := $res[10 +: 8]
      next __resumption_tag := $res[8 +: 2]
      next __st0 := $res[0 +: 8]