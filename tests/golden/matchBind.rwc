$Pure.dispatch : ([9], [8]) -> [17]
$Pure.dispatch disc i =
      if eq disc[8 +: 1] 1'h0 then (let s = disc[0 +: 8] in
            $L.ds8 i s)
            else let s = disc[0 +: 8] in
            $L.i11 i s

$L.Main.loop4 : ([8]) -> [17]
$L.Main.loop4 s0 =
      $L.i5 s0 s0

$LL.L.i52 : ([1]) -> [1]
$LL.L.i52 s =
      if eq s 1'h1 then 1'h0
            else 1'h1

$L.i11 : ([8], [8]) -> [17]
$L.i11 i s0 =
      $L.Main.loop4 i

$LL.L.i51 : ([8], [1]) -> [17]
$LL.L.i51 s0 $a =
      if eq $a 1'h0 then $L.Main.incr7 s0
            else $L.Main.incr7 s0

$L.i5 : ([8], [8]) -> [17]
$L.i5 i s0 =
      $LL.L.i5 s0 (let $t0 = trunc 1 i in
      $t0)

$L.Main.incr7 : ([8]) -> [17]
$L.Main.incr7 s0 =
      9'h4 # s0

$LL.L.i5 : ([8], [1]) -> [17]
$LL.L.i5 s0 $a =
      $LL.L.i51 s0 ($LL.L.i52 $a)

$L.ds8 : ([8], [8]) -> [17]
$L.ds8 ds $x =
      $L.Main.loop4 $x

device top_level
      input __in0 : [8]
      output __out0 : [8]
      register __resumption_tag : [1] init 1'h1
      register __st0 : [8] init 8'h0
      let $res = $Pure.dispatch (__resumption_tag # __st0) __in0
      __out0 := $res[9 +: 8]
      next __resumption_tag := $res[8 +: 1]
      next __st0 := $res[0 +: 8]