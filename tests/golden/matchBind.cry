// Generated by rwc from device: top_level.
// rw_device maps a sequence of per-cycle inputs to per-cycle outputs.

module top_level where

// Helpers implementing ReWire Hyle primitive semantics.
rw'resize : {m, n} (fin m, fin n) => [n] -> [m]
rw'resize x = drop`{n} ((zero : [m]) # x)

rw'repl : {n, w} (fin n, fin w) => [w] -> [n * w]
rw'repl x = join (repeat`{n} x)

rw'parity : {n} (fin n) => [n] -> Bit
rw'parity x = foldr (^) False x

rw'sext : {m, n} (fin m, fin n, n >= 1) => [n] -> [m]
rw'sext x = if x @ 0 then ~ (rw'resize (~ x)) else rw'resize x

// $Pure.dispatch
rw__Pure_dispatch : [9] -> [8] -> [17]
rw__Pure_dispatch x0 x1 = if (take`{1} x0) == 0b0 then (rw__L_ds8 x1 s0) else (rw__L_i11 x1 s1)
  where
    s0 : [8]
    s0 = drop`{1} x0
    s1 : [8]
    s1 = drop`{1} x0

// $L.Main.loop4
rw__L_Main_loop4 : [8] -> [17]
rw__L_Main_loop4 x0 = rw__L_i5 x0 x0

// $LL.L.i52
rw__LL_L_i52 : [1] -> [1]
rw__LL_L_i52 x0 = if x0 == 0b1 then 0b0 else 0b1

// $L.i11
rw__L_i11 : [8] -> [8] -> [17]
rw__L_i11 x0 x1 = rw__L_Main_loop4 x0

// $LL.L.i51
rw__LL_L_i51 : [8] -> [1] -> [17]
rw__LL_L_i51 x0 x1 = if x1 == 0b0 then (rw__L_Main_incr7 x0) else (rw__L_Main_incr7 x0)

// $L.i5
rw__L_i5 : [8] -> [8] -> [17]
rw__L_i5 x0 x1 = rw__LL_L_i5 x1 s0
  where
    s0 : [1]
    s0 = rw'resize`{1} x0

// $L.Main.incr7
rw__L_Main_incr7 : [8] -> [17]
rw__L_Main_incr7 x0 = 0b000000100 # x0

// $LL.L.i5
rw__LL_L_i5 : [8] -> [1] -> [17]
rw__LL_L_i5 x0 x1 = rw__LL_L_i51 x0 (rw__LL_L_i52 x1)

// $L.ds8
rw__L_ds8 : [8] -> [8] -> [17]
rw__L_ds8 x0 x1 = rw__L_Main_loop4 x1

// Per-cycle step: outputs # next register values.
rw_step : [9] -> [8] -> [17]
rw_step st i = (take`{8} s3) # ((take`{1} (drop`{8} s3)) # (drop`{9} s3))
  where
    s0 : [1]
    s0 = take`{1} st
    s1 : [8]
    s1 = drop`{1} st
    s2 : [8]
    s2 = i
    s3 : [17]
    s3 = rw__Pure_dispatch (s0 # s1) s2

// Device: top_level
// Inputs, MSB-first: __in0 : [8]
// Outputs, MSB-first: __out0 : [8]
rw_device : {n} (fin n) => [n][8] -> [n][8]
rw_device ins = outs
  where
    rs : [n][17]
    rs = [rw_step st i | st <- sts | i <- ins]
    sts : [1 + n][9]
    sts = [0b100000000] # [drop`{8} r | r <- rs]
    outs : [n][8]
    outs = [take`{8} r | r <- rs]