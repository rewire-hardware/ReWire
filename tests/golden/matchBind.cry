// Generated by rwc from device: top_level.
// rw_device maps a sequence of per-cycle inputs to per-cycle outputs.

module top_level where

// Helpers implementing ReWire Hyle primitive semantics.
rw'resize : {m, n} (fin m, fin n) => [n] -> [m]
rw'resize x = drop`{n} ((zero : [m]) # x)

rw'repl : {n, w} (fin n, fin w) => [w] -> [n * w]
rw'repl x = join (repeat`{n} x)

rw'parity : {n} (fin n) => [n] -> Bit
rw'parity x = foldr (^) False x

rw'sext : {m, n} (fin m, fin n, n >= 1) => [n] -> [m]
rw'sext x = if x @ 0 then ~ (rw'resize (~ x)) else rw'resize x

// $Pure.dispatch
rw__Pure_dispatch : [10] -> [8] -> [18]
rw__Pure_dispatch x0 x1 = if (take`{2} x0) == 0b01 then (rw__LL_Main_loop1 x1 s0) else (if (take`{2} x0) == 0b10 then (rw__LL_Main_reset x1 s1) else (rw__LL_Main_loop1 x1 s2))
  where
    s0 : [8]
    s0 = drop`{2} x0
    s1 : [8]
    s1 = drop`{2} x0
    s2 : [8]
    s2 = drop`{2} x0

// $LL.Main.loop5
rw__LL_Main_loop5 : [8] -> [18]
rw__LL_Main_loop5 x0 = rw_Main_loop x0

// $LL.Main.loop4
rw__LL_Main_loop4 : [8] -> [1]
rw__LL_Main_loop4 x0 = rw_ReWire_Prelude_not s0
  where
    s0 : [1]
    s0 = rw'resize`{1} x0

// $LL.Main.loop3
rw__LL_Main_loop3 : [8] -> [8] -> [18]
rw__LL_Main_loop3 x0 x1 = if s0 == 0b1 then (0b0000001001 # x1) else (0b0000001000 # x1)
  where
    s0 : [1]
    s0 = rw__LL_Main_loop4 x0

// $LL.ReWire.Prelude.not1
rw__LL_ReWire_Prelude_not1 : [1] -> [1] -> [1]
rw__LL_ReWire_Prelude_not1 x0 x1 = if x1 == 0b1 then 0b0 else (rw__LL_ReWire_Prelude_not x0)

// ReWire.Prelude.not
rw_ReWire_Prelude_not : [1] -> [1]
rw_ReWire_Prelude_not x0 = rw__LL_ReWire_Prelude_not1 x0 x0

// Main.loop
rw_Main_loop : [8] -> [18]
rw_Main_loop x0 = rw__LL_Main_loop3 x0 x0

// $LL.Main.loop1
rw__LL_Main_loop1 : [8] -> [8] -> [18]
rw__LL_Main_loop1 x0 x1 = rw__LL_Main_loop5 x1

// $LL.ReWire.Prelude.not
rw__LL_ReWire_Prelude_not : [1] -> [1]
rw__LL_ReWire_Prelude_not x0 = 0b1

// $LL.Main.reset
rw__LL_Main_reset : [8] -> [8] -> [18]
rw__LL_Main_reset x0 x1 = rw__LL_Main_loop5 x0

// Per-cycle step: outputs # next register values.
rw_step : [10] -> [8] -> [18]
rw_step st i = (take`{8} s3) # ((take`{2} (drop`{8} s3)) # (drop`{10} s3))
  where
    s0 : [2]
    s0 = take`{2} st
    s1 : [8]
    s1 = drop`{2} st
    s2 : [8]
    s2 = i
    s3 : [18]
    s3 = rw__Pure_dispatch (s0 # s1) s2

// Device: top_level
// Inputs, MSB-first: __in0 : [8]
// Outputs, MSB-first: __out0 : [8]
rw_device : {n} (fin n) => [n][8] -> [n][8]
rw_device ins = outs
  where
    rs : [n][18]
    rs = [rw_step st i | st <- sts | i <- ins]
    sts : [1 + n][10]
    sts = [0b1000000000] # [drop`{8} r | r <- rs]
    outs : [n][8]
    outs = [take`{8} r | r <- rs]