// Generated by rwc from device: top_level.
// rw_device maps a sequence of per-cycle inputs to per-cycle outputs.

module top_level where

// Helpers implementing ReWire Hyle primitive semantics.
rw'resize : {m, n} (fin m, fin n) => [n] -> [m]
rw'resize x = drop`{n} ((zero : [m]) # x)

rw'repl : {n, w} (fin n, fin w) => [w] -> [n * w]
rw'repl x = join (repeat`{n} x)

rw'parity : {n} (fin n) => [n] -> Bit
rw'parity x = foldr (^) False x

rw'sext : {m, n} (fin m, fin n, n >= 1) => [n] -> [m]
rw'sext x = if x @ 0 then ~ (rw'resize (~ x)) else rw'resize x

// main.$dispatch
rw_main__dispatch : [9] -> [8] -> [17]
rw_main__dispatch x0 x1 = if ~ ((take`{1} x0) @ 0) then (rw_main__ds x1 (drop`{1} x0)) else (rw_main_i2 x1 (drop`{1} x0))

// main.$ds
rw_main__ds : [8] -> [8] -> [17]
rw_main__ds x0 x1 = rw_main_loop x1

// main.incr
rw_main_incr : [8] -> [17]
rw_main_incr x0 = 0b000000100 # x0

// main.i
rw_main_i : [8] -> [8] -> [17]
rw_main_i x0 x1 = if ~ (s2 @ 0) then (rw_main_incr x1) else (rw_main_incr x1)
  where
    s0 : [1]
    s0 = rw'resize`{1} x0
    s1 : [1]
    s1 = s0
    s2 : [1]
    s2 = ~ s1

// main.loop
rw_main_loop : [8] -> [17]
rw_main_loop x0 = rw_main_i x0 x0

// main.i2
rw_main_i2 : [8] -> [8] -> [17]
rw_main_i2 x0 x1 = rw_main_loop x0

// Per-cycle step: outputs # next register values.
rw_step : [9] -> [8] -> [17]
rw_step st i = (take`{8} s3) # ((take`{1} (drop`{8} s3)) # (drop`{9} s3))
  where
    s0 : [1]
    s0 = take`{1} st
    s1 : [8]
    s1 = drop`{1} st
    s2 : [8]
    s2 = i
    s3 : [17]
    s3 = rw_main__dispatch (s0 # s1) s2

// Device: top_level
// Inputs, MSB-first: __in0 : [8]
// Outputs, MSB-first: __out0 : [8]
rw_device : {n} (fin n) => [n][8] -> [n][8]
rw_device ins = outs
  where
    rs : [n][17]
    rs = [rw_step st i | st <- sts | i <- ins]
    sts : [1 + n][9]
    sts = [0b100000000] # [drop`{8} r | r <- rs]
    outs : [n][8]
    outs = [take`{8} r | r <- rs]