// Per-cycle step: outputs # next register values.
rw_step : [1038] -> [68] -> [1103]
rw_step st i = (take`{65} s9) # ((take`{8} (drop`{65} s9)) # ((take`{224} (drop`{73} s9)) # ((take`{32} (drop`{297} s9)) # ((take`{480} (drop`{329} s9)) # ((take`{32} (drop`{809} s9)) # ((take`{224} (drop`{841} s9)) # ((take`{32} (drop`{1065} s9)) # (drop`{1097} s9))))))))
  where
    s0 : [8]
    s0 = take`{8} st
    s1 : [224]
    s1 = take`{224} (drop`{8} st)
    s2 : [32]
    s2 = take`{32} (drop`{232} st)
    s3 : [480]
    s3 = take`{480} (drop`{264} st)
    s4 : [32]
    s4 = take`{32} (drop`{744} st)
    s5 : [224]
    s5 = take`{224} (drop`{776} st)
    s6 : [32]
    s6 = take`{32} (drop`{1000} st)
    s7 : [6]
    s7 = drop`{1032} st
    s8 : [68]
    s8 = i
    s9 : [1103]
    s9 = rw_main__dispatch (s0 # (s1 # (s2 # (s3 # (s4 # (s5 # (s6 # s7))))))) s8

// Device: top_level
// Inputs, MSB-first: __in0 : [68]
// Outputs, MSB-first: __out0 : [65]
rw_device : {n} (fin n) => [n][68] -> [n][65]
rw_device ins = outs
  where
    rs : [n][1103]
    rs = [rw_step st i | st <- sts | i <- ins]
    sts : [1 + n][1038]
    sts = [] # [drop`{65} r | r <- rs]
    outs : [n][65]
    outs = [take`{65} r | r <- rs]