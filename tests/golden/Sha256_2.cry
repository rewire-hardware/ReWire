// Inputs, MSB-first: __in0 : [68]
// Outputs, MSB-first: __out0 : [65]
rw_device : {n} (fin n) => [n][68] -> [n][65]
rw_device ins = outs
  where
    rs : [n][1103]
    rs = [rw_step st i | st <- sts | i <- ins]
    sts : [1 + n][1038]
    sts = [] # [drop`{65} r | r <- rs]
    outs : [n][65]
    outs = [take`{65} r | r <- rs]