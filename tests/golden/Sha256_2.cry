// Per-cycle step: outputs # next register values.
rw_step : [1038] -> [68] -> [1103]
rw_step st i = (take`{65} (drop`{186} s6)) # ((take`{8} (drop`{251} s6)) # ((take`{224} (drop`{259} s6)) # ((take`{32} (drop`{483} s6)) # ((take`{512} (drop`{515} s6)) # (drop`{1027} s6)))))
  where
    s0 : [8]
    s0 = take`{8} st
    s1 : [224]
    s1 = take`{224} (drop`{8} st)
    s2 : [32]
    s2 = take`{32} (drop`{232} st)
    s3 : [512]
    s3 = take`{512} (drop`{264} st)
    s4 : [262]
    s4 = drop`{776} st
    s5 : [68]
    s5 = i
    s6 : [1289]
    s6 = rw__Pure_dispatch (s0 # (s1 # (s2 # (s3 # s4)))) s5

// Device: top_level
// Inputs, MSB-first: __in0 : [68]
// Outputs, MSB-first: __out0 : [65]
rw_device : {n} (fin n) => [n][68] -> [n][65]
rw_device ins = outs
  where
    rs : [n][1103]
    rs = [rw_step st i | st <- sts | i <- ins]
    sts : [1 + n][1038]
    sts = [] # [drop`{65} r | r <- rs]
    outs : [n][65]
    outs = [take`{65} r | r <- rs]