--| state dispatch for process main: 0=$ds 1=i
main.$dispatch : ([17], [1]) -> [25]
main.$dispatch disc i =
      if not disc[16 +: 1] then main.$ds i disc[0 +: 8]
            else main.i disc[8 +: 8] i disc[0 +: 8]

--| block '$L.$ds' of process main (state 0)
main.$ds : ([1], [8]) -> [25]
main.$ds $ds s0 =
      25'h10000

--| block '$L.n' of process main
main.n : ([8], [8]) -> [25]
main.n n s0 =
      add n n # 9'h0 # s0

--| block '$L._unused2' of process main
main._unused2 : ([8], [1], [8]) -> [25]
main._unused2 s i s0 =
      if not i then main.n s s0
            else main.counter s0

--| block '$L.i' of process main (state 1)
main.i : ([8], [1], [8]) -> [25]
main.i s i s0 =
      let s01 = add s 8'h1 in
      main._unused2 s i s01

--| block '$L.s' of process main
main.s : ([8], [8]) -> [25]
main.s s s0 =
      s # 1'h1 # s # s0

--| block '$L.Main.counter' of process main
main.counter : ([8]) -> [25]
main.counter s0 =
      main.s s0 s0

device top_level
      input __in0 : [1]
      output __out0 : [8]
      register __resumption_tag : [9] init 9'h100
      register __st0 : [8] init 8'h0
      tag $ds = 0
      tag i = 1
      let $res = main.$dispatch (__resumption_tag # __st0) __in0
      __out0 := $res[17 +: 8]
      next __resumption_tag := $res[8 +: 9]
      next __st0 := $res[0 +: 8]