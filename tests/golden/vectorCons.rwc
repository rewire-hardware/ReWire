$Pure.dispatch : ([128]) -> [128]
$Pure.dispatch i =
      Main.loop i

Main.compute : ([128]) -> [128]
Main.compute ds =
      let w = ds[0 +: 64] in
      ds[64 +: 56] # trunc 8 (lshr w 128'h0) # ds[120 +: 8] # ds[8 +: 56]

Main.loop : ([128]) -> [128]
Main.loop i =
      $LL.Main.loop (Main.compute i)

$LL.Main.loop : ([128]) -> [128]
$LL.Main.loop rabind =
      rabind

device top_level
      input __in0 : [64]
      input __in1 : [64]
      output __out0 : [64]
      output __out1 : [64]
      let $in = __in0 # __in1
      let $res = $Pure.dispatch $in
      __out0 := $res[64 +: 64]
      __out1 := $res[0 +: 64]