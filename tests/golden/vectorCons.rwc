$Pure.dispatch : ([128]) -> [128]
$Pure.dispatch i =
      Main.loop1 i

Main.compute : ([128]) -> [128]
Main.compute $x =
      $LL.Main.compute10 $x

$LL.Main.loop1 : ([128]) -> [128]
$LL.Main.loop1 $2 =
      $LL.Main.loop (Main.compute $2)

$LL.Main.compute13 : ([56], [8]) -> [64]
$LL.Main.compute13 $x $x1 =
      $LL.Main.compute4 $x $x1

$LL.Main.compute12 : ([64], [64], [8]) -> [128]
$LL.Main.compute12 v w $6 =
      $LL.Main.compute2 $6 w v[0 +: 56]

$LL.Main.compute11 : ([64]) -> [64]
$LL.Main.compute11 $32 =
      let v = $32[8 +: 56] in
      let x = $32[0 +: 8] in
      v # x

$LL.Main.compute10 : ([128]) -> [128]
$LL.Main.compute10 $7 =
      let v = $7[64 +: 64] in
      let w = $7[0 +: 64] in
      $LL.Main.compute12 v w ($LL.Main.compute1 v)

Main.loop1 : ([128]) -> [128]
Main.loop1 $x =
      $LL.Main.loop1 $x

$LL.Main.compute9 : ([64]) -> [8]
$LL.Main.compute9 $34 =
      trunc 8 (lshr $34 (mul (sub (sub 128'h8 (zext 128 ($LL.Main.compute $34))) 128'h1) 128'h8))

$LL.Main.compute8 : ([8], [8], [56], [56]) -> [128]
$LL.Main.compute8 v0 w7 vs $3 =
      $LL.Main.compute13 vs w7 # $LL.Main.compute3 v0 $3

$LL.Main.compute7 : ([8], [56]) -> [64]
$LL.Main.compute7 $1 $2 =
      $LL.Main.compute6 ($1 # $2)

$LL.Main.compute6 : ([64]) -> [64]
$LL.Main.compute6 $31 =
      let x = $31[56 +: 8] in
      let v = $31[0 +: 56] in
      x # v

$LL.Main.compute5 : ([8], [56], [64], [8]) -> [128]
$LL.Main.compute5 v0 vs w $4 =
      $LL.Main.compute8 v0 $4 vs w[8 +: 56]

$LL.Main.compute4 : ([56], [8]) -> [64]
$LL.Main.compute4 $3 $4 =
      $LL.Main.compute11 ($3 # $4)

$LL.Main.compute3 : ([8], [56]) -> [64]
$LL.Main.compute3 $x $x1 =
      $LL.Main.compute7 $x $x1

$LL.Main.compute2 : ([8], [64], [56]) -> [128]
$LL.Main.compute2 v0 w $5 =
      $LL.Main.compute5 v0 $5 w ($LL.Main.compute9 w)

$LL.Main.compute1 : ([64]) -> [8]
$LL.Main.compute1 $33 =
      $33[56 +: 8]

$LL.Main.compute : ([64]) -> [3]
$LL.Main.compute $35 =
      3'h7

$LL.Main.loop : ([128]) -> [128]
$LL.Main.loop rabind =
      rabind

device top_level
      input __in0 : [64]
      input __in1 : [64]
      output __out0 : [64]
      output __out1 : [64]
      let $in = __in0 # __in1
      let $res = $Pure.dispatch $in
      __out0 := $res[64 +: 64]
      __out1 := $res[0 +: 64]