--| state dispatch for process main: 0=$x2
main.$dispatch : ([128]) -> [128]
main.$dispatch i =
      main.$x2 i

--| block '$L.$x2' of process main (state 0)
main.$x2 : ([128]) -> [128]
main.$x2 $x =
      main.loop $x

--| block '$L.$x3' of process main
main.$x3 : ([128]) -> [128]
main.$x3 $x =
      $x

--| block '$L.Main.loop' of process main
main.loop : ([128]) -> [128]
main.loop i =
      let $a = Main.compute i in
      main.$x3 $a

Main.compute : ([128]) -> [128]
Main.compute $ds =
      let w = $ds[0 +: 64] in
      $ds[64 +: 56] # trunc 8 (lshr w 128'h0) # $ds[120 +: 8] # $ds[8 +: 56]

device top_level
      input __in0 : [64]
      input __in1 : [64]
      output __out0 : [64]
      output __out1 : [64]
      tag $x2 = 0
      let $in = __in0 # __in1
      let $res = main.$dispatch $in
      __out0 := $res[64 +: 64]
      __out1 := $res[0 +: 64]