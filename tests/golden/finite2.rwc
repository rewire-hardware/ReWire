$Pure.dispatch : ([7]) -> [6]
$Pure.dispatch i =
      $LL.Pure.dispatch i

$LL.Main.loop3 : ([5]) -> [6]
$LL.Main.loop3 rabind =
      1'h1 # rabind

Main.compute : ([7]) -> [5]
Main.compute $x =
      $LL.Main.compute6 $x

$LL.Main.compute6 : ([7]) -> [5]
$LL.Main.compute6 $x =
      $LL.Main.compute $x

$LL.Main.compute5 : ([5], [5]) -> [5]
$LL.Main.compute5 $0 $1 =
      $LL.Main.compute4 ($0 # $1)

$LL.Main.loop2 : ([7]) -> [6]
$LL.Main.loop2 i =
      $LL.Main.loop1 (1'h0 # Main.compute i)

$LL.Pure.dispatch : ([7]) -> [6]
$LL.Pure.dispatch i =
      Main.loop1 i

$LL.Main.compute4 : ([10]) -> [5]
$LL.Main.compute4 $22 =
      $LL.Main.compute3 $22[5 +: 5] $22[0 +: 5]

Main.loop1 : ([7]) -> [6]
Main.loop1 $x =
      $LL.Main.loop $x

$LL.Main.compute3 : ([5], [5]) -> [5]
$LL.Main.compute3 $x $x1 =
      $LL.Main.compute2 $x $x1

$LL.Main.loop1 : ([6]) -> [6]
$LL.Main.loop1 disc =
      $LL.Main.loop3 disc[0 +: 5]

$LL.Main.loop : ([7]) -> [6]
$LL.Main.loop $x =
      $LL.Main.loop2 $x

$LL.Main.compute2 : ([5], [5]) -> [5]
$LL.Main.compute2 a b =
      trunc 5 (umod (add (zext 128 a) (zext 128 b)) 128'h14)

$LL.Main.compute1 : ([5]) -> [5]
$LL.Main.compute1 sp =
      $LL.Main.compute5 sp 5'h6

$LL.Main.compute : ([7]) -> [5]
$LL.Main.compute n =
      $LL.Main.compute1 (trunc 5 (umod n 7'h14))

device top_level
      input __in0 : [7]
      output __out0 : [5]
      let $res = $Pure.dispatch __in0
      __out0 := $res[0 +: 5]