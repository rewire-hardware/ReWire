$Pure.dispatch : ([7]) -> [5]
$Pure.dispatch i =
      Main.loop i

Main.compute : ([7]) -> [5]
Main.compute n =
      trunc 5 (umod (add (zext 128 (trunc 5 (umod n 7'h14))) 128'h6) 128'h14)

Main.loop : ([7]) -> [5]
Main.loop i =
      $LL.Main.loop (Main.compute i)

$LL.Main.loop : ([5]) -> [5]
$LL.Main.loop rabind =
      rabind

device top_level
      input __in0 : [7]
      output __out0 : [5]
      let $res = $Pure.dispatch __in0
      __out0 := $res