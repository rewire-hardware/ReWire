// Generated by rwc from device: top_level.
// rw_device maps a sequence of per-cycle inputs to per-cycle outputs.

module top_level where

// Helpers implementing ReWire Hyle primitive semantics.
rw'resize : {m, n} (fin m, fin n) => [n] -> [m]
rw'resize x = drop`{n} ((zero : [m]) # x)

rw'repl : {n, w} (fin n, fin w) => [w] -> [n * w]
rw'repl x = join (repeat`{n} x)

rw'parity : {n} (fin n) => [n] -> Bit
rw'parity x = foldr (^) False x

rw'sext : {m, n} (fin m, fin n, n >= 1) => [n] -> [m]
rw'sext x = if x @ 0 then ~ (rw'resize (~ x)) else rw'resize x

// $Pure.dispatch
rw__Pure_dispatch : [16] -> [1] -> [24]
rw__Pure_dispatch x0 x1 = rw__L_i5 x1 x0

// $L.r18
rw__L_r18 : [8] -> [8] -> [16] -> [24]
rw__L_r18 x0 x1 x2 = rw__LL_L_r18 x1 (x0 + x1)

// $L.Main.first14
rw__L_Main_first14 : [16] -> [24]
rw__L_Main_first14 x0 = rw__L_r04 (take`{8} x0) x0

// $LL.L.r18
rw__LL_L_r18 : [8] -> [8] -> [24]
rw__LL_L_r18 x0 x1 = rw__L_Main_first14 (x0 # x1)

// $L.Main.first12
rw__L_Main_first12 : [16] -> [24]
rw__L_Main_first12 x0 = rw__L_Main_second10 (take`{8} x0) x0

// $L.i5
rw__L_i5 : [1] -> [16] -> [24]
rw__L_i5 x0 x1 = if x0 == 0b0 then (rw__L_Main_first12 x1) else (rw__L_Main_first14 x1)

// $L.r04
rw__L_r04 : [8] -> [16] -> [24]
rw__L_r04 x0 x1 = x0 # x1

// $L.Main.second10
rw__L_Main_second10 : [8] -> [16] -> [24]
rw__L_Main_second10 x0 x1 = rw__L_r18 x0 (rw'resize`{8} (x1 >> 0x00000000000000000000000000000000)) x1

// Per-cycle step: outputs # next register values.
rw_step : [16] -> [1] -> [24]
rw_step st i = (take`{8} s2) # (drop`{8} s2)
  where
    s0 : [16]
    s0 = st
    s1 : [1]
    s1 = i
    s2 : [24]
    s2 = rw__Pure_dispatch s0 s1

// Device: top_level
// Inputs, MSB-first: __in0 : [1]
// Outputs, MSB-first: __out0 : [8]
rw_device : {n} (fin n) => [n][1] -> [n][8]
rw_device ins = outs
  where
    rs : [n][24]
    rs = [rw_step st i | st <- sts | i <- ins]
    sts : [1 + n][16]
    sts = [0x0001] # [drop`{8} r | r <- rs]
    outs : [n][8]
    outs = [take`{8} r | r <- rs]