// Generated by rwc from device: top_level.
// rw_device maps a sequence of per-cycle inputs to per-cycle outputs.

module top_level where

// Helpers implementing ReWire Hyle primitive semantics.
rw'resize : {m, n} (fin m, fin n) => [n] -> [m]
rw'resize x = drop`{n} ((zero : [m]) # x)

rw'repl : {n, w} (fin n, fin w) => [w] -> [n * w]
rw'repl x = join (repeat`{n} x)

rw'parity : {n} (fin n) => [n] -> Bit
rw'parity x = foldr (^) False x

rw'sext : {m, n} (fin m, fin n, n >= 1) => [n] -> [m]
rw'sext x = if x @ 0 then ~ (rw'resize (~ x)) else rw'resize x

// main.$dispatch
rw_main__dispatch : [16] -> [1] -> [24]
rw_main__dispatch x0 x1 = rw_main_i x1 x0

// main.r1
rw_main_r1 : [8] -> [8] -> [16] -> [24]
rw_main_r1 x0 x1 x2 = rw_main_first2 s1
  where
    s0 : [8]
    s0 = x0 + x1
    s1 : [16]
    s1 = x1 # s0

// main.second
rw_main_second : [8] -> [16] -> [24]
rw_main_second x0 x1 = rw_main_r1 x0 (rw'resize`{8} (x1 >> 0x00000000000000000000000000000000)) x1

// main.first
rw_main_first : [16] -> [24]
rw_main_first x0 = rw_main_second (take`{8} x0) x0

// main.i
rw_main_i : [1] -> [16] -> [24]
rw_main_i x0 x1 = if ~ (x0 @ 0) then (rw_main_first x1) else (rw_main_first2 x1)

// main.r0
rw_main_r0 : [8] -> [16] -> [24]
rw_main_r0 x0 x1 = x0 # x1

// main.first2
rw_main_first2 : [16] -> [24]
rw_main_first2 x0 = rw_main_r0 (take`{8} x0) x0

// Per-cycle step: outputs # next register values.
rw_step : [16] -> [1] -> [24]
rw_step st i = (take`{8} s2) # (drop`{8} s2)
  where
    s0 : [16]
    s0 = st
    s1 : [1]
    s1 = i
    s2 : [24]
    s2 = rw_main__dispatch s0 s1

// Device: top_level
// Inputs, MSB-first: __in0 : [1]
// Outputs, MSB-first: __out0 : [8]
rw_device : {n} (fin n) => [n][1] -> [n][8]
rw_device ins = outs
  where
    rs : [n][24]
    rs = [rw_step st i | st <- sts | i <- ins]
    sts : [1 + n][16]
    sts = [0x0001] # [drop`{8} r | r <- rs]
    outs : [n][8]
    outs = [take`{8} r | r <- rs]