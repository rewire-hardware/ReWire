--| state dispatch for process main: 0=$x2
main.$dispatch : ([24]) -> [8]
main.$dispatch i =
      main.$x2 i

--| block '$L.$x2' of process main (state 0)
main.$x2 : ([24]) -> [8]
main.$x2 $x =
      main.loop $x

--| block '$L.$x3' of process main
main.$x3 : ([8]) -> [8]
main.$x3 $x =
      $x

--| block '$L.Main.loop' of process main
main.loop : ([24]) -> [8]
main.loop i =
      let $a = Main.compute i in
      main.$x3 $a

Main.compute : ([24]) -> [8]
Main.compute $ds =
      let u = $ds[16 +: 8] in
      let v = $ds[8 +: 8] in
      let w = $ds[0 +: 8] in
      or (xor (and u v) w) (not (xor (and (not u) (not v)) w))

device top_level
      input __in0 : [8]
      input __in1 : [8]
      input __in2 : [8]
      output __out0 : [8]
      tag $x2 = 0
      let $in = __in0 # __in1 # __in2
      let $res = main.$dispatch $in
      __out0 := $res