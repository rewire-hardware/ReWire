$Pure.dispatch : ([24]) -> [9]
$Pure.dispatch i =
      $LL.Pure.dispatch i

$LL.Main.compute3 : ([8], [8], [8]) -> [8]
$LL.Main.compute3 u v $x =
      $LL.Main.compute v u $x

$LL.Main.loop3 : ([24]) -> [9]
$LL.Main.loop3 i =
      $LL.Main.loop2 (1'h0 # Main.compute i)

Main.compute : ([24]) -> [8]
Main.compute $x =
      $LL.Main.compute2 $x

$LL.Main.compute2 : ([24]) -> [8]
$LL.Main.compute2 $3 =
      $LL.Main.compute1 $3[16 +: 8] $3[8 +: 8] $3[0 +: 8]

$LL.Main.compute1 : ([8], [8], [8]) -> [8]
$LL.Main.compute1 $x $x1 $x2 =
      $LL.Main.compute3 $x $x1 $x2

$LL.Main.compute : ([8], [8], [8]) -> [8]
$LL.Main.compute v u w =
      or (xor (and u v) w) (not (xor (and (not u) (not v)) w))

$LL.Main.loop2 : ([9]) -> [9]
$LL.Main.loop2 disc =
      $LL.Main.loop disc[0 +: 8]

Main.loop1 : ([24]) -> [9]
Main.loop1 $x =
      $LL.Main.loop1 $x

$LL.Main.loop1 : ([24]) -> [9]
$LL.Main.loop1 $x =
      $LL.Main.loop3 $x

$LL.Main.loop : ([8]) -> [9]
$LL.Main.loop rabind =
      1'h1 # rabind

$LL.Pure.dispatch : ([24]) -> [9]
$LL.Pure.dispatch i =
      Main.loop1 i

device top_level
      input __in0 : [8]
      input __in1 : [8]
      input __in2 : [8]
      output __out0 : [8]
      let $in = __in0 # __in1 # __in2
      let $res = $Pure.dispatch $in
      __out0 := $res[0 +: 8]