$Pure.dispatch : ([24]) -> [8]
$Pure.dispatch i =
      $L.$x4 i

Main.compute : ([24]) -> [8]
Main.compute ds =
      let u = ds[16 +: 8] in
      let v = ds[8 +: 8] in
      let w = ds[0 +: 8] in
      or (xor (and u v) w) (not (xor (and (not u) (not v)) w))

$L.Main.loop3 : ([24]) -> [8]
$L.Main.loop3 i =
      $L.$x5 (Main.compute i)

$L.$x5 : ([8]) -> [8]
$L.$x5 $x =
      $x

$L.$x4 : ([24]) -> [8]
$L.$x4 $x =
      $L.Main.loop3 $x

device top_level
      input __in0 : [8]
      input __in1 : [8]
      input __in2 : [8]
      output __out0 : [8]
      let $in = __in0 # __in1 # __in2
      let $res = $Pure.dispatch $in
      __out0 := $res