main.$dispatch : ([24]) -> [8]
main.$dispatch i =
      main.$L.$x4$258 i

main.$L.$x4$258 : ([24]) -> [8]
main.$L.$x4$258 $x =
      main.$L.Main.loop3$256 $x

main.$L.$x5$260 : ([8]) -> [8]
main.$L.$x5$260 $x =
      $x

main.$L.Main.loop3$256 : ([24]) -> [8]
main.$L.Main.loop3$256 i =
      let $a = Main.compute i in
      main.$L.$x5$260 $a

Main.compute : ([24]) -> [8]
Main.compute ds =
      let u = ds[16 +: 8] in
      let v = ds[8 +: 8] in
      let w = ds[0 +: 8] in
      or (xor (and u v) w) (not (xor (and (not u) (not v)) w))

device top_level
      input __in0 : [8]
      input __in1 : [8]
      input __in2 : [8]
      output __out0 : [8]
      let $in = __in0 # __in1 # __in2
      let $res = main.$dispatch $in
      __out0 := $res