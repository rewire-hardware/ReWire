$Pure.dispatch : ([24]) -> [8]
$Pure.dispatch i =
      Main.loop1 i

Main.compute : ([24]) -> [8]
Main.compute ds =
      let u = ds[16 +: 8] in
      let v = ds[8 +: 8] in
      let w = ds[0 +: 8] in
      or (xor (and u v) w) (not (xor (and (not u) (not v)) w))

$LL.Main.loop : ([8]) -> [8]
$LL.Main.loop rabind =
      rabind

Main.loop1 : ([24]) -> [8]
Main.loop1 i =
      $LL.Main.loop (Main.compute i)

device top_level
      input __in0 : [8]
      input __in1 : [8]
      input __in2 : [8]
      output __out0 : [8]
      let $in = __in0 # __in1 # __in2
      let $res = $Pure.dispatch $in
      __out0 := $res