rw_main__dispatch x0 x1 = if (take`{1} x0) == 0b0 then (rw_main__L_i4_248 (take`{8} (drop`{1} x0)) x1 (drop`{9} x0)) else (rw_main__L_i1_245 x1 (drop`{9} x0))

// main.$L.i4$248
rw_main__L_i4_248 : [8] -> [8] -> [8] -> [25]
