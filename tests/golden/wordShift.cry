// Helpers implementing ReWire Hyle primitive semantics.
rw'resize : {m, n} (fin m, fin n) => [n] -> [m]
rw'resize x = drop`{n} ((zero : [m]) # x)

rw'repl : {n, w} (fin n, fin w) => [w] -> [n * w]
rw'repl x = join (repeat`{n} x)

rw'parity : {n} (fin n) => [n] -> Bit
rw'parity x = foldr (^) False x

rw'sext : {m, n} (fin m, fin n, n >= 1) => [n] -> [m]
rw'sext x = if x @ 0 then ~ (rw'resize (~ x)) else rw'resize x

// $Pure.dispatch
rw__Pure_dispatch : [8] -> [8]
rw__Pure_dispatch x0 = rw__L__x4 x0

// $LL.Main.myArithRotr$s1
rw__LL_Main_myArithRotr_s1 : [8] -> [8] -> [8]
rw__LL_Main_myArithRotr_s1 x0 x1 = (x0 << (0x08 - x1)) || (x0 >>$ x1)

// $L.Main.loop3
rw__L_Main_loop3 : [8] -> [8]
rw__L_Main_loop3 x0 = rw__LL_L_Main_loop3 (rw_Main_myRotr_s1 x0)

// $LL.Main.myRotr$s1
rw__LL_Main_myRotr_s1 : [8] -> [8] -> [8]
rw__LL_Main_myRotr_s1 x0 x1 = (x0 << (0x08 - x1)) || (x0 >> x1)

// $L.$x5
rw__L__x5 : [8] -> [8]
rw__L__x5 x0 = x0

// $LL.L.Main.loop3
rw__LL_L_Main_loop3 : [8] -> [8]
rw__LL_L_Main_loop3 x0 = rw__L__x5 (rw_Main_myArithRotr_s1 x0)

// Main.myRotr$s1
rw_Main_myRotr_s1 : [8] -> [8]
rw_Main_myRotr_s1 x0 = rw__LL_Main_myRotr_s1 x0 0x03

// Main.myArithRotr$s1
rw_Main_myArithRotr_s1 : [8] -> [8]
rw_Main_myArithRotr_s1 x0 = rw__LL_Main_myArithRotr_s1 x0 0x05

// $L.$x4
rw__L__x4 : [8] -> [8]
rw__L__x4 x0 = rw__L_Main_loop3 x0

// Per-cycle step: outputs # next register values.
rw_step : [8] -> [8]
rw_step i = s1
  where
    s0 : [8]
    s0 = i
    s1 : [8]
    s1 = rw__Pure_dispatch s0

// Device: top_level
// Inputs, MSB-first: __in0 : [8]
// Outputs, MSB-first: __out0 : [8]
rw_device : {n} (fin n) => [n][8] -> [n][8]
rw_device ins = [rw_step i | i <- ins]