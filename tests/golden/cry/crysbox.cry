module crysbox where

sbox : [16][4]
sbox = [0xe, 0x4, 0xd, 0x1, 0x2, 0xf, 0xb, 0x8, 0x3, 0xa, 0x6, 0xc, 0x5, 0x9, 0x0, 0x7]

subst : [4] -> [4]
subst i = sbox @ i

bytemap : [16] -> [16]
bytemap x = join [ subst n | n <- split`{4} x ]

flipHalves : {n} (fin n) => [2 * n] -> [2 * n]
flipHalves x = drop`{n} x # take`{n} x

xorAll : [4][4] -> [4]
xorAll xs = foldl (^) zero xs

xorWord : [16] -> [4]
xorWord x = xorAll (split x)
