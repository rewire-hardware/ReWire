// SHA-256 (FIPS 180-4), single 512-bit block, standard IV. A faithful
// spec: the message schedule and the round-state sequence are recursive
// comprehensions; the round functions use rotates and shifts.
module sha256 where

sha256Block : [512] -> [256]
sha256Block block = join [ a + h | a <- states @ 64 | h <- iv ]
  where
    ws : [64][32]
    ws = split block #
           [ ssig1 (ws@(i-2)) + ws@(i-7) + ssig0 (ws@(i-15)) + ws@(i-16)
           | i <- [16 .. 63] ]

    states : [65][8][32]
    states = [iv] # [ round s k w | s <- states | k <- ks | w <- ws ]

round : [8][32] -> [32] -> [32] -> [8][32]
round [a, b, c, d, e, f, g, h] k w = [t1 + t2, a, b, c, d + t1, e, f, g]
  where t1 = h + bsig1 e + ch e f g + k + w
        t2 = bsig0 a + maj a b c

ch : [32] -> [32] -> [32] -> [32]
ch x y z = (x && y) ^ (~x && z)

maj : [32] -> [32] -> [32] -> [32]
maj x y z = (x && y) ^ (x && z) ^ (y && z)

bsig0 : [32] -> [32]
bsig0 x = (x >>> 2) ^ (x >>> 13) ^ (x >>> 22)

bsig1 : [32] -> [32]
bsig1 x = (x >>> 6) ^ (x >>> 11) ^ (x >>> 25)

ssig0 : [32] -> [32]
ssig0 x = (x >>> 7) ^ (x >>> 18) ^ (x >> 3)

ssig1 : [32] -> [32]
ssig1 x = (x >>> 17) ^ (x >>> 19) ^ (x >> 10)

iv : [8][32]
iv = [ 0x6a09e667, 0xbb67ae85, 0x3c6ef372, 0xa54ff53a
     , 0x510e527f, 0x9b05688c, 0x1f83d9ab, 0x5be0cd19 ]

ks : [64][32]
ks = [ 0x428a2f98, 0x71374491, 0xb5c0fbcf, 0xe9b5dba5, 0x3956c25b, 0x59f111f1, 0x923f82a4, 0xab1c5ed5
     , 0xd807aa98, 0x12835b01, 0x243185be, 0x550c7dc3, 0x72be5d74, 0x80deb1fe, 0x9bdc06a7, 0xc19bf174
     , 0xe49b69c1, 0xefbe4786, 0x0fc19dc6, 0x240ca1cc, 0x2de92c6f, 0x4a7484aa, 0x5cb0a9dc, 0x76f988da
     , 0x983e5152, 0xa831c66d, 0xb00327c8, 0xbf597fc7, 0xc6e00bf3, 0xd5a79147, 0x06ca6351, 0x14292967
     , 0x27b70a85, 0x2e1b2138, 0x4d2c6dfc, 0x53380d13, 0x650a7354, 0x766a0abb, 0x81c2c92e, 0x92722c85
     , 0xa2bfe8a1, 0xa81a664b, 0xc24b8b70, 0xc76c51a3, 0xd192e819, 0xd6990624, 0xf40e3585, 0x106aa070
     , 0x19a4c116, 0x1e376c08, 0x2748774c, 0x34b0bcb5, 0x391c0cb3, 0x4ed8aa4a, 0x5b9cca4f, 0x682e6ff3
     , 0x748f82ee, 0x78a5636f, 0x84c87814, 0x8cc70208, 0x90befffa, 0xa4506ceb, 0xbef9a3f7, 0xc67178f2 ]

