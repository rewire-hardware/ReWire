$Pure.dispatch : ([5], [1]) -> [6]
$Pure.dispatch disc i =
      if eq disc[3 +: 2] 2'h0 then (let e = disc[2 +: 1] in
            let s = disc[1 +: 1] in
            let s1 = disc[0 +: 1] in
            $L.z4 e i s s1)
            else if eq disc[3 +: 2] 2'h1 then (let e = disc[2 +: 1] in
            let s = disc[1 +: 1] in
            let s1 = disc[0 +: 1] in
            $L.y3 e i s s1) else let s = disc[1 +: 1] in
            let s1 = disc[0 +: 1] in
            $L.x2 i s s1

$LL.L.y35 : ([1], [1]) -> [1]
$LL.L.y35 x wild =
      if eq wild 1'h0 then $LL.L.y3 ($LL.L.y34 x x)
            else x

$LL.L.y34 : ([1], [1]) -> [1]
$LL.L.y34 x s =
      if eq s 1'h1 then x
            else 1'h0

$LL.L.y33 : ([1], [1]) -> [1]
$LL.L.y33 y s =
      if eq s 1'h1 then y
            else 1'h0

$L.Main.go1 : ([1], [1]) -> [6]
$L.Main.go1 s0 s1 =
      4'h4 # s0 # s1

$LL.L.y32 : ([1], [1], [1], [1]) -> [6]
$LL.L.y32 y s1 s0 $a =
      $LL.L.y31 y s1 s0 ($LL.L.y33 y $a)

$L.z4 : ([1], [1], [1], [1]) -> [6]
$L.z4 y z s0 s1 =
      $L.Main.go1 s0 y

$L.x2 : ([1], [1], [1]) -> [6]
$L.x2 x s0 s1 =
      if eq x 1'h0 then $L.arm6 x s0 s1
            else 3'h1 # x # s0 # s1

$LL.L.y31 : ([1], [1], [1], [1]) -> [6]
$LL.L.y31 y s1 s0 $a =
      $a # 2'h0 # y # s0 # s1

$LL.L.y3 : ([1]) -> [1]
$LL.L.y3 $a =
      $a

$L.arm6 : ([1], [1], [1]) -> [6]
$L.arm6 x s0 $x =
      $L.y3 x s0 s0 $x

$L.y3 : ([1], [1], [1], [1]) -> [6]
$L.y3 x y s0 s1 =
      $LL.L.y32 y s1 s0 ($LL.L.y35 x y)

device top_level
      input __in0 : [1]
      output __out0 : [1]
      register __resumption_tag : [3] init 3'h4
      register __st0 : [1] init 1'h0
      register __st1 : [1] init 1'h1
      let $res = $Pure.dispatch (__resumption_tag # __st0 # __st1) __in0
      __out0 := $res[5 +: 1]
      next __resumption_tag := $res[2 +: 3]
      next __st0 := $res[1 +: 1]
      next __st1 := $res[0 +: 1]