--| state dispatch for process main: 0=z 1=y 2=x
main.$dispatch : ([5], [1]) -> [6]
main.$dispatch disc i =
      if eq disc[3 +: 2] 2'h0 then main.z disc[2 +: 1] i disc[1 +: 1] disc[0 +: 1]
            else if eq disc[3 +: 2] 2'h1 then main.y disc[2 +: 1] i disc[1 +: 1] disc[0 +: 1] else main.x i disc[1 +: 1] disc[0 +: 1]

--| block '$L.z' of process main (state 0)
main.z : ([1], [1], [1], [1]) -> [6]
main.z y z s0 s1 =
      main.go s0 y

--| block '$L.y' of process main (state 1)
main.y : ([1], [1], [1], [1]) -> [6]
main.y x y s0 s1 =
      let $a = (if not y then (let $a = (if x then x
                  else 1'h0) in
            $a)
            else x) in
      let $a1 = (if $a then y
            else 1'h0) in
      $a1 # 2'h0 # y # s0 # s1

--| block '$L.arm' of process main
main.arm : ([1], [1], [1]) -> [6]
main.arm x s0 s1 =
      main.y x s0 s0 s1

--| block '$L.x' of process main (state 2)
main.x : ([1], [1], [1]) -> [6]
main.x x s0 s1 =
      if not x then main.arm x s0 s1
            else 3'h1 # x # s0 # s1

--| block '$L.Main.go' of process main
main.go : ([1], [1]) -> [6]
main.go s0 s1 =
      4'h4 # s0 # s1

device top_level
      input __in0 : [1]
      output __out0 : [1]
      register __resumption_tag : [3] init 3'h4
      register __st0 : [1] init 1'h0
      register __st1 : [1] init 1'h1
      tag z = 0
      tag y = 1
      tag x = 2
      let $res = main.$dispatch (__resumption_tag # __st0 # __st1) __in0
      __out0 := $res[5 +: 1]
      next __resumption_tag := $res[2 +: 3]
      next __st0 := $res[1 +: 1]
      next __st1 := $res[0 +: 1]