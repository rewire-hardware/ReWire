main.$dispatch : ([17], [1]) -> [25]
main.$dispatch disc i =
      if eq disc[16 +: 1] 1'h0 then main.$L.b5$250 disc[8 +: 8] disc[0 +: 8] i
            else main.$L.b3$248 disc[0 +: 8] i

main.$L.b5$250 : ([8], [8], [1]) -> [25]
main.$L.b5$250 n m b =
      if eq b 1'h0 then main.$L.Main.loop4$249 m (add n m)
            else main.$L.Main.loop4$249 n m

main.$L.Main.loop4$249 : ([8], [8]) -> [25]
main.$L.Main.loop4$249 n m =
      n # 1'h0 # n # m

main.$L.b3$248 : ([8], [1]) -> [25]
main.$L.b3$248 m b =
      if eq b 1'h0 then main.$L.Main.loop4$249 m (add 8'h0 m)
            else main.$L.Main.loop4$249 8'h0 m

device top_level
      input __in0 : [1]
      output __out0 : [8]
      register __resumption_tag : [17] init 17'h10001
      let $res = main.$dispatch __resumption_tag __in0
      __out0 := $res[17 +: 8]
      next __resumption_tag := $res[0 +: 17]