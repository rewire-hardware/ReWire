$Pure.dispatch : ([17], [1]) -> [25]
$Pure.dispatch disc i =
      if eq disc[16 +: 1] 1'h0 then (let e = disc[8 +: 8] in
            let e1 = disc[0 +: 8] in
            $L.b5 e e1 i)
            else let e = disc[0 +: 8] in
            $L.b3 e i

$L.Main.loop4 : ([8], [8]) -> [25]
$L.Main.loop4 n m =
      n # 1'h0 # n # m

$L.b3 : ([8], [1]) -> [25]
$L.b3 m b =
      if eq b 1'h0 then $L.Main.loop4 m (add 8'h0 m)
            else $L.Main.loop4 8'h0 m

$L.b5 : ([8], [8], [1]) -> [25]
$L.b5 n m b =
      if eq b 1'h0 then $L.Main.loop4 m (add n m)
            else $L.Main.loop4 n m

device top_level
      input __in0 : [1]
      output __out0 : [8]
      register __resumption_tag : [17] init 17'h10001
      let $res = $Pure.dispatch __resumption_tag __in0
      __out0 := $res[17 +: 8]
      next __resumption_tag := $res[0 +: 17]