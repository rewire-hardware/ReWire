$Pure.dispatch : ([17], [1]) -> [25]
$Pure.dispatch disc i =
      if eq disc[16 +: 1] 1'h1 then (let store0 = disc[8 +: 8] in
            let store1 = disc[0 +: 8] in
            $LL.Main.loop1 store0 store1 i)
            else let store0 = disc[0 +: 8] in
            $LL.Main.loop2 store0 i

$LL.Main.loop2 : ([8], [1]) -> [25]
$LL.Main.loop2 m $x =
      $LL.Main.loop m 8'h0 $x

Main.loop1 : ([8], [8]) -> [25]
Main.loop1 n m =
      n # 1'h1 # m # n

$LL.Main.loop1 : ([8], [8], [1]) -> [25]
$LL.Main.loop1 $x $x1 $x2 =
      $LL.Main.loop $x $x1 $x2

$LL.Main.loop : ([8], [8], [1]) -> [25]
$LL.Main.loop m n wild =
      if eq wild 1'h0 then Main.loop1 m (add n m)
            else Main.loop1 n m

device top_level
      input __in0 : [1]
      output __out0 : [8]
      register __resumption_tag : [17] init 17'h1
      let $res = $Pure.dispatch __resumption_tag __in0
      __out0 := $res[17 +: 8]
      next __resumption_tag := $res[0 +: 17]