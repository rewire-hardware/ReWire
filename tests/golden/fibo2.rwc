--| state dispatch for process main: 0=b2 1=b
main.$dispatch : ([17], [1]) -> [25]
main.$dispatch disc i =
      if not disc[16 +: 1] then main.b2 disc[8 +: 8] disc[0 +: 8] i
            else main.b disc[0 +: 8] i

--| block '$L.b2' of process main (state 0)
main.b2 : ([8], [8], [1]) -> [25]
main.b2 n m b =
      if not b then main.loop m (add n m)
            else main.loop n m

--| block '$L.Main.loop' of process main
main.loop : ([8], [8]) -> [25]
main.loop n m =
      n # 1'h0 # n # m

--| block '$L.b' of process main (state 1)
main.b : ([8], [1]) -> [25]
main.b m b =
      if not b then main.loop m (add 8'h0 m)
            else main.loop 8'h0 m

device top_level
      input __in0 : [1]
      output __out0 : [8]
      register __resumption_tag : [17] init 17'h10001
      tag b2 = 0
      tag b = 1
      let $res = main.$dispatch __resumption_tag __in0
      __out0 := $res[17 +: 8]
      next __resumption_tag := $res[0 +: 17]