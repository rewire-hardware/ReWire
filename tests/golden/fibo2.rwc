$Pure.dispatch : ([16], [1]) -> [24]
$Pure.dispatch disc i =
      let store0 = disc[8 +: 8] in
      let store1 = disc[0 +: 8] in
      $LL.Main.loop2 store0 store1 i

$LL.Main.loop4 : ([8], [8], [1]) -> [24]
$LL.Main.loop4 m n b =
      $LL.Main.loop m b n b

$LL.Main.loop3 : ([8], [8], [1]) -> [24]
$LL.Main.loop3 m n $3 =
      Main.loop m (add n m)

$LL.Main.loop2 : ([8], [8], [1]) -> [24]
$LL.Main.loop2 n m $x =
      $LL.Main.loop4 m n $x

$LL.Main.loop1 : ([16]) -> [24]
$LL.Main.loop1 $5 =
      let n = $5[8 +: 8] in
      let m = $5[0 +: 8] in
      n # n # m

Main.loop : ([8], [8]) -> [24]
Main.loop $0 $1 =
      $LL.Main.loop1 ($0 # $1)

$LL.Main.loop : ([8], [1], [8], [1]) -> [24]
$LL.Main.loop m b n $4 =
      if eq $4 1'h1 then Main.loop n m
            else $LL.Main.loop3 m n b

device top_level
      input __in0 : [1]
      output __out0 : [8]
      register __resumption_tag : [16] init 16'h1
      let $res = $Pure.dispatch __resumption_tag __in0
      __out0 := $res[16 +: 8]
      next __resumption_tag := $res[0 +: 16]