// Generated by rwc from device: top_level.
// rw_device maps a sequence of per-cycle inputs to per-cycle outputs.

module top_level where

// Helpers implementing ReWire Hyle primitive semantics.
rw'resize : {m, n} (fin m, fin n) => [n] -> [m]
rw'resize x = drop`{n} ((zero : [m]) # x)

rw'repl : {n, w} (fin n, fin w) => [w] -> [n * w]
rw'repl x = join (repeat`{n} x)

rw'parity : {n} (fin n) => [n] -> Bit
rw'parity x = foldr (^) False x

rw'sext : {m, n} (fin m, fin n, n >= 1) => [n] -> [m]
rw'sext x = if x @ 0 then ~ (rw'resize (~ x)) else rw'resize x

// $Pure.dispatch
rw__Pure_dispatch : [6] -> [3] -> [10]
rw__Pure_dispatch x0 x1 = if (take`{3} x0) == 0b000 then (rw__L__x4 x1) else (if (take`{3} x0) == 0b001 then (rw__L__unused5 s0 x1) else (if (take`{3} x0) == 0b010 then (rw__L__unused6 s1 x1) else (if (take`{3} x0) == 0b011 then (rw__L__unused7 x1) else (rw__L__unused8 x1))))
  where
    s0 : [3]
    s0 = drop`{3} x0
    s1 : [3]
    s1 = drop`{3} x0

// $LL.L._unused5
rw__LL_L__unused5 : [4] -> [10]
rw__LL_L__unused5 x0 = x0 # 0b000000

// $L._unused5
rw__L__unused5 : [3] -> [3] -> [10]
rw__L__unused5 x0 x1 = rw__LL_L__unused5 (0b1 # x0)

// $L._unused6
rw__L__unused6 : [3] -> [3] -> [10]
rw__L__unused6 x0 x1 = 0b0000001 # x0

// $L._unused8
rw__L__unused8 : [3] -> [10]
rw__L__unused8 x0 = 0b0000011000

// $L.Main.dev3
rw__L_Main_dev3 : [3] -> [10]
rw__L_Main_dev3 x0 = 0b0000010 # x0

// $L._unused7
rw__L__unused7 : [3] -> [10]
rw__L__unused7 x0 = 0b1000000000

// $L.$x4
rw__L__x4 : [3] -> [10]
rw__L__x4 x0 = rw__L_Main_dev3 x0

// Per-cycle step: outputs # next register values.
rw_step : [6] -> [3] -> [10]
rw_step st i = (take`{1} s2) # ((take`{3} (drop`{1} s2)) # (drop`{4} s2))
  where
    s0 : [6]
    s0 = st
    s1 : [3]
    s1 = i
    s2 : [10]
    s2 = rw__Pure_dispatch s0 s1

// Device: top_level
// Inputs, MSB-first: __in0 : [3]
// Outputs, MSB-first: __out0 : [1], __out1 : [3]
rw_device : {n} (fin n) => [n][3] -> [n][4]
rw_device ins = outs
  where
    rs : [n][10]
    rs = [rw_step st i | st <- sts | i <- ins]
    sts : [1 + n][6]
    sts = [0b100000] # [drop`{4} r | r <- rs]
    outs : [n][4]
    outs = [take`{4} r | r <- rs]