// Generated by rwc from device: top_level.
// rw_device maps a sequence of per-cycle inputs to per-cycle outputs.

module top_level where

// Helpers implementing ReWire Hyle primitive semantics.
rw'resize : {m, n} (fin m, fin n) => [n] -> [m]
rw'resize x = drop`{n} ((zero : [m]) # x)

rw'repl : {n, w} (fin n, fin w) => [w] -> [n * w]
rw'repl x = join (repeat`{n} x)

rw'parity : {n} (fin n) => [n] -> Bit
rw'parity x = foldr (^) False x

rw'sext : {m, n} (fin m, fin n, n >= 1) => [n] -> [m]
rw'sext x = if x @ 0 then ~ (rw'resize (~ x)) else rw'resize x

// main.$dispatch
rw_main__dispatch : [6] -> [3] -> [10]
rw_main__dispatch x0 x1 = if (take`{3} x0) == 0b000 then (rw_main__x2 x1) else (if (take`{3} x0) == 0b001 then (rw_main__unused (drop`{3} x0) x1) else (if (take`{3} x0) == 0b010 then (rw_main__unused2 (drop`{3} x0) x1) else (if (take`{3} x0) == 0b011 then (rw_main__unused3 x1) else (rw_main__unused4 x1))))

// main.$x2
rw_main__x2 : [3] -> [10]
rw_main__x2 x0 = rw_main_dev x0

// main._unused
rw_main__unused : [3] -> [3] -> [10]
rw_main__unused x0 x1 = s0 # 0b000000
  where
    s0 : [4]
    s0 = 0b1 # x0

// main._unused2
rw_main__unused2 : [3] -> [3] -> [10]
rw_main__unused2 x0 x1 = 0b0000001 # x0

// main.dev
rw_main_dev : [3] -> [10]
rw_main_dev x0 = 0b0000010 # x0

// main._unused3
rw_main__unused3 : [3] -> [10]
rw_main__unused3 x0 = 0b1000000000

// main._unused4
rw_main__unused4 : [3] -> [10]
rw_main__unused4 x0 = 0b0000011000

// Per-cycle step: outputs # next register values.
rw_step : [6] -> [3] -> [10]
rw_step st i = (take`{1} s2) # ((take`{3} (drop`{1} s2)) # (drop`{4} s2))
  where
    s0 : [6]
    s0 = st
    s1 : [3]
    s1 = i
    s2 : [10]
    s2 = rw_main__dispatch s0 s1

// Device: top_level
// Inputs, MSB-first: __in0 : [3]
// Outputs, MSB-first: __out0 : [1], __out1 : [3]
rw_device : {n} (fin n) => [n][3] -> [n][4]
rw_device ins = outs
  where
    rs : [n][10]
    rs = [rw_step st i | st <- sts | i <- ins]
    sts : [1 + n][6]
    sts = [0b100000] # [drop`{4} r | r <- rs]
    outs : [n][4]
    outs = [take`{4} r | r <- rs]