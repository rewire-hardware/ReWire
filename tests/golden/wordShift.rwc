$Pure.dispatch : ([8]) -> [8]
$Pure.dispatch i =
      Main.loop i

$LL.Main.myRotr : ([8], [8]) -> [8]
$LL.Main.myRotr w n' =
      or (shl w (sub 8'h8 n')) (lshr w n')

$LL.Main.myArithRotr : ([8], [8]) -> [8]
$LL.Main.myArithRotr w n' =
      or (shl w (sub 8'h8 n')) (ashr w n')

Main.loop : ([8]) -> [8]
Main.loop i =
      $LL.Main.loop1 (Main.myArithRotr (Main.myRotr i))

$LL.Main.loop1 : ([8]) -> [8]
$LL.Main.loop1 rabind =
      rabind

Main.myArithRotr : ([8]) -> [8]
Main.myArithRotr sp =
      $LL.Main.myArithRotr sp 8'h5

Main.myRotr : ([8]) -> [8]
Main.myRotr sp =
      $LL.Main.myRotr sp 8'h3

device top_level
      input __in0 : [8]
      output __out0 : [8]
      let $res = $Pure.dispatch __in0
      __out0 := $res