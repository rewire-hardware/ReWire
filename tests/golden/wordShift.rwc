$Pure.dispatch : ([8]) -> [8]
$Pure.dispatch i =
      $L.$x4 i

$LL.Main.myArithRotr$s1 : ([8], [8]) -> [8]
$LL.Main.myArithRotr$s1 w n' =
      or (shl w (sub 8'h8 n')) (ashr w n')

$L.Main.loop3 : ([8]) -> [8]
$L.Main.loop3 i =
      $LL.L.Main.loop3 (Main.myRotr$s1 i)

$LL.Main.myRotr$s1 : ([8], [8]) -> [8]
$LL.Main.myRotr$s1 w n' =
      or (shl w (sub 8'h8 n')) (lshr w n')

$L.$x5 : ([8]) -> [8]
$L.$x5 $x =
      $x

$LL.L.Main.loop3 : ([8]) -> [8]
$LL.L.Main.loop3 $a =
      $L.$x5 (Main.myArithRotr$s1 $a)

Main.myRotr$s1 : ([8]) -> [8]
Main.myRotr$s1 w =
      $LL.Main.myRotr$s1 w 8'h3

Main.myArithRotr$s1 : ([8]) -> [8]
Main.myArithRotr$s1 w =
      $LL.Main.myArithRotr$s1 w 8'h5

$L.$x4 : ([8]) -> [8]
$L.$x4 $x =
      $L.Main.loop3 $x

device top_level
      input __in0 : [8]
      output __out0 : [8]
      let $res = $Pure.dispatch __in0
      __out0 := $res