main.$dispatch : ([8]) -> [8]
main.$dispatch i =
      main.$L.$x4$282 i

main.$L.$x4$282 : ([8]) -> [8]
main.$L.$x4$282 $x =
      main.$L.Main.loop3$280 $x

main.$L.$x5$284 : ([8]) -> [8]
main.$L.$x5$284 $x =
      $x

main.$L.Main.loop3$280 : ([8]) -> [8]
main.$L.Main.loop3$280 i =
      let $a = Main.myRotr$s1 i in
      let $a1 = Main.myArithRotr$s1 $a in
      main.$L.$x5$284 $a1

Main.myRotr$s1 : ([8]) -> [8]
Main.myRotr$s1 w =
      or (shl w 8'h5) (lshr w 8'h3)

Main.myArithRotr$s1 : ([8]) -> [8]
Main.myArithRotr$s1 w =
      or (shl w 8'h3) (ashr w 8'h5)

device top_level
      input __in0 : [8]
      output __out0 : [8]
      let $res = main.$dispatch __in0
      __out0 := $res