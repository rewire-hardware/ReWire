$Pure.dispatch : ([8]) -> [8]
$Pure.dispatch i =
      Main.loop i

Main.myRotr : ([8]) -> [8]
Main.myRotr sp =
      $LL.Main.myRotr (sp # 8'h3)

$LL.Main.loop1 : ([8]) -> [8]
$LL.Main.loop1 $5 =
      $LL.Main.loop (Main.myArithRotr (Main.myRotr $5))

$LL.Main.myArithRotr1 : ([16]) -> [8]
$LL.Main.myArithRotr1 $9 =
      let w = $9[8 +: 8] in
      let n = $9[0 +: 8] in
      $LL.Main.myArithRotr w (umod n 8'h8)

Main.loop : ([8]) -> [8]
Main.loop $x =
      $LL.Main.loop1 $x

$LL.Main.myArithRotr : ([8], [8]) -> [8]
$LL.Main.myArithRotr w $8 =
      or (shl w (sub 8'h8 $8)) (ashr w $8)

$LL.Main.myRotr1 : ([8], [8]) -> [8]
$LL.Main.myRotr1 w $6 =
      or (shl w (sub 8'h8 $6)) (lshr w $6)

Main.myArithRotr : ([8]) -> [8]
Main.myArithRotr sp =
      $LL.Main.myArithRotr1 (sp # 8'h5)

$LL.Main.loop : ([8]) -> [8]
$LL.Main.loop rabind =
      rabind

$LL.Main.myRotr : ([16]) -> [8]
$LL.Main.myRotr $7 =
      let w = $7[8 +: 8] in
      let n = $7[0 +: 8] in
      $LL.Main.myRotr1 w (umod n 8'h8)

device top_level
      input __in0 : [8]
      output __out0 : [8]
      let $res = $Pure.dispatch __in0
      __out0 := $res