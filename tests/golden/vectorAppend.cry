// Generated by rwc from device: top_level.
// rw_device maps a sequence of per-cycle inputs to per-cycle outputs.

module top_level where

// Helpers implementing ReWire Hyle primitive semantics.
rw'resize : {m, n} (fin m, fin n) => [n] -> [m]
rw'resize x = drop`{n} ((zero : [m]) # x)

rw'repl : {n, w} (fin n, fin w) => [w] -> [n * w]
rw'repl x = join (repeat`{n} x)

rw'parity : {n} (fin n) => [n] -> Bit
rw'parity x = foldr (^) False x

rw'sext : {m, n} (fin m, fin n, n >= 1) => [n] -> [m]
rw'sext x = if x @ 0 then ~ (rw'resize (~ x)) else rw'resize x

// main.$dispatch
rw_main__dispatch : [128] -> [64]
rw_main__dispatch x0 = rw_main__x2 x0

// main.$x2
rw_main__x2 : [128] -> [64]
rw_main__x2 x0 = rw_main_loop x0

// main.$x3
rw_main__x3 : [64] -> [64]
rw_main__x3 x0 = x0

// main.loop
rw_main_loop : [128] -> [64]
rw_main_loop x0 = rw_main__x3 s0
  where
    s0 : [64]
    s0 = rw_Main_compute x0

// Main.compute
rw_Main_compute : [128] -> [64]
rw_Main_compute x0 = (take`{8} (drop`{24} x0)) # ((take`{8} (drop`{16} x0)) # ((take`{8} (drop`{8} x0)) # ((take`{8} x0) # (0x00 # (drop`{104} x0)))))

// Per-cycle step: outputs # next register values.
rw_step : [128] -> [64]
rw_step i = s3
  where
    s0 : [64]
    s0 = take`{64} i
    s1 : [64]
    s1 = drop`{64} i
    s2 : [128]
    s2 = s0 # s1
    s3 : [64]
    s3 = rw_main__dispatch s2

// Device: top_level
// Inputs, MSB-first: __in0 : [64], __in1 : [64]
// Outputs, MSB-first: __out0 : [64]
rw_device : {n} (fin n) => [n][128] -> [n][64]
rw_device ins = [rw_step i | i <- ins]