// $LL.Main.dev4
rw__LL_Main_dev4 : [1] -> [1] -> [3]
rw__LL_Main_dev4 x0 x1 = rw__LL_Main_dev1 x0 x1

// Main.thenB$1$s1
rw_Main_thenB_1_s1 : [1] -> [1]
rw_Main_thenB_1_s1 x0 = 0b1

// $LL.Main.dev3
rw__LL_Main_dev3 : [1] -> [3]
