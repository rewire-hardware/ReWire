rw__LL_Main_whenB_1_s1 : [1] -> [1] -> [1]
rw__LL_Main_whenB_1_s1 x0 x1 = if x0 == 0b0 then x1 else 0b0

// Per-cycle step: outputs # next register values.
rw_step : [1] -> [1] -> [2]
rw_step st i = (take`{1} (drop`{1} s2)) # (drop`{2} s2)
  where
    s0 : [1]
    s0 = st
    s1 : [1]
