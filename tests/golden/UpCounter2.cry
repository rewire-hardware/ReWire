// main.$L.$x8$278
rw_main__L__x8_278 : [8] -> [8] -> [16]
rw_main__L__x8_278 x0 x1 = x0 # x1

// main.$L.Main.go1$268
rw_main__L_Main_go1_268 : [8] -> [16]
rw_main__L_Main_go1_268 x0 = rw_main__L__x8_278 x0 x0

// Main.incW8
rw_Main_incW8 : [8] -> [8]
rw_Main_incW8 x0 = x0 + 0x01

// Main.msbitW8
rw_Main_msbitW8 : [8] -> [8]
rw_Main_msbitW8 x0 = rw'resize`{8} (take`{1} x0)

// Main.rolW8
rw_Main_rolW8 : [8] -> [8]
rw_Main_rolW8 x0 = (x0 << 0x01) || (rw_Main_msbitW8 x0)

// Per-cycle step: outputs # next register values.
rw_step : [8] -> [1] -> [16]
rw_step st i = (take`{8} s2) # (drop`{8} s2)
  where
    s0 : [8]
    s0 = st
    s1 : [1]
    s1 = i
    s2 : [16]
    s2 = rw_main__dispatch s0 s1

// Device: top_level
// Inputs, MSB-first: __in0 : [1]
// Outputs, MSB-first: __out0 : [8]
rw_device : {n} (fin n) => [n][1] -> [n][8]
rw_device ins = outs
  where
