// Generated by rwc from device: top_level.
// rw_device maps a sequence of per-cycle inputs to per-cycle outputs.

module top_level where

// Helpers implementing ReWire Hyle primitive semantics.
rw'resize : {m, n} (fin m, fin n) => [n] -> [m]
rw'resize x = drop`{n} ((zero : [m]) # x)

rw'repl : {n, w} (fin n, fin w) => [w] -> [n * w]
rw'repl x = join (repeat`{n} x)

rw'parity : {n} (fin n) => [n] -> Bit
rw'parity x = foldr (^) False x

rw'sext : {m, n} (fin m, fin n, n >= 1) => [n] -> [m]
rw'sext x = if x @ 0 then ~ (rw'resize (~ x)) else rw'resize x

// main.$dispatch
rw_main__dispatch : [8] -> [1] -> [16]
rw_main__dispatch x0 x1 = rw_main_b x1 x0

// main.n
rw_main_n : [8] -> [8] -> [16]
rw_main_n x0 x1 = rw_main_go s0
  where
    s0 : [8]
    s0 = rw_Main_incW8 x0

// main.arm
rw_main_arm : [8] -> [16]
rw_main_arm x0 = rw_main_n x0 x0

// main.n2
rw_main_n2 : [8] -> [8] -> [16]
rw_main_n2 x0 x1 = rw_main_go s0
  where
    s0 : [8]
    s0 = rw_Main_rolW8 x0

// main.arm2
rw_main_arm2 : [8] -> [16]
rw_main_arm2 x0 = rw_main_n2 x0 x0

// main.b
rw_main_b : [1] -> [8] -> [16]
rw_main_b x0 x1 = if ~ (x0 @ 0) then (rw_main_arm x1) else (rw_main_arm2 x1)

// main.$x
rw_main__x : [8] -> [8] -> [16]
rw_main__x x0 x1 = x0 # x1

// main.go
rw_main_go : [8] -> [16]
rw_main_go x0 = rw_main__x x0 x0

// Main.incW8
rw_Main_incW8 : [8] -> [8]
rw_Main_incW8 x0 = x0 + 0x01

// Main.msbitW8
rw_Main_msbitW8 : [8] -> [8]
rw_Main_msbitW8 x0 = rw'resize`{8} (take`{1} x0)

// Main.rolW8
rw_Main_rolW8 : [8] -> [8]
rw_Main_rolW8 x0 = (x0 << 0x01) || (rw_Main_msbitW8 x0)

// Per-cycle step: outputs # next register values.
rw_step : [8] -> [1] -> [16]
rw_step st i = (take`{8} s2) # (drop`{8} s2)
  where
    s0 : [8]
    s0 = st
    s1 : [1]
    s1 = i
    s2 : [16]
    s2 = rw_main__dispatch s0 s1

// Device: top_level
// Inputs, MSB-first: __in0 : [1]
// Outputs, MSB-first: __out0 : [8]
rw_device : {n} (fin n) => [n][1] -> [n][8]
rw_device ins = outs
  where
    rs : [n][16]
    rs = [rw_step st i | st <- sts | i <- ins]
    sts : [1 + n][8]
    sts = [0x00] # [drop`{8} r | r <- rs]
    outs : [n][8]
    outs = [take`{8} r | r <- rs]