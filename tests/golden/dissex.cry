// Generated by rwc from device: top_level.
// rw_device maps a sequence of per-cycle inputs to per-cycle outputs.

module top_level where

// Helpers implementing ReWire Hyle primitive semantics.
rw'resize : {m, n} (fin m, fin n) => [n] -> [m]
rw'resize x = drop`{n} ((zero : [m]) # x)

rw'repl : {n, w} (fin n, fin w) => [w] -> [n * w]
rw'repl x = join (repeat`{n} x)

rw'parity : {n} (fin n) => [n] -> Bit
rw'parity x = foldr (^) False x

rw'sext : {m, n} (fin m, fin n, n >= 1) => [n] -> [m]
rw'sext x = if x @ 0 then ~ (rw'resize (~ x)) else rw'resize x

// $Pure.dispatch
rw__Pure_dispatch : [16] -> [1] -> [24]
rw__Pure_dispatch x0 x1 = rw__LL_Main_sig x1 s0 s1
  where
    s0 : [8]
    s0 = take`{8} x0
    s1 : [8]
    s1 = drop`{8} x0

// $LL.Main.sig1
rw__LL_Main_sig1 : [8] -> [8] -> [8] -> [24]
rw__LL_Main_sig1 x0 x1 x2 = x0 # (x1 # x2)

// $LL.Main.incr5
rw__LL_Main_incr5 : [8] -> [8] -> [8] -> [8] -> [24]
rw__LL_Main_incr5 x0 x1 x2 x3 = rw__LL_Main_incr2 x0 x1 x1 x3

// Main.plusW8
rw_Main_plusW8 : [8] -> [8] -> [8]
rw_Main_plusW8 x0 x1 = x0 + x1

// Main.incr
rw_Main_incr : [8] -> [8] -> [24]
rw_Main_incr x0 x1 = rw__LL_Main_incr4 x0 x0 x1

// $LL.Main.incr4
rw__LL_Main_incr4 : [8] -> [8] -> [8] -> [24]
rw__LL_Main_incr4 x0 x1 x2 = rw__LL_Main_incr x0 x2 x1 x2

// $LL.Main.sig
rw__LL_Main_sig : [1] -> [8] -> [8] -> [24]
rw__LL_Main_sig x0 x1 x2 = if x0 == 0b0 then (rw_Main_sig x1 x2) else (rw_Main_incr x1 x2)

// $LL.Main.incr3
rw__LL_Main_incr3 : [8] -> [8] -> [24]
rw__LL_Main_incr3 x0 x1 = rw_Main_sig x0 x1

// Main.sig
rw_Main_sig : [8] -> [8] -> [24]
rw_Main_sig x0 x1 = rw__LL_Main_sig1 x0 x0 x1

// $LL.Main.incr2
rw__LL_Main_incr2 : [8] -> [8] -> [8] -> [8] -> [24]
rw__LL_Main_incr2 x0 x1 x2 x3 = rw__LL_Main_incr1 x1 x0 x2 x3

// $LL.Main.incr1
rw__LL_Main_incr1 : [8] -> [8] -> [8] -> [8] -> [24]
rw__LL_Main_incr1 x0 x1 x2 x3 = rw__LL_Main_incr3 x2 (rw_Main_plusW8 x1 x0)

// $LL.Main.incr
rw__LL_Main_incr : [8] -> [8] -> [8] -> [8] -> [24]
rw__LL_Main_incr x0 x1 x2 x3 = rw__LL_Main_incr5 x0 x1 x2 x3

// Per-cycle step: outputs # next register values.
rw_step : [16] -> [1] -> [24]
rw_step st i = (take`{8} s3) # ((take`{8} (drop`{8} s3)) # (drop`{16} s3))
  where
    s0 : [8]
    s0 = take`{8} st
    s1 : [8]
    s1 = drop`{8} st
    s2 : [1]
    s2 = i
    s3 : [24]
    s3 = rw__Pure_dispatch (s0 # s1) s2

// Device: top_level
// Inputs, MSB-first: __in0 : [1]
// Outputs, MSB-first: __out0 : [8]
rw_device : {n} (fin n) => [n][1] -> [n][8]
rw_device ins = outs
  where
    rs : [n][24]
    rs = [rw_step st i | st <- sts | i <- ins]
    sts : [1 + n][16]
    sts = [0x0001] # [drop`{8} r | r <- rs]
    outs : [n][8]
    outs = [take`{8} r | r <- rs]