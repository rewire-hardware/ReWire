// Generated by rwc from device: top_level.
// rw_device maps a sequence of per-cycle inputs to per-cycle outputs.

module top_level where

// Helpers implementing ReWire Hyle primitive semantics.
rw'resize : {m, n} (fin m, fin n) => [n] -> [m]
rw'resize x = drop`{n} ((zero : [m]) # x)

rw'repl : {n, w} (fin n, fin w) => [w] -> [n * w]
rw'repl x = join (repeat`{n} x)

rw'parity : {n} (fin n) => [n] -> Bit
rw'parity x = foldr (^) False x

rw'sext : {m, n} (fin m, fin n, n >= 1) => [n] -> [m]
rw'sext x = if x @ 0 then ~ (rw'resize (~ x)) else rw'resize x

// main.$dispatch
rw_main__dispatch : [16] -> [1] -> [24]
rw_main__dispatch x0 x1 = rw_main_i x1 (take`{8} x0) (drop`{8} x0)

// main._unused
rw_main__unused : [8] -> [8] -> [8] -> [8] -> [24]
rw_main__unused x0 x1 x2 x3 = rw_main_sig x2 s0
  where
    s0 : [8]
    s0 = x0 + x1

// main.r1
rw_main_r1 : [8] -> [8] -> [8] -> [8] -> [24]
rw_main_r1 x0 x1 x2 x3 = rw_main__unused x0 x1 x1 x3

// main.r02
rw_main_r02 : [8] -> [8] -> [8] -> [24]
rw_main_r02 x0 x1 x2 = rw_main_r1 x0 x2 x1 x2

// main.incr
rw_main_incr : [8] -> [8] -> [24]
rw_main_incr x0 x1 = rw_main_r02 x0 x0 x1

// main.i
rw_main_i : [1] -> [8] -> [8] -> [24]
rw_main_i x0 x1 x2 = if ~ (x0 @ 0) then (rw_main_incr x1 x2) else (rw_main_sig x1 x2)

// main.r0
rw_main_r0 : [8] -> [8] -> [8] -> [24]
rw_main_r0 x0 x1 x2 = x0 # (x1 # x2)

// main.sig
rw_main_sig : [8] -> [8] -> [24]
rw_main_sig x0 x1 = rw_main_r0 x0 x0 x1

// Per-cycle step: outputs # next register values.
rw_step : [16] -> [1] -> [24]
rw_step st i = (take`{8} s3) # ((take`{8} (drop`{8} s3)) # (drop`{16} s3))
  where
    s0 : [8]
    s0 = take`{8} st
    s1 : [8]
    s1 = drop`{8} st
    s2 : [1]
    s2 = i
    s3 : [24]
    s3 = rw_main__dispatch (s0 # s1) s2

// Device: top_level
// Inputs, MSB-first: __in0 : [1]
// Outputs, MSB-first: __out0 : [8]
rw_device : {n} (fin n) => [n][1] -> [n][8]
rw_device ins = outs
  where
    rs : [n][24]
    rs = [rw_step st i | st <- sts | i <- ins]
    sts : [1 + n][16]
    sts = [0x0001] # [drop`{8} r | r <- rs]
    outs : [n][8]
    outs = [take`{8} r | r <- rs]