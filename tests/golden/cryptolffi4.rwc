--| state dispatch for process main: 0=$x2
main.$dispatch : ([16]) -> [8]
main.$dispatch i =
      main.$x2 i

--| block '$L.$x2' of process main (state 0)
main.$x2 : ([16]) -> [8]
main.$x2 $x =
      main.iter$W8W8$W8$sMain_go $x

--| block '$L.ReWire.Monad.iter$W8W8$W8$sMain_go' of process main
main.iter$W8W8$W8$sMain_go : ([16]) -> [8]
main.iter$W8W8$W8$sMain_go i =
      let $a = Main.go i in
      $a

Main.locfn : ([8], [8]) -> [8]
Main.locfn $eta0 $eta1 =
      cry$locfn$8_8_8 $eta0 $eta1

Main.hof : ([8]) -> [8]
Main.hof $eta0 =
      cry$hof$8_8 $eta0

Main.cu : ([8], [8]) -> [8]
Main.cu $eta0 $eta1 =
      cry$cu$8_8_8 $eta0 $eta1

Main.pick : ([1], [8]) -> [8]
Main.pick $eta0 $eta1 =
      cry$pick$Bit_8_8 $eta0 $eta1

Main.pow5 : ([8]) -> [8]
Main.pow5 $eta0 =
      cry$pow5$8_8 $eta0

Main.go : ([16]) -> [8]
Main.go $ds =
      let a = $ds[8 +: 8] in
      let b = $ds[0 +: 8] in
      add (add (add (Main.locfn a b) (Main.hof b)) (Main.cu a b)) (Main.pick (eq a b) (Main.pow5 a))

--| cryptol cry/cryho.cry::locfn at [8] -> [8] -> [8]
cry$locfn$8_8_8 : ([8], [8]) -> [8]
cry$locfn$8_8_8 x$0 y$1 =
      add (add y$1 x$0) x$0

--| also: cry$pick$Bit_8_8.inc$0
cry$hof$8_8.inc$1 : ([8]) -> [8]
cry$hof$8_8.inc$1 v$0 =
      add v$0 8'h1

--| cryptol cry/cryho.cry::hof at [8] -> [8]
cry$hof$8_8 : ([8]) -> [8]
cry$hof$8_8 x$0 =
      add (add (cry$hof$8_8.inc$1 (cry$hof$8_8.inc$1 x$0)) (mul (mul x$0 8'h2) 8'h2)) x$0

cry$cu$8_8_8.sump$2 : ([16]) -> [8]
cry$cu$8_8_8.sump$2 __p0$0 =
      let v$4728 = __p0$0[0 +: 8] in
      let u$4727 = __p0$0[8 +: 8] in
      add u$4727 v$4728

--| cryptol cry/cryho.cry::cu at [8] -> [8] -> [8]
cry$cu$8_8_8 : ([8], [8]) -> [8]
cry$cu$8_8_8 a$0 b$1 =
      cry$cu$8_8_8.sump$2 (a$0 # b$1)

--| cryptol cry/cryho.cry::pick at Bit -> [8] -> [8]
cry$pick$Bit_8_8 : ([1], [8]) -> [8]
cry$pick$Bit_8_8 c$0 x$1 =
      if c$0 then cry$hof$8_8.inc$1 x$1
            else not x$1

cry$pow5$8_8.pow.e....0.$0 : ([8]) -> [8]
cry$pow5$8_8.pow.e....0.$0 x$0 =
      8'h1

cry$pow5$8_8.pow$1 : ([8]) -> [8]
cry$pow5$8_8.pow$1 $eta0 =
      cry$pow5$8_8.pow.e....0.$0 $eta0

cry$pow5$8_8.pow.e...0.$2 : ([8]) -> [8]
cry$pow5$8_8.pow.e...0.$2 x$0 =
      mul x$0 (cry$pow5$8_8.pow$1 x$0)

cry$pow5$8_8.pow$3 : ([8]) -> [8]
cry$pow5$8_8.pow$3 $eta0 =
      cry$pow5$8_8.pow.e...0.$2 $eta0

cry$pow5$8_8.pow.e...0.$4 : ([8]) -> [8]
cry$pow5$8_8.pow.e...0.$4 x$0 =
      mul x$0 (cry$pow5$8_8.pow$3 x$0)

cry$pow5$8_8.pow$5 : ([8]) -> [8]
cry$pow5$8_8.pow$5 $eta0 =
      cry$pow5$8_8.pow.e...0.$4 $eta0

cry$pow5$8_8.pow.e...0.$6 : ([8]) -> [8]
cry$pow5$8_8.pow.e...0.$6 x$0 =
      mul x$0 (cry$pow5$8_8.pow$5 x$0)

cry$pow5$8_8.pow$7 : ([8]) -> [8]
cry$pow5$8_8.pow$7 $eta0 =
      cry$pow5$8_8.pow.e...0.$6 $eta0

cry$pow5$8_8.pow.e...0.$8 : ([8]) -> [8]
cry$pow5$8_8.pow.e...0.$8 x$0 =
      mul x$0 (cry$pow5$8_8.pow$7 x$0)

cry$pow5$8_8.pow$9 : ([8]) -> [8]
cry$pow5$8_8.pow$9 $eta0 =
      cry$pow5$8_8.pow.e...0.$8 $eta0

cry$pow5$8_8.pow.e...0.$10 : ([8]) -> [8]
cry$pow5$8_8.pow.e...0.$10 x$0 =
      mul x$0 (cry$pow5$8_8.pow$9 x$0)

cry$pow5$8_8.pow$11 : ([8]) -> [8]
cry$pow5$8_8.pow$11 $eta0 =
      cry$pow5$8_8.pow.e...0.$10 $eta0

--| cryptol cry/cryho.cry::pow5 at [8] -> [8]
cry$pow5$8_8 : ([8]) -> [8]
cry$pow5$8_8 x$0 =
      cry$pow5$8_8.pow$11 x$0

device top_level
      input __in0 : [8]
      input __in1 : [8]
      output __out0 : [8]
      tag $x2 = 0
      let $in = __in0 # __in1
      let $res = main.$dispatch $in
      __out0 := $res