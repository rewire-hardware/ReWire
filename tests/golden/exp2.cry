// Per-cycle step: outputs # next register values.
rw_step : [2000] -> [100] -> [2100]
rw_step st i = (take`{100} s3) # ((take`{1000} (drop`{100} s3)) # (drop`{1100} s3))
  where
    s0 : [1000]
    s0 = take`{1000} st
    s1 : [1000]
    s1 = drop`{1000} st
    s2 : [100]
    s2 = i
    s3 : [2100]
    s3 = rw__Pure_dispatch (s0 # s1) s2

// Device: top_level
// Inputs, MSB-first: __in0 : [100]
// Outputs, MSB-first: __out0 : [100]
rw_device : {n} (fin n) => [n][100] -> [n][100]
rw_device ins = outs
  where
    rs : [n][2100]
    rs = [rw_step st i | st <- sts | i <- ins]
    sts : [1 + n][2000]
