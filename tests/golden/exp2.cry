// Generated by rwc from device: top_level.
// rw_device maps a sequence of per-cycle inputs to per-cycle outputs.

module top_level where

// Helpers implementing ReWire Hyle primitive semantics.
rw'resize : {m, n} (fin m, fin n) => [n] -> [m]
rw'resize x = drop`{n} ((zero : [m]) # x)

rw'repl : {n, w} (fin n, fin w) => [w] -> [n * w]
rw'repl x = join (repeat`{n} x)

rw'parity : {n} (fin n) => [n] -> Bit
rw'parity x = foldr (^) False x

rw'sext : {m, n} (fin m, fin n, n >= 1) => [n] -> [m]
rw'sext x = if x @ 0 then ~ (rw'resize (~ x)) else rw'resize x

// main.$dispatch
rw_main__dispatch : [2000] -> [100] -> [2100]
rw_main__dispatch x0 x1 = rw_main_i (take`{1000} x0) x1 (drop`{1000} x0)

// main.i
rw_main_i : [1000] -> [100] -> [1000] -> [2100]
rw_main_i x0 x1 x2 = rw_main_dev_Identity s0
  where
    s0 : [1000]
    s0 = rw_Main_ss_ x0 x1

// main.ss
rw_main_ss : [1000] -> [1000] -> [2100]
rw_main_ss x0 x1 = (take`{100} x0) # (x0 # x1)

// main.dev$Identity
rw_main_dev_Identity : [1000] -> [2100]
rw_main_dev_Identity x0 = rw_main_ss x0 x0

// Main.x2
rw_Main_x2 : [100] -> [100]
rw_Main_x2 x0 = x0 * 0x0000000000000000000000002

// Main.ss'
rw_Main_ss_ : [1000] -> [100] -> [1000]
rw_Main_ss_ x0 x1 = (rw_Main_x2 (take`{100} (drop`{100} x0))) # ((rw_Main_x2 (take`{100} (drop`{200} x0))) # ((rw_Main_x2 (take`{100} (drop`{300} x0))) # ((rw_Main_x2 (take`{100} (drop`{400} x0))) # ((rw_Main_x2 (take`{100} (drop`{500} x0))) # ((rw_Main_x2 (take`{100} (drop`{600} x0))) # ((rw_Main_x2 (take`{100} (drop`{700} x0))) # ((rw_Main_x2 (take`{100} (drop`{800} x0))) # ((rw_Main_x2 (drop`{900} x0)) # (rw_Main_x2 x1)))))))))

// Per-cycle step: outputs # next register values.
rw_step : [2000] -> [100] -> [2100]
rw_step st i = (take`{100} s3) # ((take`{1000} (drop`{100} s3)) # (drop`{1100} s3))
  where
    s0 : [1000]
    s0 = take`{1000} st
    s1 : [1000]
    s1 = drop`{1000} st
    s2 : [100]
    s2 = i
    s3 : [2100]
    s3 = rw_main__dispatch (s0 # s1) s2

// Device: top_level
// Inputs, MSB-first: __in0 : [100]
// Outputs, MSB-first: __out0 : [100]
rw_device : {n} (fin n) => [n][100] -> [n][100]
rw_device ins = outs
  where
    rs : [n][2100]
    rs = [rw_step st i | st <- sts | i <- ins]
    sts : [1 + n][2000]
    sts = [] # [drop`{100} r | r <- rs]
    outs : [n][100]
    outs = [take`{100} r | r <- rs]