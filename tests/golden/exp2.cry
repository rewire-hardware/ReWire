// Per-cycle step: outputs # next register values.
rw_step : [2000] -> [100] -> [2100]
rw_step st i = (take`{100} s3) # ((take`{1000} (drop`{100} s3)) # (drop`{1100} s3))
  where
    s0 : [1000]
