// $LL.Main.go9
rw__LL_Main_go9 : [1] -> [1] -> [1]
rw__LL_Main_go9 x0 x1 = if x0 == 0b1 then x1 else 0b0

// $LL.Main.go7
rw__LL_Main_go7 : [1] -> [1] -> [1] -> [1] -> [6]
rw__LL_Main_go7 x0 x1 x2 x3 = rw__LL_Main_go3 x0 x1 x2 x3

// $LL.Main.go6
rw__LL_Main_go6 : [1] -> [1] -> [1] -> [1] -> [6]
rw__LL_Main_go6 x0 x1 x2 x3 = (rw__LL_Main_go11 (rw__LL_Main_go x0 x1) x1) # (0b01 # (x1 # (x2 # x3)))

// $LL.Main.go5
rw__LL_Main_go5 : [1] -> [1] -> [1] -> [6]
rw__LL_Main_go5 x0 x1 x2 = if x0 == 0b0 then (rw__LL_Main_go10 x0 x1 x1 x2) else (0b000 # (x0 # (x1 # x2)))

// $LL.Main.go3
rw__LL_Main_go3 : [1] -> [1] -> [1] -> [1] -> [6]
