// Generated by rwc from device: top_level.
// rw_device maps a sequence of per-cycle inputs to per-cycle outputs.

module top_level where

// Helpers implementing ReWire Hyle primitive semantics.
rw'resize : {m, n} (fin m, fin n) => [n] -> [m]
rw'resize x = drop`{n} ((zero : [m]) # x)

rw'repl : {n, w} (fin n, fin w) => [w] -> [n * w]
rw'repl x = join (repeat`{n} x)

rw'parity : {n} (fin n) => [n] -> Bit
rw'parity x = foldr (^) False x

rw'sext : {m, n} (fin m, fin n, n >= 1) => [n] -> [m]
rw'sext x = if x @ 0 then ~ (rw'resize (~ x)) else rw'resize x

// main.$dispatch
rw_main__dispatch : [5] -> [1] -> [6]
rw_main__dispatch x0 x1 = if (take`{2} x0) == 0b00 then (rw_main_z (take`{1} (drop`{2} x0)) x1 (take`{1} (drop`{3} x0)) (drop`{4} x0)) else (if (take`{2} x0) == 0b01 then (rw_main_y (take`{1} (drop`{2} x0)) x1 (take`{1} (drop`{3} x0)) (drop`{4} x0)) else (rw_main_x x1 (take`{1} (drop`{3} x0)) (drop`{4} x0)))

// main.z
rw_main_z : [1] -> [1] -> [1] -> [1] -> [6]
rw_main_z x0 x1 x2 x3 = rw_main_go x2 x0

// main.y
rw_main_y : [1] -> [1] -> [1] -> [1] -> [6]
rw_main_y x0 x1 x2 x3 = s2 # (0b00 # (x1 # (x2 # x3)))
  where
    s0 : [1]
    s0 = if x0 @ 0 then x0 else 0b0
    s1 : [1]
    s1 = if ~ (x1 @ 0) then s0 else x0
    s2 : [1]
    s2 = if s1 @ 0 then x1 else 0b0

// main.arm
rw_main_arm : [1] -> [1] -> [1] -> [6]
rw_main_arm x0 x1 x2 = rw_main_y x0 x1 x1 x2

// main.x
rw_main_x : [1] -> [1] -> [1] -> [6]
rw_main_x x0 x1 x2 = if ~ (x0 @ 0) then (rw_main_arm x0 x1 x2) else (0b001 # (x0 # (x1 # x2)))

// main.go
rw_main_go : [1] -> [1] -> [6]
rw_main_go x0 x1 = 0x4 # (x0 # x1)

// Per-cycle step: outputs # next register values.
rw_step : [5] -> [1] -> [6]
rw_step st i = (take`{1} s4) # ((take`{3} (drop`{1} s4)) # ((take`{1} (drop`{4} s4)) # (drop`{5} s4)))
  where
    s0 : [3]
    s0 = take`{3} st
    s1 : [1]
    s1 = take`{1} (drop`{3} st)
    s2 : [1]
    s2 = drop`{4} st
    s3 : [1]
    s3 = i
    s4 : [6]
    s4 = rw_main__dispatch (s0 # (s1 # s2)) s3

// Device: top_level
// Inputs, MSB-first: __in0 : [1]
// Outputs, MSB-first: __out0 : [1]
rw_device : {n} (fin n) => [n][1] -> [n][1]
rw_device ins = outs
  where
    rs : [n][6]
    rs = [rw_step st i | st <- sts | i <- ins]
    sts : [1 + n][5]
    sts = [0b10001] # [drop`{1} r | r <- rs]
    outs : [n][1]
    outs = [take`{1} r | r <- rs]