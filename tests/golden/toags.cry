// Helpers implementing ReWire Hyle primitive semantics.
rw'resize : {m, n} (fin m, fin n) => [n] -> [m]
rw'resize x = drop`{n} ((zero : [m]) # x)

rw'repl : {n, w} (fin n, fin w) => [w] -> [n * w]
rw'repl x = join (repeat`{n} x)

rw'parity : {n} (fin n) => [n] -> Bit
rw'parity x = foldr (^) False x

rw'sext : {m, n} (fin m, fin n, n >= 1) => [n] -> [m]
rw'sext x = if x @ 0 then ~ (rw'resize (~ x)) else rw'resize x

// $Pure.dispatch
rw__Pure_dispatch : [5] -> [1] -> [6]
rw__Pure_dispatch x0 x1 = if (take`{2} x0) == 0b01 then (rw__LL_Main_go7 s0 x1 s1 s2) else (if (take`{2} x0) == 0b10 then (rw__LL_Main_go5 x1 s3 s4) else (rw__LL_Main_go10 s5 x1 s6 s7))
  where
    s0 : [1]
    s0 = take`{1} (drop`{2} x0)
    s1 : [1]
    s1 = take`{1} (drop`{3} x0)
    s2 : [1]
    s2 = drop`{4} x0
    s3 : [1]
    s3 = take`{1} (drop`{3} x0)
    s4 : [1]
    s4 = drop`{4} x0
    s5 : [1]
    s5 = take`{1} (drop`{2} x0)
    s6 : [1]
    s6 = take`{1} (drop`{3} x0)
    s7 : [1]
    s7 = drop`{4} x0

