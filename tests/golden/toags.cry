// Generated by rwc from device: top_level.
// rw_device maps a sequence of per-cycle inputs to per-cycle outputs.

module top_level where

// Helpers implementing ReWire Hyle primitive semantics.
rw'resize : {m, n} (fin m, fin n) => [n] -> [m]
rw'resize x = drop`{n} ((zero : [m]) # x)

rw'repl : {n, w} (fin n, fin w) => [w] -> [n * w]
rw'repl x = join (repeat`{n} x)

rw'parity : {n} (fin n) => [n] -> Bit
rw'parity x = foldr (^) False x

rw'sext : {m, n} (fin m, fin n, n >= 1) => [n] -> [m]
rw'sext x = if x @ 0 then ~ (rw'resize (~ x)) else rw'resize x

// $Pure.dispatch
rw__Pure_dispatch : [5] -> [1] -> [6]
rw__Pure_dispatch x0 x1 = if (take`{2} x0) == 0b00 then (rw__L_z4 s0 x1 s1 s2) else (if (take`{2} x0) == 0b01 then (rw__L_y3 s3 x1 s4 s5) else (rw__L_x2 x1 s6 s7))
  where
    s0 : [1]
    s0 = take`{1} (drop`{2} x0)
    s1 : [1]
    s1 = take`{1} (drop`{3} x0)
    s2 : [1]
    s2 = drop`{4} x0
    s3 : [1]
    s3 = take`{1} (drop`{2} x0)
    s4 : [1]
    s4 = take`{1} (drop`{3} x0)
    s5 : [1]
    s5 = drop`{4} x0
    s6 : [1]
    s6 = take`{1} (drop`{3} x0)
    s7 : [1]
    s7 = drop`{4} x0

// $LL.L.y35
rw__LL_L_y35 : [1] -> [1] -> [1]
rw__LL_L_y35 x0 x1 = if x1 == 0b0 then (rw__LL_L_y3 (rw__LL_L_y34 x0 x0)) else x0

// $LL.L.y34
rw__LL_L_y34 : [1] -> [1] -> [1]
rw__LL_L_y34 x0 x1 = if x1 == 0b1 then x0 else 0b0

// $LL.L.y33
rw__LL_L_y33 : [1] -> [1] -> [1]
rw__LL_L_y33 x0 x1 = if x1 == 0b1 then x0 else 0b0

// $L.Main.go1
rw__L_Main_go1 : [1] -> [1] -> [6]
rw__L_Main_go1 x0 x1 = 0x4 # (x0 # x1)

// $LL.L.y32
rw__LL_L_y32 : [1] -> [1] -> [1] -> [1] -> [6]
rw__LL_L_y32 x0 x1 x2 x3 = rw__LL_L_y31 x0 x1 x2 (rw__LL_L_y33 x0 x3)

// $L.z4
rw__L_z4 : [1] -> [1] -> [1] -> [1] -> [6]
rw__L_z4 x0 x1 x2 x3 = rw__L_Main_go1 x2 x0

// $L.x2
rw__L_x2 : [1] -> [1] -> [1] -> [6]
rw__L_x2 x0 x1 x2 = if x0 == 0b0 then (rw__L_arm6 x0 x1 x2) else (0b001 # (x0 # (x1 # x2)))

// $LL.L.y31
rw__LL_L_y31 : [1] -> [1] -> [1] -> [1] -> [6]
rw__LL_L_y31 x0 x1 x2 x3 = x3 # (0b00 # (x0 # (x2 # x1)))

// $LL.L.y3
rw__LL_L_y3 : [1] -> [1]
rw__LL_L_y3 x0 = x0

// $L.arm6
rw__L_arm6 : [1] -> [1] -> [1] -> [6]
rw__L_arm6 x0 x1 x2 = rw__L_y3 x0 x1 x1 x2

// $L.y3
rw__L_y3 : [1] -> [1] -> [1] -> [1] -> [6]
rw__L_y3 x0 x1 x2 x3 = rw__LL_L_y32 x1 x3 x2 (rw__LL_L_y35 x0 x1)

// Per-cycle step: outputs # next register values.
rw_step : [5] -> [1] -> [6]
rw_step st i = (take`{1} s4) # ((take`{3} (drop`{1} s4)) # ((take`{1} (drop`{4} s4)) # (drop`{5} s4)))
  where
    s0 : [3]
    s0 = take`{3} st
    s1 : [1]
    s1 = take`{1} (drop`{3} st)
    s2 : [1]
    s2 = drop`{4} st
    s3 : [1]
    s3 = i
    s4 : [6]
    s4 = rw__Pure_dispatch (s0 # (s1 # s2)) s3

// Device: top_level
// Inputs, MSB-first: __in0 : [1]
// Outputs, MSB-first: __out0 : [1]
rw_device : {n} (fin n) => [n][1] -> [n][1]
rw_device ins = outs
  where
    rs : [n][6]
    rs = [rw_step st i | st <- sts | i <- ins]
    sts : [1 + n][5]
    sts = [0b10001] # [drop`{1} r | r <- rs]
    outs : [n][1]
    outs = [take`{1} r | r <- rs]