// Generated by rwc from device: top_level.
// rw_device maps a sequence of per-cycle inputs to per-cycle outputs.

module top_level where

// Helpers implementing ReWire Hyle primitive semantics.
rw'resize : {m, n} (fin m, fin n) => [n] -> [m]
rw'resize x = drop`{n} ((zero : [m]) # x)

rw'repl : {n, w} (fin n, fin w) => [w] -> [n * w]
rw'repl x = join (repeat`{n} x)

rw'parity : {n} (fin n) => [n] -> Bit
rw'parity x = foldr (^) False x

rw'sext : {m, n} (fin m, fin n, n >= 1) => [n] -> [m]
rw'sext x = if x @ 0 then ~ (rw'resize (~ x)) else rw'resize x

// $Pure.dispatch
rw__Pure_dispatch : [16] -> [8] -> [24]
rw__Pure_dispatch x0 x1 = rw__LL_Main_dev2 s0 x1 s1
  where
    s0 : [8]
    s0 = take`{8} x0
    s1 : [8]
    s1 = drop`{8} x0

// Main.dev
rw_Main_dev : [8] -> [8] -> [24]
rw_Main_dev x0 x1 = rw__LL_Main_dev5 x0 x1 x1

// $LL.Main.dev5
rw__LL_Main_dev5 : [8] -> [8] -> [8] -> [24]
rw__LL_Main_dev5 x0 x1 x2 = rw__LL_Main_dev4 x0 x1 x2

// $LL.Main.dev4
rw__LL_Main_dev4 : [8] -> [8] -> [8] -> [24]
rw__LL_Main_dev4 x0 x1 x2 = (x1 + x0) # (x0 # x2)

// $LL.Main.dev3
rw__LL_Main_dev3 : [8] -> [8] -> [24]
rw__LL_Main_dev3 x0 x1 = rw__LL_Main_dev x0 x1

// $LL.Main.dev2
rw__LL_Main_dev2 : [8] -> [8] -> [8] -> [24]
rw__LL_Main_dev2 x0 x1 x2 = rw__LL_Main_dev1 x0 x1 x2

// $LL.Main.dev1
rw__LL_Main_dev1 : [8] -> [8] -> [8] -> [24]
rw__LL_Main_dev1 x0 x1 x2 = rw__LL_Main_dev3 x0 x1

// $LL.Main.dev
rw__LL_Main_dev : [8] -> [8] -> [24]
rw__LL_Main_dev x0 x1 = rw_Main_dev x0 x1

// Per-cycle step: outputs # next register values.
rw_step : [16] -> [8] -> [24]
rw_step st i = (take`{8} s3) # ((take`{8} (drop`{8} s3)) # (drop`{16} s3))
  where
    s0 : [8]
    s0 = take`{8} st
    s1 : [8]
    s1 = drop`{8} st
    s2 : [8]
    s2 = i
    s3 : [24]
    s3 = rw__Pure_dispatch (s0 # s1) s2

// Device: top_level
// Inputs, MSB-first: __in0 : [8]
// Outputs, MSB-first: __out0 : [8]
rw_device : {n} (fin n) => [n][8] -> [n][8]
rw_device ins = outs
  where
    rs : [n][24]
    rs = [rw_step st i | st <- sts | i <- ins]
    sts : [1 + n][16]
    sts = [0x0300] # [drop`{8} r | r <- rs]
    outs : [n][8]
    outs = [take`{8} r | r <- rs]