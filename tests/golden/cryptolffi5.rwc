--| cryptol cry/cryseq.cry::tspw at [8] -> [8]
cry$tspw$8_8 : ([8]) -> [8]
cry$tspw$8_8 x$0 =
      x$0[7 +: 1] # x$0[3 +: 1] # x$0[6 +: 1] # x$0[2 +: 1] # x$0[5 +: 1] # x$0[1 +: 1] # x$0[4 +: 1] # x$0[0 +: 1]

device top_level
      input __in0 : [8]
      input __in1 : [8]
      output __out0 : [8]
      tag $x2 = 0
      let $in = __in0 # __in1
      let $res = main.$dispatch $in
      __out0 := $res