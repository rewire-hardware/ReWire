    s2 : [1]
    s2 = take`{1} (drop`{2} x0)
    s3 : [1]
    s3 = take`{1} (drop`{3} x0)
    s4 : [1]
    s4 = take`{1} (drop`{4} x0)
    s5 : [1]
    s5 = take`{1} (drop`{5} x0)
    s6 : [1]
    s6 = take`{1} (drop`{6} x0)
    s7 : [1]
    s7 = take`{1} (drop`{7} x0)
    s8 : [1]
    s8 = take`{1} (drop`{8} x0)
    s9 : [1]
    s9 = drop`{9} x0

// Main.addr_in
rw_Main_addr_in : [46] -> [10]
rw_Main_addr_in x0 = s0
  where
    s0 : [10]
    s0 = take`{10} (drop`{32} x0)

// $LL.Main.nextKey1
rw__LL_Main_nextKey1 : [1] -> [10]
rw__LL_Main_nextKey1 x0 = if x0 == 0b1 then 0b0000000000 else 0b1111111111

// Main.idle
rw_Main_idle : [46] -> [205] -> [412]
rw_Main_idle x0 x1 = rw__LL_Main_idle x0 (rw_Main_partition_in x0) x1

// $LL.Main.set_partition_reg
rw__LL_Main_set_partition_reg : [2] -> [205] -> [205] -> [205]
rw__LL_Main_set_partition_reg x0 x1 x2 = (x0 # (s1 # (s2 # (s3 # s4)))) # s0
  where
    s0 : [128]
    s0 = drop`{77} x1
    s1 : [10]
    s1 = take`{10} (drop`{2} x1)
    s2 : [32]
    s2 = take`{32} (drop`{12} x1)
    s3 : [1]
    s3 = take`{1} (drop`{44} x1)
    s4 : [32]
    s4 = take`{32} (drop`{45} x1)

// Main.setloc
rw_Main_setloc : [10] -> [32] -> [205] -> [205]
rw_Main_setloc x0 x1 x2 = rw__LL_Main_setloc x1 x0 x2 x2

// $LL.Main.nextKey
rw__LL_Main_nextKey : [1] -> [1] -> [1] -> [1] -> [1] -> [1] -> [1] -> [1] -> [10]
rw__LL_Main_nextKey x0 x1 x2 x3 x4 x5 x6 x7 = if x7 == 0b0 then (rw__LL_Main_nextKey4 x0 x2 x3 x4 x5 x6 x1) else 0b1111111111

// Per-cycle step: outputs # next register values.
rw_step : [208] -> [46] -> [241]
rw_step st i = (take`{33} (drop`{171} s4)) # ((take`{3} (drop`{204} s4)) # ((take`{77} (drop`{207} s4)) # (drop`{284} s4)))
  where
    s0 : [3]
    s0 = take`{3} st
    s1 : [77]
    s1 = take`{77} (drop`{3} st)
    s2 : [128]
    s2 = drop`{80} st
    s3 : [46]
    s3 = i
    s4 : [412]
    s4 = rw__Pure_dispatch (s0 # (s1 # s2)) s3

// Device: top_level
// Inputs, MSB-first: __in0 : [46]
// Outputs, MSB-first: __out0 : [33]
rw_device : {n} (fin n) => [n][46] -> [n][33]
rw_device ins = outs
  where
    rs : [n][241]
    rs = [rw_step st i | st <- sts | i <- ins]
    sts : [1 + n][208]
    sts = [0x0006000000000000000000000000000000000000000000000000] # [drop`{33} r | r <- rs]
    outs : [n][33]
    outs = [take`{33} r | r <- rs]