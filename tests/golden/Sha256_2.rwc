$Pure.dispatch : ([1038], [68]) -> [1104]
$Pure.dispatch disc i =
      if eq disc[1036 +: 2] 2'h1 then (let s0 = disc[774 +: 256] in
            let s1 = disc[262 +: 512] in
            let s2 = disc[6 +: 256] in
            let s3 = disc[0 +: 6] in
            Main.dev i s0 s1 s2 s3)
            else if eq disc[1036 +: 2] 2'h2 then (let store0 = disc[1030 +: 6] in
