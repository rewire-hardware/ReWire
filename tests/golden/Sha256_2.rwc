            let s1 = disc[262 +: 512] in
            let s2 = disc[6 +: 256] in
            let s3 = disc[0 +: 6] in
            $LL.Main.loop6 store0 i s0 s1 s2 s3) else let s0 = disc[774 +: 256] in
