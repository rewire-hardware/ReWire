device top_level
      input __in0 : [68]
      output __out0 : [65]
      register __resumption_tag : [8] init 8'h0
      register __st0 : [224] init 224'h0
      register __st1 : [32] init 32'h0
      register __st2 : [512] init 512'h0
      register __st3 : [262] init 262'h0
      let $res = $Pure.dispatch (__resumption_tag # __st0 # __st1 # __st2 # __st3) __in0
      __out0 := $res[1038 +: 65]
      next __resumption_tag := $res[1030 +: 8]
      next __st0 := $res[806 +: 224]
      next __st1 := $res[774 +: 32]
      next __st2 := $res[262 +: 512]
      next __st3 := $res[0 +: 262]