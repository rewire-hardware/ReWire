      let b29 = ds[2 +: 1] in
      let b30 = ds[1 +: 1] in
      let b31 = ds[0 +: 1] in
      b30 # b31 # b0 # b1 # b2 # b3 # b4 # b5 # b6 # b7 # b8 # b9 # b10 # b11 # b12 # b13 # b14 # b15 # b16 # b17 # b18 # b19 # b20 # b21 # b22 # b23 # b24 # b25 # b26 # b27 # b28 # b29

$LL.Main.incCtr : ([6]) -> [6]
$LL.Main.incCtr wild =
      if eq wild 6'h0 then 6'h1
            else if eq wild 6'h1 then 6'h2 else if eq wild 6'h2 then 6'h3 else if eq wild 6'h3 then 6'h4 else if eq wild 6'h4 then 6'h5 else if eq wild 6'h5 then 6'h6 else if eq wild 6'h6 then 6'h7 else if eq wild 6'h7 then 6'h8 else if eq wild 6'h8 then 6'h9 else if eq wild 6'h9 then 6'ha else if eq wild 6'ha then 6'hb else if eq wild 6'hb then 6'hc else if eq wild 6'hc then 6'hd else if eq wild 6'hd then 6'he else if eq wild 6'he then 6'hf else if eq wild 6'hf then 6'h10 else if eq wild 6'h10 then 6'h11 else if eq wild 6'h11 then 6'h12 else if eq wild 6'h12 then 6'h13 else if eq wild 6'h13 then 6'h14 else if eq wild 6'h14 then 6'h15 else if eq wild 6'h15 then 6'h16 else if eq wild 6'h16 then 6'h17 else if eq wild 6'h17 then 6'h18 else if eq wild 6'h18 then 6'h19 else if eq wild 6'h19 then 6'h1a else if eq wild 6'h1a then 6'h1b else if eq wild 6'h1b then 6'h1c else if eq wild 6'h1c then 6'h1d else if eq wild 6'h1d then 6'h1e else if eq wild 6'h1e then 6'h1f else if eq wild 6'h1f then 6'h20 else if eq wild 6'h20 then 6'h21 else if eq wild 6'h21 then 6'h22 else if eq wild 6'h22 then 6'h23 else if eq wild 6'h23 then 6'h24 else if eq wild 6'h24 then 6'h25 else if eq wild 6'h25 then 6'h26 else if eq wild 6'h26 then 6'h27 else if eq wild 6'h27 then 6'h28 else if eq wild 6'h28 then 6'h29 else if eq wild 6'h29 then 6'h2a else if eq wild 6'h2a then 6'h2b else if eq wild 6'h2b then 6'h2c else if eq wild 6'h2c then 6'h2d else if eq wild 6'h2d then 6'h2e else if eq wild 6'h2e then 6'h2f else if eq wild 6'h2f then 6'h30 else if eq wild 6'h30 then 6'h31 else if eq wild 6'h31 then 6'h32 else if eq wild 6'h32 then 6'h33 else if eq wild 6'h33 then 6'h34 else if eq wild 6'h34 then 6'h35 else if eq wild 6'h35 then 6'h36 else if eq wild 6'h36 then 6'h37 else if eq wild 6'h37 then 6'h38 else if eq wild 6'h38 then 6'h39 else if eq wild 6'h39 then 6'h3a else if eq wild 6'h3a then 6'h3b else if eq wild 6'h3b then 6'h3c else if eq wild 6'h3c then 6'h3d else if eq wild 6'h3d then 6'h3e else if eq wild 6'h3e then 6'h3f else 6'h0

$L.arm45 : ([68], [32], [32], [32], [32], [32], [32], [32], [32], [32], [32], [32], [32], [32], [32], [32], [32], [256], [512], [256], [6]) -> [1103]
$L.arm45 i h1 h2 h3 h4 h5 h6 h7 h8 a b c d e f g h s0 s1 s2 s3 =
      $LL.L.arm453 e h8 b g f h2 h5 i s0 s3 c h4 s1 h3 h6 h7 d h (Main.plusW32 a h1)

$L.arm56 : ([6], [512], [32], [32], [32], [32], [32], [32], [32], [32], [32], [32], [32], [32], [32], [32], [32], [32], [256], [512], [256], [6]) -> [1103]
$L.arm56 ctr s w00 a b c d e f g h i j k l m n o s0 s1 s2 s3 =
      $LL.L.arm56 s0 ctr w00 s3 s2 (Main.updateSched s)

$LL.L.hw60 : ([256], [6], [256], [512]) -> [1103]
$LL.L.hw60 s2 s3 s0 s' =
      $L._unused37 s0 s' s2 s3

$L.Main.dev3 : ([68], [256], [512], [256], [6]) -> [1103]
$L.Main.dev3 ds s0 s1 s2 s3 =
      if eq ds[64 +: 4] 4'h0 then (let w1 = ds[32 +: 32] in
            let w2 = ds[0 +: 32] in
            $L.arm8 w1 w2 s0 s1 s2 s3)
            else if eq ds[64 +: 4] 4'h1 then (let w1 = ds[32 +: 32] in
            let w2 = ds[0 +: 32] in
            $L._unused6 w1 w2 s0 s1 s2 s3) else if eq ds[64 +: 4] 4'h2 then (let w1 = ds[32 +: 32] in
            let w2 = ds[0 +: 32] in
            $L.arm16 w1 w2 s0 s1 s2 s3) else if eq ds[64 +: 4] 4'h3 then (let w1 = ds[32 +: 32] in
            let w2 = ds[0 +: 32] in
            $L.arm20 w1 w2 s0 s1 s2 s3) else if eq ds[64 +: 4] 4'h4 then (let w1 = ds[32 +: 32] in
            let w2 = ds[0 +: 32] in
            $L.arm24 w1 w2 s0 s1 s2 s3) else if eq ds[64 +: 4] 4'h5 then (let w1 = ds[32 +: 32] in
            let w2 = ds[0 +: 32] in
            $L.arm28 w1 w2 s0 s1 s2 s3) else if eq ds[64 +: 4] 4'h6 then (let w1 = ds[32 +: 32] in
            let w2 = ds[0 +: 32] in
            $L.arm32 w1 w2 s0 s1 s2 s3) else if eq ds[64 +: 4] 4'h7 then (let w1 = ds[32 +: 32] in
            let w2 = ds[0 +: 32] in
            $L.arm36 w1 w2 s0 s1 s2 s3) else if eq ds[64 +: 4] 4'h8 then (let w1 = ds[32 +: 32] in
            let w2 = ds[0 +: 32] in
            $L.arm61 w1 w2 s0 s1 s2 s3) else if eq ds[64 +: 4] 4'h9 then $L.arm64 s0 s1 s2 s3 else if eq ds[64 +: 4] 4'ha then $L.arm67 s0 s1 s2 s3 else if eq ds[64 +: 4] 4'hb then $L.arm70 s0 s1 s2 s3 else $L.arm73 s0 s1 s2 s3

Main.ch : ([32], [32], [32]) -> [32]
Main.ch x y z =
      Main.xorW32 (Main.andW32 x y) (Main.andW32 (Main.notW32 x) z)

$L.arm28 : ([32], [32], [256], [512], [256], [6]) -> [1103]
$L.arm28 w1 w2 s0 s1 $x $x1 =
      $L.hw27 w1 w2 s1 s0 s1 $x $x1

$L.hw31 : ([32], [32], [512], [256], [512], [256], [6]) -> [1103]
$L.hw31 w1 w2 hw s0 s1 s2 s3 =
      $LL.L.hw311 s2 s3 s0 (let x0 = hw[480 +: 32] in
      let x1 = hw[448 +: 32] in
      let x2 = hw[416 +: 32] in
      let x3 = hw[384 +: 32] in
      let x4 = hw[352 +: 32] in
      let x5 = hw[320 +: 32] in
      let x6 = hw[288 +: 32] in
      let x7 = hw[256 +: 32] in
      let x8 = hw[224 +: 32] in
      let x9 = hw[192 +: 32] in
      let xc = hw[96 +: 32] in
      let xd = hw[64 +: 32] in
      let xe = hw[32 +: 32] in
      let xf = hw[0 +: 32] in
      $LL.L.hw151 (x0 # x1 # x2 # x3 # x4 # x5 # x6 # x7 # x8 # x9 # w1 # w2 # xc # xd # xe # xf))

$L._unused38 : ([68], [256], [512], [256], [6]) -> [1103]
$L._unused38 _unused $x $x1 $x2 $x3 =
      $L.Main.genhash'48 $x $x1 $x2 $x3

Main.digest0 : ([256]) -> [65]
Main.digest0 ds =
      let x0 = ds[224 +: 32] in
      let x1 = ds[192 +: 32] in
      1'h0 # x0 # x1

$LL.L.s53 : ([256], [32], [6], [6], [256], [512], [32]) -> [1103]
$LL.L.s53 s2 w s3 ctr s s1 $a =
      $LL.L.s531 s2 s3 ctr s1 (Main.step256 $a w s)

$L.hw19 : ([32], [32], [512], [256], [512], [256], [6]) -> [1103]
$L.hw19 w1 w2 hw s0 s1 s2 s3 =
      $LL.L.hw191 s0 s3 s2 (let x0 = hw[480 +: 32] in
      let x1 = hw[448 +: 32] in
      let x2 = hw[416 +: 32] in
      let x3 = hw[384 +: 32] in
      let x6 = hw[288 +: 32] in
      let x7 = hw[256 +: 32] in
      let x8 = hw[224 +: 32] in
      let x9 = hw[192 +: 32] in
      let xa = hw[160 +: 32] in
      let xb = hw[128 +: 32] in
      let xc = hw[96 +: 32] in
      let xd = hw[64 +: 32] in
      let xe = hw[32 +: 32] in
      let xf = hw[0 +: 32] in
      $LL.L.hw151 (x0 # x1 # x2 # x3 # w1 # w2 # x6 # x7 # x8 # x9 # xa # xb # xc # xd # xe # xf))

$LL.L.arm45 : ([68], [256], [6], [512], [256]) -> [1103]
$LL.L.arm45 i s0 s3 s1 s' =
      $L.Main.dev3 i s0 s1 s' s3

Main.shiftR3 : ([32]) -> [32]
Main.shiftR3 ds =
      let b0 = ds[31 +: 1] in
      let b1 = ds[30 +: 1] in
      let b2 = ds[29 +: 1] in
      let b3 = ds[28 +: 1] in
      let b4 = ds[27 +: 1] in
      let b5 = ds[26 +: 1] in
      let b6 = ds[25 +: 1] in
      let b7 = ds[24 +: 1] in
      let b8 = ds[23 +: 1] in
      let b9 = ds[22 +: 1] in
      let b10 = ds[21 +: 1] in
      let b11 = ds[20 +: 1] in
      let b12 = ds[19 +: 1] in
      let b13 = ds[18 +: 1] in
      let b14 = ds[17 +: 1] in
      let b15 = ds[16 +: 1] in
      let b16 = ds[15 +: 1] in
      let b17 = ds[14 +: 1] in
      let b18 = ds[13 +: 1] in
      let b19 = ds[12 +: 1] in
