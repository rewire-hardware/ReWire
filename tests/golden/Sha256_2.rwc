            let s1 = disc[262 +: 512] in
            let s2 = disc[6 +: 256] in
            let s3 = disc[0 +: 6] in
            $L.i41 e i s s1 s2 s3) else let s = disc[774 +: 256] in
            let s1 = disc[262 +: 512] in
            let s2 = disc[6 +: 256] in
            let s3 = disc[0 +: 6] in
            $L._unused38 i s s1 s2 s3

