$Pure.dispatch : ([8]) -> [16]
$Pure.dispatch i =
      ReWire.Monad.iter1 i

$LL.Main.f1 : ([8], [8]) -> [16]
$LL.Main.f1 a b =
      udiv a b # xor (umod a b) 8'hff

ReWire.Monad.iter1 : ([8]) -> [16]
ReWire.Monad.iter1 i =
      Main.f i

Main.f : ([8]) -> [16]
Main.f a =
      $LL.Main.f1 a (and a 8'h3)

device top_level
      input __in0 : [8]
      output __out0 : [16]
      let $res = $Pure.dispatch __in0
      __out0 := $res