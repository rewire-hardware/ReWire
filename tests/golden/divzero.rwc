--| state dispatch for process main: 0=$x2
main.$dispatch : ([8]) -> [16]
main.$dispatch i =
      main.$x2 i

--| block '$L.$x2' of process main (state 0)
main.$x2 : ([8]) -> [16]
main.$x2 $x =
      main.iter$W8$W16$sMain_f $x

--| block '$L.ReWire.Monad.iter$W8$W16$sMain_f' of process main
main.iter$W8$W16$sMain_f : ([8]) -> [16]
main.iter$W8$W16$sMain_f i =
      let $a = Main.f i in
      $a

Main.f : ([8]) -> [16]
Main.f a =
      let b = and a 8'h3 in
      udiv a b # xor (umod a b) 8'hff

device top_level
      input __in0 : [8]
      output __out0 : [16]
      tag $x2 = 0
      let $res = main.$dispatch __in0
      __out0 := $res