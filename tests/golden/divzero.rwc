$Pure.dispatch : ([8]) -> [16]
$Pure.dispatch i =
      ReWire.Monad.iter1 i

ReWire.Monad.iter1 : ([8]) -> [16]
ReWire.Monad.iter1 $1 =
      Main.f1 $1

$LL.Main.f2 : ([8], [8]) -> [16]
$LL.Main.f2 a $1 =
      udiv a $1 # xor (umod a $1) 8'hff

$LL.Main.f1 : ([8]) -> [16]
$LL.Main.f1 $2 =
      $LL.Main.f2 $2 (and $2 8'h3)

Main.f1 : ([8]) -> [16]
Main.f1 $x =
      $LL.Main.f1 $x

device top_level
      input __in0 : [8]
      output __out0 : [16]
      let $res = $Pure.dispatch __in0
      __out0 := $res