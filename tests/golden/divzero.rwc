$Pure.dispatch : ([8]) -> [16]
$Pure.dispatch i =
      ReWire.Monad.iter$1$s2 i

ReWire.Monad.iter$1$s2 : ([8]) -> [16]
ReWire.Monad.iter$1$s2 i =
      Main.f i

Main.f : ([8]) -> [16]
Main.f a =
      $LL.Main.f a (and a 8'h3)

$LL.Main.f : ([8], [8]) -> [16]
$LL.Main.f a b =
      udiv a b # xor (umod a b) 8'hff

device top_level
      input __in0 : [8]
      output __out0 : [16]
      let $res = $Pure.dispatch __in0
      __out0 := $res