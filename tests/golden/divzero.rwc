$Pure.dispatch : ([8]) -> [16]
$Pure.dispatch i =
      $LL.Pure.dispatch i

$LL.Main.f6 : ([8], [8]) -> [16]
$LL.Main.f6 a b =
      udiv a b # xor (umod a b) 8'hff

$LL.Pure.dispatch : ([8]) -> [16]
$LL.Pure.dispatch i =
      ReWire.Monad.iter i

$LL.Main.f4 : ([8], [8]) -> [16]
$LL.Main.f4 $x $x1 =
      $LL.Main.f6 $x $x1

$LL.Main.f3 : ([8]) -> [16]
$LL.Main.f3 $x =
      $LL.Main.f1 $x

Main.f : ([8]) -> [16]
Main.f $x =
      $LL.Main.f3 $x

$LL.Main.f1 : ([8]) -> [16]
$LL.Main.f1 a =
      $LL.Main.f a (and a 8'h3)

ReWire.Monad.iter : ([8]) -> [16]
ReWire.Monad.iter $1 =
      Main.f $1

$LL.Main.f : ([8], [8]) -> [16]
$LL.Main.f $x $x1 =
      $LL.Main.f4 $x $x1

device top_level
      input __in0 : [8]
      output __out0 : [16]
      let $res = $Pure.dispatch __in0
      __out0 := $res