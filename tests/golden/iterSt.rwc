$Pure.dispatch : ([1], [1]) -> [4]
$Pure.dispatch disc i =
      ReWire.Monad.iterSt i disc

$LL.ReWire.Monad.iterSt5 : ([2], [1]) -> [4]
$LL.ReWire.Monad.iterSt5 ds sto0 =
      let o = ds[1 +: 1] in
      let s = ds[0 +: 1] in
      $LL.ReWire.Monad.iterSt4 o s

ReWire.Monad.iterSt : ([1], [1]) -> [4]
ReWire.Monad.iterSt i sto0 =
      let $t1 = (let $t0 = $LL.ReWire.Monad.iterSt i sto0 sto0 in
      let v = $t0[1 +: 2] in
      let s0 = $t0[0 +: 1] in
      1'h0 # v # s0) in
      let v = $t1[1 +: 2] in
      let s0 = $t1[0 +: 1] in
      $LL.ReWire.Monad.iterSt5 v s0

$LL.Main.f2 : ([1], [1]) -> [1]
$LL.Main.f2 $x $x1 =
      $LL.Main.f $x $x1

$LL.ReWire.Monad.iterSt4 : ([1], [1]) -> [4]
$LL.ReWire.Monad.iterSt4 o sto0 =
      2'h2 # o # sto0

Main.f1 : ([1], [1]) -> [2]
Main.f1 i s =
      $LL.Main.f2 s i # s

$LL.ReWire.Monad.iterSt : ([1], [1], [1]) -> [3]
$LL.ReWire.Monad.iterSt i x sigma0 =
      Main.f1 i x # sigma0

$LL.Main.f : ([1], [1]) -> [1]
$LL.Main.f a b =
      let $t1 = xor a b in
      $t1

device top_level
      input __in0 : [1]
      output __out0 : [1]
      register __st0 : [1] init 1'h0
      let $res = $Pure.dispatch __st0 __in0
      __out0 := $res[1 +: 1]
      next __st0 := $res[0 +: 1]