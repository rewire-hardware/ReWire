$Pure.dispatch : ([1], [1]) -> [4]
$Pure.dispatch disc i =
      ReWire.Monad.iterSt1 i disc

$LL.Main.f3 : ([2]) -> [2]
$LL.Main.f3 $2 =
      let i = $2[1 +: 1] in
      let s = $2[0 +: 1] in
      $LL.Main.f2 s i # s

$LL.ReWire.Monad.iterSt5 : ([1], [1]) -> [4]
$LL.ReWire.Monad.iterSt5 o sto0 =
      2'h2 # o # sto0

$LL.ReWire.Monad.iterSt4 : ([1], [1], [1]) -> [3]
$LL.ReWire.Monad.iterSt4 $3 x sigma0 =
      Main.f $3 x # sigma0

$LL.ReWire.Monad.iterSt3 : ([2], [1]) -> [4]
$LL.ReWire.Monad.iterSt3 $9 sto0 =
      let o = $9[1 +: 1] in
      let s = $9[0 +: 1] in
      $LL.ReWire.Monad.iterSt5 o s

$LL.Main.f2 : ([1], [1]) -> [1]
$LL.Main.f2 $x $x1 =
      $LL.Main.f1 $x $x1

ReWire.Monad.iterSt1 : ([1], [1]) -> [4]
ReWire.Monad.iterSt1 $3 sto0 =
      let $t1 = (let $t0 = $LL.ReWire.Monad.iterSt4 $3 sto0 sto0 in
      let v = $t0[1 +: 2] in
      let s0 = $t0[0 +: 1] in
      1'h0 # v # s0) in
      let v = $t1[1 +: 2] in
      let s0 = $t1[0 +: 1] in
      $LL.ReWire.Monad.iterSt3 v s0

Main.f : ([1], [1]) -> [2]
Main.f $0 $1 =
      $LL.Main.f3 ($0 # $1)

$LL.Main.f1 : ([1], [1]) -> [1]
$LL.Main.f1 $14 $15 =
      $LL.Main.f ($14 # $15)

$LL.Main.f : ([2]) -> [1]
$LL.Main.f $31 =
      let a = $31[1 +: 1] in
      let b = $31[0 +: 1] in
      let $t1 = xor a b in
      $t1

device top_level
      input __in0 : [1]
      output __out0 : [1]
      register __st0 : [1] init 1'h0
      let $res = $Pure.dispatch __st0 __in0
      __out0 := $res[1 +: 1]
      next __st0 := $res[0 +: 1]