Main.compute : ([16]) -> [8]
Main.compute w =
      let $t2 = (let $t1 = w[15 +: 1] in
      if eq $t1 1'h1 then w[8 +: 1]
            else 1'h0) in
      if eq $t2 1'h0 then w[8 +: 8]
