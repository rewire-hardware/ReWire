$Pure.dispatch : ([16]) -> [8]
$Pure.dispatch i =
      Main.loop1 i

Main.compute : ([16]) -> [8]
Main.compute $x =
      $LL.Main.compute1 $x

$LL.Main.compute2 : ([16], [1]) -> [8]
$LL.Main.compute2 w $5 =
      if eq $5 1'h1 then w[0 +: 8]
            else $LL.Main.compute w ("ReWire.Prelude.&&" w[15 +: 1] w[8 +: 1])

$LL.Main.compute1 : ([16]) -> [8]
$LL.Main.compute1 $6 =
      $LL.Main.compute2 $6 ("ReWire.Prelude.&&" $6[15 +: 1] $6[8 +: 1])

$LL.Main.loop1 : ([16]) -> [8]
$LL.Main.loop1 $3 =
      $LL.Main.loop (Main.compute $3)

Main.loop1 : ([16]) -> [8]
Main.loop1 $x =
      $LL.Main.loop1 $x

"ReWire.Prelude.&&" : ([1], [1]) -> [1]
"ReWire.Prelude.&&" $10 $11 =
      "$LL.ReWire.Prelude.&&" $10 $11 ($10 # $11)

$LL.Main.compute : ([16], [1]) -> [8]
$LL.Main.compute w $4 =
      w[8 +: 8]

"$LL.ReWire.Prelude.&&1" : ([2]) -> [1]
"$LL.ReWire.Prelude.&&1" $51 =
      1'h0

"$LL.ReWire.Prelude.&&" : ([1], [1], [2]) -> [1]
"$LL.ReWire.Prelude.&&" $10 $11 $52 =
      if eq $52[1 +: 1] 1'h1 then (let b = $52[0 +: 1] in
            b)
            else "$LL.ReWire.Prelude.&&1" ($10 # $11)

$LL.Main.loop : ([8]) -> [8]
$LL.Main.loop rabind =
      rabind

device top_level
      input __in0 : [16]
      output __out0 : [8]
      let $res = $Pure.dispatch __in0
      __out0 := $res