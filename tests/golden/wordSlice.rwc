$Pure.dispatch : ([16]) -> [8]
$Pure.dispatch i =
      Main.loop1 i

Main.compute : ([16]) -> [8]
Main.compute w =
      $LL.Main.compute1 w ($LL.Main.compute w[15 +: 1] w[8 +: 1])

$LL.Main.loop : ([8]) -> [8]
$LL.Main.loop rabind =
      rabind

Main.loop1 : ([16]) -> [8]
Main.loop1 i =
      $LL.Main.loop (Main.compute i)

$LL.Main.compute2 : ([1], [1]) -> [1]
$LL.Main.compute2 x y =
      if eq x 1'h1 then y
            else 1'h0

$LL.Main.compute1 : ([16], [1]) -> [8]
$LL.Main.compute1 w wild =
      if eq wild 1'h0 then w[8 +: 8]
            else w[0 +: 8]

$LL.Main.compute : ([1], [1]) -> [1]
$LL.Main.compute $x $x1 =
      $LL.Main.compute2 $x $x1

device top_level
      input __in0 : [16]
      output __out0 : [8]
      let $res = $Pure.dispatch __in0
      __out0 := $res