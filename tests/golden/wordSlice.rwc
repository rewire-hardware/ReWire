$Pure.dispatch : ([16]) -> [8]
$Pure.dispatch i =
      $L.$x4 i

Main.compute : ([16]) -> [8]
Main.compute w =
      $LL.Main.compute w ($LL.Main.compute1 w w[15 +: 1])

$LL.Main.compute1 : ([16], [1]) -> [1]
$LL.Main.compute1 w s =
      if eq s 1'h1 then w[8 +: 1]
            else 1'h0

$L.Main.loop3 : ([16]) -> [8]
$L.Main.loop3 i =
      $L.$x5 (Main.compute i)

$L.$x5 : ([8]) -> [8]
$L.$x5 $x =
      $x

$LL.Main.compute : ([16], [1]) -> [8]
$LL.Main.compute w wild =
      if eq wild 1'h0 then w[8 +: 8]
            else w[0 +: 8]

$L.$x4 : ([16]) -> [8]
$L.$x4 $x =
      $L.Main.loop3 $x

device top_level
      input __in0 : [16]
      output __out0 : [8]
      let $res = $Pure.dispatch __in0
      __out0 := $res