$Pure.dispatch : ([8]) -> [8]
$Pure.dispatch i =
      Main.loop i

Main.compute : ([8]) -> [8]
Main.compute w =
      umod (udiv (mul (pow (add w 8'h1) 8'h2) (sub w 8'h2)) 8'h3) (add w 8'h1)

Main.loop : ([8]) -> [8]
Main.loop i =
      $LL.Main.loop1 (Main.compute i)

$LL.Main.loop1 : ([8]) -> [8]
$LL.Main.loop1 rabind =
      rabind

device top_level
      input __in0 : [8]
      output __out0 : [8]
      let $res = $Pure.dispatch __in0
      __out0 := $res