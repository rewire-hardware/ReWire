--| state dispatch for process main: 0=$x2
main.$dispatch : ([8]) -> [8]
main.$dispatch i =
      main.$x2 i

--| block '$L.$x2' of process main (state 0)
main.$x2 : ([8]) -> [8]
main.$x2 $x =
      main.loop $x

--| block '$L.$x3' of process main
main.$x3 : ([8]) -> [8]
main.$x3 $x =
      $x

--| block '$L.Main.loop' of process main
main.loop : ([8]) -> [8]
main.loop i =
      let $a = Main.compute i in
      main.$x3 $a

Main.compute : ([8]) -> [8]
Main.compute w =
      umod (udiv (mul (pow (add w 8'h1) 8'h2) (sub w 8'h2)) 8'h3) (add w 8'h1)

device top_level
      input __in0 : [8]
      output __out0 : [8]
      tag $x2 = 0
      let $res = main.$dispatch __in0
      __out0 := $res