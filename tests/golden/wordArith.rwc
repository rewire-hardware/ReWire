$Pure.dispatch : ([8]) -> [8]
$Pure.dispatch i =
      $L.$x4 i

Main.compute : ([8]) -> [8]
Main.compute w =
      umod (udiv (mul (pow (add w 8'h1) 8'h2) (sub w 8'h2)) 8'h3) (add w 8'h1)

$L.Main.loop3 : ([8]) -> [8]
$L.Main.loop3 i =
      $L.$x5 (Main.compute i)

$L.$x5 : ([8]) -> [8]
$L.$x5 $x =
      $x

$L.$x4 : ([8]) -> [8]
$L.$x4 $x =
      $L.Main.loop3 $x

device top_level
      input __in0 : [8]
      output __out0 : [8]
      let $res = $Pure.dispatch __in0
      __out0 := $res