// Generated by rwc from device: top_level.
// rw_device maps a sequence of per-cycle inputs to per-cycle outputs.

module top_level where

// Helpers implementing ReWire Hyle primitive semantics.
rw'resize : {m, n} (fin m, fin n) => [n] -> [m]
rw'resize x = drop`{n} ((zero : [m]) # x)

rw'repl : {n, w} (fin n, fin w) => [w] -> [n * w]
rw'repl x = join (repeat`{n} x)

rw'parity : {n} (fin n) => [n] -> Bit
rw'parity x = foldr (^) False x

rw'sext : {m, n} (fin m, fin n, n >= 1) => [n] -> [m]
rw'sext x = if x @ 0 then ~ (rw'resize (~ x)) else rw'resize x

// main.$dispatch
rw_main__dispatch : [28] -> [4] -> [44]
rw_main__dispatch x0 x1 = rw_main__x2 x1 (take`{4} x0) (take`{8} (drop`{4} x0)) (drop`{12} x0)

// main.$x2
rw_main__x2 : [4] -> [4] -> [8] -> [16] -> [44]
rw_main__x2 x0 x1 x2 x3 = rw_main_loop x0 x1 x2 x3

// main._unused6
rw_main__unused6 : [4] -> [16] -> [4] -> [8] -> [16] -> [44]
rw_main__unused6 x0 x1 x2 x3 x4 = ((rw'resize`{16} x0) + x1) # (x2 # (x3 # x4))

// main._unused5
rw_main__unused5 : [4] -> [8] -> [16] -> [4] -> [8] -> [16] -> [44]
rw_main__unused5 x0 x1 x2 x3 x4 x5 = rw_main__unused6 x0 x2 x3 x4 s0
  where
    s0 : [16]
    s0 = (rw'resize`{16} x1) + x2

// main._unused4
rw_main__unused4 : [4] -> [8] -> [16] -> [4] -> [8] -> [16] -> [44]
rw_main__unused4 x0 x1 x2 x3 x4 x5 = rw_main__unused5 x0 x1 x2 x3 s0 x5
  where
    s0 : [8]
    s0 = (rw'resize`{8} x0) + x1

// main.c2
rw_main_c2 : [4] -> [4] -> [8] -> [16] -> [4] -> [8] -> [16] -> [44]
rw_main_c2 x0 x1 x2 x3 x4 x5 x6 = rw_main__unused4 x1 x2 x3 x0 x5 x6

// main.b2
rw_main_b2 : [4] -> [4] -> [8] -> [4] -> [8] -> [16] -> [44]
rw_main_b2 x0 x1 x2 x3 x4 x5 = rw_main_c2 x0 x1 x2 x5 x3 x4 x5

// main.a2
rw_main_a2 : [4] -> [4] -> [4] -> [8] -> [16] -> [44]
rw_main_a2 x0 x1 x2 x3 x4 = rw_main_b2 x0 x1 x3 x2 x3 x4

// main.loop
rw_main_loop : [4] -> [4] -> [8] -> [16] -> [44]
rw_main_loop x0 x1 x2 x3 = rw_main_a2 x0 x1 x1 x2 x3

// Per-cycle step: outputs # next register values.
rw_step : [28] -> [4] -> [44]
rw_step st i = (take`{16} s4) # ((take`{4} (drop`{16} s4)) # ((take`{8} (drop`{20} s4)) # (drop`{28} s4)))
  where
    s0 : [4]
    s0 = take`{4} st
    s1 : [8]
    s1 = take`{8} (drop`{4} st)
    s2 : [16]
    s2 = drop`{12} st
    s3 : [4]
    s3 = i
    s4 : [44]
    s4 = rw_main__dispatch (s0 # (s1 # s2)) s3

// Device: top_level
// Inputs, MSB-first: __in0 : [4]
// Outputs, MSB-first: __out0 : [16]
rw_device : {n} (fin n) => [n][4] -> [n][16]
rw_device ins = outs
  where
    rs : [n][44]
    rs = [rw_step st i | st <- sts | i <- ins]
    sts : [1 + n][28]
    sts = [0x0030005] # [drop`{16} r | r <- rs]
    outs : [n][16]
    outs = [take`{16} r | r <- rs]