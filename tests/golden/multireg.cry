// Per-cycle step: outputs # next register values.
rw_step : [28] -> [4] -> [44]
rw_step st i = (take`{16} s4) # ((take`{4} (drop`{16} s4)) # ((take`{8} (drop`{20} s4)) # (drop`{28} s4)))
  where
    s0 : [4]
