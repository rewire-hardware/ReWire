// Per-cycle step: outputs # next register values.
rw_step : [28] -> [4] -> [44]
rw_step st i = (take`{16} (drop`{3} s4)) # ((take`{4} (drop`{19} s4)) # ((take`{8} (drop`{23} s4)) # (drop`{31} s4)))
  where
    s0 : [4]
    s0 = take`{4} st
    s1 : [8]
    s1 = take`{8} (drop`{4} st)
    s2 : [16]
    s2 = drop`{12} st
    s3 : [4]
    s3 = i
    s4 : [47]
    s4 = rw__Pure_dispatch (s0 # (s1 # s2)) s3

// Device: top_level
// Inputs, MSB-first: __in0 : [4]
// Outputs, MSB-first: __out0 : [16]
rw_device : {n} (fin n) => [n][4] -> [n][16]
rw_device ins = outs
  where
    rs : [n][44]
    rs = [rw_step st i | st <- sts | i <- ins]
    sts : [1 + n][28]
    sts = [0x0030005] # [drop`{16} r | r <- rs]
    outs : [n][16]
    outs = [take`{16} r | r <- rs]