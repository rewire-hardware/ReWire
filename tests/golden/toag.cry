// Generated by rwc from device: top_level.
// rw_device maps a sequence of per-cycle inputs to per-cycle outputs.

module top_level where

// Helpers implementing ReWire Hyle primitive semantics.
rw'resize : {m, n} (fin m, fin n) => [n] -> [m]
rw'resize x = drop`{n} ((zero : [m]) # x)

rw'repl : {n, w} (fin n, fin w) => [w] -> [n * w]
rw'repl x = join (repeat`{n} x)

rw'parity : {n} (fin n) => [n] -> Bit
rw'parity x = foldr (^) False x

rw'sext : {m, n} (fin m, fin n, n >= 1) => [n] -> [m]
rw'sext x = if x @ 0 then ~ (rw'resize (~ x)) else rw'resize x

// $Pure.dispatch
rw__Pure_dispatch : [3] -> [1] -> [4]
rw__Pure_dispatch x0 x1 = if (take`{2} x0) == 0b00 then (rw__L_z4 x1) else (if (take`{2} x0) == 0b01 then (rw__L_y3 s0 x1) else (rw__L_x2 x1))
  where
    s0 : [1]
    s0 = drop`{2} x0

// $LL.L.y35
rw__LL_L_y35 : [1] -> [1]
rw__LL_L_y35 x0 = x0

// $LL.L.y34
rw__LL_L_y34 : [1] -> [1] -> [1]
rw__LL_L_y34 x0 x1 = if x1 == 0b1 then x0 else 0b0

// $L.z4
rw__L_z4 : [1] -> [4]
rw__L_z4 x0 = 0x4

// $LL.L.y33
rw__LL_L_y33 : [1] -> [1] -> [1]
rw__LL_L_y33 x0 x1 = if x1 == 0b0 then (rw__LL_L_y35 (rw__LL_L_y3 x0 x0)) else x0

// $L.x2
rw__L_x2 : [1] -> [4]
rw__L_x2 x0 = if x0 == 0b0 then (x0 # (0b01 # x0)) else (0b001 # x0)

// $LL.L.y32
rw__LL_L_y32 : [1] -> [1] -> [4]
rw__LL_L_y32 x0 x1 = rw__LL_L_y31 (rw__LL_L_y34 x0 x1)

// $LL.L.y31
rw__LL_L_y31 : [1] -> [4]
rw__LL_L_y31 x0 = x0 # 0b000

// $LL.L.y3
rw__LL_L_y3 : [1] -> [1] -> [1]
rw__LL_L_y3 x0 x1 = if x1 == 0b1 then x0 else 0b0

// $L.y3
rw__L_y3 : [1] -> [1] -> [4]
rw__L_y3 x0 x1 = rw__LL_L_y32 x1 (rw__LL_L_y33 x0 x1)

// Per-cycle step: outputs # next register values.
rw_step : [3] -> [1] -> [4]
rw_step st i = (take`{1} s2) # (drop`{1} s2)
  where
    s0 : [3]
    s0 = st
    s1 : [1]
    s1 = i
    s2 : [4]
    s2 = rw__Pure_dispatch s0 s1

// Device: top_level
// Inputs, MSB-first: __in0 : [1]
// Outputs, MSB-first: __out0 : [1]
rw_device : {n} (fin n) => [n][1] -> [n][1]
rw_device ins = outs
  where
    rs : [n][4]
    rs = [rw_step st i | st <- sts | i <- ins]
    sts : [1 + n][3]
    sts = [0b100] # [drop`{1} r | r <- rs]
    outs : [n][1]
    outs = [take`{1} r | r <- rs]