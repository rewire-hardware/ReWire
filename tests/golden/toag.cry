// Generated by rwc from device: top_level.
// rw_device maps a sequence of per-cycle inputs to per-cycle outputs.

module top_level where

// Helpers implementing ReWire Hyle primitive semantics.
rw'resize : {m, n} (fin m, fin n) => [n] -> [m]
rw'resize x = drop`{n} ((zero : [m]) # x)

rw'repl : {n, w} (fin n, fin w) => [w] -> [n * w]
rw'repl x = join (repeat`{n} x)

rw'parity : {n} (fin n) => [n] -> Bit
rw'parity x = foldr (^) False x

rw'sext : {m, n} (fin m, fin n, n >= 1) => [n] -> [m]
rw'sext x = if x @ 0 then ~ (rw'resize (~ x)) else rw'resize x

// $Pure.dispatch
rw__Pure_dispatch : [3] -> [1] -> [4]
rw__Pure_dispatch x0 x1 = if (take`{2} x0) == 0b01 then (rw__LL_Main_go8 x1) else (if (take`{2} x0) == 0b10 then (rw__LL_Main_go9 s0 x1) else (if (take`{2} x0) == 0b11 then (rw__LL_Main_go1 x1) else (rw__LL_Main_go9 s1 x1)))
  where
    s0 : [1]
    s0 = drop`{2} x0
    s1 : [1]
    s1 = drop`{2} x0

// $LL.Main.go10
rw__LL_Main_go10 : [1] -> [1] -> [4]
rw__LL_Main_go10 x0 x1 = rw__LL_Main_go7 x0 x1

// $LL.Main.go9
rw__LL_Main_go9 : [1] -> [1] -> [4]
rw__LL_Main_go9 x0 x1 = rw__LL_Main_go10 x0 x1

// $LL.Main.go8
rw__LL_Main_go8 : [1] -> [4]
rw__LL_Main_go8 x0 = 0x6

// $LL.Main.go7
rw__LL_Main_go7 : [1] -> [1] -> [4]
rw__LL_Main_go7 x0 x1 = (rw__LL_Main_go5 (rw__LL_Main_go2 x0 x1) x1) # 0b010

// $LL.Main.go5
rw__LL_Main_go5 : [1] -> [1] -> [1]
rw__LL_Main_go5 x0 x1 = rw__LL_Main_go4 x0 x1

// $LL.Main.go4
rw__LL_Main_go4 : [1] -> [1] -> [1]
rw__LL_Main_go4 x0 x1 = if x0 == 0b1 then x1 else 0b0

// $LL.Main.go2
rw__LL_Main_go2 : [1] -> [1] -> [1]
rw__LL_Main_go2 x0 x1 = if x1 == 0b0 then (rw__LL_Main_go5 x0 x0) else x0

// $LL.Main.go1
rw__LL_Main_go1 : [1] -> [4]
rw__LL_Main_go1 x0 = if x0 == 0b0 then (x0 # (0b10 # x0)) else (0b000 # x0)

// Per-cycle step: outputs # next register values.
rw_step : [3] -> [1] -> [4]
rw_step st i = (take`{1} s2) # (drop`{1} s2)
  where
    s0 : [3]
    s0 = st
    s1 : [1]
    s1 = i
    s2 : [4]
    s2 = rw__Pure_dispatch s0 s1

// Device: top_level
// Inputs, MSB-first: __in0 : [1]
// Outputs, MSB-first: __out0 : [1]
rw_device : {n} (fin n) => [n][1] -> [n][1]
rw_device ins = outs
  where
    rs : [n][4]
    rs = [rw_step st i | st <- sts | i <- ins]
    sts : [1 + n][3]
    sts = [0b110] # [drop`{1} r | r <- rs]
    outs : [n][1]
    outs = [take`{1} r | r <- rs]