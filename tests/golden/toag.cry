// Generated by rwc from device: top_level.
// rw_device maps a sequence of per-cycle inputs to per-cycle outputs.

module top_level where

// Helpers implementing ReWire Hyle primitive semantics.
rw'resize : {m, n} (fin m, fin n) => [n] -> [m]
rw'resize x = drop`{n} ((zero : [m]) # x)

rw'repl : {n, w} (fin n, fin w) => [w] -> [n * w]
rw'repl x = join (repeat`{n} x)

rw'parity : {n} (fin n) => [n] -> Bit
rw'parity x = foldr (^) False x

rw'sext : {m, n} (fin m, fin n, n >= 1) => [n] -> [m]
rw'sext x = if x @ 0 then ~ (rw'resize (~ x)) else rw'resize x

// main.$dispatch
rw_main__dispatch : [3] -> [1] -> [4]
rw_main__dispatch x0 x1 = if (take`{2} x0) == 0b00 then (rw_main__L_z4_236 x1) else (if (take`{2} x0) == 0b01 then (rw_main__L_y3_235 (drop`{2} x0) x1) else (rw_main__L_x2_234 x1))

// main.$L.z4$236
rw_main__L_z4_236 : [1] -> [4]
rw_main__L_z4_236 x0 = 0x4

// main.$L.y3$235
rw_main__L_y3_235 : [1] -> [1] -> [4]
rw_main__L_y3_235 x0 x1 = s2 # 0b000
  where
    s0 : [1]
    s0 = if x0 == 0b1 then x0 else 0b0
    s1 : [1]
    s1 = if x1 == 0b0 then s0 else x0
    s2 : [1]
    s2 = if s1 == 0b1 then x1 else 0b0

// main.$L.x2$234
rw_main__L_x2_234 : [1] -> [4]
rw_main__L_x2_234 x0 = if x0 == 0b0 then (x0 # (0b01 # x0)) else (0b001 # x0)

// Per-cycle step: outputs # next register values.
rw_step : [3] -> [1] -> [4]
rw_step st i = (take`{1} s2) # (drop`{1} s2)
  where
    s0 : [3]
    s0 = st
    s1 : [1]
    s1 = i
    s2 : [4]
    s2 = rw_main__dispatch s0 s1

// Device: top_level
// Inputs, MSB-first: __in0 : [1]
// Outputs, MSB-first: __out0 : [1]
rw_device : {n} (fin n) => [n][1] -> [n][1]
rw_device ins = outs
  where
    rs : [n][4]
    rs = [rw_step st i | st <- sts | i <- ins]
    sts : [1 + n][3]
    sts = [0b100] # [drop`{1} r | r <- rs]
    outs : [n][1]
    outs = [take`{1} r | r <- rs]