// Generated by rwc from device: top_level.
// rw_device maps a sequence of per-cycle inputs to per-cycle outputs.

module top_level where

// Helpers implementing ReWire Hyle primitive semantics.
rw'resize : {m, n} (fin m, fin n) => [n] -> [m]
rw'resize x = drop`{n} ((zero : [m]) # x)

rw'repl : {n, w} (fin n, fin w) => [w] -> [n * w]
rw'repl x = join (repeat`{n} x)

rw'parity : {n} (fin n) => [n] -> Bit
rw'parity x = foldr (^) False x

rw'sext : {m, n} (fin m, fin n, n >= 1) => [n] -> [m]
rw'sext x = if x @ 0 then ~ (rw'resize (~ x)) else rw'resize x

// main.$dispatch
rw_main__dispatch : [17] -> [1] -> [25]
rw_main__dispatch x0 x1 = if ~ ((take`{1} x0) @ 0) then (rw_main__ds x1 (drop`{9} x0)) else (rw_main_i (take`{8} (drop`{1} x0)) x1 (drop`{9} x0))

// main.$ds
rw_main__ds : [1] -> [8] -> [25]
rw_main__ds x0 x1 = 0b0000000010000000000000000

// main.n
rw_main_n : [8] -> [8] -> [25]
rw_main_n x0 x1 = (x0 + x0) # (0b000000000 # x1)

// main._unused2
rw_main__unused2 : [8] -> [1] -> [8] -> [25]
rw_main__unused2 x0 x1 x2 = if ~ (x1 @ 0) then (rw_main_n x0 x2) else (rw_main_counter x2)

// main.i
rw_main_i : [8] -> [1] -> [8] -> [25]
rw_main_i x0 x1 x2 = rw_main__unused2 x0 x1 s0
  where
    s0 : [8]
    s0 = x0 + 0x01

// main.s
rw_main_s : [8] -> [8] -> [25]
rw_main_s x0 x1 = x0 # (0b1 # (x0 # x1))

// main.counter
rw_main_counter : [8] -> [25]
rw_main_counter x0 = rw_main_s x0 x0

// Per-cycle step: outputs # next register values.
rw_step : [17] -> [1] -> [25]
rw_step st i = (take`{8} s3) # ((take`{9} (drop`{8} s3)) # (drop`{17} s3))
  where
    s0 : [9]
    s0 = take`{9} st
    s1 : [8]
    s1 = drop`{9} st
    s2 : [1]
    s2 = i
    s3 : [25]
    s3 = rw_main__dispatch (s0 # s1) s2

// Device: top_level
// Inputs, MSB-first: __in0 : [1]
// Outputs, MSB-first: __out0 : [8]
rw_device : {n} (fin n) => [n][1] -> [n][8]
rw_device ins = outs
  where
    rs : [n][25]
    rs = [rw_step st i | st <- sts | i <- ins]
    sts : [1 + n][17]
    sts = [0b10000000000000000] # [drop`{8} r | r <- rs]
    outs : [n][8]
    outs = [take`{8} r | r <- rs]