main.$dispatch : ([8]) -> [32]
main.$dispatch i =
      main.$L.$x2$708 i

main.$L.$x2$708 : ([8]) -> [32]
main.$L.$x2$708 $x =
      main.$L.Main.dev1$706 $x

main.$L.Main.dev1$706 : ([8]) -> [32]
main.$L.Main.dev1$706 a =
      let b = Main.x2 a in
      let $a = (let $a2 = (let $a2 = trunc 1 (lshr a 128'h7) in
      $a2) in
      $a2) # (let $a2 = (let $a2 = trunc 1 (lshr b 128'h7) in
      $a2) in
      $a2) # (let $a2 = (let $a2 = trunc 1 (lshr a 128'h6) in
      $a2) in
      $a2) # (let $a2 = (let $a2 = trunc 1 (lshr b 128'h6) in
      $a2) in
      $a2) # (let $a2 = (let $a2 = trunc 1 (lshr a 128'h5) in
      $a2) in
      $a2) # (let $a2 = (let $a2 = trunc 1 (lshr b 128'h5) in
      $a2) in
      $a2) # (let $a2 = (let $a2 = trunc 1 (lshr a 128'h4) in
      $a2) in
      $a2) # (let $a2 = (let $a2 = trunc 1 (lshr b 128'h4) in
      $a2) in
      $a2) in
      let $a3 = (let $a5 = (let $a5 = trunc 1 (lshr a 128'h3) in
      $a5) in
      $a5) # (let $a5 = (let $a5 = trunc 1 (lshr b 128'h3) in
      $a5) in
      $a5) # (let $a5 = (let $a5 = trunc 1 (lshr a 128'h2) in
      $a5) in
      $a5) # (let $a5 = (let $a5 = trunc 1 (lshr b 128'h2) in
      $a5) in
      $a5) # (let $a5 = (let $a5 = trunc 1 (lshr a 128'h1) in
      $a5) in
      $a5) # (let $a5 = (let $a5 = trunc 1 (lshr b 128'h1) in
      $a5) in
      $a5) # (let $a5 = (let $a5 = trunc 1 (lshr a 128'h0) in
      $a5) in
      $a5) # (let $a5 = (let $a5 = trunc 1 (lshr b 128'h0) in
      $a5) in
      $a5) in
      let $a6 = (let $a7 = (let $a7 = trunc 1 (lshr a 128'h7) in
      $a7) in
      $a7) # (let $a7 = (let $a7 = trunc 1 (lshr a 128'h5) in
      $a7) in
      $a7) # (let $a7 = (let $a7 = trunc 1 (lshr a 128'h3) in
      $a7) in
      $a7) # (let $a7 = (let $a7 = trunc 1 (lshr a 128'h1) in
      $a7) in
      $a7) # (let $a7 = (let $a7 = trunc 1 (lshr b 128'h7) in
      $a7) in
      $a7) # (let $a7 = (let $a7 = trunc 1 (lshr b 128'h5) in
      $a7) in
      $a7) # (let $a7 = (let $a7 = trunc 1 (lshr b 128'h3) in
      $a7) in
      $a7) # (let $a7 = (let $a7 = trunc 1 (lshr b 128'h1) in
      $a7) in
      $a7) in
      let $a9 = (let $a10 = (let $a10 = trunc 1 (lshr a 128'h6) in
      $a10) in
      $a10) # (let $a10 = (let $a10 = trunc 1 (lshr a 128'h4) in
      $a10) in
      $a10) # (let $a10 = (let $a10 = trunc 1 (lshr a 128'h2) in
      $a10) in
      $a10) # (let $a10 = (let $a10 = trunc 1 (lshr a 128'h0) in
      $a10) in
      $a10) # (let $a10 = (let $a10 = trunc 1 (lshr b 128'h6) in
      $a10) in
      $a10) # (let $a10 = (let $a10 = trunc 1 (lshr b 128'h4) in
      $a10) in
      $a10) # (let $a10 = (let $a10 = trunc 1 (lshr b 128'h2) in
      $a10) in
      $a10) # (let $a10 = (let $a10 = trunc 1 (lshr b 128'h0) in
      $a10) in
      $a10) in
      let $a10 = $a # $a3 # $a6 # $a9 in
      $a10

Main.x2 : ([8]) -> [8]
Main.x2 x =
      mul x 8'h2

device top_level
      input __in0 : [8]
      output __out0 : [8]
      output __out1 : [8]
      output __out2 : [8]
      output __out3 : [8]
      let $res = main.$dispatch __in0
      __out0 := $res[24 +: 8]
      __out1 := $res[16 +: 8]
      __out2 := $res[8 +: 8]
      __out3 := $res[0 +: 8]