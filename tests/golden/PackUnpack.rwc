$Pure.dispatch : ([8]) -> [32]
$Pure.dispatch i =
      Main.dev i

$LL.Main.dev24 : ([8], [8], [3]) -> [8]
$LL.Main.dev24 a b one =
      $LL.Main.dev18 a one b 3'h2

$LL.Main.dev23 : ([8], [8], [3], [3]) -> [8]
$LL.Main.dev23 a b two n =
      $LL.Main.dev22 a b n two 3'h0 # $LL.Main.dev22 a b n two 3'h1 # $LL.Main.dev22 a b n two 3'h2 # $LL.Main.dev22 a b n two 3'h3 # $LL.Main.dev22 a b n two 3'h4 # $LL.Main.dev22 a b n two 3'h5 # $LL.Main.dev22 a b n two 3'h6 # $LL.Main.dev22 a b n two 3'h7

$LL.Main.dev22 : ([8], [8], [3], [3], [3]) -> [1]
$LL.Main.dev22 a b n two fi =
      $LL.Main.dev8 a b n fi two (ult (zext 128 fi) (zext 128 n))

$LL.Main.dev21 : ([8], [3], [8], [3], [3]) -> [8]
$LL.Main.dev21 a one b two n =
      $LL.Main.dev11 a one b two n 3'h0 # $LL.Main.dev11 a one b two n 3'h1 # $LL.Main.dev11 a one b two n 3'h2 # $LL.Main.dev11 a one b two n 3'h3 # $LL.Main.dev11 a one b two n 3'h4 # $LL.Main.dev11 a one b two n 3'h5 # $LL.Main.dev11 a one b two n 3'h6 # $LL.Main.dev11 a one b two n 3'h7

$LL.Main.dev20 : ([8], [3], [8], [3], [3]) -> [8]
$LL.Main.dev20 a one b two n' =
      $LL.Main.dev21 a one b two ($LL.Main.dev4 one n' 1'h0)

$LL.Main.dev19 : ([8], [8]) -> [32]
$LL.Main.dev19 a b =
      $LL.Main.dev3 a b 3'h2 # $LL.Main.dev7 a b 3'h1 # $LL.Main.dev13 a b 3'h2 # $LL.Main.dev24 a b 3'h1

$LL.Main.dev18 : ([8], [3], [8], [3]) -> [8]
$LL.Main.dev18 a one b two =
      $LL.Main.dev20 a one b two (trunc 3 (umod (udiv 128'h7 (zext 128 two)) 128'h8))

$LL.Main.dev17 : ([8], [8], [3], [3], [1]) -> [1]
$LL.Main.dev17 a b fi two wild =
      if eq wild 1'h0 then trunc 1 (lshr b (mul (sub (sub 128'h8 (zext 128 (trunc 3 (umod (udiv (zext 128 (trunc 3 (umod (sub (zext 128 fi) 128'h1) 128'h8))) (zext 128 two)) 128'h8)))) 128'h1) 128'h1))
            else trunc 1 (lshr a (mul (sub (sub 128'h8 (zext 128 (trunc 3 (umod (udiv (zext 128 fi) (zext 128 two)) 128'h8)))) 128'h1) 128'h1))

Main.dev : ([8]) -> [32]
Main.dev a =
      $LL.Main.dev19 a (Main.x2 a)

$LL.Main.dev16 : ([1]) -> [1]
$LL.Main.dev16 s =
      if eq s 1'h1 then 1'h0
            else 1'h1

$LL.Main.dev15 : ([8], [8], [3], [3], [3]) -> [8]
$LL.Main.dev15 a b two one n' =
      $LL.Main.dev5 a b two one ($LL.Main.dev1 n' one 1'h0)

$LL.Main.dev14 : ([8], [8], [3], [3], [3], [3]) -> [1]
$LL.Main.dev14 a b n two one fi =
      $LL.Main.dev10 a b n two one fi ($LL.Main.dev16 (let $t0 = trunc 1 (zext 128 fi) in
      $t0))

$LL.Main.dev13 : ([8], [8], [3]) -> [8]
$LL.Main.dev13 a b two =
      $LL.Main.dev a b two (trunc 3 (umod (udiv 128'h7 (zext 128 two)) 128'h8))

$LL.Main.dev12 : ([8], [8], [3], [3]) -> [1]
$LL.Main.dev12 a b two fi =
      $LL.Main.dev17 a b fi two ($LL.Main.dev16 (let $t0 = trunc 1 (zext 128 fi) in
      $t0))

$LL.Main.dev11 : ([8], [3], [8], [3], [3], [3]) -> [1]
$LL.Main.dev11 a one b two n fi =
      $LL.Main.dev9 a one b two n fi (ult (zext 128 fi) (zext 128 n))

$LL.Main.dev10 : ([8], [8], [3], [3], [3], [3], [1]) -> [1]
$LL.Main.dev10 a b n two one fi wild =
      if eq wild 1'h0 then trunc 1 (lshr b (mul (sub (sub 128'h8 (zext 128 (trunc 3 (umod (add (zext 128 n) (zext 128 (trunc 3 (umod (udiv (zext 128 (trunc 3 (umod (sub (zext 128 fi) (zext 128 one)) 128'h8))) (zext 128 two)) 128'h8)))) 128'h8)))) 128'h1) 128'h1))
            else trunc 1 (lshr a (mul (sub (sub 128'h8 (zext 128 (trunc 3 (umod (add (zext 128 n) (zext 128 (trunc 3 (umod (udiv (zext 128 fi) (zext 128 two)) 128'h8)))) 128'h8)))) 128'h1) 128'h1))

$LL.Main.dev9 : ([8], [3], [8], [3], [3], [3], [1]) -> [1]
$LL.Main.dev9 a one b two n fi wild =
      if eq wild 1'h0 then trunc 1 (lshr b (mul (sub (sub 128'h8 (zext 128 (trunc 3 (umod (add (zext 128 (trunc 3 (umod (mul (zext 128 (trunc 3 (umod (sub (zext 128 fi) (zext 128 n)) 128'h8))) (zext 128 two)) 128'h8))) (zext 128 one)) 128'h8)))) 128'h1) 128'h1))
            else trunc 1 (lshr a (mul (sub (sub 128'h8 (zext 128 (trunc 3 (umod (add (zext 128 (trunc 3 (umod (mul (zext 128 fi) (zext 128 two)) 128'h8))) (zext 128 one)) 128'h8)))) 128'h1) 128'h1))

$LL.Main.dev8 : ([8], [8], [3], [3], [3], [1]) -> [1]
$LL.Main.dev8 a b n fi two wild =
      if eq wild 1'h0 then trunc 1 (lshr b (mul (sub (sub 128'h8 (zext 128 (trunc 3 (umod (mul (zext 128 (trunc 3 (umod (sub (zext 128 fi) (zext 128 n)) 128'h8))) (zext 128 two)) 128'h8)))) 128'h1) 128'h1))
            else trunc 1 (lshr a (mul (sub (sub 128'h8 (zext 128 (trunc 3 (umod (mul (zext 128 fi) (zext 128 two)) 128'h8)))) 128'h1) 128'h1))

$LL.Main.dev7 : ([8], [8], [3]) -> [8]
$LL.Main.dev7 a b one =
      $LL.Main.dev2 a b one 3'h2

$LL.Main.dev6 : ([3], [1]) -> [3]
$LL.Main.dev6 n' wild =
      if eq wild 1'h0 then trunc 3 (umod (add (zext 128 n') 128'h1) 128'h8)
            else n'

Main.x2 : ([8]) -> [8]
Main.x2 x =
      mul x 8'h2

$LL.Main.dev5 : ([8], [8], [3], [3], [3]) -> [8]
$LL.Main.dev5 a b two one n =
      $LL.Main.dev14 a b n two one 3'h0 # $LL.Main.dev14 a b n two one 3'h1 # $LL.Main.dev14 a b n two one 3'h2 # $LL.Main.dev14 a b n two one 3'h3 # $LL.Main.dev14 a b n two one 3'h4 # $LL.Main.dev14 a b n two one 3'h5 # $LL.Main.dev14 a b n two one 3'h6 # $LL.Main.dev14 a b n two one 3'h7

$LL.Main.dev4 : ([3], [3], [1]) -> [3]
$LL.Main.dev4 one n' wild =
      if eq wild 1'h0 then trunc 3 (umod (add (zext 128 n') (zext 128 one)) 128'h8)
            else n'

$LL.Main.dev3 : ([8], [8], [3]) -> [8]
$LL.Main.dev3 a b two =
      $LL.Main.dev12 a b two 3'h0 # $LL.Main.dev12 a b two 3'h1 # $LL.Main.dev12 a b two 3'h2 # $LL.Main.dev12 a b two 3'h3 # $LL.Main.dev12 a b two 3'h4 # $LL.Main.dev12 a b two 3'h5 # $LL.Main.dev12 a b two 3'h6 # $LL.Main.dev12 a b two 3'h7

$LL.Main.dev2 : ([8], [8], [3], [3]) -> [8]
$LL.Main.dev2 a b one two =
      $LL.Main.dev15 a b two one (trunc 3 (umod (udiv 128'h7 (zext 128 two)) 128'h8))

$LL.Main.dev1 : ([3], [3], [1]) -> [3]
$LL.Main.dev1 n' one wild =
      if eq wild 1'h0 then trunc 3 (umod (add (zext 128 n') (zext 128 one)) 128'h8)
            else n'

$LL.Main.dev : ([8], [8], [3], [3]) -> [8]
$LL.Main.dev a b two n' =
      $LL.Main.dev23 a b two ($LL.Main.dev6 n' 1'h0)

device top_level
      input __in0 : [8]
      output __out0 : [8]
      output __out1 : [8]
      output __out2 : [8]
      output __out3 : [8]
      let $res = $Pure.dispatch __in0
      __out0 := $res[24 +: 8]
      __out1 := $res[16 +: 8]
      __out2 := $res[8 +: 8]
      __out3 := $res[0 +: 8]