$Pure.dispatch : ([8]) -> [32]
$Pure.dispatch i =
      Main.dev i

$LL.Main.dev101 : ([3], [3]) -> [3]
$LL.Main.dev101 $x $x1 =
      $LL.Main.dev72 $x $x1

$LL.Main.dev100 : ([3], [3]) -> [3]
$LL.Main.dev100 $x $x1 =
      $LL.Main.dev70 $x $x1

$LL.Main.dev99 : ([8], [8]) -> [8]
$LL.Main.dev99 $x $x1 =
      $LL.Main.dev87 $x $x1

$LL.Main.dev98 : ([3], [3]) -> [3]
$LL.Main.dev98 eta b =
      trunc 3 (umod (sub (zext 128 eta) (zext 128 b)) 128'h8)

$LL.Main.dev97 : ([3]) -> [1]
$LL.Main.dev97 eta =
      $LL.Main.dev89 (zext 128 eta)

$LL.Main.dev91 : ([8], [8]) -> [8]
$LL.Main.dev91 $x $x1 =
      $LL.Main.dev24 $x $x1

$LL.Main.dev90 : ([8], [8]) -> [8]
$LL.Main.dev90 eta w =
      $LL.Main.dev5 w eta

$LL.Main.dev89 : ([128]) -> [1]
$LL.Main.dev89 eta =
      $LL.Main.dev84 (let $t0 = trunc 1 eta in
      $t0)

$LL.Main.dev88 : ([3], [3]) -> [3]
$LL.Main.dev88 $x $x1 =
      $LL.Main.dev98 $x $x1

$LL.Main.dev87 : ([8], [8]) -> [8]
$LL.Main.dev87 eta w =
      $LL.Main.dev17 w eta

$LL.Main.dev86 : ([8], [8]) -> [8]
$LL.Main.dev86 $x $x1 =
      $LL.Main.dev77 $x $x1

$LL.Main.dev85 : ([3], [3], [8], [8], [3]) -> [8]
$LL.Main.dev85 one two eta w n =
      $LL.Main.dev41 one two eta w n 3'h0 # $LL.Main.dev41 one two eta w n 3'h1 # $LL.Main.dev41 one two eta w n 3'h2 # $LL.Main.dev41 one two eta w n 3'h3 # $LL.Main.dev41 one two eta w n 3'h4 # $LL.Main.dev41 one two eta w n 3'h5 # $LL.Main.dev41 one two eta w n 3'h6 # $LL.Main.dev41 one two eta w n 3'h7

$LL.Main.dev84 : ([1]) -> [1]
$LL.Main.dev84 b =
      if eq b 1'h1 then 1'h0
            else 1'h1

$LL.Main.dev83 : ([8], [3], [8], [3], [3]) -> [8]
$LL.Main.dev83 eta two w one n =
      $LL.Main.dev80 eta two w n one 3'h0 # $LL.Main.dev80 eta two w n one 3'h1 # $LL.Main.dev80 eta two w n one 3'h2 # $LL.Main.dev80 eta two w n one 3'h3 # $LL.Main.dev80 eta two w n one 3'h4 # $LL.Main.dev80 eta two w n one 3'h5 # $LL.Main.dev80 eta two w n one 3'h6 # $LL.Main.dev80 eta two w n one 3'h7

$LL.Main.dev82 : ([8]) -> [3]
$LL.Main.dev82 ds =
      3'h7

$LL.Main.dev81 : ([3], [3], [8], [8], [3]) -> [1]
$LL.Main.dev81 two one w eta fi =
      $LL.Main.dev55 two one w fi eta ($LL.Main.dev97 fi)

$LL.Main.dev80 : ([8], [3], [8], [3], [3], [3]) -> [1]
$LL.Main.dev80 eta two w n one fi =
      $LL.Main.dev2 eta fi two w n one ($LL.Main.dev67 fi n)

$LL.Main.dev77 : ([8], [8]) -> [8]
$LL.Main.dev77 $x $x1 =
      $LL.Main.dev48 $x $x1

$LL.Main.dev74 : ([3], [8], [8], [3]) -> [8]
$LL.Main.dev74 one w eta two =
      $LL.Main.dev81 two one w eta 3'h0 # $LL.Main.dev81 two one w eta 3'h1 # $LL.Main.dev81 two one w eta 3'h2 # $LL.Main.dev81 two one w eta 3'h3 # $LL.Main.dev81 two one w eta 3'h4 # $LL.Main.dev81 two one w eta 3'h5 # $LL.Main.dev81 two one w eta 3'h6 # $LL.Main.dev81 two one w eta 3'h7

$LL.Main.dev72 : ([3], [3]) -> [3]
$LL.Main.dev72 eta b =
      trunc 3 (umod (udiv (zext 128 eta) (zext 128 b)) 128'h8)

$LL.Main.dev71 : ([3], [3]) -> [3]
$LL.Main.dev71 $x $x1 =
      $LL.Main.dev31 $x $x1

$LL.Main.dev70 : ([3], [3]) -> [3]
$LL.Main.dev70 eta b =
      trunc 3 (umod (add (zext 128 eta) (zext 128 b)) 128'h8)

$LL.Main.dev69 : ([8], [3], [8], [3], [3]) -> [8]
$LL.Main.dev69 eta two w one n' =
      $LL.Main.dev83 eta two w one ($LL.Main.dev57 n' one ($LL.Main.dev97 ($LL.Main.dev82 eta)))

$LL.Main.dev68 : ([3], [3], [8], [8], [3]) -> [8]
$LL.Main.dev68 one two eta w n' =
      $LL.Main.dev85 one two eta w ($LL.Main.dev21 one n' ($LL.Main.dev97 ($LL.Main.dev82 eta)))

$LL.Main.dev67 : ([3], [3]) -> [1]
$LL.Main.dev67 $x $x1 =
      $LL.Main.dev52 $x $x1

Main.dev : ([8]) -> [32]
Main.dev a =
      $LL.Main.dev62 a (Main.x2 a)

$LL.Main.dev62 : ([8], [8]) -> [32]
$LL.Main.dev62 a b =
      $LL.Main.dev54 a b # $LL.Main.dev86 a b # $LL.Main.dev99 a b # $LL.Main.dev91 a b

$LL.Main.dev58 : ([3], [1]) -> [3]
$LL.Main.dev58 n' wild =
      if eq wild 1'h0 then $LL.Main.dev38 n'
            else n'

$LL.Main.dev57 : ([3], [3], [1]) -> [3]
$LL.Main.dev57 n' one wild =
      if eq wild 1'h0 then $LL.Main.dev100 n' one
            else n'

$LL.Main.dev55 : ([3], [3], [8], [3], [8], [1]) -> [1]
$LL.Main.dev55 two one w fi eta wild =
      if eq wild 1'h0 then trunc 1 (lshr w (mul (sub (sub 128'h8 (zext 128 ($LL.Main.dev101 ($LL.Main.dev88 fi one) two))) 128'h1) 128'h1))
            else trunc 1 (lshr eta (mul (sub (sub 128'h8 (zext 128 ($LL.Main.dev101 fi two))) 128'h1) 128'h1))

$LL.Main.dev54 : ([8], [8]) -> [8]
$LL.Main.dev54 $x $x1 =
      $LL.Main.dev90 $x $x1

$LL.Main.dev52 : ([3], [3]) -> [1]
$LL.Main.dev52 eta eta1 =
      ult (zext 128 eta) (zext 128 eta1)

$LL.Main.dev49 : ([8], [8], [3], [3]) -> [8]
$LL.Main.dev49 eta w one two =
      $LL.Main.dev69 eta two w one ($LL.Main.dev101 ($LL.Main.dev82 eta) two)

$LL.Main.dev48 : ([8], [8]) -> [8]
$LL.Main.dev48 sp sp1 =
      $LL.Main.dev10 3'h1 sp sp1 3'h2

$LL.Main.dev47 : ([8], [8], [3], [3], [3]) -> [1]
$LL.Main.dev47 w eta n two fi =
      $LL.Main.dev34 w eta n two fi ($LL.Main.dev67 fi n)

$LL.Main.dev41 : ([3], [3], [8], [8], [3], [3]) -> [1]
$LL.Main.dev41 one two eta w n fi =
      $LL.Main.dev32 one two eta w fi n ($LL.Main.dev97 fi)

$LL.Main.dev39 : ([8], [8], [3], [3]) -> [8]
$LL.Main.dev39 w eta two n' =
      $LL.Main.dev26 w eta two ($LL.Main.dev58 n' ($LL.Main.dev97 ($LL.Main.dev82 eta)))

$LL.Main.dev38 : ([3]) -> [3]
$LL.Main.dev38 sp =
      $LL.Main.dev70 sp 3'h1

$LL.Main.dev36 : ([8], [8]) -> [8]
$LL.Main.dev36 sp sp1 =
      $LL.Main.dev49 sp sp1 3'h1 3'h2

$LL.Main.dev34 : ([8], [8], [3], [3], [3], [1]) -> [1]
$LL.Main.dev34 w eta n two fi wild =
      if eq wild 1'h0 then trunc 1 (lshr w (mul (sub (sub 128'h8 (zext 128 ($LL.Main.dev71 ($LL.Main.dev88 fi n) two))) 128'h1) 128'h1))
            else trunc 1 (lshr eta (mul (sub (sub 128'h8 (zext 128 ($LL.Main.dev71 fi two))) 128'h1) 128'h1))

$LL.Main.dev32 : ([3], [3], [8], [8], [3], [3], [1]) -> [1]
$LL.Main.dev32 one two eta w fi n wild =
      if eq wild 1'h0 then trunc 1 (lshr w (mul (sub (sub 128'h8 (zext 128 ($LL.Main.dev100 n ($LL.Main.dev101 ($LL.Main.dev88 fi one) two)))) 128'h1) 128'h1))
            else trunc 1 (lshr eta (mul (sub (sub 128'h8 (zext 128 ($LL.Main.dev100 n ($LL.Main.dev101 fi two)))) 128'h1) 128'h1))

$LL.Main.dev31 : ([3], [3]) -> [3]
$LL.Main.dev31 eta b =
      trunc 3 (umod (mul (zext 128 eta) (zext 128 b)) 128'h8)

$LL.Main.dev26 : ([8], [8], [3], [3]) -> [8]
$LL.Main.dev26 w eta two n =
      $LL.Main.dev47 w eta n two 3'h0 # $LL.Main.dev47 w eta n two 3'h1 # $LL.Main.dev47 w eta n two 3'h2 # $LL.Main.dev47 w eta n two 3'h3 # $LL.Main.dev47 w eta n two 3'h4 # $LL.Main.dev47 w eta n two 3'h5 # $LL.Main.dev47 w eta n two 3'h6 # $LL.Main.dev47 w eta n two 3'h7

$LL.Main.dev24 : ([8], [8]) -> [8]
$LL.Main.dev24 $x $x1 =
      $LL.Main.dev36 $x $x1

$LL.Main.dev21 : ([3], [3], [1]) -> [3]
$LL.Main.dev21 one n' wild =
      if eq wild 1'h0 then $LL.Main.dev100 n' one
            else n'

$LL.Main.dev17 : ([8], [8]) -> [8]
$LL.Main.dev17 sp sp1 =
      $LL.Main.dev39 sp sp1 3'h2 ($LL.Main.dev101 ($LL.Main.dev82 sp1) 3'h2)

$LL.Main.dev10 : ([3], [8], [8], [3]) -> [8]
$LL.Main.dev10 one eta w two =
      $LL.Main.dev68 one two eta w ($LL.Main.dev101 ($LL.Main.dev82 eta) two)

Main.x2 : ([8]) -> [8]
Main.x2 x =
      mul x 8'h2

$LL.Main.dev5 : ([8], [8]) -> [8]
$LL.Main.dev5 sp sp1 =
      $LL.Main.dev74 3'h1 sp sp1 3'h2

$LL.Main.dev2 : ([8], [3], [3], [8], [3], [3], [1]) -> [1]
$LL.Main.dev2 eta fi two w n one wild =
      if eq wild 1'h0 then trunc 1 (lshr w (mul (sub (sub 128'h8 (zext 128 ($LL.Main.dev100 ($LL.Main.dev71 ($LL.Main.dev88 fi n) two) one))) 128'h1) 128'h1))
            else trunc 1 (lshr eta (mul (sub (sub 128'h8 (zext 128 ($LL.Main.dev100 ($LL.Main.dev71 fi two) one))) 128'h1) 128'h1))

device top_level
      input __in0 : [8]
      output __out0 : [8]
      output __out1 : [8]
      output __out2 : [8]
      output __out3 : [8]
      let $res = $Pure.dispatch __in0
      __out0 := $res[24 +: 8]
      __out1 := $res[16 +: 8]
      __out2 := $res[8 +: 8]
      __out3 := $res[0 +: 8]