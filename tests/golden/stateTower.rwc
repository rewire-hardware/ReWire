--| state dispatch for process main: 0=$x2
main.$dispatch : ([2], [1]) -> [3]
main.$dispatch disc i =
      main.$x2 i disc[1 +: 1] disc[0 +: 1]

--| block '$L.$x2' of process main (state 0)
main.$x2 : ([1], [1], [1]) -> [3]
main.$x2 $x s0 s1 =
      main.sig $x s0 s1

--| block '$L.r02' of process main
main.r02 : ([1], [1], [1]) -> [3]
main.r02 r0 s0 s1 =
      r0 # s0 # s1

--| block '$L._unused' of process main
main._unused : ([1], [1]) -> [3]
main._unused s0 s1 =
      main.r02 s0 s0 s1

--| block '$L._unused2' of process main
main._unused2 : ([1], [1], [1], [1]) -> [3]
main._unused2 r0 r1 s0 s1 =
      let s11 = (let $t1 = xor r0 r1 in
      $t1) in
      main._unused s0 s11

--| block '$L.r1' of process main
main.r1 : ([1], [1], [1], [1]) -> [3]
main.r1 r0 r1 s0 s1 =
      main._unused2 r0 r1 r1 s1

--| block '$L.r03' of process main
main.r03 : ([1], [1], [1]) -> [3]
main.r03 r0 s0 s1 =
      main.r1 r0 s1 s0 s1

--| block '$L.Main.incr' of process main
main.incr : ([1], [1]) -> [3]
main.incr s0 s1 =
      main.r03 s0 s0 s1

--| block '$L.Main.sig' of process main
main.sig : ([1], [1], [1]) -> [3]
main.sig i s0 s1 =
      let $a = not i in
      if not $a then main._unused s0 s1
            else main.incr s0 s1

device top_level
      input __in0 : [1]
      output __out0 : [1]
      register __st0 : [1] init 1'h1
      register __st1 : [1] init 1'h1
      tag $x2 = 0
      let $res = main.$dispatch (__st0 # __st1) __in0
      __out0 := $res[2 +: 1]
      next __st0 := $res[1 +: 1]
      next __st1 := $res[0 +: 1]