$Pure.dispatch : ([2], [1]) -> [3]
$Pure.dispatch disc i =
      let s0 = disc[1 +: 1] in
      let s1 = disc[0 +: 1] in
      Main.sig i s0 s1

$LL.Main.sig5 : ([1], [1], [1], [1]) -> [3]
$LL.Main.sig5 rabind rabind1 sto0 sto1 =
      $LL.Main.sig3 sto0 (let $t1 = xor rabind1 rabind in
      $t1)

$LL.Main.sig4 : ([1], [1], [1]) -> [3]
$LL.Main.sig4 rabind sto0 sto1 =
      $LL.Main.sig rabind sto1 sto0 sto1

$LL.Main.sig3 : ([1], [1]) -> [3]
$LL.Main.sig3 sto0 sto1 =
      $LL.Main.sig1 sto0 sto0 sto1

Main.sig : ([1], [1], [1]) -> [3]
Main.sig i sto0 sto1 =
      let $t0 = $LL.Main.sig2 i in
      if eq $t0 1'h0 then $LL.Main.sig3 sto0 sto1
            else $LL.Main.sig4 sto0 sto0 sto1

$LL.Main.sig2 : ([1]) -> [1]
$LL.Main.sig2 s =
      if eq s 1'h1 then 1'h0
            else 1'h1

$LL.Main.sig1 : ([1], [1], [1]) -> [3]
$LL.Main.sig1 r0 sto0 sto1 =
      r0 # sto0 # sto1

$LL.Main.sig : ([1], [1], [1], [1]) -> [3]
$LL.Main.sig rabind rabind1 sto0 sto1 =
      $LL.Main.sig5 rabind1 rabind rabind1 sto1

device top_level
      input __in0 : [1]
      output __out0 : [1]
      register __st0 : [1] init 1'h1
      register __st1 : [1] init 1'h1
      let $res = $Pure.dispatch (__st0 # __st1) __in0
      __out0 := $res[2 +: 1]
      next __st0 := $res[1 +: 1]
      next __st1 := $res[0 +: 1]