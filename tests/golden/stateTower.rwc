$Pure.dispatch : ([2], [1]) -> [3]
$Pure.dispatch disc i =
      let s0 = disc[1 +: 1] in
      let s1 = disc[0 +: 1] in
      Main.sig i s0 s1

$LL.Main.incr2 : ([2]) -> [1]
$LL.Main.incr2 $31 =
      let a = $31[1 +: 1] in
      let b = $31[0 +: 1] in
      let $t1 = xor a b in
      $t1

$LL.Main.sig5 : ([1], [1], [1]) -> [3]
$LL.Main.sig5 $4 sto0 sto1 =
      let $t1 = ReWire.Prelude.not $4 in
      if eq $t1 1'h1 then $LL.Main.sig1 sto0 sto0 sto1
            else $LL.Main.sig3 sto0 sto1

$LL.Main.sig4 : ([1], [1], [1], [1]) -> [3]
$LL.Main.sig4 rabind rabind1 sto0 sto1 =
      $LL.Main.sig2 rabind1 rabind rabind1 sto1

ReWire.Prelude.not : ([1]) -> [1]
ReWire.Prelude.not $14 =
      $LL.ReWire.Prelude.not $14 $14

$LL.Main.incr1 : ([1], [1]) -> [1]
$LL.Main.incr1 $14 $15 =
      $LL.Main.incr2 ($14 # $15)

Main.sig : ([1], [1], [1]) -> [3]
Main.sig $x sto0 sto1 =
      $LL.Main.sig5 $x sto0 sto1

$LL.Main.incr : ([1], [1]) -> [1]
$LL.Main.incr $x $x1 =
      $LL.Main.incr1 $x $x1

$LL.ReWire.Prelude.not1 : ([1]) -> [1]
$LL.ReWire.Prelude.not1 $55 =
      1'h1

$LL.Main.sig3 : ([1], [1]) -> [3]
$LL.Main.sig3 sto0 sto1 =
      $LL.Main.sig sto0 sto0 sto1

$LL.ReWire.Prelude.not : ([1], [1]) -> [1]
$LL.ReWire.Prelude.not $14 $56 =
      if eq $56 1'h1 then 1'h0
            else $LL.ReWire.Prelude.not1 $14

$LL.Main.sig2 : ([1], [1], [1], [1]) -> [3]
$LL.Main.sig2 rabind rabind1 sto0 sto1 =
      $LL.Main.sig3 sto0 ($LL.Main.incr rabind1 rabind)

$LL.Main.sig1 : ([1], [1], [1]) -> [3]
$LL.Main.sig1 rabind sto0 sto1 =
      $LL.Main.sig4 rabind sto1 sto0 sto1

$LL.Main.sig : ([1], [1], [1]) -> [3]
$LL.Main.sig r0 sto0 sto1 =
      r0 # sto0 # sto1

device top_level
      input __in0 : [1]
      output __out0 : [1]
      register __st0 : [1] init 1'h1
      register __st1 : [1] init 1'h1
      let $res = $Pure.dispatch (__st0 # __st1) __in0
      __out0 := $res[2 +: 1]
      next __st0 := $res[1 +: 1]
      next __st1 := $res[0 +: 1]