$Pure.dispatch : ([2], [1]) -> [3]
$Pure.dispatch disc i =
      let s = disc[1 +: 1] in
      let s1 = disc[0 +: 1] in
      $L.$x6 i s s1

$L.Main.sig4 : ([1], [1], [1]) -> [3]
$L.Main.sig4 i s0 s1 =
      $LL.L.Main.sig41 s1 s0 ($LL.L.Main.sig4 i)

$LL.L.r110 : ([1], [1], [1], [1]) -> [3]
$LL.L.r110 s1 r1 r0 s' =
      $L._unused11 r0 r1 s' s1

$L._unused11 : ([1], [1], [1], [1]) -> [3]
$L._unused11 r0 r1 s0 s1 =
      $L._unused7 s0 (let $t1 = xor r0 r1 in
      $t1)

$L.r09 : ([1], [1], [1]) -> [3]
$L.r09 r0 s0 s1 =
      $L.r110 r0 s1 s0 s1

$L.r110 : ([1], [1], [1], [1]) -> [3]
$L.r110 r0 r1 s0 s1 =
      $LL.L.r110 s1 r1 r0 r1

$LL.L.Main.sig41 : ([1], [1], [1]) -> [3]
$LL.L.Main.sig41 s1 s0 $a =
      if eq $a 1'h0 then $L._unused7 s0 s1
            else $L.Main.incr8 s0 s1

$L.$x6 : ([1], [1], [1]) -> [3]
$L.$x6 $x $x1 $x2 =
      $L.Main.sig4 $x $x1 $x2

$L.Main.incr8 : ([1], [1]) -> [3]
$L.Main.incr8 s0 $x =
      $L.r09 s0 s0 $x

$L.r05 : ([1], [1], [1]) -> [3]
$L.r05 r0 s0 s1 =
      r0 # s0 # s1

$LL.L.Main.sig4 : ([1]) -> [1]
$LL.L.Main.sig4 s =
      if eq s 1'h1 then 1'h0
            else 1'h1

$L._unused7 : ([1], [1]) -> [3]
$L._unused7 s0 $x =
      $L.r05 s0 s0 $x

device top_level
      input __in0 : [1]
      output __out0 : [1]
      register __st0 : [1] init 1'h1
      register __st1 : [1] init 1'h1
      let $res = $Pure.dispatch (__st0 # __st1) __in0
      __out0 := $res[2 +: 1]
      next __st0 := $res[1 +: 1]
      next __st1 := $res[0 +: 1]