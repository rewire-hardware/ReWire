-- Procify input shape (positive since the plan's Q3 relaxation): a
-- pausing reactive callee in bind-LHS position splices its block graph
-- once per continuation — sequential machine composition. The callee's
-- internal tail recursion re-enters under the same continuation and
-- closes through the (definition, continuation) memo.
data Bool * {
      False :: Bool;
      True :: Bool
}

Main.pauser#5 :: Bool -> ReacT Bool Bool Identity Bool
Main.pauser#5 (i#6 :: Bool) =
      (rwPrimBind :: ReacT Bool Bool Identity Bool -> (Bool -> ReacT Bool Bool Identity Bool) -> ReacT Bool Bool Identity Bool)
        ((rwPrimSignal :: Bool -> ReacT Bool Bool Identity Bool) i#6)
        Main.pauser#5

Main.start#20 :: ReacT Bool Bool Identity ()
Main.start#20 =
      (rwPrimBind :: ReacT Bool Bool Identity Bool -> (Bool -> ReacT Bool Bool Identity ()) -> ReacT Bool Bool Identity ())
        (Main.pauser#5 (False :: Bool))
        (\ (x#21 :: Bool) -> Main.start#20)

top Main.start#20
