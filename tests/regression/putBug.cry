// Per-cycle step: outputs # next register values.
rw_step : [2] -> [1] -> [3]
rw_step st i = (take`{1} (drop`{1} s4)) # ((take`{1} (drop`{2} s4)) # (drop`{3} s4))
  where
    s0 : [1]
    s0 = take`{1} st
    s1 : [1]
    s1 = drop`{1} st
    s2 : [1]
    s2 = i
    s3 : [3]
    s3 = s0 # (s1 # s2)
    s4 : [4]
    s4 = rw__Pure_dispatch (take`{2} s3) (drop`{2} s3)

// Device: top_level
// Inputs, MSB-first: __in0 : [1]
// Outputs, MSB-first: __out0 : [1]
rw_device : {n} (fin n) => [n][1] -> [n][1]
rw_device ins = outs
  where
    rs : [n][3]
    rs = [rw_step st i | st <- sts | i <- ins]
    sts : [1 + n][2]
    sts = [0b00] # [drop`{1} r | r <- rs]
    outs : [n][1]
    outs = [take`{1} r | r <- rs]