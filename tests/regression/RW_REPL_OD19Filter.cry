// Device: top_level
// Inputs, MSB-first: __in0 : [1], __in1 : [32]
// Outputs, MSB-first: __out0 : [1], __out1 : [1]
rw_device : {n} (fin n) => [n][33] -> [n][2]
rw_device ins = outs
  where
    rs : [n][81]
    rs = [rw__Pure_dispatch st i | st <- sts | i <- ins]
    sts : [1 + n][39]
    sts = [drop`{42} rw__Pure_start] # [drop`{42} r | r <- rs]
    outs : [n][2]
    outs = [take`{2} (drop`{40} r) | r <- rs]