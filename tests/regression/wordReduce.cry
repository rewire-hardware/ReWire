// Generated by rwc from device: top_level.
// rw_device maps a sequence of per-cycle inputs to per-cycle outputs.

module top_level where

// Helpers implementing ReWire Core primitive semantics.
rw'resize : {m, n} (fin m, fin n) => [n] -> [m]
rw'resize x = drop`{n} ((zero : [m]) # x)

rw'repl : {n, w} (fin n, fin w) => [w] -> [n * w]
rw'repl x = join (repeat`{n} x)

rw'parity : {n} (fin n) => [n] -> Bit
rw'parity x = foldr (^) False x

// $Pure.dispatch
rw__Pure_dispatch : [8] -> [6]
rw__Pure_dispatch arg0 = rw__LL_Main_compute1 arg0

// $Pure.start
rw__Pure_start : [6]
rw__Pure_start = 0b010101

// $LL.Main.compute1
rw__LL_Main_compute1 : [8] -> [6]
rw__LL_Main_compute1 arg0 = [arg0 == (~ zero)] # ([arg0 != (~ zero)] # ([arg0 != zero] # ([arg0 == zero] # ([rw'parity arg0] # [~ (rw'parity arg0)]))))

// Device: top_level
// Inputs, MSB-first: __in0 : [8]
// Outputs, MSB-first: __out0 : [6]
rw_device : {n} (fin n) => [n][8] -> [n][6]
rw_device ins = [rw__Pure_dispatch i | i <- ins]