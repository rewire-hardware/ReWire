$LL.Main.compute3 : ([7]) -> [5]
$LL.Main.compute3 $0 =
      $LL.Main.compute1 $0

$LL.Main.compute2 : ([5], [5]) -> [5]
$LL.Main.compute2 $0 $1 =
      trunc 5 (umod (add (zext 128 $0) (zext 128 $1)) 128'h14)

$LL.Pure.dispatch : ([7]) -> [6]
$LL.Pure.dispatch $0 =
      Main.loop1 $0

$LL.Main.loop1 : ([7]) -> [6]
$LL.Main.loop1 $0 =
      $LL.Main.loop2 $0

$LL.Main.compute1 : ([7]) -> [5]
$LL.Main.compute1 $0 =
      $LL.Main.compute5 (trunc 5 (umod $0 7'h14))

$LL.Main.compute : ([10]) -> [5]
$LL.Main.compute $0 =
      $LL.Main.compute6 $0[5 +: 5] $0[0 +: 5]

$LL.Main.loop : ([6]) -> [6]
$LL.Main.loop $0 =
      $LL.Main.loop3 $0[0 +: 5]

device top_level
      input __in0 : [7]
      output __out0 : [5]
