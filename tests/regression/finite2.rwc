$Pure.dispatch : ([7]) -> [6]
$Pure.dispatch $1 =
      $LL.Pure.dispatch $1

Main.compute : ([7]) -> [5]
Main.compute $0 =
      $LL.Main.compute3 $0

$LL.Main.compute6 : ([5], [5]) -> [5]
$LL.Main.compute6 $0 $1 =
      $LL.Main.compute2 $0 $1

$LL.Main.compute5 : ([5]) -> [5]
$LL.Main.compute5 $0 =
      $LL.Main.compute4 $0 5'h6

$LL.Main.loop3 : ([5]) -> [6]
$LL.Main.loop3 $0 =
      1'h1 # $0

$LL.Main.loop2 : ([7]) -> [6]
$LL.Main.loop2 $0 =
      $LL.Main.loop (1'h0 # Main.compute $0)

$LL.Main.compute4 : ([5], [5]) -> [5]
$LL.Main.compute4 $0 $1 =
      $LL.Main.compute ($0 # $1)

Main.loop1 : ([7]) -> [6]
Main.loop1 $0 =
