$Pure.dispatch : ([8]) -> [9]
$Pure.dispatch $1 =
      $LL.Pure.dispatch $1

$LL.Main.myRotr5 : ([8], [8]) -> [8]
$LL.Main.myRotr5 $0 $1 =
      $LL.Main.myRotr3 $0 $1

$LL.Main.myArithRotr5 : ([8], [8]) -> [8]
$LL.Main.myArithRotr5 $0 $1 =
      or (shl $0 (sub 8'h8 $1)) (ashr $0 $1)

Main.myArithRotr : ([8]) -> [8]
Main.myArithRotr $0 =
      $LL.Main.myArithRotr1 ($0 # 8'h5)

$LL.Main.myArithRotr4 : ([8], [8]) -> [8]
$LL.Main.myArithRotr4 $0 $1 =
      $LL.Main.myArithRotr5 $0 $1

Main.myRotr : ([8]) -> [8]
Main.myRotr $0 =
      $LL.Main.myRotr2 ($0 # 8'h3)

$LL.Main.myArithRotr3 : ([8], [8]) -> [8]
$LL.Main.myArithRotr3 $0 $1 =
      $LL.Main.myArithRotr2 $0 (umod $1 8'h8)

$LL.Pure.dispatch : ([8]) -> [9]
$LL.Pure.dispatch $0 =
      Main.loop $0

$LL.Main.loop3 : ([8]) -> [9]
$LL.Main.loop3 $0 =
      $LL.Main.loop2 $0

$LL.Main.myRotr4 : ([8], [8]) -> [8]
$LL.Main.myRotr4 $0 $1 =
      or (shl $0 (sub 8'h8 $1)) (lshr $0 $1)

$LL.Main.myRotr3 : ([8], [8]) -> [8]
$LL.Main.myRotr3 $0 $1 =
      $LL.Main.myRotr4 $0 $1

$LL.Main.myArithRotr2 : ([8], [8]) -> [8]
$LL.Main.myArithRotr2 $0 $1 =
      $LL.Main.myArithRotr4 $0 $1

Main.loop : ([8]) -> [9]
Main.loop $0 =
      $LL.Main.loop3 $0

$LL.Main.loop2 : ([8]) -> [9]
$LL.Main.loop2 $0 =
      $LL.Main.loop (1'h0 # Main.myArithRotr (Main.myRotr $0))

$LL.Main.myRotr2 : ([16]) -> [8]
$LL.Main.myRotr2 $0 =
      $LL.Main.myRotr1 $0[8 +: 8] $0[0 +: 8]

$LL.Main.myRotr1 : ([8], [8]) -> [8]
$LL.Main.myRotr1 $0 $1 =
      $LL.Main.myRotr $0 $1

$LL.Main.myArithRotr1 : ([16]) -> [8]
$LL.Main.myArithRotr1 $0 =
      $LL.Main.myArithRotr $0[8 +: 8] $0[0 +: 8]

$LL.Main.loop1 : ([8]) -> [9]
$LL.Main.loop1 $0 =
      1'h1 # $0

$LL.Main.loop : ([9]) -> [9]
$LL.Main.loop $0 =
      $LL.Main.loop1 $0[0 +: 8]

$LL.Main.myRotr : ([8], [8]) -> [8]
$LL.Main.myRotr $0 $1 =
      $LL.Main.myRotr5 $0 (umod $1 8'h8)

$LL.Main.myArithRotr : ([8], [8]) -> [8]
$LL.Main.myArithRotr $0 $1 =
      $LL.Main.myArithRotr3 $0 $1

device top_level
      input __in0 : [8]
      output __out0 : [8]
      let $in = __in0
      let $res = $Pure.dispatch $in
      __out0 := $res[0 +: 8]