// Per-cycle step: outputs # next register values.
rw_step : [39] -> [33] -> [41]
rw_step st i = (take`{1} (drop`{25} s5)) # ((take`{1} (drop`{26} s5)) # ((take`{7} (drop`{27} s5)) # (drop`{34} s5)))
  where
    s0 : [7]
    s0 = take`{7} st
    s1 : [32]
    s1 = drop`{7} st
    s2 : [1]
    s2 = take`{1} i
    s3 : [32]
    s3 = drop`{1} i
    s4 : [72]
    s4 = s0 # (s1 # (s2 # s3))
    s5 : [66]
    s5 = rw__Pure_dispatch (take`{39} s4) (drop`{39} s4)

// Device: top_level
// Inputs, MSB-first: __in0 : [1], __in1 : [32]
// Outputs, MSB-first: __out0 : [1], __out1 : [1]
rw_device : {n} (fin n) => [n][33] -> [n][2]
rw_device ins = outs
  where
    rs : [n][41]
    rs = [rw_step st i | st <- sts | i <- ins]
    sts : [1 + n][39]
    sts = [0b001101100000000000000000000000000000000] # [drop`{2} r | r <- rs]
    outs : [n][2]
    outs = [take`{2} r | r <- rs]