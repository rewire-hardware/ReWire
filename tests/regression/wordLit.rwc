$Pure.dispatch : ([8]) -> [17]
$Pure.dispatch $1 =
      $LL.Pure.dispatch $1

$LL.Main.loop3 : ([8]) -> [17]
$LL.Main.loop3 $0 =
      $LL.Main.loop2 $0

$LL.Main.loop2 : ([8]) -> [17]
$LL.Main.loop2 $0 =
      $LL.Main.loop (1'h0 # xor (zext 16 $0) 16'h1)

Main.loop1 : ([8]) -> [17]
Main.loop1 $0 =
      $LL.Main.loop3 $0

$LL.Main.loop1 : ([16]) -> [17]
$LL.Main.loop1 $0 =
      1'h1 # $0

$LL.Main.loop : ([17]) -> [17]
$LL.Main.loop $0 =
      $LL.Main.loop1 $0[0 +: 16]

$LL.Pure.dispatch : ([8]) -> [17]
$LL.Pure.dispatch $0 =
      Main.loop1 $0

device top_level
      input __in0 : [8]
      output __out0 : [16]
      let $res = $Pure.dispatch __in0
      __out0 := $res[0 +: 16]