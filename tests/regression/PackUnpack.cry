rw__LL_Main_dev arg0 arg1 arg2 arg3 = (rw__LL_Main_dev72 (take`{8} s0) (take`{8} (drop`{8} s0)) (take`{3} (drop`{16} s0)) (take`{3} (drop`{19} s0)) (drop`{22} s0)) # ((rw__LL_Main_dev72 (take`{8} s1) (take`{8} (drop`{8} s1)) (take`{3} (drop`{16} s1)) (take`{3} (drop`{19} s1)) (drop`{22} s1)) # ((rw__LL_Main_dev72 (take`{8} s2) (take`{8} (drop`{8} s2)) (take`{3} (drop`{16} s2)) (take`{3} (drop`{19} s2)) (drop`{22} s2)) # ((rw__LL_Main_dev72 (take`{8} s3) (take`{8} (drop`{8} s3)) (take`{3} (drop`{16} s3)) (take`{3} (drop`{19} s3)) (drop`{22} s3)) # ((rw__LL_Main_dev72 (take`{8} s4) (take`{8} (drop`{8} s4)) (take`{3} (drop`{16} s4)) (take`{3} (drop`{19} s4)) (drop`{22} s4)) # ((rw__LL_Main_dev72 (take`{8} s5) (take`{8} (drop`{8} s5)) (take`{3} (drop`{16} s5)) (take`{3} (drop`{19} s5)) (drop`{22} s5)) # ((rw__LL_Main_dev72 (take`{8} s6) (take`{8} (drop`{8} s6)) (take`{3} (drop`{16} s6)) (take`{3} (drop`{19} s6)) (drop`{22} s6)) # (rw__LL_Main_dev72 (take`{8} s7) (take`{8} (drop`{8} s7)) (take`{3} (drop`{16} s7)) (take`{3} (drop`{19} s7)) (drop`{22} s7))))))))
  where
    s0 : [25]
    s0 = arg0 # (arg1 # (arg2 # (arg3 # 0b000)))
    s1 : [25]
    s1 = arg0 # (arg1 # (arg2 # (arg3 # 0b001)))
    s2 : [25]
    s2 = arg0 # (arg1 # (arg2 # (arg3 # 0b010)))
    s3 : [25]
    s3 = arg0 # (arg1 # (arg2 # (arg3 # 0b011)))
    s4 : [25]
    s4 = arg0 # (arg1 # (arg2 # (arg3 # 0b100)))
    s5 : [25]
    s5 = arg0 # (arg1 # (arg2 # (arg3 # 0b101)))
    s6 : [25]
    s6 = arg0 # (arg1 # (arg2 # (arg3 # 0b110)))
    s7 : [25]
    s7 = arg0 # (arg1 # (arg2 # (arg3 # 0b111)))

// Device: top_level
// Inputs, MSB-first: __in0 : [8]
// Outputs, MSB-first: __out0 : [8], __out1 : [8], __out2 : [8], __out3 : [8]
rw_device : {n} (fin n) => [n][8] -> [n][32]
rw_device ins = [rw__Pure_dispatch i | i <- ins]