// $LL.Main.dev9
rw__LL_Main_dev9 : [8] -> [8] -> [3] -> [8]
rw__LL_Main_dev9 arg0 arg1 arg2 = rw__LL_Main_dev140 (take`{8} s0) (take`{8} (drop`{8} s0)) (take`{3} (drop`{16} s0)) (drop`{19} s0)
