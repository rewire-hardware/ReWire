$Pure.dispatch : ([3], [1]) -> [4]
$Pure.dispatch $0 $1 =
      if eq $0[1 +: 2] 2'h1 then $LL.Pure.dispatch4 $1 $0[0 +: 1]
            else if eq $0[1 +: 2] 2'h2 then $LL.Pure.dispatch3 $1 else if eq $0[1 +: 2] 2'h3 then $LL.Pure.dispatch4 $1 $0[0 +: 1] else $LL.Pure.dispatch5 $1

"$LL.ReWire.Prelude.&&3" : ([1], [1], [2]) -> [1]
"$LL.ReWire.Prelude.&&3" $0 $1 $2 =
      if eq $2[1 +: 1] 1'h1 then $LL.Main.go8 $2[0 +: 1]
            else "$LL.ReWire.Prelude.&&2" ($1 # $0)

$LL.Main.go13 : ([1], [1]) -> [1]
$LL.Main.go13 $0 $1 =
      $LL.Main.go $0

$LL.Main.go12 : ([1], [1]) -> [4]
$LL.Main.go12 $0 $1 =
      $LL.Main.go10 $0 $1

$LL.Main.go11 : ([1]) -> [4]
$LL.Main.go11 $0 =
      if eq $0 1'h1 then $LL.Main.go3 $0
            else $LL.Main.go2 $0 $0

$LL.Main.go10 : ([1], [1]) -> [4]
$LL.Main.go10 $0 $1 =
      $1 # 2'h1 # $0

$LL.Main.go9 : ([1], [1]) -> [4]
$LL.Main.go9 $0 $1 =
      $LL.Main.go1 $0 $1

"$LL.ReWire.Prelude.&&2" : ([2]) -> [1]
"$LL.ReWire.Prelude.&&2" $0 =
      "$LL.ReWire.Prelude.&&1" $0[0 +: 1]

$LL.Main.go8 : ([1]) -> [1]
$LL.Main.go8 $0 =
      $0

$LL.Pure.dispatch5 : ([1]) -> [4]
$LL.Pure.dispatch5 $0 =
      $LL.Main.go11 $0

$LL.Main.go7 : ([1], [1], [1]) -> [1]
$LL.Main.go7 $0 $1 $2 =
      if eq $2 1'h1 then $LL.Main.go8 $0
            else $LL.Main.go13 $0 $1

"$LL.ReWire.Prelude.&&1" : ([1]) -> [1]
"$LL.ReWire.Prelude.&&1" $0 =
      1'h0

$LL.Main.go6 : ([1]) -> [4]
$LL.Main.go6 $0 =
      4'h0

$LL.Main.go5 : ([1], [1]) -> [4]
$LL.Main.go5 $0 $1 =
      "ReWire.Prelude.&&" ($LL.Main.go7 $0 $1 $1) $1 # 3'h4

"ReWire.Prelude.&&" : ([1], [1]) -> [1]
"ReWire.Prelude.&&" $0 $1 =
      "$LL.ReWire.Prelude.&&3" $1 $0 ($0 # $1)

$LL.Pure.dispatch4 : ([1], [1]) -> [4]
$LL.Pure.dispatch4 $0 $1 =
      $LL.Pure.dispatch2 $0 $1

$LL.Pure.dispatch3 : ([1]) -> [4]
$LL.Pure.dispatch3 $0 =
      $LL.Main.go6 $0

$LL.Main.go3 : ([1]) -> [4]
$LL.Main.go3 $0 =
      3'h3 # $0

$LL.Main.go2 : ([1], [1]) -> [4]
$LL.Main.go2 $0 $1 =
      $LL.Main.go12 $0 $1

$LL.Pure.dispatch2 : ([1], [1]) -> [4]
$LL.Pure.dispatch2 $0 $1 =
      $LL.Main.go9 $1 $0

$LL.Main.go1 : ([1], [1]) -> [4]
$LL.Main.go1 $0 $1 =
      $LL.Main.go5 $0 $1

$LL.Main.go : ([1]) -> [1]
$LL.Main.go $0 =
      "ReWire.Prelude.&&" $0 $0

device top_level
      input __in0 : [1]
      output __out0 : [1]
      register __resumption_tag : [3] init 3'h0
      let $res = $Pure.dispatch __resumption_tag __in0
      __out0 := $res[3 +: 1]
      next __resumption_tag := $res[0 +: 3]