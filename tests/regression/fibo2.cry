rw__LL_Main_loop : [8] -> [8] -> [1] -> [24]
rw__LL_Main_loop x0 x1 x2 = rw__LL_Main_loop7 x0 x1 x2 x2

// Per-cycle step: outputs # next register values.
rw_step : [16] -> [1] -> [24]
rw_step st i = (take`{8} s3) # (drop`{8} s3)
  where
    s0 : [16]
    s0 = st
    s1 : [1]
    s1 = i
    s2 : [17]
    s2 = s0 # s1
    s3 : [24]
    s3 = rw__Pure_dispatch (take`{16} s2) (drop`{16} s2)

// Device: top_level
// Inputs, MSB-first: __in0 : [1]
// Outputs, MSB-first: __out0 : [8]
rw_device : {n} (fin n) => [n][1] -> [n][8]
rw_device ins = outs
  where
    rs : [n][24]
    rs = [rw_step st i | st <- sts | i <- ins]
    sts : [1 + n][16]
    sts = [0x0100] # [drop`{8} r | r <- rs]
    outs : [n][8]
    outs = [take`{8} r | r <- rs]