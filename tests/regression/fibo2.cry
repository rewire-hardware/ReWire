// $LL.Main.loop8
rw__LL_Main_loop8 : [16] -> [24]
rw__LL_Main_loop8 x0 = rw__LL_Main_loop9 (take`{8} x0) (drop`{8} x0)

// $LL.Main.loop7
rw__LL_Main_loop7 : [8] -> [8] -> [1] -> [1] -> [24]
rw__LL_Main_loop7 x0 x1 x2 x3 = if (drop`{16} s0) == 0b1 then (rw__LL_Main_loop5 (take`{8} s0) (take`{8} (drop`{8} s0))) else (rw__LL_Main_loop3 x0 x1 x2)
  where
    s0 : [17]
    s0 = x0 # (x1 # x3)

// $LL.Main.loop6
rw__LL_Main_loop6 : [8] -> [8] -> [24]
rw__LL_Main_loop6 x0 x1 = rw_Main_loop x0 (x1 + x0)

// $LL.Main.loop5
rw__LL_Main_loop5 : [8] -> [8] -> [24]
