// Generated by rwc from device: top_level.
// rw_device maps a sequence of per-cycle inputs to per-cycle outputs.

module top_level where

// Helpers implementing ReWire Mantle primitive semantics.
rw'resize : {m, n} (fin m, fin n) => [n] -> [m]
rw'resize x = drop`{n} ((zero : [m]) # x)

rw'repl : {n, w} (fin n, fin w) => [w] -> [n * w]
rw'repl x = join (repeat`{n} x)

rw'parity : {n} (fin n) => [n] -> Bit
rw'parity x = foldr (^) False x

rw'sext : {m, n} (fin m, fin n, n >= 1) => [n] -> [m]
rw'sext x = if x @ 0 then ~ (rw'resize (~ x)) else rw'resize x

// $Pure.dispatch
rw__Pure_dispatch : [8] -> [8] -> [17]
rw__Pure_dispatch x0 x1 = rw__LL_Pure_dispatch (take`{8} s0) (drop`{8} s0)
  where
    s0 : [16]
    s0 = x1 # x0

// Main.start'
rw_Main_start_ : [8] -> [17]
rw_Main_start_ x0 = 0b000000000 # x0

// $LL.Main.start'1
rw__LL_Main_start_1 : [8] -> [8] -> [17]
rw__LL_Main_start_1 x0 x1 = rw__LL_Main_start_ x0 x1

// $LL.Main.start'
rw__LL_Main_start_ : [8] -> [8] -> [17]
rw__LL_Main_start_ x0 x1 = rw_Main_start_ x1

// $LL.Pure.dispatch
rw__LL_Pure_dispatch : [8] -> [8] -> [17]
rw__LL_Pure_dispatch x0 x1 = rw__LL_Main_start_1 x0 x1

// Per-cycle step: outputs # next register values.
rw_step : [8] -> [8] -> [17]
rw_step st i = (take`{1} s3) # ((take`{8} (drop`{1} s3)) # (drop`{9} s3))
  where
    s0 : [8]
    s0 = st
    s1 : [8]
    s1 = i
    s2 : [16]
    s2 = s0 # s1
    s3 : [17]
    s3 = rw__Pure_dispatch (take`{8} s2) (drop`{8} s2)

// Device: top_level
// Inputs, MSB-first: __in0 : [8]
// Outputs, MSB-first: __out0 : [1], __out1 : [8]
rw_device : {n} (fin n) => [n][8] -> [n][9]
rw_device ins = outs
  where
    rs : [n][17]
    rs = [rw_step st i | st <- sts | i <- ins]
    sts : [1 + n][8]
    sts = [0x00] # [drop`{9} r | r <- rs]
    outs : [n][9]
    outs = [take`{9} r | r <- rs]