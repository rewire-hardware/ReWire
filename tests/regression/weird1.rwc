$Pure.dispatch : ([2], [1]) -> [3]
$Pure.dispatch $0 $1 =
      $LL.Pure.dispatch $1 $0

Main.repl1 : ([1], [2]) -> [3]
Main.repl1 $0 $1 =
      $LL.Main.repl1 $0 $1

$LL.Main.repl1 : ([1], [2]) -> [3]
$LL.Main.repl1 $0 $1 =
      $LL.Main.repl $0 $1

$LL.Pure.dispatch : ([1], [2]) -> [3]
$LL.Pure.dispatch $0 $1 =
      Main.repl1 $0 $1

$LL.Main.repl : ([1], [2]) -> [3]
$LL.Main.repl $0 $1 =
      1'h0 # $1

device top_level
      input __in0 : [1]
      output __out0 : [1]
      register __st0 : [1] init 1'h0
      register __st1 : [1] init 1'h0
      let $res = $Pure.dispatch (__st0 # __st1) __in0
      __out0 := $res[2 +: 1]
      next __st0 := $res[1 +: 1]
      next __st1 := $res[0 +: 1]