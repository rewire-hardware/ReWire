// $LL.Main.compute
rw__LL_Main_compute : [8] -> [8]
rw__LL_Main_compute arg0 = (take`{8} s6) % (drop`{8} s6)
  where
    s0 : [16]
    s0 = arg0 # 0x01
    s1 : [16]
    s1 = ((take`{8} s0) + (drop`{8} s0)) # 0x02
    s2 : [16]
    s2 = arg0 # 0x02
    s3 : [16]
    s3 = ((take`{8} s1) ^^ (drop`{8} s1)) # ((take`{8} s2) - (drop`{8} s2))
    s4 : [16]
    s4 = ((take`{8} s3) * (drop`{8} s3)) # 0x03
    s5 : [16]
    s5 = arg0 # 0x01
    s6 : [16]
    s6 = ((take`{8} s4) / (drop`{8} s4)) # ((take`{8} s5) + (drop`{8} s5))

// Device: top_level
// Inputs, MSB-first: __in0 : [8]
// Outputs, MSB-first: __out0 : [8]
rw_device : {n} (fin n) => [n][8] -> [n][8]
