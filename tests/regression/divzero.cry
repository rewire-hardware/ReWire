// Generated by rwc from device: top_level.
// rw_device maps a sequence of per-cycle inputs to per-cycle outputs.

module top_level where

// Helpers implementing ReWire Hyle primitive semantics.
rw'resize : {m, n} (fin m, fin n) => [n] -> [m]
rw'resize x = drop`{n} ((zero : [m]) # x)

rw'repl : {n, w} (fin n, fin w) => [w] -> [n * w]
rw'repl x = join (repeat`{n} x)

rw'parity : {n} (fin n) => [n] -> Bit
rw'parity x = foldr (^) False x

rw'sext : {m, n} (fin m, fin n, n >= 1) => [n] -> [m]
rw'sext x = if x @ 0 then ~ (rw'resize (~ x)) else rw'resize x

// $Pure.dispatch
rw__Pure_dispatch : [8] -> [16]
rw__Pure_dispatch x0 = rw__LL_Pure_dispatch x0

// $LL.Main.f5
rw__LL_Main_f5 : [8] -> [8] -> [16]
rw__LL_Main_f5 x0 x1 = rw__LL_Main_f x0 x1

// Main.f
rw_Main_f : [8] -> [16]
rw_Main_f x0 = rw__LL_Main_f2 x0

// $LL.Pure.dispatch
rw__LL_Pure_dispatch : [8] -> [16]
rw__LL_Pure_dispatch x0 = rw_ReWire_Monad_iter x0

// $LL.Main.f4
rw__LL_Main_f4 : [8] -> [8] -> [16]
rw__LL_Main_f4 x0 x1 = rw__LL_Main_f5 x0 x1

// $LL.Main.f3
rw__LL_Main_f3 : [8] -> [16]
rw__LL_Main_f3 x0 = rw__LL_Main_f4 x0 (if 0x00 == zero then (x0 && 0x03) else ((x0 && 0x03) % 0x00))

// $LL.Main.f2
rw__LL_Main_f2 : [8] -> [16]
rw__LL_Main_f2 x0 = rw__LL_Main_f3 x0

// ReWire.Monad.iter
rw_ReWire_Monad_iter : [8] -> [16]
rw_ReWire_Monad_iter x0 = rw_Main_f x0

// $LL.Main.f
rw__LL_Main_f : [8] -> [8] -> [16]
rw__LL_Main_f x0 x1 = (if x1 == zero then 0xff else (x0 / x1)) # ((if x1 == zero then x0 else (x0 % x1)) ^ 0xff)

// Per-cycle step: outputs # next register values.
rw_step : [8] -> [16]
rw_step i = s2
  where
    s0 : [8]
    s0 = i
    s1 : [8]
    s1 = s0
    s2 : [16]
    s2 = rw__Pure_dispatch s1

// Device: top_level
// Inputs, MSB-first: __in0 : [8]
// Outputs, MSB-first: __out0 : [16]
rw_device : {n} (fin n) => [n][8] -> [n][16]
rw_device ins = [rw_step i | i <- ins]