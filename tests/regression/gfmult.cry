// Per-cycle step: outputs # next register values.
rw_step : [256] -> [128]
rw_step i = s3
  where
    s0 : [128]
    s0 = take`{128} i
    s1 : [128]
    s1 = drop`{128} i
    s2 : [256]
    s2 = s0 # s1
    s3 : [128]
    s3 = rw__Pure_dispatch s2

// Device: top_level
// Inputs, MSB-first: __in0 : [128], __in1 : [128]
// Outputs, MSB-first: __out0 : [128]
rw_device : {n} (fin n) => [n][256] -> [n][128]
rw_device ins = [rw_step i | i <- ins]