$Pure.dispatch : ([8]) -> [16]
$Pure.dispatch $1 =
      $LL.Pure.dispatch $1

$LL.Main.f5 : ([8], [8]) -> [16]
$LL.Main.f5 $0 $1 =
      $LL.Main.f $0 $1

Main.f : ([8]) -> [16]
Main.f $0 =
      $LL.Main.f2 $0

$LL.Pure.dispatch : ([8]) -> [16]
$LL.Pure.dispatch $0 =
      ReWire.Monad.iter $0

$LL.Main.f4 : ([8], [8]) -> [16]
$LL.Main.f4 $0 $1 =
      $LL.Main.f5 $0 $1

$LL.Main.f3 : ([8]) -> [16]
$LL.Main.f3 $0 =
      $LL.Main.f4 $0 (umod (and $0 8'h3) 8'h0)

$LL.Main.f2 : ([8]) -> [16]
$LL.Main.f2 $0 =
      $LL.Main.f3 $0

ReWire.Monad.iter : ([8]) -> [16]
ReWire.Monad.iter $0 =
      Main.f $0

$LL.Main.f : ([8], [8]) -> [16]
$LL.Main.f $0 $1 =
      udiv $0 $1 # xor (umod $0 $1) 8'hff

device top_level
      input __in0 : [8]
      output __out0 : [16]
      let $in = __in0
      let $res = $Pure.dispatch $in
      __out0 := $res