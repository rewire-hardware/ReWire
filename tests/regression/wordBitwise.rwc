$Pure.dispatch : ([24]) -> [9]
$Pure.dispatch $1 =
      $LL.Pure.dispatch $1

Main.compute : ([24]) -> [8]
Main.compute $0 =
      $LL.Main.compute $0

$LL.Main.loop3 : ([9]) -> [9]
$LL.Main.loop3 $0 =
      $LL.Main.loop1 $0[0 +: 8]

$LL.Main.loop2 : ([24]) -> [9]
$LL.Main.loop2 $0 =
      $LL.Main.loop $0

Main.loop : ([24]) -> [9]
Main.loop $0 =
      $LL.Main.loop2 $0

$LL.Main.compute3 : ([8], [8], [8]) -> [8]
$LL.Main.compute3 $0 $1 $2 =
      or (xor (and $0 $1) $2) (not (xor (and (not $0) (not $1)) $2))

$LL.Main.compute2 : ([8], [8], [8]) -> [8]
$LL.Main.compute2 $0 $1 $2 =
      $LL.Main.compute3 $0 $1 $2

$LL.Main.compute1 : ([8], [8], [8]) -> [8]
$LL.Main.compute1 $0 $1 $2 =
      $LL.Main.compute2 $0 $1 $2

$LL.Main.loop1 : ([8]) -> [9]
$LL.Main.loop1 $0 =
      1'h1 # $0

$LL.Main.loop : ([24]) -> [9]
$LL.Main.loop $0 =
      $LL.Main.loop3 (1'h0 # Main.compute $0)

$LL.Main.compute : ([24]) -> [8]
$LL.Main.compute $0 =
      $LL.Main.compute1 $0[16 +: 8] $0[8 +: 8] $0[0 +: 8]

$LL.Pure.dispatch : ([24]) -> [9]
$LL.Pure.dispatch $0 =
      Main.loop $0

device top_level
      input __in0 : [8]
      input __in1 : [8]
      input __in2 : [8]
      output __out0 : [8]
      let $in = __in0 # __in1 # __in2
      let $res = $Pure.dispatch $in
      __out0 := $res[0 +: 8]