// rw_device maps a sequence of per-cycle inputs to per-cycle outputs.

module top_level where

// Helpers implementing ReWire Core primitive semantics.
rw'resize : {m, n} (fin m, fin n) => [n] -> [m]
rw'resize x = drop`{n} ((zero : [m]) # x)

rw'repl : {n, w} (fin n, fin w) => [w] -> [n * w]
rw'repl x = join (repeat`{n} x)

rw'parity : {n} (fin n) => [n] -> Bit
rw'parity x = foldr (^) False x

// $Pure.dispatch
rw__Pure_dispatch : [2] -> [1]
rw__Pure_dispatch arg0 = rw__LL_Main_proc4 arg0

// $Pure.start
rw__Pure_start : [1]
rw__Pure_start = 0b0

// $LL.Main.proc7
rw__LL_Main_proc7 : [2] -> [1]
rw__LL_Main_proc7 arg0 = if arg0 == 0b10 then 0b0 else 0b1

// $LL.Main.proc4
rw__LL_Main_proc4 : [2] -> [1]
rw__LL_Main_proc4 arg0 = rw__LL_Main_proc (take`{2} s0) (drop`{2} s0)
  where
    s0 : [4]
    s0 = arg0 # arg0

// $LL.Main.proc2
rw__LL_Main_proc2 : [2] -> [2] -> [1]
rw__LL_Main_proc2 arg0 arg1 = if arg1 == 0b01 then 0b0 else (rw__LL_Main_proc7 arg0)

// $LL.Main.proc
rw__LL_Main_proc : [2] -> [2] -> [1]
rw__LL_Main_proc arg0 arg1 = if arg1 == 0b00 then 0b0 else (rw__LL_Main_proc2 (take`{2} s0) (drop`{2} s0))
  where
    s0 : [4]
    s0 = arg0 # arg0

// Device: top_level
// Inputs, MSB-first: __in0 : [2]
// Outputs, MSB-first: __out0 : [1]
rw_device : {n} (fin n) => [n][2] -> [n][1]
rw_device ins = [rw__Pure_dispatch i | i <- ins]