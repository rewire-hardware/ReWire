// Generated by rwc from device: top_level.
// rw_device maps a sequence of per-cycle inputs to per-cycle outputs.

module top_level where

// Helpers implementing ReWire Hyle primitive semantics.
rw'resize : {m, n} (fin m, fin n) => [n] -> [m]
rw'resize x = drop`{n} ((zero : [m]) # x)

rw'repl : {n, w} (fin n, fin w) => [w] -> [n * w]
rw'repl x = join (repeat`{n} x)

rw'parity : {n} (fin n) => [n] -> Bit
rw'parity x = foldr (^) False x

rw'sext : {m, n} (fin m, fin n, n >= 1) => [n] -> [m]
rw'sext x = if x @ 0 then ~ (rw'resize (~ x)) else rw'resize x

// $Pure.dispatch
rw__Pure_dispatch : [2] -> [1]
rw__Pure_dispatch x0 = rw__LL_Pure_dispatch x0

// $LL.Main.startp1
rw__LL_Main_startp1 : [2] -> [1]
rw__LL_Main_startp1 x0 = rw_Main_proc x0

// Main.startp1
rw_Main_startp1 : [2] -> [1]
rw_Main_startp1 x0 = rw__LL_Main_startp x0

// $LL.Main.proc6
rw__LL_Main_proc6 : [2] -> [1]
rw__LL_Main_proc6 x0 = rw__LL_Main_proc2 x0 x0

// $LL.Main.startp
rw__LL_Main_startp : [2] -> [1]
rw__LL_Main_startp x0 = rw__LL_Main_startp1 x0

// $LL.Pure.dispatch
rw__LL_Pure_dispatch : [2] -> [1]
rw__LL_Pure_dispatch x0 = rw_Main_startp1 x0

// $LL.Main.proc4
rw__LL_Main_proc4 : [2] -> [1]
rw__LL_Main_proc4 x0 = rw__LL_Main_proc6 x0

// $LL.Main.proc2
rw__LL_Main_proc2 : [2] -> [2] -> [1]
rw__LL_Main_proc2 x0 x1 = if x1 == 0b00 then 0b0 else (rw__LL_Main_proc x0 x0)

// $LL.Main.proc1
rw__LL_Main_proc1 : [2] -> [1]
rw__LL_Main_proc1 x0 = if x0 == 0b10 then 0b0 else 0b1

// Main.proc
rw_Main_proc : [2] -> [1]
rw_Main_proc x0 = rw__LL_Main_proc4 x0

// $LL.Main.proc
rw__LL_Main_proc : [2] -> [2] -> [1]
rw__LL_Main_proc x0 x1 = if x1 == 0b01 then 0b0 else (rw__LL_Main_proc1 x0)

// Per-cycle step: outputs # next register values.
rw_step : [2] -> [1]
rw_step i = s1
  where
    s0 : [2]
    s0 = i
    s1 : [1]
    s1 = rw__Pure_dispatch s0

// Device: top_level
// Inputs, MSB-first: __in0 : [2]
// Outputs, MSB-first: __out0 : [1]
rw_device : {n} (fin n) => [n][2] -> [n][1]
rw_device ins = [rw_step i | i <- ins]