// Generated by rwc from device: top_level.
// rw_device maps a sequence of per-cycle inputs to per-cycle outputs.

module top_level where

// Helpers implementing ReWire Hyle primitive semantics.
rw'resize : {m, n} (fin m, fin n) => [n] -> [m]
rw'resize x = drop`{n} ((zero : [m]) # x)

rw'repl : {n, w} (fin n, fin w) => [w] -> [n * w]
rw'repl x = join (repeat`{n} x)

rw'parity : {n} (fin n) => [n] -> Bit
rw'parity x = foldr (^) False x

rw'sext : {m, n} (fin m, fin n, n >= 1) => [n] -> [m]
rw'sext x = if x @ 0 then ~ (rw'resize (~ x)) else rw'resize x

// $Pure.dispatch
rw__Pure_dispatch : [128] -> [65]
rw__Pure_dispatch x0 = rw__LL_Pure_dispatch x0

// Main.compute
rw_Main_compute : [128] -> [64]
rw_Main_compute x0 = rw__LL_Main_compute2 x0

// $LL.Pure.dispatch
rw__LL_Pure_dispatch : [128] -> [65]
rw__LL_Pure_dispatch x0 = rw_Main_loop x0

// $LL.Main.loop3
rw__LL_Main_loop3 : [128] -> [65]
rw__LL_Main_loop3 x0 = rw__LL_Main_loop1 (0b0 # (rw_Main_compute x0))

// Main.loop
rw_Main_loop : [128] -> [65]
rw_Main_loop x0 = rw__LL_Main_loop2 x0

// $LL.Main.loop2
rw__LL_Main_loop2 : [128] -> [65]
rw__LL_Main_loop2 x0 = rw__LL_Main_loop3 x0

// $LL.Main.loop1
rw__LL_Main_loop1 : [65] -> [65]
rw__LL_Main_loop1 x0 = rw__LL_Main_loop (drop`{1} x0)

// $LL.Main.compute2
rw__LL_Main_compute2 : [128] -> [64]
rw__LL_Main_compute2 x0 = rw__LL_Main_compute (take`{64} x0) (drop`{64} x0)

// $LL.Main.loop
rw__LL_Main_loop : [64] -> [65]
rw__LL_Main_loop x0 = 0b1 # x0

// $LL.Main.compute1
rw__LL_Main_compute1 : [64] -> [64] -> [64]
rw__LL_Main_compute1 x0 x1 = (take`{8} (drop`{24} x0)) # ((take`{8} (drop`{16} x0)) # ((take`{8} (drop`{8} x0)) # ((take`{8} x0) # (0x00 # (drop`{40} x1)))))

// $LL.Main.compute
rw__LL_Main_compute : [64] -> [64] -> [64]
rw__LL_Main_compute x0 x1 = rw__LL_Main_compute1 x0 x1

// Per-cycle step: outputs # next register values.
rw_step : [128] -> [64]
rw_step i = drop`{1} s3
  where
    s0 : [64]
    s0 = take`{64} i
    s1 : [64]
    s1 = drop`{64} i
    s2 : [128]
    s2 = s0 # s1
    s3 : [65]
    s3 = rw__Pure_dispatch s2

// Device: top_level
// Inputs, MSB-first: __in0 : [64], __in1 : [64]
// Outputs, MSB-first: __out0 : [64]
rw_device : {n} (fin n) => [n][128] -> [n][64]
rw_device ins = [rw_step i | i <- ins]