// Helpers implementing ReWire Hyle primitive semantics.
rw'resize : {m, n} (fin m, fin n) => [n] -> [m]
rw'resize x = drop`{n} ((zero : [m]) # x)

rw'repl : {n, w} (fin n, fin w) => [w] -> [n * w]
rw'repl x = join (repeat`{n} x)

rw'parity : {n} (fin n) => [n] -> Bit
rw'parity x = foldr (^) False x

rw'sext : {m, n} (fin m, fin n, n >= 1) => [n] -> [m]
rw'sext x = if x @ 0 then ~ (rw'resize (~ x)) else rw'resize x

// $Pure.dispatch
rw__Pure_dispatch : [1] -> [1]
rw__Pure_dispatch x0 = rw__LL_Pure_dispatch x0

// ReWire.Prelude.not1
rw_ReWire_Prelude_not1 : [1] -> [1]
rw_ReWire_Prelude_not1 x0 = rw__LL_ReWire_Prelude_not x0 x0

// $LL.ReWire.Prelude.not3
rw__LL_ReWire_Prelude_not3 : [1] -> [1]
rw__LL_ReWire_Prelude_not3 x0 = 0b1

// Main.f
rw_Main_f : [1] -> [1]
rw_Main_f x0 = rw_ReWire_Prelude_not1 x0

// ReWire.Monad.iter
rw_ReWire_Monad_iter : [1] -> [1]
rw_ReWire_Monad_iter x0 = rw_Main_f x0

// $LL.ReWire.Prelude.not
rw__LL_ReWire_Prelude_not : [1] -> [1] -> [1]
rw__LL_ReWire_Prelude_not x0 x1 = if x1 == 0b1 then 0b0 else (rw__LL_ReWire_Prelude_not3 x0)

// $LL.Pure.dispatch
rw__LL_Pure_dispatch : [1] -> [1]
rw__LL_Pure_dispatch x0 = rw_ReWire_Monad_iter x0

// Per-cycle step: outputs # next register values.
rw_step : [1] -> [1]
rw_step i = s2
  where
    s0 : [1]
    s0 = i
    s1 : [1]
    s1 = s0
    s2 : [1]
    s2 = rw__Pure_dispatch s1

// Device: top_level
// Inputs, MSB-first: __in0 : [1]
// Outputs, MSB-first: __out0 : [1]
rw_device : {n} (fin n) => [n][1] -> [n][1]
rw_device ins = [rw_step i | i <- ins]