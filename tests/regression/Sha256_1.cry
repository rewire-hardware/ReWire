// Per-cycle step: outputs # next register values.
rw_step : [1038] -> [514] -> [1296]
rw_step st i = (take`{258} (drop`{1} s7)) # ((take`{8} (drop`{259} s7)) # ((take`{224} (drop`{267} s7)) # ((take`{32} (drop`{491} s7)) # ((take`{512} (drop`{523} s7)) # (drop`{1035} s7)))))
  where
    s0 : [8]
    s0 = take`{8} st
    s1 : [224]
    s1 = take`{224} (drop`{8} st)
    s2 : [32]
    s2 = take`{32} (drop`{232} st)
    s3 : [512]
    s3 = take`{512} (drop`{264} st)
    s4 : [262]
    s4 = drop`{776} st
    s5 : [514]
    s5 = i
    s6 : [1552]
    s6 = s0 # (s1 # (s2 # (s3 # (s4 # s5))))
    s7 : [1297]
    s7 = rw__Pure_dispatch (take`{1038} s6) (drop`{1038} s6)

// Device: top_level
// Inputs, MSB-first: __in0 : [514]
// Outputs, MSB-first: __out0 : [258]
rw_device : {n} (fin n) => [n][514] -> [n][258]
rw_device ins = outs
  where
    rs : [n][1296]
    rs = [rw_step st i | st <- sts | i <- ins]
    sts : [1 + n][1038]
    sts = [] # [drop`{258} r | r <- rs]
    outs : [n][258]
    outs = [take`{258} r | r <- rs]