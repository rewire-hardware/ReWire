// Generated by rwc from device: top_level.
// rw_device maps a sequence of per-cycle inputs to per-cycle outputs.

module top_level where

// Helpers implementing ReWire Core primitive semantics.
rw'resize : {m, n} (fin m, fin n) => [n] -> [m]
rw'resize x = drop`{n} ((zero : [m]) # x)

rw'repl : {n, w} (fin n, fin w) => [w] -> [n * w]
rw'repl x = join (repeat`{n} x)

rw'parity : {n} (fin n) => [n] -> Bit
rw'parity x = foldr (^) False x

rw'sext : {m, n} (fin m, fin n, n >= 1) => [n] -> [m]
rw'sext x = if x @ 0 then ~ (rw'resize (~ x)) else rw'resize x

// $Pure.dispatch
rw__Pure_dispatch : [8] -> [17]
rw__Pure_dispatch x0 = rw__LL_Pure_dispatch x0

// $LL.Main.loop3
rw__LL_Main_loop3 : [8] -> [17]
rw__LL_Main_loop3 x0 = rw__LL_Main_loop2 x0

// $LL.Main.loop2
rw__LL_Main_loop2 : [8] -> [17]
rw__LL_Main_loop2 x0 = rw__LL_Main_loop (0b0 # ((rw'resize`{16} x0) ^ 0x0001))

// Main.loop
rw_Main_loop : [8] -> [17]
rw_Main_loop x0 = rw__LL_Main_loop3 x0

// $LL.Main.loop1
rw__LL_Main_loop1 : [16] -> [17]
rw__LL_Main_loop1 x0 = 0b1 # x0

// $LL.Main.loop
rw__LL_Main_loop : [17] -> [17]
rw__LL_Main_loop x0 = rw__LL_Main_loop1 (drop`{1} x0)

// $LL.Pure.dispatch
rw__LL_Pure_dispatch : [8] -> [17]
rw__LL_Pure_dispatch x0 = rw_Main_loop x0

// Per-cycle step: outputs # next register values.
rw_step : [8] -> [16]
rw_step i = drop`{1} s2
  where
    s0 : [8]
    s0 = i
    s1 : [8]
    s1 = s0
    s2 : [17]
    s2 = rw__Pure_dispatch s1

// Device: top_level
// Inputs, MSB-first: __in0 : [8]
// Outputs, MSB-first: __out0 : [16]
rw_device : {n} (fin n) => [n][8] -> [n][16]
rw_device ins = [rw_step i | i <- ins]