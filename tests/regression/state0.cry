// Generated by rwc from device: top_level.
// rw_device maps a sequence of per-cycle inputs to per-cycle outputs.

module top_level where

// Helpers implementing ReWire Hyle primitive semantics.
rw'resize : {m, n} (fin m, fin n) => [n] -> [m]
rw'resize x = drop`{n} ((zero : [m]) # x)

rw'repl : {n, w} (fin n, fin w) => [w] -> [n * w]
rw'repl x = join (repeat`{n} x)

rw'parity : {n} (fin n) => [n] -> Bit
rw'parity x = foldr (^) False x

rw'sext : {m, n} (fin m, fin n, n >= 1) => [n] -> [m]
rw'sext x = if x @ 0 then ~ (rw'resize (~ x)) else rw'resize x

// $Pure.dispatch
rw__Pure_dispatch : [5] -> [3] -> [9]
rw__Pure_dispatch x0 x1 = if (take`{2} x0) == 0b01 then (rw__LL_Pure_dispatch3 x1) else (if (take`{2} x0) == 0b10 then (rw__LL_Pure_dispatch1 x1 (drop`{2} x0)) else (rw__LL_Pure_dispatch4 x1 (drop`{2} x0)))

// $LL.Pure.dispatch4
rw__LL_Pure_dispatch4 : [3] -> [3] -> [9]
rw__LL_Pure_dispatch4 x0 x1 = rw__LL_Pure_dispatch2 x0 x1

// $LL.Main.dev3
rw__LL_Main_dev3 : [3] -> [3] -> [9]
rw__LL_Main_dev3 x0 x1 = 0b000010 # x0

// $LL.Main.dev2
rw__LL_Main_dev2 : [3] -> [9]
rw__LL_Main_dev2 x0 = rw__LL_Main_dev1 x0

// $LL.Pure.dispatch3
rw__LL_Pure_dispatch3 : [3] -> [9]
rw__LL_Pure_dispatch3 x0 = rw_Main_dev x0

// Main.dev
rw_Main_dev : [3] -> [9]
rw_Main_dev x0 = rw__LL_Main_dev2 x0

// $LL.Pure.dispatch2
rw__LL_Pure_dispatch2 : [3] -> [3] -> [9]
rw__LL_Pure_dispatch2 x0 x1 = rw__LL_Main_dev3 x1 x0

// $LL.Pure.dispatch1
rw__LL_Pure_dispatch1 : [3] -> [3] -> [9]
rw__LL_Pure_dispatch1 x0 x1 = rw__LL_Pure_dispatch x0 x1

// $LL.Main.dev1
rw__LL_Main_dev1 : [3] -> [9]
rw__LL_Main_dev1 x0 = 0b000000 # x0

// $LL.Main.dev
rw__LL_Main_dev : [3] -> [3] -> [9]
rw__LL_Main_dev x0 x1 = 0b1 # (x0 # 0b01000)

// $LL.Pure.dispatch
rw__LL_Pure_dispatch : [3] -> [3] -> [9]
rw__LL_Pure_dispatch x0 x1 = rw__LL_Main_dev x1 x0

// Per-cycle step: outputs # next register values.
rw_step : [5] -> [3] -> [9]
rw_step st i = (take`{1} s2) # ((take`{3} (drop`{1} s2)) # (drop`{4} s2))
  where
    s0 : [5]
    s0 = st
    s1 : [3]
    s1 = i
    s2 : [9]
    s2 = rw__Pure_dispatch s0 s1

// Device: top_level
// Inputs, MSB-first: __in0 : [3]
// Outputs, MSB-first: __out0 : [1], __out1 : [3]
rw_device : {n} (fin n) => [n][3] -> [n][4]
rw_device ins = outs
  where
    rs : [n][9]
    rs = [rw_step st i | st <- sts | i <- ins]
    sts : [1 + n][5]
    sts = [0b00000] # [drop`{4} r | r <- rs]
    outs : [n][4]
    outs = [take`{4} r | r <- rs]